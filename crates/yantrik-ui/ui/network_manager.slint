// Network Manager — comprehensive network settings app.
// Screen 22. Six tabs: WiFi, Ethernet, Bluetooth, VPN, Firewall, Diagnostics.

import { Theme } from "theme.slint";
import { YButton, YIconButton } from "components/y_button.slint";
import { YInput } from "components/y_input.slint";
import { YTabs, YTabItem } from "components/y_tabs.slint";
import { YEmptyState } from "components/y_empty_state.slint";
import { YListItem } from "components/y_list_item.slint";

// ── Data structs ──

export struct WifiNetwork {
    ssid: string,
    signal: int,          // 0-100
    security: string,     // "WPA2", "WPA3", "Open", etc.
    is-connected: bool,
    is-saved: bool,
}

export struct EthernetInterface {
    name: string,         // "eth0", "enp0s3"
    status: string,       // "UP", "DOWN"
    ip-address: string,
    mac-address: string,
    speed: string,        // "1000Mbps"
    is-dhcp: bool,
    subnet: string,
    gateway: string,
    dns: string,
}

export struct BluetoothDevice {
    name: string,
    address: string,      // MAC
    device-type: string,  // "headphones", "keyboard", "mouse", "phone", "speaker", "unknown"
    is-paired: bool,
    is-connected: bool,
}

export struct VpnConnection {
    name: string,
    vpn-type: string,     // "WireGuard", "OpenVPN"
    status: string,       // "connected", "disconnected"
    ip-address: string,
    traffic: string,      // "1.2 GB / 340 MB"
}

export struct FirewallRule {
    id: int,
    description: string,  // "tcp/22 ACCEPT", "DROP 10.0.0.5"
    chain: string,        // "INPUT", "OUTPUT", "FORWARD"
    action: string,       // "ACCEPT", "DROP", "REJECT"
}

export struct DiagTestResult {
    name: string,         // "Gateway", "DNS", "Internet"
    status: string,       // "ok", "fail", "running", "idle"
    latency: string,      // "12ms" or "unreachable" or ""
}

export struct ConnectionEvent {
    description: string,  // "WiFi connected to HomeNet"
    timestamp: string,    // "14:32:05"
}

export struct NetAIProviderStatus {
    name: string,
    provider-type: string,
    base-url: string,
    status: string,       // "reachable", "unreachable", "testing"
    latency-ms: int,      // -1 = unknown
    is-primary: bool,
    is-fallback: bool,
}

// ── Signal bar component ──

component SignalBars inherits HorizontalLayout {
    in property <int> strength;  // 0-100
    spacing: 2px;

    // Bar 1 (always lit if signal > 0)
    Rectangle {
        width: 4px;
        height: 8px;
        border-radius: 1px;
        background: strength > 0 ? Theme.accent : Theme.text-dim;
        vertical-stretch: 0;
    }
    Rectangle {
        width: 4px;
        height: 12px;
        border-radius: 1px;
        background: strength > 25 ? Theme.accent : Theme.text-dim;
        vertical-stretch: 0;
    }
    Rectangle {
        width: 4px;
        height: 16px;
        border-radius: 1px;
        background: strength > 50 ? Theme.accent : Theme.text-dim;
        vertical-stretch: 0;
    }
    Rectangle {
        width: 4px;
        height: 20px;
        border-radius: 1px;
        background: strength > 75 ? Theme.accent : Theme.text-dim;
        vertical-stretch: 0;
    }
}

// ── Toggle Switch component ──

component ToggleSwitch inherits TouchArea {
    in-out property <bool> checked;
    in property <string> label;
    width: 100%;
    height: 40px;

    callback toggled();

    clicked => {
        checked = !checked;
        root.toggled();
    }

    HorizontalLayout {
        spacing: Theme.sp-3;
        alignment: space-between;
        padding-left: Theme.sp-4;
        padding-right: Theme.sp-4;

        Text {
            text: label;
            color: Theme.text-primary;
            font-size: Theme.fs-body;
            vertical-alignment: center;
        }

        // Track
        Rectangle {
            width: 44px;
            height: 24px;
            border-radius: Theme.r-lg;
            background: checked ? Theme.accent : Theme.bg-elevated;
            border-width: 1px;
            border-color: checked ? Theme.accent-dim : Theme.text-dim;

            // Knob
            Rectangle {
                x: checked ? parent.width - self.width - 3px : 3px;
                y: 3px;
                width: 18px;
                height: 18px;
                border-radius: 9px;
                background: Theme.text-primary;
                animate x { duration: Theme.dur-fast; easing: ease-in-out; }
            }
        }
    }
}

// ── Tab button component ──

component TabButton inherits TouchArea {
    in property <string> label;
    in property <bool> active;
    in property <string> icon;
    height: 44px;

    Rectangle {
        background: active ? Theme.bg-elevated : (parent.has-hover ? Theme.hover-fill : transparent);

        HorizontalLayout {
            spacing: Theme.sp-2;
            padding-left: Theme.sp-4;
            padding-right: Theme.sp-4;
            alignment: center;

            Text {
                text: icon;
                color: active ? Theme.accent : Theme.text-secondary;
                font-size: Theme.fs-headline;
                vertical-alignment: center;
            }
            Text {
                text: label;
                color: active ? Theme.accent : Theme.text-secondary;
                font-size: Theme.fs-body;
                font-weight: active ? 600 : 400;
                vertical-alignment: center;
            }
        }

        // Bottom accent line
        if active : Rectangle {
            y: parent.height - 2px;
            width: 100%;
            height: 2px;
            background: Theme.accent;
        }
    }
}

// ── Action button component ──

component ActionButton inherits TouchArea {
    in property <string> label;
    in property <bool> danger: false;
    in property <bool> primary: false;
    height: 36px;

    Rectangle {
        border-radius: Theme.r-lg;
        background: primary ? Theme.accent
                  : danger ? Theme.color-danger-dim
                  : (parent.has-hover ? Theme.hover-fill-strong : Theme.bg-elevated);
        border-width: 1px;
        border-color: primary ? Theme.accent-dim
                    : danger ? Theme.color-danger
                    : Theme.border-subtle;

        HorizontalLayout {
            padding-left: Theme.sp-4;
            padding-right: Theme.sp-4;
            alignment: center;

            Text {
                text: label;
                color: primary ? Theme.bg-deep
                     : danger ? Theme.color-danger
                     : Theme.text-primary;
                font-size: Theme.fs-caption;
                font-weight: 600;
                vertical-alignment: center;
            }
        }
    }
}

// ── Main component ──

export component NetworkManager inherits Rectangle {
    background: Theme.bg-deep;

    // Active tab: 0=WiFi, 1=Ethernet, 2=Bluetooth, 3=VPN, 4=Firewall, 5=Diagnostics
    in-out property <int> active-tab: 0;

    // WiFi state
    in property <bool> wifi-enabled: false;
    in property <string> wifi-current-ssid: "";
    in property <int> wifi-signal-strength: 0;
    in property <string> wifi-ip-address: "";
    in property <string> wifi-speed: "";
    in property <[WifiNetwork]> wifi-networks: [];
    in property <[WifiNetwork]> wifi-saved-networks: [];
    in property <bool> wifi-scanning: false;

    // WiFi password dialog
    in-out property <bool> wifi-password-visible: false;
    in-out property <string> wifi-password-ssid: "";
    in-out property <string> wifi-password-input: "";
    in property <string> wifi-connect-status: "";

    // Ethernet state
    in property <[EthernetInterface]> ethernet-interfaces: [];

    // Bluetooth state
    in property <bool> bt-enabled: false;
    in property <[BluetoothDevice]> bt-paired-devices: [];
    in property <[BluetoothDevice]> bt-available-devices: [];
    in property <bool> bt-scanning: false;

    // VPN state
    in property <[VpnConnection]> vpn-connections: [];

    // Firewall state
    in property <bool> firewall-enabled: false;
    in property <string> firewall-backend-name: "";
    in property <int> firewall-rule-count: 0;
    in property <[FirewallRule]> firewall-rules: [];
    in property <string> firewall-profile: "Custom";

    // WiFi connection details (expandable section)
    in property <string> wifi-gateway: "";
    in property <string> wifi-dns: "";
    in property <string> wifi-subnet: "";
    in-out property <bool> wifi-details-expanded: false;

    // Diagnostics state
    in property <[DiagTestResult]> diag-tests: [];
    in property <[ConnectionEvent]> diag-connection-history: [];

    // AI Provider Connectivity
    in property <[NetAIProviderStatus]> ai-provider-connectivity: [];
    in property <bool> ai-connectivity-testing: false;

    // Status bar (shown on all tabs)
    in property <string> status-connection-type: "";   // "WiFi", "Ethernet", ""
    in property <string> status-ip-address: "";
    in property <int> status-signal-strength: 0;        // 0-100, for WiFi
    in property <string> status-state: "disconnected";  // "connected", "disconnected", "connecting"

    // Callbacks
    callback toggle-wifi();
    callback wifi-scan();
    callback wifi-connect(string, string);  // ssid, password
    callback wifi-disconnect();
    callback wifi-forget(string);           // ssid

    callback toggle-bluetooth();
    callback bt-scan();
    callback bt-pair(string);               // address
    callback bt-connect(string);            // address
    callback bt-disconnect(string);         // address

    callback vpn-connect(string);           // name
    callback vpn-disconnect(string);        // name

    callback toggle-firewall();
    callback firewall-allow-port(string);   // port string
    callback firewall-block-port(string);
    callback firewall-apply-profile(string);

    // Diagnostics callbacks
    callback diag-run-test(string);    // "gateway", "dns", "internet"
    callback diag-run-all-tests();
    callback test-ai-connectivity();   // test all AI providers

    // Diagnostics — Ping / Traceroute
    in-out property <string> net-diag-ping-target: "8.8.8.8";
    in property <string> net-diag-ping-result: "";
    in property <bool> net-diag-ping-running: false;
    in property <string> net-diag-traceroute-result: "";
    in property <bool> net-diag-traceroute-running: false;
    callback net-diag-run-ping();
    callback net-diag-run-traceroute();

    // VPN config import
    in-out property <string> net-vpn-import-path: "";
    in property <string> net-vpn-import-status: "";
    callback net-vpn-import-config();

    // AI Assist
    in property <bool> ai-is-working: false;
    in property <string> ai-response: "";
    in-out property <bool> ai-panel-open: false;
    callback ai-explain-pressed();
    callback ai-dismiss();

    // Background nebula
    Rectangle {
        x: parent.width * 0.6;
        y: -parent.height * 0.1;
        width: 500px;
        height: 400px;
        background: @radial-gradient(circle,
            Theme.accent.transparentize(60%) 0%,
            transparent 60%
        );
    }

    VerticalLayout {
        spacing: 0px;

        // ── Tab bar ──
        Rectangle {
            height: 46px;
            background: @linear-gradient(180deg,
                Theme.bg-surface.transparentize(40%) 0%,
                Theme.bg-deep.transparentize(50%) 100%
            );

            // Bottom glow
            Rectangle {
                y: parent.height - 1px;
                width: 100%;
                height: 1px;
                background: @linear-gradient(90deg,
                    transparent 10%,
                    Theme.accent-glow 50%,
                    transparent 90%
                );
                opacity: 0.3;
            }

            HorizontalLayout {
                spacing: 0px;

                TabButton {
                    icon: "\u{25CE}";  // WiFi icon
                    label: "WiFi";
                    active: root.active-tab == 0;
                    clicked => { root.active-tab = 0; }
                }
                TabButton {
                    icon: "\u{2550}";  // Ethernet
                    label: "Ethernet";
                    active: root.active-tab == 1;
                    clicked => { root.active-tab = 1; }
                }
                TabButton {
                    icon: "\u{2630}";  // Bluetooth
                    label: "Bluetooth";
                    active: root.active-tab == 2;
                    clicked => { root.active-tab = 2; }
                }
                TabButton {
                    icon: "\u{229B}";  // VPN
                    label: "VPN";
                    active: root.active-tab == 3;
                    clicked => { root.active-tab = 3; }
                }
                TabButton {
                    icon: "\u{2AF5}";  // Firewall
                    label: "Firewall";
                    active: root.active-tab == 4;
                    clicked => { root.active-tab = 4; }
                }
                TabButton {
                    icon: "\u{2699}";  // Diagnostics
                    label: "Diagnostics";
                    active: root.active-tab == 5;
                    clicked => { root.active-tab = 5; }
                }

                // Spacer
                Rectangle { horizontal-stretch: 1; }

                // AI Explain button
                TouchArea {
                    width: ai-net-btn.preferred-width + 16px;
                    height: 32px;
                    clicked => {
                        if root.ai-panel-open {
                            root.ai-dismiss();
                            root.ai-panel-open = false;
                        } else {
                            root.ai-explain-pressed();
                            root.ai-panel-open = true;
                        }
                    }
                    ai-net-btn := Rectangle {
                        height: 32px;
                        border-radius: Theme.r-pill;
                        background: root.ai-is-working ? Theme.accent
                            : (parent.has-hover ? Theme.hover-fill-strong : Theme.bg-card);
                        border-width: 1px;
                        border-color: Theme.border-subtle;
                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: Theme.sp-1;
                            alignment: center;
                            Text {
                                text: root.ai-is-working ? "\u{2B50}" : "\u{2728}";
                                font-size: Theme.fs-caption;
                                vertical-alignment: center;
                            }
                            Text {
                                text: root.ai-is-working ? "Analyzing..." : "AI Explain";
                                color: root.ai-is-working ? Theme.text-on-accent : Theme.text-secondary;
                                font-size: Theme.fs-micro;
                                font-weight: 500;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                Rectangle { width: Theme.sp-3; }
            }
        }

        // ── AI Response Panel ──
        if root.ai-panel-open && root.ai-response != "" : Rectangle {
            max-height: 160px;
            background: Theme.bg-elevated;
            border-width: 1px;
            border-color: Theme.accent.transparentize(70%);

            Flickable {
                viewport-height: ai-net-resp.preferred-height + 16px;

                ai-net-resp := VerticalLayout {
                    padding: Theme.sp-3;
                    spacing: Theme.sp-2;

                    HorizontalLayout {
                        spacing: Theme.sp-2;
                        Text {
                            text: "\u{2728}";
                            font-size: Theme.fs-caption;
                            vertical-alignment: center;
                        }
                        Text {
                            text: "AI Analysis";
                            color: Theme.accent;
                            font-size: Theme.fs-caption;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                        Rectangle { horizontal-stretch: 1; }
                        TouchArea {
                            width: 24px;
                            height: 24px;
                            clicked => {
                                root.ai-panel-open = false;
                                root.ai-dismiss();
                            }
                            Rectangle {
                                width: 24px; height: 24px;
                                border-radius: Theme.r-lg;
                                background: parent.has-hover ? Theme.hover-fill : transparent;
                                Text {
                                    text: "\u{2715}";
                                    font-size: Theme.fs-micro;
                                    color: Theme.text-dim;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    Text {
                        text: root.ai-response;
                        color: Theme.text-primary;
                        font-size: Theme.fs-caption;
                        wrap: word-wrap;
                    }
                }
            }
        }

        // ── Tab content ──
        Rectangle {
            vertical-stretch: 1;
            clip: true;

            // ═════════════════════════════════════
            // TAB 0: WiFi
            // ═════════════════════════════════════
            if root.active-tab == 0 : Flickable {
                width: 100%;
                height: 100%;
                viewport-height: wifi-content.preferred-height + 40px;

                wifi-content := VerticalLayout {
                    padding: Theme.sp-5;
                    spacing: Theme.sp-4;

                    // WiFi toggle
                    Rectangle {
                        height: 56px;
                        background: Theme.bg-card;
                        border-radius: Theme.r-lg;
                        border-width: 1px;
                        border-color: Theme.border-subtle;

                        ToggleSwitch {
                            checked: root.wifi-enabled;
                            label: "WiFi";
                            toggled => { root.toggle-wifi(); }
                        }
                    }

                    // Current connection card
                    if root.wifi-current-ssid != "" : Rectangle {
                        background: Theme.bg-card;
                        border-radius: Theme.r-lg;
                        border-width: 1px;
                        border-color: Theme.accent-glow;
                        height: conn-layout.preferred-height + 24px;

                        conn-layout := VerticalLayout {
                            padding: Theme.sp-4;
                            spacing: Theme.sp-2;

                            HorizontalLayout {
                                spacing: Theme.sp-3;
                                alignment: space-between;

                                VerticalLayout {
                                    spacing: Theme.sp-1;
                                    Text {
                                        text: "Connected";
                                        color: Theme.accent;
                                        font-size: Theme.fs-caption;
                                        font-weight: 600;
                                        letter-spacing: 1px;
                                    }
                                    HorizontalLayout {
                                        spacing: Theme.sp-2;
                                        Text {
                                            text: root.wifi-current-ssid;
                                            color: Theme.text-primary;
                                            font-size: Theme.fs-headline;
                                            font-weight: 600;
                                        }
                                        SignalBars {
                                            strength: root.wifi-signal-strength;
                                        }
                                    }
                                }

                                ActionButton {
                                    label: "Disconnect";
                                    width: 110px;
                                    danger: true;
                                    clicked => { root.wifi-disconnect(); }
                                }
                            }

                            // Details row
                            HorizontalLayout {
                                spacing: Theme.sp-6;
                                VerticalLayout {
                                    spacing: 2px;
                                    Text { text: "IP Address"; color: Theme.text-dim; font-size: Theme.fs-caption; }
                                    Text { text: root.wifi-ip-address != "" ? root.wifi-ip-address : "—"; color: Theme.text-secondary; font-size: Theme.fs-body; }
                                }
                                VerticalLayout {
                                    spacing: 2px;
                                    Text { text: "Signal"; color: Theme.text-dim; font-size: Theme.fs-caption; }
                                    Text { text: root.wifi-signal-strength + "%"; color: Theme.text-secondary; font-size: Theme.fs-body; }
                                }
                                VerticalLayout {
                                    spacing: 2px;
                                    Text { text: "Speed"; color: Theme.text-dim; font-size: Theme.fs-caption; }
                                    Text { text: root.wifi-speed != "" ? root.wifi-speed : "—"; color: Theme.text-secondary; font-size: Theme.fs-body; }
                                }
                            }
                        }
                    }

                    // Connection Details (expandable)
                    if root.wifi-current-ssid != "" : Rectangle {
                        background: Theme.bg-card;
                        border-radius: Theme.r-lg;
                        border-width: 1px;
                        border-color: Theme.border-subtle;
                        height: wifi-details-inner.preferred-height + 16px;

                        wifi-details-inner := VerticalLayout {
                            padding: Theme.sp-3;
                            padding-left: Theme.sp-4;
                            padding-right: Theme.sp-4;
                            spacing: Theme.sp-2;

                            details-toggle := TouchArea {
                                height: 28px;
                                clicked => { root.wifi-details-expanded = !root.wifi-details-expanded; }

                                HorizontalLayout {
                                    spacing: Theme.sp-2;
                                    alignment: space-between;

                                    HorizontalLayout {
                                        spacing: Theme.sp-2;
                                        Text {
                                            text: root.wifi-details-expanded ? "\u{25BC}" : "\u{25B6}";
                                            color: Theme.text-dim;
                                            font-size: Theme.fs-micro;
                                            vertical-alignment: center;
                                        }
                                        Text {
                                            text: "Connection Details";
                                            color: Theme.text-secondary;
                                            font-size: Theme.fs-body;
                                            font-weight: 500;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }

                            if root.wifi-details-expanded : VerticalLayout {
                                spacing: 10px;
                                // Row 1
                                HorizontalLayout {
                                    spacing: Theme.sp-7;
                                    VerticalLayout {
                                        spacing: 2px;
                                        Text { text: "IP Address"; color: Theme.text-dim; font-size: Theme.fs-caption; }
                                        Text { text: root.wifi-ip-address != "" ? root.wifi-ip-address : "\u{2014}"; color: Theme.text-secondary; font-size: Theme.fs-body; }
                                    }
                                    VerticalLayout {
                                        spacing: 2px;
                                        Text { text: "Subnet Mask"; color: Theme.text-dim; font-size: Theme.fs-caption; }
                                        Text { text: root.wifi-subnet != "" ? root.wifi-subnet : "\u{2014}"; color: Theme.text-secondary; font-size: Theme.fs-body; }
                                    }
                                }
                                // Row 2
                                HorizontalLayout {
                                    spacing: Theme.sp-7;
                                    VerticalLayout {
                                        spacing: 2px;
                                        Text { text: "Gateway"; color: Theme.text-dim; font-size: Theme.fs-caption; }
                                        Text { text: root.wifi-gateway != "" ? root.wifi-gateway : "\u{2014}"; color: Theme.text-secondary; font-size: Theme.fs-body; }
                                    }
                                    VerticalLayout {
                                        spacing: 2px;
                                        Text { text: "DNS"; color: Theme.text-dim; font-size: Theme.fs-caption; }
                                        Text { text: root.wifi-dns != "" ? root.wifi-dns : "\u{2014}"; color: Theme.text-secondary; font-size: Theme.fs-body; }
                                    }
                                }
                            }
                        }
                    }

                    // Available networks section
                    if root.wifi-enabled : VerticalLayout {
                        spacing: Theme.sp-2;

                        HorizontalLayout {
                            spacing: Theme.sp-3;
                            alignment: space-between;

                            Text {
                                text: "Available Networks";
                                color: Theme.text-primary;
                                font-size: Theme.fs-headline;
                                font-weight: 600;
                                vertical-alignment: center;
                            }

                            HorizontalLayout {
                                spacing: Theme.sp-2;

                                if root.wifi-scanning : Text {
                                    text: "Scanning...";
                                    color: Theme.text-dim;
                                    font-size: Theme.fs-caption;
                                    vertical-alignment: center;
                                }

                                ActionButton {
                                    label: "Scan";
                                    width: 80px;
                                    primary: true;
                                    clicked => { root.wifi-scan(); }
                                }
                            }
                        }

                        // Network list
                        for network[idx] in root.wifi-networks : net-ta := TouchArea {
                            height: 52px;

                            clicked => {
                                if network.is-connected {
                                    // Already connected — do nothing
                                } else if network.is-saved {
                                    // Saved network — connect without password
                                    root.wifi-connect(network.ssid, "");
                                } else {
                                    // Need password
                                    root.wifi-password-ssid = network.ssid;
                                    root.wifi-password-input = "";
                                    root.wifi-password-visible = true;
                                }
                            }

                            Rectangle {
                                background: network.is-connected ? Theme.tint-accent
                                          : net-ta.has-hover ? Theme.hover-fill
                                          : Theme.bg-card;
                                border-radius: Theme.r-lg;
                                border-width: 1px;
                                border-color: network.is-connected ? Theme.accent-dim : Theme.border-subtle;

                                HorizontalLayout {
                                    padding-left: Theme.sp-4;
                                    padding-right: Theme.sp-4;
                                    spacing: Theme.sp-3;
                                    alignment: space-between;

                                    HorizontalLayout {
                                        spacing: Theme.sp-3;

                                        SignalBars {
                                            strength: network.signal;
                                        }

                                        VerticalLayout {
                                            spacing: 2px;
                                            alignment: center;
                                            Text {
                                                text: network.ssid;
                                                color: Theme.text-primary;
                                                font-size: Theme.fs-body;
                                                font-weight: network.is-connected ? 600 : 400;
                                            }
                                            Text {
                                                text: network.is-connected ? "Connected" : network.security;
                                                color: network.is-connected ? Theme.accent : Theme.text-dim;
                                                font-size: Theme.fs-caption;
                                            }
                                        }
                                    }

                                    if network.is-saved && !network.is-connected : Text {
                                        text: "Saved";
                                        color: Theme.text-dim;
                                        font-size: Theme.fs-caption;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }

                    // Saved networks section
                    if root.wifi-enabled && root.wifi-saved-networks.length > 0 : VerticalLayout {
                        spacing: Theme.sp-2;

                        Text {
                            text: "Known Networks";
                            color: Theme.text-primary;
                            font-size: Theme.fs-headline;
                            font-weight: 600;
                        }

                        for saved[idx] in root.wifi-saved-networks : Rectangle {
                            height: 44px;
                            background: Theme.bg-card;
                            border-radius: Theme.r-lg;
                            border-width: 1px;
                            border-color: Theme.border-subtle;

                            HorizontalLayout {
                                padding-left: Theme.sp-4;
                                padding-right: Theme.sp-4;
                                alignment: space-between;

                                Text {
                                    text: saved.ssid;
                                    color: Theme.text-primary;
                                    font-size: Theme.fs-body;
                                    vertical-alignment: center;
                                }

                                forget-ta := TouchArea {
                                    width: 70px;
                                    height: 100%;
                                    clicked => { root.wifi-forget(saved.ssid); }
                                    Text {
                                        text: "Forget";
                                        color: forget-ta.has-hover ? Theme.color-danger : Theme.text-dim;
                                        font-size: Theme.fs-caption;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }
            }

            // ═════════════════════════════════════
            // TAB 1: Ethernet
            // ═════════════════════════════════════
            if root.active-tab == 1 : Flickable {
                width: 100%;
                height: 100%;
                viewport-height: eth-content.preferred-height + 40px;

                eth-content := VerticalLayout {
                    padding: Theme.sp-5;
                    spacing: Theme.sp-4;

                    Text {
                        text: "Ethernet Interfaces";
                        color: Theme.text-primary;
                        font-size: Theme.fs-headline;
                        font-weight: 600;
                    }

                    if root.ethernet-interfaces.length == 0 : Rectangle {
                        height: 80px;
                        background: Theme.bg-card;
                        border-radius: Theme.r-lg;
                        border-width: 1px;
                        border-color: Theme.border-subtle;
                        Text {
                            text: "No Ethernet interfaces detected";
                            color: Theme.text-dim;
                            font-size: Theme.fs-body;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    for iface[idx] in root.ethernet-interfaces : Rectangle {
                        background: Theme.bg-card;
                        border-radius: Theme.r-lg;
                        border-width: 1px;
                        border-color: iface.status == "UP" ? Theme.accent-dim : Theme.border-subtle;
                        height: eth-iface-layout.preferred-height + 24px;

                        eth-iface-layout := VerticalLayout {
                            padding: Theme.sp-4;
                            spacing: 10px;

                            // Header row
                            HorizontalLayout {
                                spacing: Theme.sp-3;
                                alignment: space-between;

                                HorizontalLayout {
                                    spacing: Theme.sp-2;
                                    Text {
                                        text: iface.name;
                                        color: Theme.text-primary;
                                        font-size: Theme.fs-headline;
                                        font-weight: 600;
                                        vertical-alignment: center;
                                    }
                                    Rectangle {
                                        width: eth-status-text.preferred-width + 16px;
                                        height: 22px;
                                        border-radius: 11px;
                                        background: iface.status == "UP" ? Theme.accent-glow : Theme.bg-elevated;
                                        eth-status-text := Text {
                                            text: iface.status;
                                            color: iface.status == "UP" ? Theme.accent : Theme.text-dim;
                                            font-size: Theme.fs-caption;
                                            font-weight: 600;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }

                                if iface.is-dhcp : Rectangle {
                                    width: 60px;
                                    height: 22px;
                                    border-radius: 11px;
                                    background: Theme.tint-accent;
                                    Text {
                                        text: "DHCP";
                                        color: Theme.accent;
                                        font-size: Theme.fs-caption;
                                        font-weight: 600;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            // Details grid
                            HorizontalLayout {
                                spacing: Theme.sp-7;
                                VerticalLayout {
                                    spacing: 2px;
                                    Text { text: "IP Address"; color: Theme.text-dim; font-size: Theme.fs-caption; }
                                    Text { text: iface.ip-address != "" ? iface.ip-address : "—"; color: Theme.text-secondary; font-size: Theme.fs-body; }
                                }
                                VerticalLayout {
                                    spacing: 2px;
                                    Text { text: "MAC"; color: Theme.text-dim; font-size: Theme.fs-caption; }
                                    Text { text: iface.mac-address != "" ? iface.mac-address : "—"; color: Theme.text-secondary; font-size: Theme.fs-body; }
                                }
                                VerticalLayout {
                                    spacing: 2px;
                                    Text { text: "Speed"; color: Theme.text-dim; font-size: Theme.fs-caption; }
                                    Text { text: iface.speed != "" ? iface.speed : "—"; color: Theme.text-secondary; font-size: Theme.fs-body; }
                                }
                            }

                            if iface.status == "UP" : HorizontalLayout {
                                spacing: Theme.sp-7;
                                VerticalLayout {
                                    spacing: 2px;
                                    Text { text: "Subnet"; color: Theme.text-dim; font-size: Theme.fs-caption; }
                                    Text { text: iface.subnet != "" ? iface.subnet : "—"; color: Theme.text-secondary; font-size: Theme.fs-body; }
                                }
                                VerticalLayout {
                                    spacing: 2px;
                                    Text { text: "Gateway"; color: Theme.text-dim; font-size: Theme.fs-caption; }
                                    Text { text: iface.gateway != "" ? iface.gateway : "—"; color: Theme.text-secondary; font-size: Theme.fs-body; }
                                }
                                VerticalLayout {
                                    spacing: 2px;
                                    Text { text: "DNS"; color: Theme.text-dim; font-size: Theme.fs-caption; }
                                    Text { text: iface.dns != "" ? iface.dns : "—"; color: Theme.text-secondary; font-size: Theme.fs-body; }
                                }
                            }
                        }
                    }
                }
            }

            // ═════════════════════════════════════
            // TAB 2: Bluetooth
            // ═════════════════════════════════════
            if root.active-tab == 2 : Flickable {
                width: 100%;
                height: 100%;
                viewport-height: bt-content.preferred-height + 40px;

                bt-content := VerticalLayout {
                    padding: Theme.sp-5;
                    spacing: Theme.sp-4;

                    // Bluetooth toggle
                    Rectangle {
                        height: 56px;
                        background: Theme.bg-card;
                        border-radius: Theme.r-lg;
                        border-width: 1px;
                        border-color: Theme.border-subtle;

                        ToggleSwitch {
                            checked: root.bt-enabled;
                            label: "Bluetooth";
                            toggled => { root.toggle-bluetooth(); }
                        }
                    }

                    // Paired devices
                    if root.bt-enabled : VerticalLayout {
                        spacing: Theme.sp-2;

                        Text {
                            text: "Paired Devices";
                            color: Theme.text-primary;
                            font-size: Theme.fs-headline;
                            font-weight: 600;
                        }

                        if root.bt-paired-devices.length == 0 : Rectangle {
                            height: 52px;
                            background: Theme.bg-card;
                            border-radius: Theme.r-lg;
                            border-width: 1px;
                            border-color: Theme.border-subtle;
                            Text {
                                text: "No paired devices";
                                color: Theme.text-dim;
                                font-size: Theme.fs-body;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        for device[idx] in root.bt-paired-devices : Rectangle {
                            height: 56px;
                            background: Theme.bg-card;
                            border-radius: Theme.r-lg;
                            border-width: 1px;
                            border-color: device.is-connected ? Theme.accent-dim : Theme.border-subtle;

                            HorizontalLayout {
                                padding-left: Theme.sp-4;
                                padding-right: Theme.sp-3;
                                spacing: Theme.sp-3;
                                alignment: space-between;

                                HorizontalLayout {
                                    spacing: 10px;

                                    // Device type icon
                                    Text {
                                        text: device.device-type == "headphones" ? "\u{1F3A7}"
                                            : device.device-type == "keyboard" ? "\u{2328}"
                                            : device.device-type == "mouse" ? "\u{1F5B1}"
                                            : device.device-type == "phone" ? "\u{1F4F1}"
                                            : device.device-type == "speaker" ? "\u{1F50A}"
                                            : "\u{2630}";
                                        color: device.is-connected ? Theme.accent : Theme.text-secondary;
                                        font-size: Theme.fs-title-1;
                                        vertical-alignment: center;
                                    }

                                    VerticalLayout {
                                        spacing: 2px;
                                        alignment: center;
                                        Text {
                                            text: device.name;
                                            color: Theme.text-primary;
                                            font-size: Theme.fs-body;
                                        }
                                        Text {
                                            text: device.is-connected ? "Connected" : "Not connected";
                                            color: device.is-connected ? Theme.accent : Theme.text-dim;
                                            font-size: Theme.fs-caption;
                                        }
                                    }
                                }

                                if device.is-connected : ActionButton {
                                    label: "Disconnect";
                                    width: 100px;
                                    clicked => { root.bt-disconnect(device.address); }
                                }
                                if !device.is-connected : ActionButton {
                                    label: "Connect";
                                    width: 90px;
                                    primary: true;
                                    clicked => { root.bt-connect(device.address); }
                                }
                            }
                        }
                    }

                    // Available devices
                    if root.bt-enabled : VerticalLayout {
                        spacing: Theme.sp-2;

                        HorizontalLayout {
                            spacing: Theme.sp-3;
                            alignment: space-between;

                            Text {
                                text: "Available Devices";
                                color: Theme.text-primary;
                                font-size: Theme.fs-headline;
                                font-weight: 600;
                                vertical-alignment: center;
                            }

                            HorizontalLayout {
                                spacing: Theme.sp-2;

                                if root.bt-scanning : Text {
                                    text: "Scanning...";
                                    color: Theme.text-dim;
                                    font-size: Theme.fs-caption;
                                    vertical-alignment: center;
                                }

                                ActionButton {
                                    label: "Scan";
                                    width: 80px;
                                    primary: true;
                                    clicked => { root.bt-scan(); }
                                }
                            }
                        }

                        for device[idx] in root.bt-available-devices : bt-avail-ta := TouchArea {
                            height: 52px;

                            Rectangle {
                                background: bt-avail-ta.has-hover ? Theme.hover-fill : Theme.bg-card;
                                border-radius: Theme.r-lg;
                                border-width: 1px;
                                border-color: Theme.border-subtle;

                                HorizontalLayout {
                                    padding-left: Theme.sp-4;
                                    padding-right: Theme.sp-3;
                                    spacing: Theme.sp-3;
                                    alignment: space-between;

                                    VerticalLayout {
                                        spacing: 2px;
                                        alignment: center;
                                        Text {
                                            text: device.name;
                                            color: Theme.text-primary;
                                            font-size: Theme.fs-body;
                                        }
                                        Text {
                                            text: device.address;
                                            color: Theme.text-dim;
                                            font-size: Theme.fs-caption;
                                        }
                                    }

                                    ActionButton {
                                        label: "Pair";
                                        width: 70px;
                                        primary: true;
                                        clicked => { root.bt-pair(device.address); }
                                    }
                                }
                            }
                        }
                    }
                }
            }

            // ═════════════════════════════════════
            // TAB 3: VPN
            // ═════════════════════════════════════
            if root.active-tab == 3 : Flickable {
                width: 100%;
                height: 100%;
                viewport-height: vpn-content.preferred-height + 40px;

                vpn-content := VerticalLayout {
                    padding: Theme.sp-5;
                    spacing: Theme.sp-4;

                    Text {
                        text: "VPN Connections";
                        color: Theme.text-primary;
                        font-size: Theme.fs-headline;
                        font-weight: 600;
                    }

                    if root.vpn-connections.length == 0 : Rectangle {
                        height: 100px;
                        background: Theme.bg-card;
                        border-radius: Theme.r-lg;
                        border-width: 1px;
                        border-color: Theme.border-subtle;

                        VerticalLayout {
                            spacing: Theme.sp-2;
                            alignment: center;
                            Text {
                                text: "No VPN connections detected";
                                color: Theme.text-dim;
                                font-size: Theme.fs-body;
                                horizontal-alignment: center;
                            }
                            Text {
                                text: "Configure WireGuard or OpenVPN on the system";
                                color: Theme.text-dim;
                                font-size: Theme.fs-caption;
                                horizontal-alignment: center;
                            }
                        }
                    }

                    for vpn[idx] in root.vpn-connections : Rectangle {
                        background: Theme.bg-card;
                        border-radius: Theme.r-lg;
                        border-width: 1px;
                        border-color: vpn.status == "connected" ? Theme.accent-dim : Theme.border-subtle;
                        height: vpn-layout.preferred-height + 24px;

                        vpn-layout := VerticalLayout {
                            padding: Theme.sp-4;
                            spacing: Theme.sp-2;

                            HorizontalLayout {
                                spacing: Theme.sp-3;
                                alignment: space-between;

                                HorizontalLayout {
                                    spacing: 10px;
                                    // Type badge
                                    Rectangle {
                                        width: vpn-type-text.preferred-width + 14px;
                                        height: 22px;
                                        border-radius: 11px;
                                        background: Theme.tint-accent;
                                        vpn-type-text := Text {
                                            text: vpn.vpn-type;
                                            color: Theme.accent;
                                            font-size: Theme.fs-caption;
                                            font-weight: 600;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                    Text {
                                        text: vpn.name;
                                        color: Theme.text-primary;
                                        font-size: Theme.fs-body;
                                        font-weight: 600;
                                        vertical-alignment: center;
                                    }
                                }

                                if vpn.status == "connected" : ActionButton {
                                    label: "Disconnect";
                                    width: 110px;
                                    danger: true;
                                    clicked => { root.vpn-disconnect(vpn.name); }
                                }
                                if vpn.status != "connected" : ActionButton {
                                    label: "Connect";
                                    width: 100px;
                                    primary: true;
                                    clicked => { root.vpn-connect(vpn.name); }
                                }
                            }

                            if vpn.status == "connected" : HorizontalLayout {
                                spacing: Theme.sp-6;
                                VerticalLayout {
                                    spacing: 2px;
                                    Text { text: "Status"; color: Theme.text-dim; font-size: Theme.fs-caption; }
                                    Text { text: "Connected"; color: Theme.accent; font-size: Theme.fs-body; }
                                }
                                VerticalLayout {
                                    spacing: 2px;
                                    Text { text: "Tunnel IP"; color: Theme.text-dim; font-size: Theme.fs-caption; }
                                    Text { text: vpn.ip-address != "" ? vpn.ip-address : "—"; color: Theme.text-secondary; font-size: Theme.fs-body; }
                                }
                                VerticalLayout {
                                    spacing: 2px;
                                    Text { text: "Traffic"; color: Theme.text-dim; font-size: Theme.fs-caption; }
                                    Text { text: vpn.traffic != "" ? vpn.traffic : "—"; color: Theme.text-secondary; font-size: Theme.fs-body; }
                                }
                            }
                        }
                    }

                    // ── Import VPN Config ──
                    Rectangle {
                        background: Theme.bg-card;
                        border-radius: Theme.r-lg;
                        border-width: 1px;
                        border-color: Theme.border-subtle;
                        height: vpn-import-layout.preferred-height + 24px;

                        vpn-import-layout := VerticalLayout {
                            padding: Theme.sp-4;
                            spacing: 10px;

                            Text {
                                text: "Import VPN Config";
                                color: Theme.text-primary;
                                font-size: Theme.fs-body;
                                font-weight: 600;
                            }

                            HorizontalLayout {
                                spacing: Theme.sp-2;

                                Rectangle {
                                    horizontal-stretch: 1;
                                    height: 36px;
                                    background: Theme.bg-input; clip: true;
                                    border-radius: Theme.r-lg;
                                    border-width: 1px;
                                    border-color: Theme.border-subtle;

                                    vpn-import-input := TextInput {
                                        x: 10px;
                                        width: parent.width - 20px;
                                        height: 100%;
                                        text <=> root.net-vpn-import-path;
                                        color: Theme.text-primary;
                                        font-size: Theme.fs-body;
                                        accepted => { root.net-vpn-import-config(); }
                                    }
                                }

                                ActionButton {
                                    label: "Import";
                                    width: 80px;
                                    primary: true;
                                    clicked => { root.net-vpn-import-config(); }
                                }
                            }

                            if root.net-vpn-import-status != "" : Text {
                                text: root.net-vpn-import-status;
                                color: Theme.text-secondary;
                                font-size: Theme.fs-caption;
                            }
                        }
                    }
                }
            }

            // ═════════════════════════════════════
            // TAB 4: Firewall
            // ═════════════════════════════════════
            if root.active-tab == 4 : Flickable {
                width: 100%;
                height: 100%;
                viewport-height: fw-content.preferred-height + 40px;

                fw-content := VerticalLayout {
                    padding: Theme.sp-5;
                    spacing: Theme.sp-4;

                    // Firewall toggle + status
                    Rectangle {
                        background: Theme.bg-card;
                        border-radius: Theme.r-lg;
                        border-width: 1px;
                        border-color: root.firewall-enabled ? Theme.accent-dim : Theme.border-subtle;
                        height: fw-header.preferred-height + 24px;

                        fw-header := VerticalLayout {
                            padding: Theme.sp-4;
                            spacing: Theme.sp-2;

                            ToggleSwitch {
                                checked: root.firewall-enabled;
                                label: "Firewall";
                                toggled => { root.toggle-firewall(); }
                            }

                            HorizontalLayout {
                                padding-left: Theme.sp-4;
                                spacing: Theme.sp-6;

                                VerticalLayout {
                                    spacing: 2px;
                                    Text { text: "Backend"; color: Theme.text-dim; font-size: Theme.fs-caption; }
                                    Text {
                                        text: root.firewall-backend-name != "" ? root.firewall-backend-name : "—";
                                        color: Theme.text-secondary;
                                        font-size: Theme.fs-body;
                                    }
                                }
                                VerticalLayout {
                                    spacing: 2px;
                                    Text { text: "Rules"; color: Theme.text-dim; font-size: Theme.fs-caption; }
                                    Text {
                                        text: root.firewall-rule-count;
                                        color: Theme.text-secondary;
                                        font-size: Theme.fs-body;
                                    }
                                }
                                VerticalLayout {
                                    spacing: 2px;
                                    Text { text: "Profile"; color: Theme.text-dim; font-size: Theme.fs-caption; }
                                    Text {
                                        text: root.firewall-profile;
                                        color: Theme.text-secondary;
                                        font-size: Theme.fs-body;
                                    }
                                }
                            }
                        }
                    }

                    // Quick profiles
                    if root.firewall-enabled : VerticalLayout {
                        spacing: Theme.sp-2;

                        Text {
                            text: "Quick Profiles";
                            color: Theme.text-primary;
                            font-size: Theme.fs-headline;
                            font-weight: 600;
                        }

                        HorizontalLayout {
                            spacing: 10px;

                            ActionButton {
                                label: "Home";
                                width: 100px;
                                primary: root.firewall-profile == "Home";
                                clicked => { root.firewall-apply-profile("home"); }
                            }
                            ActionButton {
                                label: "Public";
                                width: 100px;
                                primary: root.firewall-profile == "Public";
                                clicked => { root.firewall-apply-profile("public"); }
                            }
                            ActionButton {
                                label: "Restrictive";
                                width: 110px;
                                primary: root.firewall-profile == "Restrictive";
                                clicked => { root.firewall-apply-profile("restrictive"); }
                            }
                        }
                    }

                    // Quick actions — Allow/Block port
                    if root.firewall-enabled : VerticalLayout {
                        spacing: Theme.sp-2;

                        Text {
                            text: "Quick Actions";
                            color: Theme.text-primary;
                            font-size: Theme.fs-headline;
                            font-weight: 600;
                        }

                        HorizontalLayout {
                            spacing: 10px;

                            Rectangle {
                                horizontal-stretch: 1;
                                height: 36px;
                                background: Theme.bg-input; clip: true;
                                border-radius: Theme.r-lg;
                                border-width: 1px;
                                border-color: Theme.border-subtle;

                                fw-port-input := TextInput {
                                    x: 12px;
                                    width: parent.width - 24px;
                                    height: 100%;
                                    text: "";
                                    color: Theme.text-primary;
                                    font-size: Theme.fs-body;
                                }
                                if fw-port-input.text == "" : Text {
                                    x: 12px;
                                    text: "Port number...";
                                    color: Theme.text-dim;
                                    font-size: Theme.fs-body;
                                    vertical-alignment: center;
                                }
                            }

                            ActionButton {
                                label: "Allow";
                                width: 80px;
                                primary: true;
                                clicked => {
                                    if fw-port-input.text != "" {
                                        root.firewall-allow-port(fw-port-input.text);
                                        fw-port-input.text = "";
                                    }
                                }
                            }
                            ActionButton {
                                label: "Block";
                                width: 80px;
                                danger: true;
                                clicked => {
                                    if fw-port-input.text != "" {
                                        root.firewall-block-port(fw-port-input.text);
                                        fw-port-input.text = "";
                                    }
                                }
                            }
                        }
                    }

                    // Active rules
                    if root.firewall-enabled && root.firewall-rules.length > 0 : VerticalLayout {
                        spacing: Theme.sp-2;

                        Text {
                            text: "Active Rules";
                            color: Theme.text-primary;
                            font-size: Theme.fs-headline;
                            font-weight: 600;
                        }

                        for rule[idx] in root.firewall-rules : Rectangle {
                            height: 44px;
                            background: Theme.bg-card;
                            border-radius: Theme.r-lg;
                            border-width: 1px;
                            border-color: Theme.border-subtle;

                            HorizontalLayout {
                                padding-left: Theme.sp-4;
                                padding-right: Theme.sp-4;
                                spacing: Theme.sp-3;

                                // Action badge
                                Rectangle {
                                    width: rule-action-text.preferred-width + Theme.sp-3;
                                    height: 20px;
                                    border-radius: 10px;
                                    background: rule.action == "ACCEPT" ? Theme.color-success-dim
                                              : rule.action == "DROP" ? Theme.color-danger-dim
                                              : Theme.bg-elevated;
                                    rule-action-text := Text {
                                        text: rule.action;
                                        color: rule.action == "ACCEPT" ? Theme.color-success
                                             : rule.action == "DROP" ? Theme.color-danger
                                             : Theme.text-secondary;
                                        font-size: Theme.fs-micro;
                                        font-weight: 600;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                Text {
                                    text: rule.chain;
                                    color: Theme.text-dim;
                                    font-size: Theme.fs-caption;
                                    vertical-alignment: center;
                                }

                                Text {
                                    text: rule.description;
                                    color: Theme.text-secondary;
                                    font-size: Theme.fs-body;
                                    vertical-alignment: center;
                                    overflow: elide;
                                    horizontal-stretch: 1;
                                }
                            }
                        }
                    }
                }
            }

            // ═════════════════════════════════════
            // TAB 5: Diagnostics
            // ═════════════════════════════════════
            if root.active-tab == 5 : Flickable {
                width: 100%;
                height: 100%;
                viewport-height: diag-content.preferred-height + 40px;

                diag-content := VerticalLayout {
                    padding: Theme.sp-5;
                    spacing: Theme.sp-4;

                    // Connection Tests section
                    VerticalLayout {
                        spacing: Theme.sp-2;

                        HorizontalLayout {
                            spacing: Theme.sp-3;
                            alignment: space-between;

                            Text {
                                text: "Connection Tests";
                                color: Theme.text-primary;
                                font-size: Theme.fs-headline;
                                font-weight: 600;
                                vertical-alignment: center;
                            }

                            ActionButton {
                                label: "Run All Tests";
                                width: 130px;
                                primary: true;
                                clicked => { root.diag-run-all-tests(); }
                            }
                        }

                        // Test rows
                        for test[idx] in root.diag-tests : Rectangle {
                            height: 56px;
                            background: Theme.bg-card;
                            border-radius: Theme.r-lg;
                            border-width: 1px;
                            border-color: test.status == "ok" ? Theme.color-success-dim
                                        : test.status == "fail" ? Theme.color-danger-dim
                                        : Theme.border-subtle;

                            HorizontalLayout {
                                padding-left: Theme.sp-4;
                                padding-right: Theme.sp-3;
                                spacing: Theme.sp-3;
                                alignment: space-between;

                                HorizontalLayout {
                                    spacing: Theme.sp-3;

                                    // Status icon
                                    Rectangle {
                                        width: 28px;
                                        height: 28px;
                                        border-radius: 14px;
                                        background: test.status == "ok" ? Theme.color-success-dim
                                                  : test.status == "fail" ? Theme.color-danger-dim
                                                  : test.status == "running" ? Theme.color-warning-dim
                                                  : Theme.bg-elevated;

                                        Text {
                                            text: test.status == "ok" ? "\u{2713}"
                                                : test.status == "fail" ? "\u{2717}"
                                                : test.status == "running" ? "\u{25CB}"
                                                : "\u{2014}";
                                            color: test.status == "ok" ? Theme.color-success
                                                 : test.status == "fail" ? Theme.color-danger
                                                 : test.status == "running" ? Theme.color-warning
                                                 : Theme.text-dim;
                                            font-size: Theme.fs-body;
                                            font-weight: 700;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }

                                    VerticalLayout {
                                        spacing: 2px;
                                        alignment: center;

                                        Text {
                                            text: test.name;
                                            color: Theme.text-primary;
                                            font-size: Theme.fs-body;
                                            font-weight: 500;
                                        }
                                        Text {
                                            text: test.status == "running" ? "Testing..."
                                                : test.status == "ok" ? test.latency
                                                : test.status == "fail" ? "unreachable"
                                                : "Not tested";
                                            color: test.status == "ok" ? Theme.accent
                                                 : test.status == "fail" ? Theme.color-danger
                                                 : test.status == "running" ? Theme.color-warning
                                                 : Theme.text-dim;
                                            font-size: Theme.fs-caption;
                                        }
                                    }
                                }

                                ActionButton {
                                    label: test.status == "running" ? "..." : "Test";
                                    width: 70px;
                                    clicked => { root.diag-run-test(test.name); }
                                }
                            }
                        }
                    }

                    // ── AI Provider Connectivity ──
                    VerticalLayout {
                        spacing: Theme.sp-2;

                        HorizontalLayout {
                            spacing: Theme.sp-3;
                            alignment: space-between;

                            HorizontalLayout {
                                spacing: Theme.sp-2;

                                Text {
                                    text: "\u{1F916}";
                                    font-size: Theme.fs-headline;
                                    vertical-alignment: center;
                                }

                                Text {
                                    text: "AI Provider Connectivity";
                                    color: Theme.text-primary;
                                    font-size: Theme.fs-headline;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                }
                            }

                            ActionButton {
                                label: root.ai-connectivity-testing ? "Testing..." : "Test All";
                                width: 110px;
                                primary: true;
                                clicked => { root.test-ai-connectivity(); }
                            }
                        }

                        if root.ai-provider-connectivity.length == 0 : Rectangle {
                            height: 64px;
                            background: Theme.bg-card;
                            border-radius: Theme.r-lg;
                            border-width: 1px;
                            border-color: Theme.border-subtle;

                            Text {
                                text: "No AI providers configured. Add providers in Settings → AI & Intelligence.";
                                color: Theme.text-dim;
                                font-size: Theme.fs-body;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                wrap: word-wrap;
                            }
                        }

                        for provider[idx] in root.ai-provider-connectivity : Rectangle {
                            height: 72px;
                            background: Theme.bg-card;
                            border-radius: Theme.r-lg;
                            border-width: 1px;
                            border-color: provider.status == "reachable" ? Theme.color-success-dim
                                        : provider.status == "unreachable" ? Theme.color-danger-dim
                                        : Theme.border-subtle;

                            HorizontalLayout {
                                padding-left: Theme.sp-4;
                                padding-right: Theme.sp-4;
                                spacing: Theme.sp-3;
                                alignment: space-between;

                                HorizontalLayout {
                                    spacing: Theme.sp-3;

                                    // Status dot
                                    Rectangle {
                                        width: 10px;
                                        height: 10px;
                                        border-radius: 5px;
                                        y: (parent.height - self.height) / 2;
                                        background: provider.status == "reachable" ? Theme.color-reminder
                                                  : provider.status == "unreachable" ? Theme.color-danger
                                                  : provider.status == "testing" ? Theme.amber
                                                  : Theme.text-dim;

                                        // Glow
                                        Rectangle {
                                            width: parent.width + 6px;
                                            height: parent.height + 6px;
                                            x: -3px;
                                            y: -3px;
                                            border-radius: Theme.r-md;
                                            background: provider.status == "reachable" ? Theme.accent-glow
                                                      : provider.status == "unreachable" ? Theme.color-danger.transparentize(60%)
                                                      : transparent;
                                        }
                                    }

                                    VerticalLayout {
                                        spacing: 2px;
                                        alignment: center;

                                        HorizontalLayout {
                                            spacing: Theme.sp-2;

                                            Text {
                                                text: provider.name;
                                                color: Theme.text-primary;
                                                font-size: Theme.fs-body;
                                                font-weight: 500;
                                            }

                                            // Primary/Fallback badge
                                            if provider.is-primary : Rectangle {
                                                width: 58px;
                                                height: 18px;
                                                border-radius: 9px;
                                                background: Theme.accent-glow;
                                                Text {
                                                    text: "Primary";
                                                    color: Theme.accent;
                                                    font-size: Theme.fs-caption;
                                                    font-weight: 600;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                            }
                                            if provider.is-fallback : Rectangle {
                                                width: 62px;
                                                height: 18px;
                                                border-radius: 9px;
                                                background: Theme.amber-glow;
                                                Text {
                                                    text: "Fallback";
                                                    color: Theme.amber;
                                                    font-size: Theme.fs-caption;
                                                    font-weight: 600;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                            }
                                        }

                                        Text {
                                            text: provider.base-url;
                                            color: Theme.text-dim;
                                            font-size: Theme.fs-caption;
                                            overflow: elide;
                                        }
                                    }
                                }

                                // Latency display
                                VerticalLayout {
                                    alignment: center;
                                    spacing: 2px;

                                    Text {
                                        text: provider.status == "testing" ? "..."
                                            : provider.status == "reachable" ? (provider.latency-ms + "ms")
                                            : provider.status == "unreachable" ? "\u{2717}"
                                            : "\u{2014}";
                                        color: provider.status == "reachable" ?
                                                (provider.latency-ms < 100 ? Theme.color-reminder
                                               : provider.latency-ms < 500 ? Theme.amber
                                               : Theme.color-danger)
                                             : provider.status == "unreachable" ? Theme.color-danger
                                             : Theme.text-dim;
                                        font-size: Theme.fs-body;
                                        font-weight: 600;
                                        horizontal-alignment: right;
                                    }

                                    Text {
                                        text: provider.provider-type;
                                        color: Theme.text-dim;
                                        font-size: Theme.fs-caption;
                                        horizontal-alignment: right;
                                    }
                                }
                            }
                        }
                    }

                    // ── Ping Tool ──
                    VerticalLayout {
                        spacing: Theme.sp-2;

                        Text {
                            text: "Ping / Traceroute";
                            color: Theme.text-primary;
                            font-size: Theme.fs-headline;
                            font-weight: 600;
                        }

                        Rectangle {
                            background: Theme.bg-card;
                            border-radius: Theme.r-lg;
                            border-width: 1px;
                            border-color: Theme.border-subtle;
                            height: ping-tool-layout.preferred-height + 24px;

                            ping-tool-layout := VerticalLayout {
                                padding: Theme.sp-4;
                                spacing: 10px;

                                HorizontalLayout {
                                    spacing: Theme.sp-2;

                                    // Target input
                                    Rectangle {
                                        horizontal-stretch: 1;
                                        height: 36px;
                                        background: Theme.bg-input; clip: true;
                                        border-radius: Theme.r-lg;
                                        border-width: 1px;
                                        border-color: Theme.border-subtle;

                                        ping-target-input := TextInput {
                                            x: 10px;
                                            width: parent.width - 20px;
                                            height: 100%;
                                            text <=> root.net-diag-ping-target;
                                            color: Theme.text-primary;
                                            font-size: Theme.fs-body;
                                            accepted => { root.net-diag-run-ping(); }
                                        }
                                    }

                                    ActionButton {
                                        label: root.net-diag-ping-running ? "..." : "Ping";
                                        width: 80px;
                                        primary: true;
                                        clicked => { root.net-diag-run-ping(); }
                                    }

                                    ActionButton {
                                        label: root.net-diag-traceroute-running ? "..." : "Traceroute";
                                        width: 110px;
                                        clicked => { root.net-diag-run-traceroute(); }
                                    }
                                }

                                // Ping spinner
                                if root.net-diag-ping-running || root.net-diag-traceroute-running : HorizontalLayout {
                                    spacing: Theme.sp-2;
                                    Rectangle {
                                        width: 14px;
                                        height: 14px;
                                        border-radius: 7px;
                                        border-width: 2px;
                                        border-color: Theme.accent;
                                        background: transparent;
                                    }
                                    Text {
                                        text: root.net-diag-ping-running ? "Pinging..." : "Running traceroute...";
                                        color: Theme.accent;
                                        font-size: Theme.fs-caption;
                                        vertical-alignment: center;
                                    }
                                }

                                // Ping result
                                if root.net-diag-ping-result != "" : Rectangle {
                                    background: Theme.bg-elevated;
                                    border-radius: Theme.r-sm;
                                    height: Math.min(ping-result-text.preferred-height + 16px, 160px);

                                    Flickable {
                                        width: parent.width;
                                        height: parent.height;
                                        viewport-height: ping-result-text.preferred-height + 16px;

                                        ping-result-text := Text {
                                            x: 10px;
                                            y: Theme.sp-2;
                                            width: parent.width - 20px;
                                            text: root.net-diag-ping-result;
                                            color: Theme.text-secondary;
                                            font-size: Theme.fs-micro;
                                            wrap: word-wrap;
                                        }
                                    }
                                }

                                // Traceroute result
                                if root.net-diag-traceroute-result != "" : Rectangle {
                                    background: Theme.bg-elevated;
                                    border-radius: Theme.r-sm;
                                    height: Math.min(traceroute-result-text.preferred-height + 16px, 200px);

                                    HorizontalLayout {
                                        padding-left: Theme.sp-3;
                                        padding-top: Theme.sp-1;
                                        Text {
                                            text: "Traceroute:";
                                            color: Theme.text-dim;
                                            font-size: Theme.fs-micro;
                                            font-weight: 600;
                                        }
                                    }

                                    Flickable {
                                        y: 18px;
                                        width: parent.width;
                                        height: parent.height - 18px;
                                        viewport-height: traceroute-result-text.preferred-height + 16px;

                                        traceroute-result-text := Text {
                                            x: 10px;
                                            y: Theme.sp-1;
                                            width: parent.width - 20px;
                                            text: root.net-diag-traceroute-result;
                                            color: Theme.text-secondary;
                                            font-size: Theme.fs-micro;
                                            wrap: word-wrap;
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // Connection History section
                    VerticalLayout {
                        spacing: Theme.sp-2;

                        Text {
                            text: "Connection History";
                            color: Theme.text-primary;
                            font-size: Theme.fs-headline;
                            font-weight: 600;
                        }

                        if root.diag-connection-history.length == 0 : Rectangle {
                            height: 60px;
                            background: Theme.bg-card;
                            border-radius: Theme.r-lg;
                            border-width: 1px;
                            border-color: Theme.border-subtle;
                            Text {
                                text: "No recent connection events";
                                color: Theme.text-dim;
                                font-size: Theme.fs-body;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        for event[idx] in root.diag-connection-history : Rectangle {
                            height: 44px;
                            background: Theme.bg-card;
                            border-radius: Theme.r-lg;
                            border-width: 1px;
                            border-color: Theme.border-subtle;

                            HorizontalLayout {
                                padding-left: Theme.sp-4;
                                padding-right: Theme.sp-4;
                                spacing: Theme.sp-3;
                                alignment: space-between;

                                Text {
                                    text: event.description;
                                    color: Theme.text-primary;
                                    font-size: Theme.fs-body;
                                    vertical-alignment: center;
                                    overflow: elide;
                                    horizontal-stretch: 1;
                                }

                                Text {
                                    text: event.timestamp;
                                    color: Theme.text-dim;
                                    font-size: Theme.fs-caption;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }
            }
        }

        // ── Network Status Bar (shown on all tabs) ──
        Rectangle {
            height: 32px;
            background: @linear-gradient(180deg,
                Theme.bg-deep.transparentize(50%) 0%,
                Theme.bg-surface.transparentize(40%) 100%
            );

            // Top border glow
            Rectangle {
                y: 0px;
                width: 100%;
                height: 1px;
                background: Theme.border-subtle;
                opacity: 0.5;
            }

            HorizontalLayout {
                padding-left: Theme.sp-4;
                padding-right: Theme.sp-4;
                spacing: Theme.sp-4;
                alignment: start;

                // Status dot
                Rectangle {
                    width: 8px;
                    height: 8px;
                    border-radius: 4px;
                    background: root.status-state == "connected" ? Theme.color-success
                              : root.status-state == "connecting" ? Theme.color-warning
                              : Theme.color-danger;
                    y: (parent.height - self.height) / 2;
                }

                // Connection type
                Text {
                    text: root.status-connection-type != "" ? root.status-connection-type : "No Connection";
                    color: Theme.text-secondary;
                    font-size: Theme.fs-micro;
                    font-weight: 500;
                    vertical-alignment: center;
                }

                // IP address
                if root.status-ip-address != "" : Text {
                    text: root.status-ip-address;
                    color: Theme.text-dim;
                    font-size: Theme.fs-micro;
                    vertical-alignment: center;
                }

                // Signal strength (WiFi only)
                if root.status-connection-type == "WiFi" && root.status-signal-strength > 0 : HorizontalLayout {
                    spacing: Theme.sp-1;
                    SignalBars {
                        strength: root.status-signal-strength;
                    }
                    Text {
                        text: root.status-signal-strength + "%";
                        color: Theme.text-dim;
                        font-size: Theme.fs-micro;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // ── WiFi Password Dialog (overlay) ──
        if root.wifi-password-visible : Rectangle {
            width: 100%;
            height: 100%;
            background: Theme.overlay-backdrop;

            TouchArea {
                width: 100%;
                height: 100%;
                clicked => { root.wifi-password-visible = false; }
            }

            Rectangle {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                width: 400px;
                height: pw-dialog-layout.preferred-height + 32px;
                background: Theme.bg-card;
                border-radius: Theme.r-lg;
                border-width: 1px;
                border-color: Theme.accent-dim;
                drop-shadow-blur: 20px;
                drop-shadow-color: Theme.overlay-shadow;

                // Block clicks from closing
                TouchArea { width: 100%; height: 100%; }

                pw-dialog-layout := VerticalLayout {
                    padding: Theme.sp-5;
                    spacing: Theme.sp-4;

                    Text {
                        text: "Connect to " + root.wifi-password-ssid;
                        color: Theme.text-primary;
                        font-size: Theme.fs-headline;
                        font-weight: 600;
                    }

                    VerticalLayout {
                        spacing: Theme.sp-2;
                        Text {
                            text: "Password";
                            color: Theme.text-secondary;
                            font-size: Theme.fs-caption;
                        }
                        Rectangle {
                            height: 40px;
                            background: Theme.bg-input; clip: true;
                            border-radius: Theme.r-lg;
                            border-width: 1px;
                            border-color: Theme.border-subtle;

                            pw-input := TextInput {
                                x: 12px;
                                width: parent.width - 24px;
                                height: 100%;
                                text <=> root.wifi-password-input;
                                color: Theme.text-primary;
                                font-size: Theme.fs-body;
                                accepted => {
                                    root.wifi-connect(root.wifi-password-ssid, root.wifi-password-input);
                                    root.wifi-password-visible = false;
                                }
                            }
                        }
                    }

                    if root.wifi-connect-status != "" : Text {
                        text: root.wifi-connect-status;
                        color: Theme.color-emotional;
                        font-size: Theme.fs-caption;
                    }

                    HorizontalLayout {
                        spacing: 10px;
                        alignment: end;

                        ActionButton {
                            label: "Cancel";
                            width: 80px;
                            clicked => { root.wifi-password-visible = false; }
                        }
                        ActionButton {
                            label: "Connect";
                            width: 100px;
                            primary: true;
                            clicked => {
                                root.wifi-connect(root.wifi-password-ssid, root.wifi-password-input);
                                root.wifi-password-visible = false;
                            }
                        }
                    }
                }
            }
        }
    }
}
