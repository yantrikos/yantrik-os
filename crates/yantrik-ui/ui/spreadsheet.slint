// Spreadsheet — full-featured spreadsheet app for Yantrik OS.
// Screen 29. Opens from dock "ySheets" icon or app grid.
// Features: formulas, multi-sheet, formatting, sort/filter, freeze panes,
// find/replace, cell colors, comments, charts, number formatting.

import { Theme } from "theme.slint";
import { ScrollView, LineEdit } from "std-widgets.slint";

export struct SpreadsheetCell {
    text: string,
    is-formula: bool,
    is-bold: bool,
    is-italic: bool,
    align: int,       // 0=left, 1=center, 2=right
    bg-color: brush,
    text-color: brush,
    has-comment: bool,
    number-format: int, // 0=general,1=number,2=currency,3=percent,4=date,5=scientific
}

export struct SheetTab {
    name: string,
    is-active: bool,
}

export struct ChartData {
    chart-type: int,   // 0=bar, 1=line, 2=pie
    title: string,
    labels: string,    // comma-separated
    values: string,    // comma-separated
}

component CellView inherits Rectangle {
    in property <string> cell-text: "";
    in property <bool> is-bold: false;
    in property <bool> is-italic: false;
    in property <int> align: 0;
    in property <brush> cell-bg: Theme.bg-deep;
    in property <brush> cell-text-color: Theme.text-primary;
    in property <bool> is-selected: false;
    in property <bool> is-header: false;
    in property <bool> has-comment: false;
    in property <bool> is-active-row: false;
    in property <bool> is-active-col: false;

    callback clicked();

    width: 100px;
    height: 28px;
    background: is-header
        ? (is-active-col ? #1e1d2a : Theme.bg-elevated)
        : is-selected
            ? #2e9b4730
            : (is-active-row || is-active-col)
                ? #ffffff06
                : cell-bg;
    border-width: is-selected ? 2px : 1px;
    border-color: is-selected ? #2e9b47 : #ffffff12;

    // Selected cell glow
    Rectangle {
        visible: root.is-selected;
        width: parent.width;
        height: parent.height;
        border-width: 1px;
        border-color: #2e9b4760;
        drop-shadow-blur: 6px;
        drop-shadow-color: #2e9b4740;
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }

    txt := Text {
        x: 4px;
        y: 0px;
        width: parent.width - 8px;
        height: parent.height;
        text: root.cell-text;
        color: is-header ? Theme.text-primary : root.cell-text-color;
        font-size: is-header ? Theme.font-small : 13px;
        font-weight: root.is-bold ? 700 : (is-header ? 700 : 400);
        font-italic: root.is-italic;
        horizontal-alignment: root.align == 1 ? center : (root.align == 2 ? right : left);
        vertical-alignment: center;
        overflow: elide;
    }

    // Comment indicator (red triangle in top-right)
    Rectangle {
        visible: root.has-comment;
        x: parent.width - 8px;
        y: 0px;
        width: 8px;
        height: 8px;
        // Use a colored rectangle as indicator
        Rectangle {
            width: 6px;
            height: 6px;
            x: 2px;
            y: 0px;
            background: #e74c3c;
            border-radius: 1px;
        }
    }
}

// Toolbar button component — minimum 36px hit target
component SheetToolBtn inherits Rectangle {
    in property <string> label;
    in property <bool> active: false;
    in property <brush> active-color: #2e9b47;
    callback clicked();

    width: 36px;
    height: 30px;
    border-radius: 4px;
    background: active ? active-color.transparentize(0.75) : (ta.has-hover ? Theme.hover-fill-strong : transparent);
    border-width: active ? 1px : 0px;
    border-color: active-color;

    ta := TouchArea { clicked => { root.clicked(); } }

    Text {
        text: root.label;
        font-size: 13px;
        font-weight: active ? 700 : 500;
        color: active ? active-color : Theme.text-primary;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component SheetToolBtnWide inherits Rectangle {
    in property <string> label;
    in property <bool> active: false;
    callback clicked();

    width: 72px;
    height: 30px;
    border-radius: 4px;
    background: active ? #2e9b4720 : (ta.has-hover ? Theme.hover-fill-strong : transparent);

    ta := TouchArea { clicked => { root.clicked(); } }

    Text {
        text: root.label;
        font-size: Theme.font-small;
        color: active ? #2e9b47 : Theme.text-primary;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

// Vertical separator between toolbar groups
component ToolSep inherits Rectangle {
    width: 1px;
    height: 22px;
    background: #ffffff14;
}

// Color picker palette (8 colors)
component ColorPalette inherits Rectangle {
    in property <bool> show: false;
    callback color-selected(int);

    visible: show;
    width: 148px;
    height: 44px;
    background: Theme.bg-card;
    border-radius: 6px;
    border-width: 1px;
    border-color: Theme.border-subtle;
    drop-shadow-blur: 8px;
    drop-shadow-color: #00000040;

    HorizontalLayout {
        padding: 6px;
        spacing: 4px;

        // None
        Rectangle {
            width: 14px; height: 14px; border-radius: 3px;
            background: transparent; border-width: 1px; border-color: Theme.border-subtle;
            TouchArea { clicked => { root.color-selected(0); } }
            Text { text: "x"; font-size: 10px; color: Theme.text-dim; horizontal-alignment: center; vertical-alignment: center; }
        }
        // Red
        Rectangle { width: 14px; height: 14px; border-radius: 3px; background: #e74c3c;
            TouchArea { clicked => { root.color-selected(1); } } }
        // Orange
        Rectangle { width: 14px; height: 14px; border-radius: 3px; background: #f39c12;
            TouchArea { clicked => { root.color-selected(2); } } }
        // Yellow
        Rectangle { width: 14px; height: 14px; border-radius: 3px; background: #f1c40f;
            TouchArea { clicked => { root.color-selected(3); } } }
        // Green
        Rectangle { width: 14px; height: 14px; border-radius: 3px; background: #2ecc71;
            TouchArea { clicked => { root.color-selected(4); } } }
        // Blue
        Rectangle { width: 14px; height: 14px; border-radius: 3px; background: #3498db;
            TouchArea { clicked => { root.color-selected(5); } } }
        // Purple
        Rectangle { width: 14px; height: 14px; border-radius: 3px; background: #9b59b6;
            TouchArea { clicked => { root.color-selected(6); } } }
        // Gray
        Rectangle { width: 14px; height: 14px; border-radius: 3px; background: #95a5a6;
            TouchArea { clicked => { root.color-selected(7); } } }
    }
}

export component SpreadsheetScreen inherits Rectangle {
    background: Theme.bg-deep;

    // Grid data — flat array, indexed as [row * col-count + col]
    in property <[SpreadsheetCell]> cell-grid: [];

    // Active cell
    in-out property <int> active-row: 0;
    in-out property <int> active-col: 0;

    // Formula bar content
    in property <string> cell-data: "";

    // Sheet tabs
    in property <[SheetTab]> sheet-tabs: [{ name: "Sheet 1", is-active: true }];

    // Status bar
    in property <string> status-text: "Ready";

    // AI Assist
    in-out property <bool> show-ai-panel: false;
    in property <bool> sheet-ai-working: false;
    in property <string> sheet-ai-response: "";
    in-out property <string> sheet-ai-prompt: "";
    callback sheet-ai-submit(string);
    callback sheet-ai-apply();
    callback sheet-ai-dismiss();
    callback sheet-ai-formula(string);
    callback sheet-ai-analyze();
    callback sheet-ai-suggest-chart();
    callback sheet-ai-insights();

    // Grid dimensions
    in property <int> row-count: 50;
    in property <int> col-count: 26;

    // Formatting state for toolbar toggles
    in property <bool> fmt-bold-active: false;
    in property <bool> fmt-italic-active: false;
    in property <int> fmt-align-active: 0;

    // Number format of active cell
    in property <int> fmt-number-format: 0;

    // Freeze panes
    in property <int> freeze-rows: 0;
    in property <int> freeze-cols: 0;

    // Find/Replace state
    in-out property <bool> show-find: false;
    in-out property <string> find-query: "";
    in-out property <string> replace-text: "";
    in property <string> find-status: "";

    // Comment for active cell
    in property <string> active-comment: "";
    in-out property <bool> show-comment-panel: false;
    in-out property <string> comment-input: "";

    // Chart data
    in property <ChartData> chart-data: { chart-type: 0, title: "", labels: "", values: "" };
    in-out property <bool> show-chart: false;

    // Color picker state
    property <bool> show-bg-picker: false;
    property <bool> show-text-picker: false;

    // Filter active
    in property <bool> filter-active: false;

    // Sort indicator
    in property <int> sort-col: -1;
    in property <bool> sort-ascending: true;

    // Formula help
    in property <string> sheet-formula-error: "";
    in property <[string]> sheet-formula-hints: [];
    in-out property <bool> sheet-formula-help-open: false;

    // Callbacks — existing
    callback cell-clicked(int, int);
    callback cell-edited(int, int, string);
    callback formula-submitted(string);
    callback switch-sheet(int);
    callback add-sheet();
    callback format-bold();
    callback format-italic();
    callback format-align(int);
    callback import-csv();
    callback export-csv();

    // Callbacks — new
    callback sort-column(int, bool);       // col, ascending
    callback filter-column(int, string);   // col, filter-text
    callback clear-filter();
    callback insert-row(int);              // after-row
    callback delete-row(int);
    callback insert-col(int);              // after-col
    callback delete-col(int);
    callback format-number(int);           // format-type
    callback set-bg-color(int);            // color-idx
    callback set-text-color(int);          // color-idx
    callback find-text(string);
    callback find-next();
    callback replace-one(string, string);
    callback replace-all(string, string);
    callback copy-cell();
    callback paste-cell();
    callback cut-cell();
    callback undo();
    callback redo();
    callback key-pressed(string);
    callback add-comment(string);
    callback delete-comment();
    callback merge-cells(int, int, int, int);
    callback unmerge-cells();
    callback freeze-panes(int, int);       // rows, cols
    callback save-sheet();
    callback load-sheet();
    callback create-chart(int, string);    // type, range
    callback sheet-show-formula-help();

    // Helper: column letter from index
    pure function col-letter(col: int) -> string {
        col == 0 ? "A" : col == 1 ? "B" : col == 2 ? "C" : col == 3 ? "D"
        : col == 4 ? "E" : col == 5 ? "F" : col == 6 ? "G" : col == 7 ? "H"
        : col == 8 ? "I" : col == 9 ? "J" : col == 10 ? "K" : col == 11 ? "L"
        : col == 12 ? "M" : col == 13 ? "N" : col == 14 ? "O" : col == 15 ? "P"
        : col == 16 ? "Q" : col == 17 ? "R" : col == 18 ? "S" : col == 19 ? "T"
        : col == 20 ? "U" : col == 21 ? "V" : col == 22 ? "W" : col == 23 ? "X"
        : col == 24 ? "Y" : "Z";
    }

    VerticalLayout {
        // ── Primary Toolbar — grouped with separators ──
        Rectangle {
            height: 38px;
            background: Theme.bg-surface;

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 3px;
                alignment: start;

                // ── File group: Save / Import / Export ──
                SheetToolBtnWide { label: "Save"; clicked => { root.save-sheet(); } }
                SheetToolBtnWide { label: "Import"; clicked => { root.import-csv(); } }
                SheetToolBtnWide { label: "Export"; clicked => { root.export-csv(); } }

                ToolSep { }

                // ── Edit group: Undo / Redo / Find ──
                SheetToolBtn { label: "Undo"; width: 44px; clicked => { root.undo(); } }
                SheetToolBtn { label: "Redo"; width: 44px; clicked => { root.redo(); } }
                SheetToolBtn {
                    label: "Find";
                    width: 44px;
                    active: root.show-find;
                    clicked => { root.show-find = !root.show-find; }
                }

                ToolSep { }

                // ── Format group: Bold / Italic / Color / Alignment ──
                SheetToolBtn { label: "B"; active: root.fmt-bold-active; clicked => { root.format-bold(); } }
                SheetToolBtn { label: "I"; active: root.fmt-italic-active; clicked => { root.format-italic(); } }

                // Cell bg color
                Rectangle {
                    width: 36px;
                    height: 30px;
                    border-radius: 4px;
                    background: bg-ta.has-hover ? Theme.hover-fill-strong : transparent;

                    bg-ta := TouchArea { clicked => { root.show-bg-picker = !root.show-bg-picker; root.show-text-picker = false; } }

                    VerticalLayout {
                        alignment: center;
                        spacing: 1px;
                        Text { text: "A"; font-size: 12px; font-weight: 700; color: Theme.text-primary; horizontal-alignment: center; }
                        Rectangle { width: 16px; height: 3px; background: #f39c12; }
                    }
                }

                // Cell text color
                Rectangle {
                    width: 36px;
                    height: 30px;
                    border-radius: 4px;
                    background: tc-ta.has-hover ? Theme.hover-fill-strong : transparent;

                    tc-ta := TouchArea { clicked => { root.show-text-picker = !root.show-text-picker; root.show-bg-picker = false; } }

                    VerticalLayout {
                        alignment: center;
                        spacing: 1px;
                        Text { text: "A"; font-size: 12px; font-weight: 700; color: #e74c3c; horizontal-alignment: center; }
                        Rectangle { width: 16px; height: 3px; background: #e74c3c; }
                    }
                }

                // Alignment
                SheetToolBtn { label: "Left"; width: 40px; active: root.fmt-align-active == 0; clicked => { root.format-align(0); } }
                SheetToolBtn { label: "Ctr"; width: 36px; active: root.fmt-align-active == 1; clicked => { root.format-align(1); } }
                SheetToolBtn { label: "Rgt"; width: 36px; active: root.fmt-align-active == 2; clicked => { root.format-align(2); } }

                // Number format dropdown-like button
                Rectangle {
                    width: 84px;
                    height: 30px;
                    border-radius: 4px;
                    background: nf-ta.has-hover ? Theme.hover-fill-strong : Theme.bg-card;
                    border-width: 1px;
                    border-color: #ffffff10;

                    nf-ta := TouchArea {
                        clicked => {
                            // Cycle through number formats
                            root.format-number(mod(root.fmt-number-format + 1, 6));
                        }
                    }

                    Text {
                        text: root.fmt-number-format == 0 ? "General"
                            : root.fmt-number-format == 1 ? "Number"
                            : root.fmt-number-format == 2 ? "Currency"
                            : root.fmt-number-format == 3 ? "Percent"
                            : root.fmt-number-format == 4 ? "Date"
                            : "Scientific";
                        font-size: 11px;
                        color: Theme.text-primary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                ToolSep { }

                // ── Insert group: Row / Col / Chart / Comment ──
                SheetToolBtn { label: "+Row"; width: 44px; clicked => { root.insert-row(root.active-row); } }
                SheetToolBtn { label: "-Row"; width: 44px; clicked => { root.delete-row(root.active-row); } }
                SheetToolBtn { label: "+Col"; width: 40px; clicked => { root.insert-col(root.active-col); } }
                SheetToolBtn { label: "-Col"; width: 40px; clicked => { root.delete-col(root.active-col); } }

                SheetToolBtnWide {
                    label: "Chart";
                    clicked => { root.create-chart(0, root.col-letter(root.active-col) + "1:" + root.col-letter(root.active-col) + "50"); }
                }

                SheetToolBtn {
                    label: "Note";
                    width: 42px;
                    active: root.show-comment-panel;
                    clicked => { root.show-comment-panel = !root.show-comment-panel; }
                }

                ToolSep { }

                // ── Data group: Sort / Filter / Freeze / Validation ──
                SheetToolBtn { label: "Sort"; width: 40px; clicked => { root.sort-column(root.active-col, true); } }
                SheetToolBtn {
                    label: "Filter";
                    width: 46px;
                    active: root.filter-active;
                    clicked => {
                        if root.filter-active { root.clear-filter(); }
                    }
                }
                SheetToolBtnWide {
                    label: root.freeze-rows > 0 || root.freeze-cols > 0 ? "Unfreeze" : "Freeze";
                    active: root.freeze-rows > 0 || root.freeze-cols > 0;
                    clicked => {
                        if root.freeze-rows > 0 || root.freeze-cols > 0 {
                            root.freeze-panes(0, 0);
                        } else {
                            root.freeze-panes(root.active-row + 1, root.active-col + 1);
                        }
                    }
                }

                ToolSep { }

                // ── Clipboard ──
                SheetToolBtn { label: "Copy"; width: 42px; clicked => { root.copy-cell(); } }
                SheetToolBtn { label: "Paste"; width: 44px; clicked => { root.paste-cell(); } }

                ToolSep { }

                // ── AI Assist toggle — at the end ──
                Rectangle {
                    width: 52px;
                    height: 30px;
                    border-radius: 4px;
                    background: root.show-ai-panel ? Theme.accent.transparentize(0.75) : (ai-ta.has-hover ? Theme.hover-fill-strong : transparent);
                    border-width: root.show-ai-panel ? 1px : 0px;
                    border-color: Theme.accent;

                    ai-ta := TouchArea { clicked => { root.show-ai-panel = !root.show-ai-panel; } }

                    Text {
                        text: "AI";
                        font-size: 13px;
                        font-weight: 700;
                        color: root.show-ai-panel ? Theme.accent : Theme.accent-dim;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // Color palettes (positioned over toolbar)
        Rectangle {
            height: 0px;

            ColorPalette {
                x: 380px;
                y: -44px;
                show: root.show-bg-picker;
                color-selected(idx) => {
                    root.set-bg-color(idx);
                    root.show-bg-picker = false;
                }
            }

            ColorPalette {
                x: 416px;
                y: -44px;
                show: root.show-text-picker;
                color-selected(idx) => {
                    root.set-text-color(idx);
                    root.show-text-picker = false;
                }
            }
        }

        // Separator
        Rectangle { height: 1px; background: #ffffff10; }

        // ── Find/Replace Bar ──
        Rectangle {
            height: root.show-find ? 36px : 0px;
            visible: root.show-find;
            background: Theme.bg-card;

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                spacing: 8px;
                alignment: start;

                Text { text: "Find:"; color: Theme.text-primary; font-size: Theme.font-small; vertical-alignment: center; }

                find-input := LineEdit {
                    width: 160px;
                    text <=> root.find-query;
                    placeholder-text: "Search cells...";
                    accepted => { root.find-text(root.find-query); }
                }

                SheetToolBtn { label: "Next"; width: 42px; clicked => { root.find-next(); } }

                ToolSep { }

                Text { text: "Replace:"; color: Theme.text-primary; font-size: Theme.font-small; vertical-alignment: center; }

                replace-input := LineEdit {
                    width: 140px;
                    text <=> root.replace-text;
                    placeholder-text: "Replace with...";
                }

                SheetToolBtn { label: "One"; width: 36px; clicked => { root.replace-one(root.find-query, root.replace-text); } }
                SheetToolBtn { label: "All"; width: 36px; clicked => { root.replace-all(root.find-query, root.replace-text); } }

                ToolSep { }

                Text { text: root.find-status; color: Theme.text-dim; font-size: Theme.font-small; vertical-alignment: center; }
            }
        }

        // Separator (only if find visible)
        Rectangle { height: root.show-find ? 1px : 0px; background: #ffffff10; }

        // ── Formula Bar — prominent ──
        Rectangle {
            height: 38px;
            background: Theme.bg-surface;

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 0px;

                // Cell reference label (e.g. "A1")
                Rectangle {
                    width: 64px;
                    height: 32px;
                    border-radius: 4px;
                    background: Theme.bg-card;
                    border-width: 1px;
                    border-color: #ffffff10;

                    Text {
                        text: root.col-letter(root.active-col) + "\{root.active-row + 1}";
                        font-size: 14px;
                        font-weight: 700;
                        color: #2e9b47;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                // Separator between cell ref and formula
                Rectangle {
                    width: 1px;
                    height: 24px;
                    background: #ffffff14;
                }

                // fx label — clickable to toggle formula help
                Rectangle {
                    width: 32px;
                    height: 32px;
                    border-radius: 4px;
                    background: fx-ta.has-hover ? Theme.hover-fill : (root.sheet-formula-help-open ? Theme.accent.transparentize(0.8) : transparent);

                    fx-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.sheet-show-formula-help(); }
                    }

                    Text {
                        width: 32px;
                        text: "fx";
                        font-size: 15px;
                        font-italic: true;
                        font-weight: 600;
                        color: root.sheet-formula-help-open ? Theme.accent : Theme.text-secondary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                // Formula input — lighter background to stand out
                Rectangle {
                    height: 30px;
                    border-radius: 4px;
                    background: #0e0d16;
                    border-width: 1px;
                    border-color: #ffffff10;

                    formula-input := TextInput {
                        x: 8px;
                        y: 0px;
                        width: parent.width - 16px;
                        height: parent.height;
                        text: root.cell-data;
                        font-size: 13px;
                        color: Theme.text-primary;
                        vertical-alignment: center;

                        accepted => {
                            root.formula-submitted(self.text);
                        }
                    }
                }
            }
        }

        // ── Formula error display ──
        Rectangle {
            height: root.sheet-formula-error != "" ? 26px : 0px;
            visible: root.sheet-formula-error != "";
            background: #f59e0b20;
            border-width: 0px;

            HorizontalLayout {
                padding-left: 12px;
                spacing: 6px;
                alignment: start;

                Text {
                    text: root.sheet-formula-error;
                    color: #f59e0b;
                    font-size: 11px;
                    font-weight: 500;
                    vertical-alignment: center;
                }
            }
        }

        // ── Formula help panel ──
        Rectangle {
            height: root.sheet-formula-help-open ? 160px : 0px;
            visible: root.sheet-formula-help-open;
            background: Theme.bg-card;
            border-width: 1px;
            border-color: Theme.accent.transparentize(0.7);
            border-radius: 0px;

            VerticalLayout {
                padding: 10px;
                spacing: 4px;

                Text {
                    text: "Available Functions";
                    color: Theme.accent;
                    font-size: 12px;
                    font-weight: 700;
                }

                ScrollView {
                    VerticalLayout {
                        spacing: 2px;

                        for hint in root.sheet-formula-hints: Rectangle {
                            height: 18px;

                            Text {
                                x: 8px;
                                text: hint;
                                color: Theme.text-primary;
                                font-size: 11px;
                                font-family: "monospace";
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }

        // Separator
        Rectangle { height: 1px; background: #ffffff10; }

        // ── Main area: Grid + optional comment panel ──
        HorizontalLayout {
            // ── Grid Area ──
            Rectangle {
                ScrollView {
                    width: 100%;
                    height: 100%;

                    VerticalLayout {
                        // Column header row
                        HorizontalLayout {
                            // Top-left corner cell (empty)
                            Rectangle {
                                width: 48px;
                                height: 28px;
                                background: #16152020;
                                border-width: 1px;
                                border-color: #ffffff12;
                            }

                            // Column headers A-Z
                            for col-idx in root.col-count : CellView {
                                width: 100px;
                                height: 28px;
                                cell-text: root.col-letter(col-idx);
                                is-header: true;
                                is-selected: col-idx == root.active-col;
                                is-active-col: col-idx == root.active-col;

                                clicked => {
                                    // Click header to sort
                                    root.sort-column(col-idx, root.sort-col != col-idx ? true : !root.sort-ascending);
                                }
                            }
                        }

                        // Data rows
                        for row-idx in root.row-count : HorizontalLayout {
                            // Row header
                            Rectangle {
                                width: 48px;
                                height: 28px;
                                background: row-idx == root.active-row ? #1e1d2a : #16152020;
                                border-width: 1px;
                                border-color: #ffffff12;

                                Text {
                                    text: "\{row-idx + 1}";
                                    font-size: Theme.font-small;
                                    font-weight: row-idx == root.active-row ? 700 : 600;
                                    color: row-idx == root.active-row ? #2e9b47 : Theme.text-secondary;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            // Data cells
                            for col-idx in root.col-count : CellView {
                                width: 100px;
                                height: 28px;
                                cell-text: (row-idx * root.col-count + col-idx) < root.cell-grid.length
                                    ? root.cell-grid[row-idx * root.col-count + col-idx].text : "";
                                is-bold: (row-idx * root.col-count + col-idx) < root.cell-grid.length
                                    ? root.cell-grid[row-idx * root.col-count + col-idx].is-bold : false;
                                is-italic: (row-idx * root.col-count + col-idx) < root.cell-grid.length
                                    ? root.cell-grid[row-idx * root.col-count + col-idx].is-italic : false;
                                align: (row-idx * root.col-count + col-idx) < root.cell-grid.length
                                    ? root.cell-grid[row-idx * root.col-count + col-idx].align : 0;
                                cell-bg: (row-idx * root.col-count + col-idx) < root.cell-grid.length
                                    ? root.cell-grid[row-idx * root.col-count + col-idx].bg-color : Theme.bg-deep;
                                cell-text-color: (row-idx * root.col-count + col-idx) < root.cell-grid.length
                                    ? root.cell-grid[row-idx * root.col-count + col-idx].text-color : Theme.text-primary;
                                has-comment: (row-idx * root.col-count + col-idx) < root.cell-grid.length
                                    ? root.cell-grid[row-idx * root.col-count + col-idx].has-comment : false;
                                is-selected: row-idx == root.active-row && col-idx == root.active-col;
                                is-active-row: row-idx == root.active-row;
                                is-active-col: col-idx == root.active-col;

                                clicked => {
                                    root.active-row = row-idx;
                                    root.active-col = col-idx;
                                    root.cell-clicked(row-idx, col-idx);
                                }
                            }
                        }
                    }
                }
            }

            // ── Comment panel (right sidebar) ──
            Rectangle {
                visible: root.show-comment-panel;
                width: root.show-comment-panel ? 220px : 0px;
                background: Theme.bg-surface;

                // Left border
                Rectangle {
                    width: 1px;
                    height: 100%;
                    background: Theme.separator;
                }

                VerticalLayout {
                    padding: 12px;
                    spacing: 8px;

                    Text {
                        text: "Cell Comment";
                        color: Theme.text-secondary;
                        font-size: 12px;
                        font-weight: 600;
                    }

                    Text {
                        text: root.col-letter(root.active-col) + "\{root.active-row + 1}";
                        color: #2e9b47;
                        font-size: 13px;
                        font-weight: 600;
                    }

                    Rectangle { height: 1px; background: Theme.separator; }

                    // Existing comment
                    Rectangle {
                        visible: root.active-comment != "";
                        height: 60px;
                        background: Theme.bg-card;
                        border-radius: 6px;
                        border-width: 1px;
                        border-color: Theme.border-subtle;

                        Text {
                            x: 8px;
                            y: 4px;
                            width: parent.width - 16px;
                            text: root.active-comment;
                            color: Theme.text-primary;
                            font-size: 12px;
                            wrap: word-wrap;
                            overflow: elide;
                        }
                    }

                    // Comment input
                    Rectangle {
                        height: 60px;
                        background: Theme.bg-input;
                        border-radius: 6px;
                        border-width: 1px;
                        border-color: Theme.border-subtle;

                        comment-ti := TextInput {
                            x: 8px;
                            y: 4px;
                            width: parent.width - 16px;
                            height: parent.height - 8px;
                            text <=> root.comment-input;
                            color: Theme.text-primary;
                            font-size: 12px;
                            wrap: word-wrap;
                            vertical-alignment: top;
                        }
                    }

                    HorizontalLayout {
                        spacing: 8px;

                        Rectangle {
                            height: 28px;
                            border-radius: 4px;
                            background: add-cmt-ta.has-hover ? #2e9b47 : #2e9b47cc;

                            add-cmt-ta := TouchArea {
                                clicked => {
                                    root.add-comment(root.comment-input);
                                    root.comment-input = "";
                                }
                            }

                            Text {
                                text: root.active-comment != "" ? "Update" : "Add";
                                color: white;
                                font-size: 12px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        Rectangle {
                            visible: root.active-comment != "";
                            height: 28px;
                            border-radius: 4px;
                            background: del-cmt-ta.has-hover ? #e74c3c : #e74c3ccc;

                            del-cmt-ta := TouchArea { clicked => { root.delete-comment(); } }

                            Text {
                                text: "Delete";
                                color: white;
                                font-size: 12px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Fill remaining space
                    Rectangle {}
                }
            }
        }

        // Separator
        Rectangle { height: 1px; background: #ffffff10; }

        // ── Bottom bar: Sheet tabs + Status ──
        Rectangle {
            height: 32px;
            background: Theme.bg-surface;

            HorizontalLayout {
                padding-left: 4px;
                padding-right: 8px;
                spacing: 0px;

                // Sheet tabs
                for tab[tab-idx] in root.sheet-tabs : Rectangle {
                    width: 100px;
                    height: 30px;
                    border-radius: 4px;
                    background: tab.is-active ? Theme.bg-card : (tab-touch.has-hover ? Theme.hover-fill : transparent);
                    border-width: tab.is-active ? 1px : 0px;
                    border-color: tab.is-active ? #2e9b47 : transparent;

                    tab-touch := TouchArea {
                        clicked => { root.switch-sheet(tab-idx); }
                    }

                    Text {
                        text: tab.name;
                        font-size: Theme.font-small;
                        color: tab.is-active ? #2e9b47 : Theme.text-secondary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                // Add sheet button
                Rectangle {
                    width: 32px;
                    height: 30px;
                    border-radius: 4px;
                    background: add-touch.has-hover ? Theme.hover-fill : transparent;

                    add-touch := TouchArea { clicked => { root.add-sheet(); } }

                    Text {
                        text: "+";
                        font-size: 16px;
                        font-weight: 700;
                        color: Theme.text-dim;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                // Spacer
                Rectangle { }

                // Freeze indicator
                Rectangle {
                    visible: root.freeze-rows > 0 || root.freeze-cols > 0;
                    width: 80px;
                    height: 22px;
                    border-radius: 3px;
                    background: #3498db30;

                    Text {
                        text: "Frozen " + root.freeze-rows + "R " + root.freeze-cols + "C";
                        font-size: 10px;
                        color: #3498db;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                // Filter indicator
                Rectangle {
                    visible: root.filter-active;
                    width: 60px;
                    height: 22px;
                    border-radius: 3px;
                    background: #f39c1230;

                    Text {
                        text: "Filtered";
                        font-size: 10px;
                        color: #f39c12;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                // Status text
                Text {
                    width: 300px;
                    text: root.status-text;
                    font-size: Theme.font-small;
                    color: Theme.text-dim;
                    horizontal-alignment: right;
                    vertical-alignment: center;
                }
            }
        }
    }

    // AI Assist Panel (right sidebar)
    Rectangle {
        visible: root.show-ai-panel;
        x: parent.width - 280px;
        y: 0px;
        width: 280px;
        height: parent.height;
        background: Theme.bg-card;
        border-width: 1px;
        border-color: Theme.separator;

        VerticalLayout {
            padding: 10px;
            spacing: 8px;

            // Header
            HorizontalLayout {
                spacing: 6px;
                height: 28px;

                Text {
                    text: "AI Assistant";
                    color: Theme.accent;
                    font-size: 13px;
                    font-weight: 600;
                    vertical-alignment: center;
                }

                Rectangle { }

                Rectangle {
                    width: 24px; height: 24px; border-radius: 4px;
                    background: close-ai-ta.has-hover ? Theme.hover-fill : transparent;
                    close-ai-ta := TouchArea { clicked => { root.show-ai-panel = false; } }
                    Text { text: "x"; color: Theme.text-dim; font-size: 14px; horizontal-alignment: center; vertical-alignment: center; }
                }
            }

            Rectangle { height: 1px; background: Theme.separator; }

            // Quick actions
            Text { text: "Quick Actions"; color: Theme.text-secondary; font-size: 10px; }

            HorizontalLayout {
                spacing: 4px;

                Rectangle {
                    height: 28px;
                    border-radius: 4px;
                    background: formula-ta.has-hover ? Theme.accent.transparentize(0.8) : Theme.bg-elevated;
                    border-width: 1px;
                    border-color: Theme.accent.transparentize(0.6);

                    formula-ta := TouchArea {
                        clicked => { root.sheet-ai-formula(root.sheet-ai-prompt); }
                    }
                    Text { text: "Formula"; color: Theme.accent; font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
                }

                Rectangle {
                    height: 28px;
                    border-radius: 4px;
                    background: analyze-ta.has-hover ? Theme.accent.transparentize(0.8) : Theme.bg-elevated;
                    border-width: 1px;
                    border-color: Theme.accent.transparentize(0.6);

                    analyze-ta := TouchArea {
                        clicked => { root.sheet-ai-analyze(); }
                    }
                    Text { text: "Analyze"; color: Theme.accent; font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
                }

                Rectangle {
                    height: 28px;
                    border-radius: 4px;
                    background: chart-ta.has-hover ? Theme.accent.transparentize(0.8) : Theme.bg-elevated;
                    border-width: 1px;
                    border-color: Theme.accent.transparentize(0.6);

                    chart-ta := TouchArea {
                        clicked => { root.sheet-ai-suggest-chart(); }
                    }
                    Text { text: "Chart"; color: Theme.accent; font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
                }

                Rectangle {
                    height: 28px;
                    border-radius: 4px;
                    background: insights-ta.has-hover ? #9b59b6cc : #9b59b680;
                    border-width: 1px;
                    border-color: #9b59b6;

                    insights-ta := TouchArea {
                        clicked => { root.sheet-ai-insights(); }
                    }
                    Text { text: "Insights"; color: #d2b4de; font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
                }
            }

            Rectangle { height: 1px; background: Theme.separator; }

            // Prompt input
            Text { text: "Ask AI"; color: Theme.text-secondary; font-size: 10px; }

            Rectangle {
                height: 60px;
                border-radius: 6px;
                background: Theme.bg-elevated;
                border-width: 1px;
                border-color: Theme.separator;

                ai-input := TextInput {
                    x: 8px; y: 6px;
                    width: parent.width - 16px;
                    height: parent.height - 12px;
                    color: Theme.text-primary;
                    font-size: 11px;
                    text: root.sheet-ai-prompt;
                    edited => { root.sheet-ai-prompt = self.text; }
                    accepted => { root.sheet-ai-submit(self.text); }
                }
            }

            // Submit button
            Rectangle {
                height: 28px;
                border-radius: 4px;
                background: root.sheet-ai-working ? Theme.text-dim : (submit-ai-ta.has-hover ? Theme.accent : Theme.accent.transparentize(0.2));

                submit-ai-ta := TouchArea {
                    enabled: !root.sheet-ai-working;
                    clicked => { root.sheet-ai-submit(root.sheet-ai-prompt); }
                }
                Text {
                    text: root.sheet-ai-working ? "Thinking..." : "Ask";
                    color: white;
                    font-size: 11px;
                    font-weight: 600;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            Rectangle { height: 1px; background: Theme.separator; }

            // Response area
            ScrollView {
                Rectangle {
                    background: transparent;

                    ai-response-text := Text {
                        text: root.sheet-ai-response;
                        color: Theme.text-primary;
                        font-size: 11px;
                        wrap: word-wrap;
                        width: parent.width;
                    }
                }
            }

            // Apply/Dismiss buttons (visible when there's a response)
            HorizontalLayout {
                visible: root.sheet-ai-response != "";
                spacing: 6px;
                height: 28px;

                Rectangle {
                    border-radius: 4px;
                    background: apply-ta.has-hover ? #2ecc71 : #2ecc71cc;

                    apply-ta := TouchArea { clicked => { root.sheet-ai-apply(); } }
                    Text { text: "Apply"; color: white; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                }

                Rectangle {
                    border-radius: 4px;
                    background: dismiss-ta.has-hover ? #e74c3c : #e74c3ccc;

                    dismiss-ta := TouchArea { clicked => { root.sheet-ai-dismiss(); } }
                    Text { text: "Dismiss"; color: white; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                }
            }
        }
    }

    // Keyboard handler (captures focus for the whole screen)
    key-handler := FocusScope {
        width: 0px;
        height: 0px;

        key-pressed(event) => {
            if event.text == "\u{001b}" {
                // Escape — close panels
                root.show-find = false;
                root.show-comment-panel = false;
                root.show-bg-picker = false;
                root.show-text-picker = false;
                root.show-ai-panel = false;
                root.sheet-formula-help-open = false;
            }
            if event.text == Key.UpArrow { root.key-pressed("up"); }
            if event.text == Key.DownArrow { root.key-pressed("down"); }
            if event.text == Key.LeftArrow { root.key-pressed("left"); }
            if event.text == Key.RightArrow { root.key-pressed("right"); }
            if event.text == Key.Tab { root.key-pressed("tab"); }
            if event.text == Key.Return { root.key-pressed("enter"); }
            if event.text == Key.Home { root.key-pressed("home"); }
            if event.text == Key.End { root.key-pressed("end"); }
            if event.text == Key.Delete { root.key-pressed("delete"); }
            accept
        }
    }
}
