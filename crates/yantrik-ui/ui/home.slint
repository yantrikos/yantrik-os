// Home screen — glance cards (proactive urges) + neural background.

import { Theme } from "theme.slint";
import { UrgeCardData, GlanceCard } from "components/glance_card.slint";
import { StatusPill } from "components/status_pill.slint";
import { InputBar } from "components/input_bar.slint";
import { Orb } from "components/orb.slint";
import { ParticleField } from "components/particle_field.slint";
import { ListView } from "std-widgets.slint";

export component HomeScreen inherits Rectangle {
    in property <[UrgeCardData]> urges: [];
    in property <int> memory-count: 0;
    callback orb-tapped();
    callback send-message(string);
    callback card-tapped(string);
    callback mic-pressed();
    callback navigate-to(int);  // 4=bond, 5=personality, 6=memory

    background: Theme.bg-deep;
    clip: true;

    // Neural particle background (dimmer than idle)
    ParticleField {
        width: 100%;
        height: 100%;
        active: true;
        intensity: 0.4;
    }

    VerticalLayout {
        // Header
        Rectangle {
            height: 56px;
            background: #0c0b10e0;

            HorizontalLayout {
                padding: 12px;
                padding-left: 16px;
                padding-right: 16px;
                alignment: space-between;

                // Logo
                Text {
                    text: "Yantrik";
                    color: Theme.amber;
                    font-size: Theme.font-logo;
                    font-weight: 700;
                    vertical-alignment: center;
                }

                // Status pill
                StatusPill {
                    memory-count: root.memory-count;
                }

                // Orb button -> idle
                TouchArea {
                    width: Theme.touch-target;
                    height: Theme.touch-target;
                    clicked => { root.orb-tapped(); }

                    Orb {
                        size-px: 28;
                        is-thinking: false;
                        has-urges: false;
                    }
                }
            }
        }

        // Thin separator glow
        Rectangle {
            height: 1px;
            background: @linear-gradient(90deg, transparent 0%, Theme.cyan-glow 50%, transparent 100%);
        }

        // Glance cards
        if urges.length > 0 : ListView {
            vertical-stretch: 1;

            for urge[idx] in root.urges : Rectangle {
                height: card.preferred-height + 8px;
                background: transparent;

                card := GlanceCard {
                    x: 16px;
                    y: 4px;
                    width: parent.width - 32px;
                    data: urge;
                    tapped(msg) => { root.card-tapped(msg); }
                }
            }
        }

        // Empty state — breathing orb + neural message
        if urges.length == 0 : Rectangle {
            vertical-stretch: 1;

            VerticalLayout {
                alignment: center;
                spacing: 24px;

                // Breathing orb (alive, centered)
                HorizontalLayout {
                    alignment: center;

                    Orb {
                        size-px: 80;
                        is-thinking: true;
                        has-urges: false;
                    }
                }

                // Caption
                Text {
                    text: "All quiet.";
                    color: Theme.text-secondary;
                    font-size: Theme.font-body;
                    horizontal-alignment: center;
                }

                Text {
                    text: "Neural pathways are forming...";
                    color: Theme.text-dim;
                    font-size: Theme.font-small;
                    horizontal-alignment: center;
                }
            }
        }

        // Quick links
        Rectangle {
            height: 52px;
            background: #0c0b10e0;

            // Top glow line
            Rectangle {
                y: 0;
                width: 100%;
                height: 1px;
                background: @linear-gradient(90deg, transparent 0%, Theme.cyan-glow 50%, transparent 100%);
            }

            HorizontalLayout {
                padding-left: 24px;
                padding-right: 24px;
                padding-top: 10px;
                padding-bottom: 10px;
                spacing: 12px;
                alignment: center;

                for nav-item in [
                    { label: "Bond", screen: 4 },
                    { label: "Personality", screen: 5 },
                    { label: "Memory", screen: 6 },
                ] : TouchArea {
                    width: 96px;
                    height: 32px;
                    clicked => { root.navigate-to(nav-item.screen); }

                    Rectangle {
                        border-radius: Theme.radius-pill;
                        background: Theme.bg-card;
                        border-width: 1px;
                        border-color: Theme.text-dim;

                        Text {
                            text: nav-item.label;
                            color: Theme.text-secondary;
                            font-size: Theme.font-small;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        // Input bar
        InputBar {
            send-message(text) => { root.send-message(text); }
            mic-pressed => { root.mic-pressed(); }
        }
    }
}
