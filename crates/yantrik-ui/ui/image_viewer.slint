// Image Viewer — full-screen image display with prev/next navigation.
// Screen 11. Opens from file browser when clicking image files.

import { Theme } from "theme.slint";

export component ImageViewer inherits Rectangle {
    background: Theme.bg-deep;

    in property <image> current-image;
    in property <string> file-name: "";
    in property <string> counter-text: "";   // e.g. "3 / 12"
    in-out property <bool> fit-contain: true; // true=contain, false=cover

    callback back-pressed();
    callback nav-prev();
    callback nav-next();
    callback toggle-fit();

    VerticalLayout {
        spacing: 0px;

        // Header
        Rectangle {
            height: 56px;
            background: Theme.bg-surface;

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                alignment: space-between;

                // Left: back + filename
                HorizontalLayout {
                    spacing: 12px;
                    alignment: start;

                    TouchArea {
                        width: Theme.touch-target;
                        height: Theme.touch-target;
                        clicked => { root.back-pressed(); }
                        Text {
                            text: "←";
                            color: Theme.text-secondary;
                            font-size: 22px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    Text {
                        text: root.file-name;
                        color: Theme.text-primary;
                        font-size: Theme.font-title;
                        font-weight: 600;
                        vertical-alignment: center;
                        overflow: elide;
                        max-width: 300px;
                    }
                }

                // Right: counter + fit toggle
                HorizontalLayout {
                    spacing: 16px;
                    alignment: end;

                    Text {
                        text: root.counter-text;
                        color: Theme.text-dim;
                        font-size: Theme.font-small;
                        vertical-alignment: center;
                    }

                    TouchArea {
                        width: Theme.touch-target;
                        height: Theme.touch-target;
                        clicked => { root.toggle-fit(); }
                        Rectangle {
                            width: 32px;
                            height: 32px;
                            border-radius: 6px;
                            background: parent.has-hover ? Theme.hover-fill-strong : transparent;
                            Text {
                                text: root.fit-contain ? "⊞" : "⊟";
                                color: Theme.text-secondary;
                                font-size: 18px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }

        // Separator
        Rectangle { height: 1px; background: Theme.separator; }

        // Image area
        Rectangle {
            background: #000000;

            Image {
                width: 100%;
                height: 100%;
                source: root.current-image;
                image-fit: root.fit-contain ? contain : cover;
            }

            // Left nav zone
            TouchArea {
                x: 0;
                y: 0;
                width: parent.width * 0.25;
                height: 100%;
                clicked => { root.nav-prev(); }

                if self.has-hover : Rectangle {
                    width: 100%;
                    height: 100%;
                    background: @linear-gradient(90deg, #00000040 0%, transparent 100%);

                    Text {
                        x: 16px;
                        text: "‹";
                        color: #ffffffc0;
                        font-size: 48px;
                        vertical-alignment: center;
                    }
                }
            }

            // Right nav zone
            TouchArea {
                x: parent.width * 0.75;
                y: 0;
                width: parent.width * 0.25;
                height: 100%;
                clicked => { root.nav-next(); }

                if self.has-hover : Rectangle {
                    width: 100%;
                    height: 100%;
                    background: @linear-gradient(270deg, #00000040 0%, transparent 100%);

                    Text {
                        x: parent.width - 40px;
                        text: "›";
                        color: #ffffffc0;
                        font-size: 48px;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}
