                            ig-layout := VerticalLayout {
                                padding: Theme.sp-4;
                                spacing: Theme.sp-3;

                                HorizontalLayout {
                                    spacing: Theme.sp-3;

                                    Rectangle {
                                        width: 36px; height: 36px;
                                        border-radius: Theme.r-md;
                                        background: Theme.color-danger-dim;

                                        Text {
                                            text: "\u{1F4F7}";
                                            color: Theme.color-emotional;
                                            font-size: Theme.fs-headline;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }

                                    VerticalLayout {
                                        horizontal-stretch: 1;
                                        spacing: 2px;

                                        Text {
                                            text: "Instagram";
                                            color: Theme.text-primary;
                                            font-size: Theme.fs-body;
                                            font-weight: 600;
                                        }
                                        Text {
                                            text: "Profile, interests, hashtags";
                                            color: Theme.text-dim;
                                            font-size: Theme.fs-caption;
                                        }
                                    }

                                    Rectangle {
                                        width: ig-status-text.preferred-width + 16px;
                                        height: 24px;
                                        border-radius: Theme.r-lg;
                                        background: root.conn-instagram-status == "connected" ? Theme.color-danger-dim :
                                                    root.conn-instagram-status == "connecting" ? Theme.color-warning-dim : Theme.border-subtle;
                                        border-width: 1px;
                                        border-color: root.conn-instagram-status == "connected" ? Theme.color-danger-dim :
                                                      root.conn-instagram-status == "connecting" ? Theme.color-warning-dim : Theme.border-subtle;

                                        ig-status-text := Text {
                                            text: root.conn-instagram-status == "connected" ? "Connected" :
                                                  root.conn-instagram-status == "connecting" ? "Connecting..." : "Not Connected";
                                            color: root.conn-instagram-status == "connected" ? Theme.color-emotional :
                                                   root.conn-instagram-status == "connecting" ? Theme.color-warning : Theme.text-dim;
                                            font-size: Theme.fs-micro;
                                            font-weight: 600;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }

                                if root.conn-instagram-detail != "" : Text {
                                    text: root.conn-instagram-detail;
                                    color: Theme.text-dim;
                                    font-size: Theme.fs-caption;
                                }

                                HorizontalLayout {
                                    spacing: Theme.sp-2;
                                    alignment: end;

                                    if root.conn-instagram-status == "connected" : TouchArea {
                                        width: sync-ig-text.preferred-width + 20px;
                                        height: 30px;
                                        clicked => { root.sync-service("instagram"); }

                                        Rectangle {
                                            border-radius: Theme.r-sm;
                                            background: parent.has-hover ? Theme.hover-fill : Theme.hover-fill;
                                            border-width: 1px;
                                            border-color: Theme.border-subtle;

                                            sync-ig-text := Text {
                                                text: "Sync";
                                                color: Theme.text-secondary;
                                                font-size: Theme.fs-micro;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }

                                    if root.conn-instagram-status == "connected" : TouchArea {
                                        width: disc-ig-text.preferred-width + 20px;
                                        height: 30px;
                                        clicked => { root.disconnect-service("instagram"); }

                                        Rectangle {
                                            border-radius: Theme.r-sm;
                                            background: parent.has-hover ? Theme.color-danger-dim : transparent;
                                            border-width: 1px;
                                            border-color: Theme.color-danger-dim;

                                            disc-ig-text := Text {
                                                text: "Disconnect";
                                                color: Theme.color-danger;
                                                font-size: Theme.fs-micro;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }

                                    if root.conn-instagram-status == "disconnected" : TouchArea {
                                        width: connect-ig-text.preferred-width + 20px;
                                        height: 30px;
                                        clicked => { root.connect-service("instagram"); }

                                        Rectangle {
                                            border-radius: Theme.r-sm;
                                            background: parent.has-hover ? Theme.color-danger-dim : Theme.color-danger-dim;
                                            border-width: 1px;
                                            border-color: Theme.color-danger-dim;

                                            connect-ig-text := Text {
                                                text: "Connect";
                                                color: Theme.color-emotional;
                                                font-size: Theme.fs-micro;
                                                font-weight: 600;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        // Bottom spacer
                        Rectangle { height: 40px; }
                    }
                }

                // ===== CATEGORY 7: SKILLS =====
                if root.active-category == 7 : SkillStore {
                    width: 100%;
                    height: 100%;
                    skills: root.skills;
                    categories: root.skill-categories;
                    toggle-skill(id) => { root.toggle-skill(id); }
                    search-skills(query) => { root.search-skills(query); }
                    filter-category(cat) => { root.filter-skill-category(cat); }
                }
            }
        }
    }
}
