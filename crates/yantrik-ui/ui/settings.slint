// Settings panel — holographic system configuration.
// Screen 7. Glassmorphic cards with glowing borders.
// Categorized sidebar navigation with scrollable panels.

import { Theme, AccentPreset } from "theme.slint";
import { SkillStore, SkillData } from "skill_store.slint";

export component SettingsScreen inherits Rectangle {
    background: Theme.bg-deep;

    // Account
    in property <string> user-name: "";
    in property <string> companion-name: "Yantrik";

    // AI Model
    in property <string> model-name: "";
    in property <int> max-context: 4096;
    in property <int> max-tokens: 512;
    in property <string> tool-permission: "sensitive";

    // Security
    in property <int> auto-lock-secs: 300;
    in-out property <bool> incognito-mode: false;
    in-out property <bool> dnd-mode: false;
    callback toggle-incognito-mode();
    callback toggle-dnd-mode();

    // Network
    in property <bool> wifi-connected: false;
    in property <string> wifi-ssid: "";
    in property <string> ip-address: "";

    // Display
    in property <string> display-resolution: "";

    // LLM Backend
    in property <string> llm-backend: "candle";
    in property <string> llm-api-url: "";
    in property <string> llm-api-model: "";

    // System info
    in property <int> memory-count: 0;
    in property <string> version-text: "0.1.0";
    in property <int> notification-count: 0;

    // Appearance
    in-out property <bool> dark-mode: true;
    in-out property <string> accent-color: "cyan";
    callback toggle-dark-mode();
    callback cycle-accent-color();

    // Wallpaper
    in-out property <string> wallpaper-path: "";
    property <string> custom-wallpaper-input: "";
    property <bool> custom-input-visible: false;
    callback wallpaper-changed(string);

    // Interactive settings
    callback cycle-tool-permission();
    callback cycle-auto-lock();

    callback back-pressed();
    callback navigate-to(int);

    // Connected Services (category 5)
    // Each connector: status is "connected", "disconnected", or "connecting"
    in property <string> conn-google-status: "disconnected";
    in property <string> conn-google-detail: "";
    in property <string> conn-spotify-status: "disconnected";
    in property <string> conn-spotify-detail: "";
    in property <string> conn-facebook-status: "disconnected";
    in property <string> conn-facebook-detail: "";
    in property <string> conn-instagram-status: "disconnected";
    in property <string> conn-instagram-detail: "";
    callback connect-service(string);
    callback disconnect-service(string);
    callback sync-service(string);

    // Skills / Skill Store (category 6) — data-driven via models
    in property <[SkillData]> skills;
    in property <[string]> skill-categories: ["All"];
    callback toggle-skill(string);
    callback search-skills(string);
    callback filter-skill-category(string);

    // Active settings category (sidebar)
    property <int> active-category: 0;

    // Ambient glow phase
    property <float> glow-phase: 0;
    Timer {
        interval: 16ms;
        running: true;
        triggered => {
            glow-phase = mod(glow-phase + 0.0015, 1.0);
        }
    }

    // Background nebula wash
    Rectangle {
        x: parent.width * 0.5;
        y: -parent.height * 0.1;
        width: 600px;
        height: 500px;
        background: @radial-gradient(circle,
            #5ac8d406 0%,
            transparent 60%
        );
    }

    VerticalLayout {
        spacing: 0px;

        // Header — glassmorphic
        Rectangle {
            height: 56px;
            background: @linear-gradient(180deg,
                #12111aa0 0%,
                #0c0b1080 100%
            );

            // Bottom glow
            Rectangle {
                y: parent.height - 1px;
                width: 100%;
                height: 1px;
                background: @linear-gradient(90deg,
                    transparent 10%,
                    Theme.cyan-glow 50%,
                    transparent 90%
                );
                opacity: 0.3;
            }

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                alignment: start;
                spacing: 12px;

                TouchArea {
                    width: Theme.touch-target;
                    height: Theme.touch-target;
                    clicked => { root.back-pressed(); }
                    Text {
                        text: "\u{2190}";
                        color: Theme.text-secondary;
                        font-size: 22px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Text {
                    text: "Settings";
                    color: Theme.text-primary;
                    font-size: Theme.font-title;
                    font-weight: 600;
                    letter-spacing: 1px;
                    vertical-alignment: center;
                }
            }
        }

        // Main content: sidebar + panel
        HorizontalLayout {
            vertical-stretch: 1;
            spacing: 0px;

            // ===== LEFT SIDEBAR =====
            Rectangle {
                width: 200px;
                background: @linear-gradient(180deg, #0c0b1080 0%, #08070d60 100%);

                // Right edge separator
                Rectangle {
                    x: parent.width - 1px;
                    width: 1px;
                    height: 100%;
                    background: Theme.separator;
                    opacity: 0.3;
                }

                VerticalLayout {
                    padding-top: 16px;
                    padding-bottom: 16px;
                    spacing: 2px;
                    alignment: start;

                    // Category 0: Display & Appearance
                    cat0-ta := TouchArea {
                        height: 44px;
                        clicked => { root.active-category = 0; }

                        Rectangle {
                            background: root.active-category == 0 ? Theme.bg-elevated : (cat0-ta.has-hover ? Theme.hover-fill : transparent);
                            border-radius: 0;

                            // Left accent bar
                            if root.active-category == 0 : Rectangle {
                                x: 0;
                                width: 2px;
                                height: parent.height;
                                background: Theme.cyan;
                                drop-shadow-blur: 4px;
                                drop-shadow-color: Theme.cyan-glow;
                            }

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 12px;
                                spacing: 10px;
                                alignment: start;

                                Text {
                                    text: "\u{25D0}";
                                    color: root.active-category == 0 ? Theme.cyan : Theme.text-dim;
                                    font-size: 16px;
                                    vertical-alignment: center;
                                    width: 24px;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: "Display";
                                    color: root.active-category == 0 ? Theme.text-primary : Theme.text-secondary;
                                    font-size: 13px;
                                    font-weight: root.active-category == 0 ? 600 : 400;
                                    vertical-alignment: center;
                                }
                            }

                            animate background { duration: 120ms; }
                        }
                    }

                    // Category 1: AI & Companion
                    cat1-ta := TouchArea {
                        height: 44px;
                        clicked => { root.active-category = 1; }

                        Rectangle {
                            background: root.active-category == 1 ? Theme.bg-elevated : (cat1-ta.has-hover ? Theme.hover-fill : transparent);
                            border-radius: 0;

                            if root.active-category == 1 : Rectangle {
                                x: 0;
                                width: 2px;
                                height: parent.height;
                                background: Theme.cyan;
                                drop-shadow-blur: 4px;
                                drop-shadow-color: Theme.cyan-glow;
                            }

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 12px;
                                spacing: 10px;
                                alignment: start;

                                Text {
                                    text: "\u{25C9}";
                                    color: root.active-category == 1 ? Theme.cyan : Theme.text-dim;
                                    font-size: 16px;
                                    vertical-alignment: center;
                                    width: 24px;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: "AI & Companion";
                                    color: root.active-category == 1 ? Theme.text-primary : Theme.text-secondary;
                                    font-size: 13px;
                                    font-weight: root.active-category == 1 ? 600 : 400;
                                    vertical-alignment: center;
                                }
                            }

                            animate background { duration: 120ms; }
                        }
                    }

                    // Category 2: Network
                    cat2-ta := TouchArea {
                        height: 44px;
                        clicked => { root.active-category = 2; }

                        Rectangle {
                            background: root.active-category == 2 ? Theme.bg-elevated : (cat2-ta.has-hover ? Theme.hover-fill : transparent);
                            border-radius: 0;

                            if root.active-category == 2 : Rectangle {
                                x: 0;
                                width: 2px;
                                height: parent.height;
                                background: Theme.cyan;
                                drop-shadow-blur: 4px;
                                drop-shadow-color: Theme.cyan-glow;
                            }

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 12px;
                                spacing: 10px;
                                alignment: start;

                                Text {
                                    text: "\u{25CE}";
                                    color: root.active-category == 2 ? Theme.cyan : Theme.text-dim;
                                    font-size: 16px;
                                    vertical-alignment: center;
                                    width: 24px;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: "Network";
                                    color: root.active-category == 2 ? Theme.text-primary : Theme.text-secondary;
                                    font-size: 13px;
                                    font-weight: root.active-category == 2 ? 600 : 400;
                                    vertical-alignment: center;
                                }
                            }

                            animate background { duration: 120ms; }
                        }
                    }

                    // Category 3: Security & Privacy
                    cat3-ta := TouchArea {
                        height: 44px;
                        clicked => { root.active-category = 3; }

                        Rectangle {
                            background: root.active-category == 3 ? Theme.bg-elevated : (cat3-ta.has-hover ? Theme.hover-fill : transparent);
                            border-radius: 0;

                            if root.active-category == 3 : Rectangle {
                                x: 0;
                                width: 2px;
                                height: parent.height;
                                background: Theme.cyan;
                                drop-shadow-blur: 4px;
                                drop-shadow-color: Theme.cyan-glow;
                            }

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 12px;
                                spacing: 10px;
                                alignment: start;

                                Text {
                                    text: "\u{2298}";
                                    color: root.active-category == 3 ? Theme.cyan : Theme.text-dim;
                                    font-size: 16px;
                                    vertical-alignment: center;
                                    width: 24px;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: "Security";
                                    color: root.active-category == 3 ? Theme.text-primary : Theme.text-secondary;
                                    font-size: 13px;
                                    font-weight: root.active-category == 3 ? 600 : 400;
                                    vertical-alignment: center;
                                }
                            }

                            animate background { duration: 120ms; }
                        }
                    }

                    // Category 4: System
                    cat4-ta := TouchArea {
                        height: 44px;
                        clicked => { root.active-category = 4; }

                        Rectangle {
                            background: root.active-category == 4 ? Theme.bg-elevated : (cat4-ta.has-hover ? Theme.hover-fill : transparent);
                            border-radius: 0;

                            if root.active-category == 4 : Rectangle {
                                x: 0;
                                width: 2px;
                                height: parent.height;
                                background: Theme.cyan;
                                drop-shadow-blur: 4px;
                                drop-shadow-color: Theme.cyan-glow;
                            }

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 12px;
                                spacing: 10px;
                                alignment: start;

                                Text {
                                    text: "\u{2299}";
                                    color: root.active-category == 4 ? Theme.cyan : Theme.text-dim;
                                    font-size: 16px;
                                    vertical-alignment: center;
                                    width: 24px;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: "System";
                                    color: root.active-category == 4 ? Theme.text-primary : Theme.text-secondary;
                                    font-size: 13px;
                                    font-weight: root.active-category == 4 ? 600 : 400;
                                    vertical-alignment: center;
                                }
                            }

                            animate background { duration: 120ms; }
                        }
                    }
                    // Category 5: Connected Services
                    cat5-ta := TouchArea {
                        height: 44px;
                        clicked => { root.active-category = 5; }

                        Rectangle {
                            background: root.active-category == 5 ? Theme.bg-elevated : (cat5-ta.has-hover ? Theme.hover-fill : transparent);
                            border-radius: 0;

                            if root.active-category == 5 : Rectangle {
                                x: 0;
                                width: 2px;
                                height: parent.height;
                                background: Theme.cyan;
                                drop-shadow-blur: 4px;
                                drop-shadow-color: Theme.cyan-glow;
                            }

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 12px;
                                spacing: 10px;
                                alignment: start;

                                Text {
                                    text: "\u{1F517}";
                                    color: root.active-category == 5 ? Theme.cyan : Theme.text-dim;
                                    font-size: 16px;
                                    vertical-alignment: center;
                                    width: 24px;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: "Connections";
                                    color: root.active-category == 5 ? Theme.text-primary : Theme.text-secondary;
                                    font-size: 13px;
                                    font-weight: root.active-category == 5 ? 600 : 400;
                                    vertical-alignment: center;
                                }
                            }

                            animate background { duration: 120ms; }
                        }
                    }

                    // Category 6: Skills
                    cat6-ta := TouchArea {
                        height: 44px;
                        clicked => { root.active-category = 6; }

                        Rectangle {
                            background: root.active-category == 6 ? Theme.bg-elevated : (cat6-ta.has-hover ? Theme.hover-fill : transparent);
                            border-radius: 0;

                            if root.active-category == 6 : Rectangle {
                                x: 0;
                                width: 2px;
                                height: parent.height;
                                background: Theme.cyan;
                                drop-shadow-blur: 4px;
                                drop-shadow-color: Theme.cyan-glow;
                            }

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 12px;
                                spacing: 10px;
                                alignment: start;

                                Text {
                                    text: "\u{26A1}";
                                    color: root.active-category == 6 ? Theme.cyan : Theme.text-dim;
                                    font-size: 16px;
                                    vertical-alignment: center;
                                    width: 24px;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: "Skills";
                                    color: root.active-category == 6 ? Theme.text-primary : Theme.text-secondary;
                                    font-size: 13px;
                                    font-weight: root.active-category == 6 ? 600 : 400;
                                    vertical-alignment: center;
                                }
                            }

                            animate background { duration: 120ms; }
                        }
                    }
                }
            }

            // ===== RIGHT PANEL — category content =====
            Rectangle {
                horizontal-stretch: 1;
                background: transparent;

                // ===== CATEGORY 0: DISPLAY & APPEARANCE =====
                if root.active-category == 0 : Flickable {
                    width: 100%;
                    height: 100%;

                    VerticalLayout {
                        padding: 20px;
                        spacing: 16px;
                        alignment: start;

                        // Section header
                        HorizontalLayout {
                            spacing: 8px;
                            Rectangle {
                                width: 3px;
                                height: 14px;
                                y: 0;
                                border-radius: 1.5px;
                                background: Theme.cyan;
                                drop-shadow-blur: 4px;
                                drop-shadow-color: Theme.cyan-glow;
                            }
                            Text {
                                text: "DISPLAY & APPEARANCE";
                                color: Theme.cyan;
                                font-size: 10px;
                                font-weight: 600;
                                letter-spacing: 3px;
                                vertical-alignment: center;
                            }
                        }

                        // Dark / Light mode toggle
                        Rectangle {
                            background: @linear-gradient(135deg, #12111a80 0%, #0c0b1060 100%);
                            border-radius: Theme.radius-card;
                            border-width: 1px;
                            border-color: #ffffff08;
                            height: 52px;

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;

                                Text {
                                    text: "Theme";
                                    color: Theme.text-secondary;
                                    font-size: Theme.font-body;
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                }

                                // Pill toggle: Dark / Light — holographic
                                TouchArea {
                                    width: 110px;
                                    height: 36px;
                                    clicked => { root.toggle-dark-mode(); }

                                    Rectangle {
                                        width: 110px;
                                        height: 32px;
                                        y: (parent.height - self.height) / 2;
                                        border-radius: 16px;
                                        background: #0808100a;
                                        border-width: 1px;
                                        border-color: root.dark-mode ? Theme.cyan-dim : Theme.amber-dim;

                                        // Sliding pill indicator
                                        Rectangle {
                                            x: root.dark-mode ? 2px : 56px;
                                            y: 2px;
                                            width: 52px;
                                            height: 28px;
                                            border-radius: 14px;
                                            background: root.dark-mode ? Theme.cyan-dim : Theme.amber-dim;
                                            drop-shadow-blur: 6px;
                                            drop-shadow-color: root.dark-mode ? Theme.cyan-glow : Theme.amber-glow;

                                            animate x { duration: 150ms; easing: ease-out; }
                                            animate background { duration: 150ms; }
                                            animate drop-shadow-color { duration: 150ms; }
                                        }

                                        HorizontalLayout {
                                            Rectangle {
                                                width: 55px;
                                                Text {
                                                    text: "Dark";
                                                    color: root.dark-mode ? Theme.cyan : Theme.text-dim;
                                                    font-size: 11px;
                                                    font-weight: root.dark-mode ? 600 : 400;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                    animate color { duration: 150ms; }
                                                }
                                            }
                                            Rectangle {
                                                width: 55px;
                                                Text {
                                                    text: "Light";
                                                    color: root.dark-mode ? Theme.text-dim : Theme.amber;
                                                    font-size: 11px;
                                                    font-weight: root.dark-mode ? 400 : 600;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                    animate color { duration: 150ms; }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        // Accent color picker row
                        Rectangle {
                            background: @linear-gradient(135deg, #12111a80 0%, #0c0b1060 100%);
                            border-radius: Theme.radius-card;
                            border-width: 1px;
                            border-color: #ffffff08;
                            height: 52px;

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;

                                Text {
                                    text: "Accent color";
                                    color: Theme.text-secondary;
                                    font-size: Theme.font-body;
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                }

                                accent-ta := TouchArea {
                                    width: accent-pill.preferred-width + 8px;
                                    height: 36px;
                                    clicked => { root.cycle-accent-color(); }

                                    accent-pill := Rectangle {
                                        width: accent-swatch.width + accent-label.preferred-width + 20px;
                                        height: 28px;
                                        y: (parent.height - self.height) / 2;
                                        border-radius: 14px;
                                        background: accent-ta.has-hover ? Theme.hover-fill-strong : Theme.hover-fill;
                                        border-width: 1px;
                                        border-color: AccentPreset.accent-dim;
                                        drop-shadow-blur: 4px;
                                        drop-shadow-color: AccentPreset.accent-glow;

                                        HorizontalLayout {
                                            padding-left: 8px;
                                            padding-right: 10px;
                                            spacing: 6px;
                                            alignment: center;

                                            // Color swatch dot
                                            accent-swatch := Rectangle {
                                                width: 12px;
                                                height: 12px;
                                                y: (parent.height - 12px) / 2;
                                                border-radius: 6px;
                                                background: AccentPreset.accent;
                                                drop-shadow-blur: 4px;
                                                drop-shadow-color: AccentPreset.accent-glow;
                                            }

                                            accent-label := Text {
                                                text: AccentPreset.label;
                                                color: AccentPreset.accent;
                                                font-size: 11px;
                                                font-weight: 600;
                                                vertical-alignment: center;
                                            }
                                        }

                                        animate border-color { duration: 200ms; }
                                        animate drop-shadow-color { duration: 200ms; }
                                    }
                                }
                            }
                        }

                        // ── Wallpaper section ──
                        Rectangle {
                            background: @linear-gradient(135deg, #12111a80 0%, #0c0b1060 100%);
                            border-radius: Theme.radius-card;
                            border-width: 1px;
                            border-color: #ffffff08;
                            height: wp-layout.preferred-height;

                            wp-layout := VerticalLayout {
                                padding: 16px;
                                spacing: 12px;

                                Text {
                                    text: "Wallpaper";
                                    color: Theme.text-secondary;
                                    font-size: Theme.font-body;
                                }

                                // Preset thumbnail row
                                HorizontalLayout {
                                    spacing: 10px;

                                    // None (solid dark)
                                    wp-none-ta := TouchArea {
                                        width: 60px; height: 40px;
                                        clicked => {
                                            root.wallpaper-path = "";
                                            root.custom-input-visible = false;
                                            root.wallpaper-changed("");
                                        }
                                        Rectangle {
                                            width: 60px; height: 40px;
                                            border-radius: 6px;
                                            background: @radial-gradient(circle, #0a0a1c 0%, #050510 50%, #020206 100%);
                                            border-width: root.wallpaper-path == "" ? 2px : 1px;
                                            border-color: root.wallpaper-path == "" ? Theme.cyan : (wp-none-ta.has-hover ? #ffffff30 : #ffffff10);
                                            drop-shadow-blur: root.wallpaper-path == "" ? 4px : 0px;
                                            drop-shadow-color: root.wallpaper-path == "" ? Theme.cyan-glow : transparent;

                                            Text {
                                                text: "None";
                                                color: root.wallpaper-path == "" ? Theme.cyan : Theme.text-dim;
                                                font-size: 9px;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }

                                            animate border-color { duration: 150ms; }
                                            animate border-width { duration: 150ms; }
                                        }
                                    }

                                    // Aurora (green/purple)
                                    wp-aurora-ta := TouchArea {
                                        width: 60px; height: 40px;
                                        clicked => {
                                            root.wallpaper-path = "aurora";
                                            root.custom-input-visible = false;
                                            root.wallpaper-changed("aurora");
                                        }
                                        Rectangle {
                                            width: 60px; height: 40px;
                                            border-radius: 6px;
                                            clip: true;
                                            background: @linear-gradient(135deg, #0d2818 0%, #1a0a2e 50%, #0a3020 100%);
                                            border-width: root.wallpaper-path == "aurora" ? 2px : 1px;
                                            border-color: root.wallpaper-path == "aurora" ? Theme.cyan : (wp-aurora-ta.has-hover ? #ffffff30 : #ffffff10);
                                            drop-shadow-blur: root.wallpaper-path == "aurora" ? 4px : 0px;
                                            drop-shadow-color: root.wallpaper-path == "aurora" ? Theme.cyan-glow : transparent;

                                            // Mini glow accent
                                            Rectangle {
                                                x: 5px; y: 5px;
                                                width: 30px; height: 20px;
                                                border-radius: 10px;
                                                background: @radial-gradient(circle, #30e87830 0%, transparent 70%);
                                            }

                                            Text {
                                                y: parent.height - 12px;
                                                text: "Aurora";
                                                color: root.wallpaper-path == "aurora" ? Theme.cyan : Theme.text-dim;
                                                font-size: 8px;
                                                horizontal-alignment: center;
                                                width: 100%;
                                            }

                                            animate border-color { duration: 150ms; }
                                            animate border-width { duration: 150ms; }
                                        }
                                    }

                                    // Sunset (orange/pink)
                                    wp-sunset-ta := TouchArea {
                                        width: 60px; height: 40px;
                                        clicked => {
                                            root.wallpaper-path = "sunset";
                                            root.custom-input-visible = false;
                                            root.wallpaper-changed("sunset");
                                        }
                                        Rectangle {
                                            width: 60px; height: 40px;
                                            border-radius: 6px;
                                            clip: true;
                                            background: @linear-gradient(180deg, #3d1020 0%, #d4503a 50%, #e88c30 100%);
                                            border-width: root.wallpaper-path == "sunset" ? 2px : 1px;
                                            border-color: root.wallpaper-path == "sunset" ? Theme.cyan : (wp-sunset-ta.has-hover ? #ffffff30 : #ffffff10);
                                            drop-shadow-blur: root.wallpaper-path == "sunset" ? 4px : 0px;
                                            drop-shadow-color: root.wallpaper-path == "sunset" ? Theme.cyan-glow : transparent;

                                            Text {
                                                y: parent.height - 12px;
                                                text: "Sunset";
                                                color: root.wallpaper-path == "sunset" ? #ffd6b0 : Theme.text-dim;
                                                font-size: 8px;
                                                horizontal-alignment: center;
                                                width: 100%;
                                            }

                                            animate border-color { duration: 150ms; }
                                            animate border-width { duration: 150ms; }
                                        }
                                    }

                                    // Ocean (blue/teal)
                                    wp-ocean-ta := TouchArea {
                                        width: 60px; height: 40px;
                                        clicked => {
                                            root.wallpaper-path = "ocean";
                                            root.custom-input-visible = false;
                                            root.wallpaper-changed("ocean");
                                        }
                                        Rectangle {
                                            width: 60px; height: 40px;
                                            border-radius: 6px;
                                            clip: true;
                                            background: @linear-gradient(180deg, #041830 0%, #063050 50%, #0a4868 100%);
                                            border-width: root.wallpaper-path == "ocean" ? 2px : 1px;
                                            border-color: root.wallpaper-path == "ocean" ? Theme.cyan : (wp-ocean-ta.has-hover ? #ffffff30 : #ffffff10);
                                            drop-shadow-blur: root.wallpaper-path == "ocean" ? 4px : 0px;
                                            drop-shadow-color: root.wallpaper-path == "ocean" ? Theme.cyan-glow : transparent;

                                            // Mini wave accent
                                            Rectangle {
                                                x: 10px; y: 15px;
                                                width: 40px; height: 15px;
                                                border-radius: 8px;
                                                background: @radial-gradient(circle, #06b6d418 0%, transparent 70%);
                                            }

                                            Text {
                                                y: parent.height - 12px;
                                                text: "Ocean";
                                                color: root.wallpaper-path == "ocean" ? #b0e0ff : Theme.text-dim;
                                                font-size: 8px;
                                                horizontal-alignment: center;
                                                width: 100%;
                                            }

                                            animate border-color { duration: 150ms; }
                                            animate border-width { duration: 150ms; }
                                        }
                                    }

                                    // Nebula (purple/cyan)
                                    wp-nebula-ta := TouchArea {
                                        width: 60px; height: 40px;
                                        clicked => {
                                            root.wallpaper-path = "nebula";
                                            root.custom-input-visible = false;
                                            root.wallpaper-changed("nebula");
                                        }
                                        Rectangle {
                                            width: 60px; height: 40px;
                                            border-radius: 6px;
                                            clip: true;
                                            background: @linear-gradient(135deg, #1a0838 0%, #2e0e58 50%, #0a0828 100%);
                                            border-width: root.wallpaper-path == "nebula" ? 2px : 1px;
                                            border-color: root.wallpaper-path == "nebula" ? Theme.cyan : (wp-nebula-ta.has-hover ? #ffffff30 : #ffffff10);
                                            drop-shadow-blur: root.wallpaper-path == "nebula" ? 4px : 0px;
                                            drop-shadow-color: root.wallpaper-path == "nebula" ? Theme.cyan-glow : transparent;

                                            // Mini nebula accent
                                            Rectangle {
                                                x: 15px; y: 8px;
                                                width: 30px; height: 20px;
                                                border-radius: 10px;
                                                background: @radial-gradient(circle, #a855f728 0%, transparent 70%);
                                            }
                                            Rectangle {
                                                x: 25px; y: 15px;
                                                width: 25px; height: 18px;
                                                border-radius: 9px;
                                                background: @radial-gradient(circle, #06b6d420 0%, transparent 70%);
                                            }

                                            Text {
                                                y: parent.height - 12px;
                                                text: "Nebula";
                                                color: root.wallpaper-path == "nebula" ? #d0b0ff : Theme.text-dim;
                                                font-size: 8px;
                                                horizontal-alignment: center;
                                                width: 100%;
                                            }

                                            animate border-color { duration: 150ms; }
                                            animate border-width { duration: 150ms; }
                                        }
                                    }
                                }

                                // Custom wallpaper button + path input
                                HorizontalLayout {
                                    spacing: 8px;

                                    wp-custom-ta := TouchArea {
                                        width: custom-btn-rect.preferred-width;
                                        height: 32px;
                                        clicked => {
                                            root.custom-input-visible = !root.custom-input-visible;
                                        }
                                        custom-btn-rect := Rectangle {
                                            width: custom-btn-text.preferred-width + 24px;
                                            height: 32px;
                                            border-radius: 8px;
                                            background: wp-custom-ta.has-hover ? Theme.hover-fill-strong : Theme.hover-fill;
                                            border-width: 1px;
                                            border-color: root.custom-input-visible ? Theme.cyan-dim : #ffffff10;

                                            custom-btn-text := Text {
                                                text: "Custom...";
                                                color: root.custom-input-visible ? Theme.cyan : Theme.text-secondary;
                                                font-size: 12px;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }

                                    // Show active wallpaper label
                                    if root.wallpaper-path != "" && root.wallpaper-path != "aurora" && root.wallpaper-path != "sunset" && root.wallpaper-path != "ocean" && root.wallpaper-path != "nebula" : Text {
                                        text: root.wallpaper-path;
                                        color: Theme.text-dim;
                                        font-size: 11px;
                                        vertical-alignment: center;
                                        horizontal-stretch: 1;
                                        overflow: elide;
                                    }
                                }

                                // Custom path input row (shown when "Custom..." toggled)
                                if root.custom-input-visible : HorizontalLayout {
                                    spacing: 8px;

                                    Rectangle {
                                        horizontal-stretch: 1;
                                        height: 32px;
                                        border-radius: 8px;
                                        background: #0808100a;
                                        border-width: 1px;
                                        border-color: #ffffff10;

                                        wp-input := TextInput {
                                            x: 8px;
                                            width: parent.width - 16px;
                                            height: 100%;
                                            text <=> root.custom-wallpaper-input;
                                            color: Theme.text-primary;
                                            font-size: 12px;
                                            vertical-alignment: center;

                                            accepted => {
                                                if root.custom-wallpaper-input != "" {
                                                    root.wallpaper-path = root.custom-wallpaper-input;
                                                    root.wallpaper-changed(root.custom-wallpaper-input);
                                                }
                                            }
                                        }

                                        // Placeholder text
                                        if root.custom-wallpaper-input == "" : Text {
                                            x: 8px;
                                            text: "/path/to/image.png";
                                            color: Theme.text-dim;
                                            font-size: 12px;
                                            vertical-alignment: center;
                                            opacity: 0.5;
                                        }
                                    }

                                    wp-apply-ta := TouchArea {
                                        width: 60px;
                                        height: 32px;
                                        clicked => {
                                            if root.custom-wallpaper-input != "" {
                                                root.wallpaper-path = root.custom-wallpaper-input;
                                                root.wallpaper-changed(root.custom-wallpaper-input);
                                            }
                                        }
                                        Rectangle {
                                            width: 60px; height: 32px;
                                            border-radius: 8px;
                                            background: wp-apply-ta.has-hover ? Theme.cyan-dim : Theme.hover-fill;
                                            border-width: 1px;
                                            border-color: Theme.cyan-dim;

                                            Text {
                                                text: "Apply";
                                                color: Theme.cyan;
                                                font-size: 11px;
                                                font-weight: 600;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        // Display resolution
                        Rectangle {
                            background: @linear-gradient(135deg, #12111a80 0%, #0c0b1060 100%);
                            border-radius: Theme.radius-card;
                            border-width: 1px;
                            border-color: #ffffff08;
                            height: disp-layout.preferred-height;

                            disp-layout := VerticalLayout {
                                padding: 16px;
                                spacing: 12px;

                                HorizontalLayout {
                                    Text {
                                        text: "Resolution";
                                        color: Theme.text-secondary;
                                        font-size: Theme.font-body;
                                        horizontal-stretch: 1;
                                    }
                                    Text {
                                        text: root.display-resolution != "" ? root.display-resolution : "auto";
                                        color: Theme.text-primary;
                                        font-size: Theme.font-body;
                                    }
                                }
                            }
                        }

                        // Bottom spacer
                        Rectangle { height: 40px; }
                    }
                }

                // ===== CATEGORY 1: AI & COMPANION =====
                if root.active-category == 1 : Flickable {
                    width: 100%;
                    height: 100%;

                    VerticalLayout {
                        padding: 20px;
                        spacing: 16px;
                        alignment: start;

                        // Section header — Account
                        HorizontalLayout {
                            spacing: 8px;
                            Rectangle {
                                width: 3px; height: 14px;
                                border-radius: 1.5px;
                                background: Theme.amber;
                                drop-shadow-blur: 4px;
                                drop-shadow-color: Theme.amber-glow;
                            }
                            Text {
                                text: "ACCOUNT";
                                color: Theme.amber;
                                font-size: 10px;
                                font-weight: 600;
                                letter-spacing: 3px;
                                vertical-alignment: center;
                            }
                        }

                        Rectangle {
                            background: @linear-gradient(135deg, #12111a80 0%, #0c0b1060 100%);
                            border-radius: Theme.radius-card;
                            border-width: 1px;
                            border-color: #ffffff08;
                            height: acct-layout.preferred-height;

                            acct-layout := VerticalLayout {
                                padding: 16px;
                                spacing: 12px;

                                HorizontalLayout {
                                    Text {
                                        text: "User";
                                        color: Theme.text-secondary;
                                        font-size: Theme.font-body;
                                        horizontal-stretch: 1;
                                    }
                                    Text {
                                        text: root.user-name;
                                        color: Theme.text-primary;
                                        font-size: Theme.font-body;
                                    }
                                }

                                Rectangle { height: 1px; background: #ffffff08; }

                                HorizontalLayout {
                                    Text {
                                        text: "Companion";
                                        color: Theme.text-secondary;
                                        font-size: Theme.font-body;
                                        horizontal-stretch: 1;
                                    }
                                    Text {
                                        text: root.companion-name;
                                        color: Theme.amber;
                                        font-size: Theme.font-body;
                                        font-weight: 500;
                                    }
                                }
                            }
                        }

                        // Section header — AI Model
                        HorizontalLayout {
                            spacing: 8px;
                            Rectangle {
                                width: 3px; height: 14px;
                                border-radius: 1.5px;
                                background: Theme.holo-blue;
                                drop-shadow-blur: 4px;
                                drop-shadow-color: Theme.holo-blue-glow;
                            }
                            Text {
                                text: "AI MODEL";
                                color: Theme.holo-blue;
                                font-size: 10px;
                                font-weight: 600;
                                letter-spacing: 3px;
                                vertical-alignment: center;
                            }
                        }

                        Rectangle {
                            background: @linear-gradient(135deg, #12111a80 0%, #0c0b1060 100%);
                            border-radius: Theme.radius-card;
                            border-width: 1px;
                            border-color: #ffffff08;
                            height: model-layout.preferred-height;

                            model-layout := VerticalLayout {
                                padding: 16px;
                                spacing: 12px;

                                HorizontalLayout {
                                    Text {
                                        text: "Backend";
                                        color: Theme.text-secondary;
                                        font-size: Theme.font-body;
                                        horizontal-stretch: 1;
                                    }
                                    Rectangle {
                                        width: backend-tag.preferred-width + 16px;
                                        height: 24px;
                                        border-radius: 12px;
                                        background: root.llm-backend == "api" ? Theme.tint-cyan : Theme.tint-amber;
                                        border-width: 1px;
                                        border-color: root.llm-backend == "api" ? Theme.cyan-dim : Theme.amber-dim;

                                        backend-tag := Text {
                                            text: root.llm-backend == "api" ? "API" : "Candle";
                                            color: root.llm-backend == "api" ? Theme.cyan : Theme.amber;
                                            font-size: 11px;
                                            font-weight: 600;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }

                                Rectangle { height: 1px; background: #ffffff08; }

                                HorizontalLayout {
                                    Text {
                                        text: "Model";
                                        color: Theme.text-secondary;
                                        font-size: Theme.font-body;
                                        horizontal-stretch: 1;
                                    }
                                    Text {
                                        text: root.llm-backend == "api" && root.llm-api-model != ""
                                            ? root.llm-api-model : root.model-name;
                                        color: Theme.cyan;
                                        font-size: Theme.font-small;
                                    }
                                }

                                if root.llm-backend == "api" && root.llm-api-url != "" : Rectangle { height: 1px; background: #ffffff08; }
                                if root.llm-backend == "api" && root.llm-api-url != "" : HorizontalLayout {
                                    Text {
                                        text: "Endpoint";
                                        color: Theme.text-secondary;
                                        font-size: Theme.font-body;
                                        horizontal-stretch: 1;
                                    }
                                    Text {
                                        text: root.llm-api-url;
                                        color: Theme.text-dim;
                                        font-size: 11px;
                                    }
                                }

                                Rectangle { height: 1px; background: #ffffff08; }

                                HorizontalLayout {
                                    Text {
                                        text: "Context window";
                                        color: Theme.text-secondary;
                                        font-size: Theme.font-body;
                                        horizontal-stretch: 1;
                                    }
                                    Text {
                                        text: root.max-context + " tokens";
                                        color: Theme.text-primary;
                                        font-size: Theme.font-body;
                                    }
                                }

                                Rectangle { height: 1px; background: #ffffff08; }

                                HorizontalLayout {
                                    Text {
                                        text: "Max output";
                                        color: Theme.text-secondary;
                                        font-size: Theme.font-body;
                                        horizontal-stretch: 1;
                                    }
                                    Text {
                                        text: root.max-tokens + " tokens";
                                        color: Theme.text-primary;
                                        font-size: Theme.font-body;
                                    }
                                }

                                Rectangle { height: 1px; background: #ffffff08; }

                                perm-ta := TouchArea {
                                    height: 24px;
                                    clicked => { root.cycle-tool-permission(); }

                                    HorizontalLayout {
                                        Text {
                                            text: "Tool permission";
                                            color: Theme.text-secondary;
                                            font-size: Theme.font-body;
                                            horizontal-stretch: 1;
                                        }
                                        Rectangle {
                                            width: perm-tag.preferred-width + 16px;
                                            height: 24px;
                                            border-radius: 12px;
                                            background: root.tool-permission == "safe" ? Theme.tint-cyan
                                                : (root.tool-permission == "standard" ? Theme.tint-amber
                                                : #e86b6b18);
                                            border-width: 1px;
                                            border-color: root.tool-permission == "safe" ? Theme.cyan-dim
                                                : (root.tool-permission == "standard" ? Theme.amber-dim
                                                : #e86b6b40);

                                            perm-tag := Text {
                                                text: root.tool-permission == "safe" ? "Safe"
                                                    : (root.tool-permission == "standard" ? "Standard"
                                                    : "Sensitive");
                                                color: root.tool-permission == "safe" ? Theme.cyan
                                                    : (root.tool-permission == "standard" ? Theme.amber
                                                    : Theme.color-emotional);
                                                font-size: 11px;
                                                font-weight: 600;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        // Section header — Companion
                        HorizontalLayout {
                            spacing: 8px;
                            Rectangle {
                                width: 3px; height: 14px;
                                border-radius: 1.5px;
                                background: Theme.amber;
                                drop-shadow-blur: 4px;
                                drop-shadow-color: Theme.amber-glow;
                            }
                            Text {
                                text: "COMPANION";
                                color: Theme.amber;
                                font-size: 10px;
                                font-weight: 600;
                                letter-spacing: 3px;
                                vertical-alignment: center;
                            }
                        }

                        // Bond link — glassmorphic nav card
                        Rectangle {
                            background: @linear-gradient(135deg, #12111a80 0%, #0c0b1060 100%);
                            border-radius: Theme.radius-card;
                            border-width: 1px;
                            border-color: #ffffff08;
                            height: 52px;

                            TouchArea {
                                clicked => { root.navigate-to(4); }
                            }

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;

                                Text {
                                    text: "Bond";
                                    color: Theme.text-primary;
                                    font-size: Theme.font-body;
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: "\u{2192}";
                                    color: Theme.cyan-dim;
                                    font-size: 18px;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        // Personality link
                        Rectangle {
                            background: @linear-gradient(135deg, #12111a80 0%, #0c0b1060 100%);
                            border-radius: Theme.radius-card;
                            border-width: 1px;
                            border-color: #ffffff08;
                            height: 52px;

                            TouchArea {
                                clicked => { root.navigate-to(5); }
                            }

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;

                                Text {
                                    text: "Personality";
                                    color: Theme.text-primary;
                                    font-size: Theme.font-body;
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: "\u{2192}";
                                    color: Theme.cyan-dim;
                                    font-size: 18px;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        // Memory browser link
                        Rectangle {
                            background: @linear-gradient(135deg, #12111a80 0%, #0c0b1060 100%);
                            border-radius: Theme.radius-card;
                            border-width: 1px;
                            border-color: #ffffff08;
                            height: 52px;

                            TouchArea {
                                clicked => { root.navigate-to(6); }
                            }

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;

                                Text {
                                    text: "Memory Browser";
                                    color: Theme.text-primary;
                                    font-size: Theme.font-body;
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                }
                                Rectangle {
                                    width: mem-count-txt.preferred-width + 14px;
                                    height: 20px;
                                    y: (parent.height - 20px) / 2;
                                    border-radius: 10px;
                                    background: Theme.tint-amber;

                                    mem-count-txt := Text {
                                        text: root.memory-count;
                                        color: Theme.amber;
                                        font-size: 10px;
                                        font-weight: 600;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                                Text {
                                    text: "  \u{2192}";
                                    color: Theme.cyan-dim;
                                    font-size: 18px;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        // Bottom spacer
                        Rectangle { height: 40px; }
                    }
                }

                // ===== CATEGORY 2: NETWORK =====
                if root.active-category == 2 : Flickable {
                    width: 100%;
                    height: 100%;

                    VerticalLayout {
                        padding: 20px;
                        spacing: 16px;
                        alignment: start;

                        // Section header
                        HorizontalLayout {
                            spacing: 8px;
                            Rectangle {
                                width: 3px; height: 14px;
                                border-radius: 1.5px;
                                background: Theme.cyan;
                                drop-shadow-blur: 4px;
                                drop-shadow-color: Theme.cyan-glow;
                            }
                            Text {
                                text: "NETWORK";
                                color: Theme.cyan;
                                font-size: 10px;
                                font-weight: 600;
                                letter-spacing: 3px;
                                vertical-alignment: center;
                            }
                        }

                        Rectangle {
                            background: @linear-gradient(135deg, #12111a80 0%, #0c0b1060 100%);
                            border-radius: Theme.radius-card;
                            border-width: 1px;
                            border-color: #ffffff08;
                            height: net-layout.preferred-height;

                            net-layout := VerticalLayout {
                                padding: 16px;
                                spacing: 12px;

                                HorizontalLayout {
                                    Text {
                                        text: "WiFi";
                                        color: Theme.text-secondary;
                                        font-size: Theme.font-body;
                                        horizontal-stretch: 1;
                                    }
                                    Text {
                                        text: root.wifi-connected
                                            ? (root.wifi-ssid != "" ? root.wifi-ssid : "Connected")
                                            : "Disconnected";
                                        color: root.wifi-connected ? Theme.cyan : Theme.text-dim;
                                        font-size: Theme.font-body;
                                    }
                                }

                                Rectangle { height: 1px; background: #ffffff08; }

                                HorizontalLayout {
                                    Text {
                                        text: "IP address";
                                        color: Theme.text-secondary;
                                        font-size: Theme.font-body;
                                        horizontal-stretch: 1;
                                    }
                                    Text {
                                        text: root.ip-address != "" ? root.ip-address : "\u{2014}";
                                        color: Theme.text-primary;
                                        font-size: Theme.font-body;
                                    }
                                }
                            }
                        }

                        // Bottom spacer
                        Rectangle { height: 40px; }
                    }
                }

                // ===== CATEGORY 3: SECURITY & PRIVACY =====
                if root.active-category == 3 : Flickable {
                    width: 100%;
                    height: 100%;

                    VerticalLayout {
                        padding: 20px;
                        spacing: 16px;
                        alignment: start;

                        // Section header
                        HorizontalLayout {
                            spacing: 8px;
                            Rectangle {
                                width: 3px; height: 14px;
                                border-radius: 1.5px;
                                background: Theme.color-emotional;
                                drop-shadow-blur: 4px;
                                drop-shadow-color: #e86b6b40;
                            }
                            Text {
                                text: "SECURITY & PRIVACY";
                                color: Theme.color-emotional;
                                font-size: 10px;
                                font-weight: 600;
                                letter-spacing: 3px;
                                vertical-alignment: center;
                            }
                        }

                        Rectangle {
                            background: @linear-gradient(135deg, #12111a80 0%, #0c0b1060 100%);
                            border-radius: Theme.radius-card;
                            border-width: 1px;
                            border-color: #ffffff08;
                            height: sec-layout.preferred-height;

                            sec-layout := VerticalLayout {
                                padding: 16px;
                                spacing: 12px;

                                lock-ta := TouchArea {
                                    height: 24px;
                                    clicked => { root.cycle-auto-lock(); }

                                    HorizontalLayout {
                                        Text {
                                            text: "Auto-lock";
                                            color: Theme.text-secondary;
                                            font-size: Theme.font-body;
                                            horizontal-stretch: 1;
                                        }
                                        Rectangle {
                                            width: lock-tag.preferred-width + 16px;
                                            height: 24px;
                                            border-radius: 12px;
                                            background: lock-ta.has-hover ? Theme.hover-fill-strong : Theme.hover-fill;
                                            border-width: 1px;
                                            border-color: Theme.border-subtle;

                                            lock-tag := Text {
                                                text: root.auto-lock-secs == 0 ? "Never"
                                                    : (root.auto-lock-secs >= 60
                                                        ? Math.floor(root.auto-lock-secs / 60) + " min"
                                                        : root.auto-lock-secs + " sec");
                                                color: Theme.text-primary;
                                                font-size: 11px;
                                                font-weight: 500;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                }

                                Rectangle { height: 1px; background: #ffffff08; }

                                HorizontalLayout {
                                    Text {
                                        text: "PIN lock";
                                        color: Theme.text-secondary;
                                        font-size: Theme.font-body;
                                        horizontal-stretch: 1;
                                    }
                                    // Active indicator with glow
                                    Rectangle {
                                        width: 8px; height: 8px;
                                        y: (parent.height - 8px) / 2;
                                        border-radius: 4px;
                                        background: Theme.color-reminder;
                                        drop-shadow-blur: 4px;
                                        drop-shadow-color: #8be86b40;
                                    }
                                    Text {
                                        text: " Enabled";
                                        color: Theme.color-reminder;
                                        font-size: Theme.font-body;
                                    }
                                }

                                Rectangle { height: 1px; background: #ffffff08; }

                                incognito-ta := TouchArea {
                                    height: 24px;
                                    clicked => { root.toggle-incognito-mode(); }

                                    HorizontalLayout {
                                        Text {
                                            text: "Incognito";
                                            color: Theme.text-secondary;
                                            font-size: Theme.font-body;
                                            horizontal-stretch: 1;
                                        }
                                        Rectangle {
                                            width: incognito-tag.preferred-width + 16px;
                                            height: 24px;
                                            border-radius: 12px;
                                            background: root.incognito-mode ? Theme.color-emotional : (incognito-ta.has-hover ? Theme.hover-fill-strong : Theme.hover-fill);
                                            border-width: 1px;
                                            border-color: root.incognito-mode ? Theme.color-emotional : Theme.border-subtle;
                                            drop-shadow-blur: root.incognito-mode ? 6px : 0;
                                            drop-shadow-color: root.incognito-mode ? #e86b6b40 : transparent;

                                            incognito-tag := Text {
                                                text: root.incognito-mode ? "ON" : "OFF";
                                                color: root.incognito-mode ? #ffffff : Theme.text-primary;
                                                font-size: 11px;
                                                font-weight: 600;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                }

                                Rectangle { height: 1px; background: #ffffff08; }

                                dnd-ta := TouchArea {
                                    height: 24px;
                                    clicked => { root.toggle-dnd-mode(); }

                                    HorizontalLayout {
                                        Text {
                                            text: "Do Not Disturb";
                                            color: Theme.text-secondary;
                                            font-size: Theme.font-body;
                                            horizontal-stretch: 1;
                                        }
                                        Rectangle {
                                            width: dnd-tag.preferred-width + 16px;
                                            height: 24px;
                                            border-radius: 12px;
                                            background: root.dnd-mode ? Theme.amber : (dnd-ta.has-hover ? Theme.hover-fill-strong : Theme.hover-fill);
                                            border-width: 1px;
                                            border-color: root.dnd-mode ? Theme.amber : Theme.border-subtle;
                                            drop-shadow-blur: root.dnd-mode ? 6px : 0;
                                            drop-shadow-color: root.dnd-mode ? Theme.amber-glow : transparent;

                                            dnd-tag := Text {
                                                text: root.dnd-mode ? "ON" : "OFF";
                                                color: root.dnd-mode ? Theme.bg-deep : Theme.text-primary;
                                                font-size: 11px;
                                                font-weight: 600;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        // Bottom spacer
                        Rectangle { height: 40px; }
                    }
