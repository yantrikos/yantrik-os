                                    }
                                }

                                if root.conn-instagram-detail != "" : Text {
                                    text: root.conn-instagram-detail;
                                    color: Theme.text-dim;
                                    font-size: Theme.font-small;
                                }

                                HorizontalLayout {
                                    spacing: 8px;
                                    alignment: end;

                                    if root.conn-instagram-status == "connected" : TouchArea {
                                        width: sync-ig-text.preferred-width + 20px;
                                        height: 30px;
                                        clicked => { root.sync-service("instagram"); }

                                        Rectangle {
                                            border-radius: 6px;
                                            background: parent.has-hover ? #ffffff10 : #ffffff06;
                                            border-width: 1px;
                                            border-color: #ffffff10;

                                            sync-ig-text := Text {
                                                text: "Sync";
                                                color: Theme.text-secondary;
                                                font-size: 11px;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }

                                    if root.conn-instagram-status == "connected" : TouchArea {
                                        width: disc-ig-text.preferred-width + 20px;
                                        height: 30px;
                                        clicked => { root.disconnect-service("instagram"); }

                                        Rectangle {
                                            border-radius: 6px;
                                            background: parent.has-hover ? #ea433520 : transparent;
                                            border-width: 1px;
                                            border-color: #ea433530;

                                            disc-ig-text := Text {
                                                text: "Disconnect";
                                                color: #ea4335;
                                                font-size: 11px;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }

                                    if root.conn-instagram-status == "disconnected" : TouchArea {
                                        width: connect-ig-text.preferred-width + 20px;
                                        height: 30px;
                                        clicked => { root.connect-service("instagram"); }

                                        Rectangle {
                                            border-radius: 6px;
                                            background: parent.has-hover ? #e1306c30 : #e1306c20;
                                            border-width: 1px;
                                            border-color: #e1306c40;

                                            connect-ig-text := Text {
                                                text: "Connect";
                                                color: #e1306c;
                                                font-size: 11px;
                                                font-weight: 600;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        // Bottom spacer
                        Rectangle { height: 40px; }
                    }
                }

                // ===== CATEGORY 6: SKILLS =====
                if root.active-category == 6 : SkillStore {
                    width: 100%;
                    height: 100%;
                    skills: root.skills;
                    categories: root.skill-categories;
                    toggle-skill(id) => { root.toggle-skill(id); }
                    search-skills(query) => { root.search-skills(query); }
                    filter-category(cat) => { root.filter-skill-category(cat); }
                }
            }
        }
    }
}
