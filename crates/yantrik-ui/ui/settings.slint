// Settings panel — enterprise system configuration.
// Screen 7. Two-pane layout: 240px sidebar + fluid content.
// Data-driven sidebar with search. AI & Intelligence flagship page.

import { Theme, ThemeMode, AccentPreset } from "theme.slint";
import { SkillStore, SkillData } from "skill_store.slint";
import { YButton, YIconButton } from "components/y_button.slint";
import { YInput } from "components/y_input.slint";

// ── Settings sidebar category item ──
export struct SettingsCategoryItem {
    icon: string,
    label: string,
    id: int,
}

// ── AI Provider data (for provider list) ──
export struct AIProviderData {
    id: string,
    name: string,
    provider-type: string,      // "ollama", "openai", "anthropic", "openrouter", "gemini", "together", "groq", "fireworks", "mistral", "deepseek", "huggingface", "custom"
    base-url: string,
    status: string,             // "connected", "disconnected", "testing", "error"
    is-primary: bool,
    is-fallback: bool,
    latency-ms: int,            // -1 = unknown
    error-message: string,
}

// ── AI Model data (for model list) ──
export struct AIModelData {
    id: string,
    name: string,
    tier: string,               // "Tiny", "Small", "Medium", "Large"
    param-count: string,        // "0.8B", "4B", "27B"
    context-length: string,     // "4K", "32K", "128K"
    is-active: bool,
    is-local: bool,             // true for locally available models (Ollama)
}

// ── Live AI status data ──
export struct AIStatusData {
    provider-name: string,
    provider-type: string,
    model-name: string,
    model-tier: string,         // "Tiny", "Small", "Medium", "Large"
    status: string,             // "connected", "disconnected", "fallback", "error"
    latency-ms: int,
    tokens-per-sec: float,
    tokens-today: int,
    using-fallback: bool,
    fallback-provider: string,
    fallback-model: string,
}

export component SettingsScreen inherits Rectangle {
    background: Theme.bg-deep;

    // Account
    in-out property <string> user-name: "";
    in-out property <string> companion-name: "Yantrik";
    callback rename-user(string);
    callback rename-companion(string);

    // AI Model
    in property <string> model-name: "";
    in property <int> max-context: 4096;
    in property <int> max-tokens: 512;
    in property <string> tool-permission: "sensitive";

    // Security
    in property <int> auto-lock-secs: 300;
    in-out property <bool> incognito-mode: false;
    in-out property <bool> dnd-mode: false;
    callback toggle-incognito-mode();
    callback toggle-dnd-mode();

    // Network
    in property <bool> wifi-connected: false;
    in property <string> wifi-ssid: "";
    in property <string> ip-address: "";

    // Display
    in property <string> display-resolution: "";

    // LLM Backend
    in property <string> llm-backend: "candle";
    in property <string> llm-api-url: "";
    in property <string> llm-api-model: "";

    // System info
    in property <int> memory-count: 0;
    in property <string> version-text: "0.1.0";
    in property <int> notification-count: 0;

    // Appearance
    in-out property <bool> dark-mode: true;
    in-out property <string> accent-color: "cyan";
    callback toggle-dark-mode();
    callback cycle-accent-color();

    // Wallpaper
    in-out property <string> wallpaper-path: "";
    property <string> custom-wallpaper-input: "";
    property <bool> custom-input-visible: false;
    callback wallpaper-changed(string);

    // Interactive settings
    callback cycle-tool-permission();
    callback cycle-auto-lock();

    callback back-pressed();
    callback navigate-to(int);

    // Connected Services (category 5)
    // Each connector: status is "connected", "disconnected", or "connecting"
    in property <string> conn-google-status: "disconnected";
    in property <string> conn-google-detail: "";
    in property <string> conn-spotify-status: "disconnected";
    in property <string> conn-spotify-detail: "";
    in property <string> conn-facebook-status: "disconnected";
    in property <string> conn-facebook-detail: "";
    in property <string> conn-instagram-status: "disconnected";
    in property <string> conn-instagram-detail: "";
    callback connect-service(string);
    callback disconnect-service(string);
    callback sync-service(string);

    // Skills / Skill Store (category 6) — data-driven via models
    in property <[SkillData]> skills;
    in property <[string]> skill-categories: ["All"];
    callback toggle-skill(string);
    callback search-skills(string);
    callback filter-skill-category(string);

    // ── AI Provider management (Phase 2) ──
    in property <AIStatusData> ai-status;
    in property <[AIProviderData]> ai-providers: [];
    in property <[AIModelData]> available-models: [];
    in property <string> provider-test-result: "";      // "success", "error: ...", "testing", ""
    in-out property <bool> provider-panel-open: false;
    in-out property <string> editing-provider-id: "";   // empty = new provider
    callback add-provider();
    callback save-provider(string, string, string, string, string);  // name, type, url, key, auth
    callback delete-provider(string);
    callback test-provider(string);
    callback test-new-provider(string, string, string);              // url, key, auth
    callback set-primary-provider(string);
    callback set-fallback-provider(string);
    callback select-model(string);
    callback refresh-models();
    callback toggle-auto-fallback();

    // V60 — Task routing
    in-out property <string> route-fast-provider: "";
    in-out property <string> route-balanced-provider: "";
    in-out property <string> route-powerful-provider: "";
    callback save-task-routing(string, string, string);

    // V60 — Privacy controls
    in-out property <bool> privacy-local-only: false;
    in-out property <bool> privacy-cloud-confirm: true;
    in-out property <string> privacy-preset: "balanced";  // "maximum", "balanced", "cloud-first"
    callback set-privacy-preset(string);

    // V62 — Usage / Cost tracking
    in property <string> usage-period: "monthly";
    in property <float> usage-local-percent: 0.0;
    in property <float> usage-cloud-percent: 0.0;
    in property <string> usage-total-cost: "$0.00";
    in property <string> usage-daily-cost: "$0.00";
    in property <string> usage-tokens-today: "0";
    in property <string> usage-tokens-month: "0";
    in property <string> budget-limit: "";
    in property <float> budget-used-percent: 0.0;
    in property <bool> budget-warning: false;
    in-out property <string> budget-input: "";
    callback save-budget(string);

    // Active settings category (sidebar)
    property <int> active-category: 0;

    // Sidebar categories — data-driven
    property <[SettingsCategoryItem]> all-categories: [
        { icon: "\u{25D0}", label: "Appearance",         id: 0 },
        { icon: "\u{25C9}", label: "AI & Intelligence",  id: 1 },
        { icon: "\u{25A3}", label: "Desktop",            id: 2 },
        { icon: "\u{25CE}", label: "Network",            id: 3 },
        { icon: "\u{1F517}", label: "Accounts",          id: 4 },
        { icon: "\u{2298}", label: "Privacy & Security", id: 5 },
        { icon: "\u{2299}", label: "System",             id: 6 },
        { icon: "\u{26A1}", label: "Skills",             id: 7 },
    ];

    // Search-filtered categories (set from Rust callback or defaults to all)
    in-out property <[SettingsCategoryItem]> categories: root.all-categories;
    in-out property <string> search-query: "";
    callback settings-search(string);

    // Ambient glow phase
    property <float> glow-phase: 0;
    Timer {
        interval: 16ms;
        running: true;
        triggered => {
            glow-phase = mod(glow-phase + 0.0015, 1.0);
        }
    }

    // Background nebula wash
    Rectangle {
        x: parent.width * 0.5;
        y: -parent.height * 0.1;
        width: 600px;
        height: 500px;
        background: @radial-gradient(circle,
            Theme.accent-glow 0%,
            transparent 60%
        );
    }

    VerticalLayout {
        spacing: 0px;

        // Header
        Rectangle {
            height: Theme.sp-9;
            background: Theme.bg-surface;

            // Bottom divider
            Rectangle {
                y: parent.height - 1px;
                width: 100%;
                height: 1px;
                background: Theme.separator;
            }

            HorizontalLayout {
                padding-left: Theme.sp-3;
                padding-right: Theme.sp-3;
                alignment: start;
                spacing: Theme.sp-3;

                YIconButton {
                    icon: "\u{2190}";
                    variant: 2;
                    clicked => { root.back-pressed(); }
                }

                Text {
                    text: "Settings";
                    color: Theme.text-primary;
                    font-size: Theme.fs-title-2;
                    font-weight: Theme.fw-title-2;
                    vertical-alignment: center;
                }
            }
        }

        // Main content: sidebar + panel
        HorizontalLayout {
            vertical-stretch: 1;
            spacing: 0px;

            // ===== LEFT SIDEBAR (240px, data-driven) =====
            Rectangle {
                width: 240px;
                background: Theme.bg-surface;

                // Right edge separator
                Rectangle {
                    x: parent.width - 1px;
                    width: 1px;
                    height: 100%;
                    background: Theme.separator;
                }

                VerticalLayout {
                    padding-top: Theme.sp-3;
                    padding-bottom: Theme.sp-4;
                    spacing: 0px;
                    alignment: start;

                    // ── Search bar ──
                    Rectangle {
                        height: Theme.touch-target;

                        HorizontalLayout {
                            padding-left: Theme.sp-3;
                            padding-right: Theme.sp-3;

                            YInput {
                                mode: 1;
                                placeholder: "Search settings...";
                                value <=> root.search-query;
                                edited(text) => { root.settings-search(text); }
                                accepted(text) => { root.settings-search(text); }
                            }
                        }
                    }

                    // ── Spacer ──
                    Rectangle { height: Theme.sp-2; }

                    // ── Category list (data-driven) ──
                    for cat[idx] in root.categories : Rectangle {
                        property <bool> is-active: root.active-category == cat.id;
                        property <bool> hovered: cat-ta.has-hover;

                        height: Theme.touch-target;
                        background: is-active ? Theme.tint-accent
                                  : hovered ? Theme.hover-fill
                                  : transparent;

                        animate background { duration: Theme.dur-fast; }

                        // Left accent bar (active indicator)
                        if is-active : Rectangle {
                            x: 0;
                            width: 3px;
                            height: 20px;
                            y: (parent.height - 20px) / 2;
                            border-radius: 2px;
                            background: Theme.accent;
                        }

                        cat-ta := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.active-category = cat.id; }
                        }

                        HorizontalLayout {
                            padding-left: Theme.sp-4;
                            padding-right: Theme.sp-3;
                            spacing: Theme.sp-3;
                            alignment: start;

                            Text {
                                text: cat.icon;
                                color: is-active ? Theme.accent : Theme.text-dim;
                                font-size: Theme.fs-body;
                                vertical-alignment: center;
                                width: 24px;
                                horizontal-alignment: center;
                            }
                            Text {
                                text: cat.label;
                                color: is-active ? Theme.text-primary : Theme.text-secondary;
                                font-size: Theme.fs-body;
                                font-weight: is-active ? Theme.fw-body-strong : Theme.fw-body;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }

            // ===== RIGHT PANEL — category content =====
            Rectangle {
                horizontal-stretch: 1;
                background: transparent;

                // ===== CATEGORY 0: APPEARANCE =====
                if root.active-category == 0 : Flickable {
                    width: 100%;
                    height: 100%;

                    VerticalLayout {
                        padding: Theme.sp-6;
                        spacing: Theme.sp-4;
                        alignment: start;

                        // Section header
                        HorizontalLayout {
                            spacing: Theme.sp-2;
                            Rectangle {
                                width: 3px;
                                height: 14px;
                                y: 0;
                                border-radius: 1.5px;
                                background: Theme.accent;
                                drop-shadow-blur: 4px;
                                drop-shadow-color: Theme.accent-glow;
                            }
                            Text {
                                text: "APPEARANCE";
                                color: Theme.accent;
                                font-size: Theme.fs-caption;
                                font-weight: 600;
                                letter-spacing: 3px;
                                vertical-alignment: center;
                            }
                        }

                        // Dark / Light mode toggle
                        Rectangle {
                            background: Theme.bg-card;
                            border-radius: Theme.r-lg;
                            border-width: 1px;
                            border-color: Theme.border-subtle;
                            height: 52px;

                            HorizontalLayout {
                                padding-left: Theme.sp-4;
                                padding-right: Theme.sp-4;

                                Text {
                                    text: "Theme";
                                    color: Theme.text-secondary;
                                    font-size: Theme.fs-body;
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                }

                                // Pill toggle: Dark / Light — holographic
                                TouchArea {
                                    width: 110px;
                                    height: 36px;
                                    clicked => { root.toggle-dark-mode(); }

                                    Rectangle {
                                        width: 110px;
                                        height: 32px;
                                        y: (parent.height - self.height) / 2;
                                        border-radius: 16px;
                                        background: Theme.bg-elevated;
                                        border-width: 1px;
                                        border-color: root.dark-mode ? Theme.accent-dim : Theme.amber-dim;

                                        // Sliding pill indicator
                                        Rectangle {
                                            x: root.dark-mode ? 2px : 56px;
                                            y: 2px;
                                            width: 52px;
                                            height: 28px;
                                            border-radius: 14px;
                                            background: root.dark-mode ? Theme.accent-dim : Theme.amber-dim;
                                            drop-shadow-blur: 6px;
                                            drop-shadow-color: root.dark-mode ? Theme.accent-glow : Theme.amber-glow;

                                            animate x { duration: Theme.dur-fast; easing: ease-out; }
                                            animate background { duration: Theme.dur-fast; }
                                            animate drop-shadow-color { duration: Theme.dur-fast; }
                                        }

                                        HorizontalLayout {
                                            Rectangle {
                                                width: 55px;
                                                Text {
                                                    text: "Dark";
                                                    color: root.dark-mode ? Theme.accent : Theme.text-dim;
                                                    font-size: Theme.fs-micro;
                                                    font-weight: root.dark-mode ? 600 : 400;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                    animate color { duration: Theme.dur-fast; }
                                                }
                                            }
                                            Rectangle {
                                                width: 55px;
                                                Text {
                                                    text: "Light";
                                                    color: root.dark-mode ? Theme.text-dim : Theme.amber;
                                                    font-size: Theme.fs-micro;
                                                    font-weight: root.dark-mode ? 400 : 600;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                    animate color { duration: Theme.dur-fast; }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        // Accent color picker row
                        Rectangle {
                            background: Theme.bg-card;
                            border-radius: Theme.r-lg;
                            border-width: 1px;
                            border-color: Theme.border-subtle;
                            height: 52px;

                            HorizontalLayout {
                                padding-left: Theme.sp-4;
                                padding-right: Theme.sp-4;

                                Text {
                                    text: "Accent color";
                                    color: Theme.text-secondary;
                                    font-size: Theme.fs-body;
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                }

                                accent-ta := TouchArea {
                                    width: accent-pill.preferred-width + 8px;
                                    height: 36px;
                                    clicked => { root.cycle-accent-color(); }

                                    accent-pill := Rectangle {
                                        width: accent-swatch.width + accent-label.preferred-width + 20px;
                                        height: 28px;
                                        y: (parent.height - self.height) / 2;
                                        border-radius: 14px;
                                        background: accent-ta.has-hover ? Theme.hover-fill-strong : Theme.hover-fill;
                                        border-width: 1px;
                                        border-color: AccentPreset.accent-dim;
                                        drop-shadow-blur: 4px;
                                        drop-shadow-color: AccentPreset.accent-glow;

                                        HorizontalLayout {
                                            padding-left: 8px;
                                            padding-right: 10px;
                                            spacing: Theme.sp-2;
                                            alignment: center;

                                            // Color swatch dot
                                            accent-swatch := Rectangle {
                                                width: 12px;
                                                height: 12px;
                                                y: (parent.height - 12px) / 2;
                                                border-radius: Theme.r-sm;
                                                background: AccentPreset.accent;
                                                drop-shadow-blur: 4px;
                                                drop-shadow-color: AccentPreset.accent-glow;
                                            }

                                            accent-label := Text {
                                                text: AccentPreset.label;
                                                color: AccentPreset.accent;
                                                font-size: Theme.fs-micro;
                                                font-weight: 600;
                                                vertical-alignment: center;
                                            }
                                        }

                                        animate border-color { duration: Theme.dur-normal; }
                                        animate drop-shadow-color { duration: Theme.dur-normal; }
                                    }
                                }
                            }
                        }

                        // ── Wallpaper section ──
                        Rectangle {
                            background: Theme.bg-card;
                            border-radius: Theme.r-lg;
                            border-width: 1px;
                            border-color: Theme.border-subtle;
                            height: wp-layout.preferred-height;

                            wp-layout := VerticalLayout {
                                padding: Theme.sp-4;
                                spacing: Theme.sp-3;

                                Text {
                                    text: "Wallpaper";
                                    color: Theme.text-secondary;
                                    font-size: Theme.fs-body;
                                }

                                // Preset thumbnail row
                                HorizontalLayout {
                                    spacing: Theme.sp-3;

                                    // None (solid dark)
                                    wp-none-ta := TouchArea {
                                        width: 60px; height: 40px;
                                        clicked => {
                                            root.wallpaper-path = "";
                                            root.custom-input-visible = false;
                                            root.wallpaper-changed("");
                                        }
                                        Rectangle {
                                            width: 60px; height: 40px;
                                            border-radius: Theme.r-sm;
                                            background: @radial-gradient(circle, #0a0a1c 0%, #050510 50%, #020206 100%);
                                            border-width: root.wallpaper-path == "" ? 2px : 1px;
                                            border-color: root.wallpaper-path == "" ? Theme.accent : (wp-none-ta.has-hover ? Theme.border-default : Theme.border-subtle);
                                            drop-shadow-blur: root.wallpaper-path == "" ? 4px : 0px;
                                            drop-shadow-color: root.wallpaper-path == "" ? Theme.accent-glow : transparent;

                                            Text {
                                                text: "None";
                                                color: root.wallpaper-path == "" ? Theme.accent : Theme.text-dim;
                                                font-size: 9px;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }

                                            animate border-color { duration: Theme.dur-fast; }
                                            animate border-width { duration: Theme.dur-fast; }
                                        }
                                    }

                                    // Aurora (green/purple)
                                    wp-aurora-ta := TouchArea {
                                        width: 60px; height: 40px;
                                        clicked => {
                                            root.wallpaper-path = "aurora";
                                            root.custom-input-visible = false;
                                            root.wallpaper-changed("aurora");
                                        }
                                        Rectangle {
                                            width: 60px; height: 40px;
                                            border-radius: Theme.r-sm;
                                            clip: true;
                                            background: @linear-gradient(135deg, #0d2818 0%, #1a0a2e 50%, #0a3020 100%);
                                            border-width: root.wallpaper-path == "aurora" ? 2px : 1px;
                                            border-color: root.wallpaper-path == "aurora" ? Theme.accent : (wp-aurora-ta.has-hover ? Theme.border-default : Theme.border-subtle);
                                            drop-shadow-blur: root.wallpaper-path == "aurora" ? 4px : 0px;
                                            drop-shadow-color: root.wallpaper-path == "aurora" ? Theme.accent-glow : transparent;

                                            // Mini glow accent
                                            Rectangle {
                                                x: 5px; y: 5px;
                                                width: 30px; height: 20px;
                                                border-radius: 10px;
                                                background: @radial-gradient(circle, #30e87830 0%, transparent 70%);
                                            }

                                            Text {
                                                y: parent.height - 12px;
                                                text: "Aurora";
                                                color: root.wallpaper-path == "aurora" ? Theme.accent : Theme.text-dim;
                                                font-size: 8px;
                                                horizontal-alignment: center;
                                                width: 100%;
                                            }

                                            animate border-color { duration: Theme.dur-fast; }
                                            animate border-width { duration: Theme.dur-fast; }
                                        }
                                    }

                                    // Sunset (orange/pink)
                                    wp-sunset-ta := TouchArea {
                                        width: 60px; height: 40px;
                                        clicked => {
                                            root.wallpaper-path = "sunset";
                                            root.custom-input-visible = false;
                                            root.wallpaper-changed("sunset");
                                        }
                                        Rectangle {
                                            width: 60px; height: 40px;
                                            border-radius: Theme.r-sm;
                                            clip: true;
                                            background: @linear-gradient(180deg, #3d1020 0%, #d4503a 50%, #e88c30 100%);
                                            border-width: root.wallpaper-path == "sunset" ? 2px : 1px;
                                            border-color: root.wallpaper-path == "sunset" ? Theme.accent : (wp-sunset-ta.has-hover ? Theme.border-default : Theme.border-subtle);
                                            drop-shadow-blur: root.wallpaper-path == "sunset" ? 4px : 0px;
                                            drop-shadow-color: root.wallpaper-path == "sunset" ? Theme.accent-glow : transparent;

                                            Text {
                                                y: parent.height - 12px;
                                                text: "Sunset";
                                                color: root.wallpaper-path == "sunset" ? #ffd6b0 : Theme.text-dim;
                                                font-size: 8px;
                                                horizontal-alignment: center;
                                                width: 100%;
                                            }

                                            animate border-color { duration: Theme.dur-fast; }
                                            animate border-width { duration: Theme.dur-fast; }
                                        }
                                    }

                                    // Ocean (blue/teal)
                                    wp-ocean-ta := TouchArea {
                                        width: 60px; height: 40px;
                                        clicked => {
                                            root.wallpaper-path = "ocean";
                                            root.custom-input-visible = false;
                                            root.wallpaper-changed("ocean");
                                        }
                                        Rectangle {
                                            width: 60px; height: 40px;
                                            border-radius: Theme.r-sm;
                                            clip: true;
                                            background: @linear-gradient(180deg, #041830 0%, #063050 50%, #0a4868 100%);
                                            border-width: root.wallpaper-path == "ocean" ? 2px : 1px;
                                            border-color: root.wallpaper-path == "ocean" ? Theme.accent : (wp-ocean-ta.has-hover ? Theme.border-default : Theme.border-subtle);
                                            drop-shadow-blur: root.wallpaper-path == "ocean" ? 4px : 0px;
                                            drop-shadow-color: root.wallpaper-path == "ocean" ? Theme.accent-glow : transparent;

                                            // Mini wave accent
                                            Rectangle {
                                                x: 10px; y: 15px;
                                                width: 40px; height: 15px;
                                                border-radius: Theme.r-md;
                                                background: @radial-gradient(circle, #06b6d418 0%, transparent 70%);
                                            }

                                            Text {
                                                y: parent.height - 12px;
                                                text: "Ocean";
                                                color: root.wallpaper-path == "ocean" ? #b0e0ff : Theme.text-dim;
                                                font-size: 8px;
                                                horizontal-alignment: center;
                                                width: 100%;
                                            }

                                            animate border-color { duration: Theme.dur-fast; }
                                            animate border-width { duration: Theme.dur-fast; }
                                        }
                                    }

                                    // Nebula (purple/cyan)
                                    wp-nebula-ta := TouchArea {
                                        width: 60px; height: 40px;
                                        clicked => {
                                            root.wallpaper-path = "nebula";
                                            root.custom-input-visible = false;
                                            root.wallpaper-changed("nebula");
                                        }
                                        Rectangle {
                                            width: 60px; height: 40px;
                                            border-radius: Theme.r-sm;
                                            clip: true;
                                            background: @linear-gradient(135deg, #1a0838 0%, #2e0e58 50%, #0a0828 100%);
                                            border-width: root.wallpaper-path == "nebula" ? 2px : 1px;
                                            border-color: root.wallpaper-path == "nebula" ? Theme.accent : (wp-nebula-ta.has-hover ? Theme.border-default : Theme.border-subtle);
                                            drop-shadow-blur: root.wallpaper-path == "nebula" ? 4px : 0px;
                                            drop-shadow-color: root.wallpaper-path == "nebula" ? Theme.accent-glow : transparent;

                                            // Mini nebula accent
                                            Rectangle {
                                                x: 15px; y: 8px;
                                                width: 30px; height: 20px;
                                                border-radius: 10px;
                                                background: @radial-gradient(circle, #a855f728 0%, transparent 70%);
                                            }
                                            Rectangle {
                                                x: 25px; y: 15px;
                                                width: 25px; height: 18px;
                                                border-radius: 9px;
                                                background: @radial-gradient(circle, #06b6d420 0%, transparent 70%);
                                            }

                                            Text {
                                                y: parent.height - 12px;
                                                text: "Nebula";
                                                color: root.wallpaper-path == "nebula" ? #d0b0ff : Theme.text-dim;
                                                font-size: 8px;
                                                horizontal-alignment: center;
                                                width: 100%;
                                            }

                                            animate border-color { duration: Theme.dur-fast; }
                                            animate border-width { duration: Theme.dur-fast; }
                                        }
                                    }
                                }

                                // Custom wallpaper button + path input
                                HorizontalLayout {
                                    spacing: Theme.sp-2;

                                    wp-custom-ta := TouchArea {
                                        width: custom-btn-rect.preferred-width;
                                        height: 32px;
                                        clicked => {
                                            root.custom-input-visible = !root.custom-input-visible;
                                        }
                                        custom-btn-rect := Rectangle {
                                            width: custom-btn-text.preferred-width + 24px;
                                            height: 32px;
                                            border-radius: Theme.r-md;
                                            background: wp-custom-ta.has-hover ? Theme.hover-fill-strong : Theme.hover-fill;
                                            border-width: 1px;
                                            border-color: root.custom-input-visible ? Theme.accent-dim : Theme.border-subtle;

                                            custom-btn-text := Text {
                                                text: "Custom...";
                                                color: root.custom-input-visible ? Theme.accent : Theme.text-secondary;
                                                font-size: Theme.fs-caption;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }

                                    // Show active wallpaper label
                                    if root.wallpaper-path != "" && root.wallpaper-path != "aurora" && root.wallpaper-path != "sunset" && root.wallpaper-path != "ocean" && root.wallpaper-path != "nebula" : Text {
                                        text: root.wallpaper-path;
                                        color: Theme.text-dim;
                                        font-size: Theme.fs-micro;
                                        vertical-alignment: center;
                                        horizontal-stretch: 1;
                                        overflow: elide;
                                    }
                                }

                                // Custom path input row (shown when "Custom..." toggled)
                                if root.custom-input-visible : HorizontalLayout {
                                    spacing: Theme.sp-2;

                                    Rectangle {
                                        horizontal-stretch: 1;
                                        height: 32px;
                                        border-radius: Theme.r-md;
                                        background: Theme.bg-elevated;
                                        border-width: 1px;
                                        border-color: Theme.border-subtle;
                                        clip: true;

                                        wp-input := TextInput {
                                            x: 8px;
                                            width: parent.width - 16px;
                                            height: 100%;
                                            text <=> root.custom-wallpaper-input;
                                            color: Theme.text-primary;
                                            font-size: Theme.fs-caption;
                                            vertical-alignment: center;

                                            accepted => {
                                                if root.custom-wallpaper-input != "" {
                                                    root.wallpaper-path = root.custom-wallpaper-input;
                                                    root.wallpaper-changed(root.custom-wallpaper-input);
                                                }
                                            }
                                        }

                                        // Placeholder text
                                        if root.custom-wallpaper-input == "" : Text {
                                            x: 8px;
                                            text: "/path/to/image.png";
                                            color: Theme.text-dim;
                                            font-size: Theme.fs-caption;
                                            vertical-alignment: center;
                                            opacity: 0.5;
                                        }
                                    }

                                    wp-apply-ta := TouchArea {
                                        width: 60px;
                                        height: 32px;
                                        clicked => {
                                            if root.custom-wallpaper-input != "" {
                                                root.wallpaper-path = root.custom-wallpaper-input;
                                                root.wallpaper-changed(root.custom-wallpaper-input);
                                            }
                                        }
                                        Rectangle {
                                            width: 60px; height: 32px;
                                            border-radius: Theme.r-md;
                                            background: wp-apply-ta.has-hover ? Theme.accent-dim : Theme.hover-fill;
                                            border-width: 1px;
                                            border-color: Theme.accent-dim;

                                            Text {
                                                text: "Apply";
                                                color: Theme.accent;
                                                font-size: Theme.fs-micro;
                                                font-weight: 600;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        // Display resolution
                        Rectangle {
                            background: Theme.bg-card;
                            border-radius: Theme.r-lg;
                            border-width: 1px;
                            border-color: Theme.border-subtle;
                            height: disp-layout.preferred-height;

                            disp-layout := VerticalLayout {
                                padding: Theme.sp-4;
                                spacing: Theme.sp-3;

                                HorizontalLayout {
                                    Text {
                                        text: "Resolution";
                                        color: Theme.text-secondary;
                                        font-size: Theme.fs-body;
                                        horizontal-stretch: 1;
                                    }
                                    Text {
                                        text: root.display-resolution != "" ? root.display-resolution : "auto";
                                        color: Theme.text-primary;
                                        font-size: Theme.fs-body;
                                    }
                                }
                            }
                        }

                        // Bottom spacer
                        Rectangle { height: 40px; }
                    }
                }

                // ===== CATEGORY 1: AI & INTELLIGENCE =====
                if root.active-category == 1 : Rectangle {
                    width: 100%;
                    height: 100%;

                    // Local form state for Add/Edit provider panel
                    property <string> form-name: "";
                    property <string> form-type: "custom";
                    property <string> form-url: "";
                    property <string> form-key: "";
                    property <string> form-auth: "bearer";
                    property <int> form-preset: -1;
                    property <bool> show-model-picker: false;

                    Flickable {
                        width: 100%;
                        height: 100%;

                        VerticalLayout {
                            padding: Theme.sp-6;
                            spacing: Theme.sp-4;
                            alignment: start;

                            // ── Page title ──
                            Text {
                                text: "AI & Intelligence";
                                color: Theme.text-primary;
                                font-size: Theme.fs-title-1;
                                font-weight: 700;
                            }
                            Text {
                                text: "Manage AI providers, models, and companion intelligence.";
                                color: Theme.text-secondary;
                                font-size: Theme.fs-body;
                            }

                            // ── ACTIVE AI STATUS ──
                            HorizontalLayout {
                                spacing: Theme.sp-2;
                                Rectangle {
                                    width: 3px; height: 14px;
                                    border-radius: 1.5px;
                                    background: root.ai-status.status == "connected" ? Theme.color-success
                                              : root.ai-status.status == "fallback" ? Theme.amber
                                              : Theme.color-emotional;
                                    drop-shadow-blur: 6px;
                                    drop-shadow-color: root.ai-status.status == "connected" ? Theme.color-success-dim
                                                     : root.ai-status.status == "fallback" ? Theme.amber-glow
                                                     : Theme.color-danger-dim;
                                }
                                Text {
                                    text: "ACTIVE AI";
                                    color: Theme.text-secondary;
                                    font-size: Theme.fs-caption;
                                    font-weight: 600;
                                    letter-spacing: 3px;
                                    vertical-alignment: center;
                                }
                            }

                            // Status card
                            Rectangle {
                                background: Theme.bg-card;
                                border-radius: Theme.r-lg;
                                border-width: 1px;
                                border-color: root.ai-status.status == "connected" ? Theme.color-success-dim
                                            : root.ai-status.status == "fallback" ? Theme.amber-dim
                                            : Theme.color-danger-dim;
                                height: ai-status-layout.preferred-height;

                                ai-status-layout := VerticalLayout {
                                    padding: Theme.sp-4;
                                    spacing: Theme.sp-3;

                                    // Provider + status row
                                    HorizontalLayout {
                                        spacing: Theme.sp-3;
                                        // Status dot with glow
                                        Rectangle {
                                            width: 10px;
                                            height: 10px;
                                            y: (parent.height - 10px) / 2;
                                            border-radius: 5px;
                                            background: root.ai-status.status == "connected" ? Theme.color-success
                                                      : root.ai-status.status == "fallback" ? Theme.amber
                                                      : root.ai-status.status == "disconnected" ? Theme.text-dim
                                                      : Theme.color-emotional;
                                            drop-shadow-blur: 8px;
                                            drop-shadow-color: root.ai-status.status == "connected" ? Theme.color-success-dim
                                                             : root.ai-status.status == "fallback" ? Theme.amber-glow-strong
                                                             : transparent;
                                            animate background { duration: Theme.dur-fast; }
                                            animate drop-shadow-color { duration: Theme.dur-fast; }
                                        }
                                        VerticalLayout {
                                            spacing: 2px;
                                            horizontal-stretch: 1;
                                            Text {
                                                text: root.ai-status.provider-name != "" ? root.ai-status.provider-name : "No provider";
                                                color: Theme.text-primary;
                                                font-size: Theme.fs-headline;
                                                font-weight: 600;
                                            }
                                            HorizontalLayout {
                                                spacing: Theme.sp-2;
                                                Text {
                                                    text: root.ai-status.provider-type;
                                                    color: Theme.text-dim;
                                                    font-size: Theme.fs-caption;
                                                }
                                                if root.ai-status.using-fallback : Text {
                                                    text: " \u{2022} using fallback";
                                                    color: Theme.amber;
                                                    font-size: Theme.fs-caption;
                                                    font-weight: 500;
                                                }
                                            }
                                        }
                                        // Status badge
                                        Rectangle {
                                            width: status-txt.preferred-width + 16px;
                                            height: 24px;
                                            border-radius: Theme.r-lg;
                                            background: root.ai-status.status == "connected" ? Theme.color-success-dim
                                                      : root.ai-status.status == "fallback" ? Theme.tint-amber
                                                      : Theme.color-danger-dim;
                                            border-width: 1px;
                                            border-color: root.ai-status.status == "connected" ? Theme.color-success-dim
                                                        : root.ai-status.status == "fallback" ? Theme.amber-dim
                                                        : Theme.color-danger-dim;
                                            status-txt := Text {
                                                text: root.ai-status.status == "connected" ? "Connected"
                                                    : root.ai-status.status == "fallback" ? "Fallback"
                                                    : root.ai-status.status == "disconnected" ? "Offline"
                                                    : "Error";
                                                color: root.ai-status.status == "connected" ? Theme.color-success
                                                     : root.ai-status.status == "fallback" ? Theme.amber
                                                     : Theme.color-emotional;
                                                font-size: Theme.fs-caption;
                                                font-weight: 600;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }

                                    Rectangle { height: 1px; background: Theme.border-subtle; }

                                    // Model + tier row
                                    HorizontalLayout {
                                        Text {
                                            text: "Model";
                                            color: Theme.text-secondary;
                                            font-size: Theme.fs-body;
                                            horizontal-stretch: 1;
                                        }
                                        HorizontalLayout {
                                            spacing: Theme.sp-2;
                                            Text {
                                                text: root.ai-status.model-name != "" ? root.ai-status.model-name : "—";
                                                color: Theme.accent;
                                                font-size: Theme.fs-body;
                                                font-weight: 500;
                                            }
                                            if root.ai-status.model-tier != "" : Rectangle {
                                                width: tier-txt.preferred-width + 12px;
                                                height: 20px;
                                                border-radius: 10px;
                                                background: root.ai-status.model-tier == "Large" ? Theme.tint-accent
                                                          : root.ai-status.model-tier == "Medium" ? Theme.tint-cyan
                                                          : root.ai-status.model-tier == "Small" ? Theme.tint-amber
                                                          : Theme.border-subtle;
                                                tier-txt := Text {
                                                    text: root.ai-status.model-tier;
                                                    color: root.ai-status.model-tier == "Large" ? Theme.accent
                                                         : root.ai-status.model-tier == "Medium" ? Theme.accent
                                                         : root.ai-status.model-tier == "Small" ? Theme.amber
                                                         : Theme.text-secondary;
                                                    font-size: Theme.fs-micro;
                                                    font-weight: 600;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                            }
                                        }
                                    }

                                    Rectangle { height: 1px; background: Theme.border-subtle; }

                                    // Metrics row: latency + TPS + tokens today
                                    HorizontalLayout {
                                        spacing: Theme.sp-6;
                                        VerticalLayout {
                                            spacing: 2px;
                                            horizontal-stretch: 1;
                                            Text {
                                                text: "Latency";
                                                color: Theme.text-dim;
                                                font-size: Theme.fs-caption;
                                            }
                                            Text {
                                                text: root.ai-status.latency-ms >= 0 ? root.ai-status.latency-ms + "ms" : "—";
                                                color: root.ai-status.latency-ms >= 0 && root.ai-status.latency-ms < 200 ? Theme.color-success
                                                     : root.ai-status.latency-ms < 500 ? Theme.amber
                                                     : Theme.color-emotional;
                                                font-size: Theme.fs-headline;
                                                font-weight: 600;
                                            }
                                        }
                                        VerticalLayout {
                                            spacing: 2px;
                                            horizontal-stretch: 1;
                                            Text {
                                                text: "Tokens/sec";
                                                color: Theme.text-dim;
                                                font-size: Theme.fs-caption;
                                            }
                                            Text {
                                                text: root.ai-status.tokens-per-sec > 0 ? round(root.ai-status.tokens-per-sec) + " t/s" : "—";
                                                color: Theme.text-primary;
                                                font-size: Theme.fs-headline;
                                                font-weight: 600;
                                            }
                                        }
                                        VerticalLayout {
                                            spacing: 2px;
                                            horizontal-stretch: 1;
                                            Text {
                                                text: "Today";
                                                color: Theme.text-dim;
                                                font-size: Theme.fs-caption;
                                            }
                                            Text {
                                                text: root.ai-status.tokens-today > 0 ? root.ai-status.tokens-today + " tokens" : "—";
                                                color: Theme.text-primary;
                                                font-size: Theme.fs-headline;
                                                font-weight: 600;
                                            }
                                        }
                                    }

                                    Rectangle { height: 1px; background: Theme.border-subtle; }

                                    // Fallback info (shown when using fallback)
                                    if root.ai-status.using-fallback : HorizontalLayout {
                                        spacing: Theme.sp-2;
                                        Text {
                                            text: "\u{26A0}";
                                            color: Theme.amber;
                                            font-size: Theme.fs-body;
                                            vertical-alignment: center;
                                        }
                                        VerticalLayout {
                                            spacing: 2px;
                                            horizontal-stretch: 1;
                                            Text {
                                                text: "Running on fallback: " + root.ai-status.fallback-provider;
                                                color: Theme.amber;
                                                font-size: Theme.fs-caption;
                                                font-weight: 500;
                                            }
                                            Text {
                                                text: "Model: " + root.ai-status.fallback-model;
                                                color: Theme.text-dim;
                                                font-size: Theme.fs-caption;
                                            }
                                        }
                                    }

                                    // Tool permission
                                    perm-ta := TouchArea {
                                        height: 24px;
                                        clicked => { root.cycle-tool-permission(); }

                                        HorizontalLayout {
                                            Text {
                                                text: "Tool permission";
                                                color: Theme.text-secondary;
                                                font-size: Theme.fs-body;
                                                horizontal-stretch: 1;
                                            }
                                            Rectangle {
                                                width: perm-tag.preferred-width + 16px;
                                                height: 24px;
                                                border-radius: Theme.r-lg;
                                                background: root.tool-permission == "safe" ? Theme.tint-cyan
                                                    : (root.tool-permission == "standard" ? Theme.tint-amber
                                                    : Theme.color-danger-dim);
                                                border-width: 1px;
                                                border-color: root.tool-permission == "safe" ? Theme.accent-dim
                                                    : (root.tool-permission == "standard" ? Theme.amber-dim
                                                    : Theme.color-danger-dim);
                                                perm-tag := Text {
                                                    text: root.tool-permission == "safe" ? "Safe"
                                                        : (root.tool-permission == "standard" ? "Standard"
                                                        : "Sensitive");
                                                    color: root.tool-permission == "safe" ? Theme.accent
                                                        : (root.tool-permission == "standard" ? Theme.amber
                                                        : Theme.color-emotional);
                                                    font-size: Theme.fs-micro;
                                                    font-weight: 600;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                            }
                                        }
                                    }
                                }
                            }

                            // ── PROVIDERS ──
                            HorizontalLayout {
                                spacing: Theme.sp-2;
                                Rectangle {
                                    width: 3px; height: 14px;
                                    border-radius: 1.5px;
                                    background: Theme.holo-blue;
                                    drop-shadow-blur: 4px;
                                    drop-shadow-color: Theme.holo-blue-glow;
                                }
                                Text {
                                    text: "PROVIDERS";
                                    color: Theme.holo-blue;
                                    font-size: Theme.fs-caption;
                                    font-weight: 600;
                                    letter-spacing: 3px;
                                    vertical-alignment: center;
                                }
                                Rectangle { horizontal-stretch: 1; }
                                // Add provider button
                                TouchArea {
                                    width: add-btn-row.preferred-width;
                                    height: 28px;
                                    clicked => {
                                        root.provider-panel-open = true;
                                        root.editing-provider-id = "";
                                    }
                                    add-btn-row := HorizontalLayout {
                                        spacing: Theme.sp-1;
                                        Rectangle {
                                            width: 28px;
                                            height: 28px;
                                            border-radius: 14px;
                                            background: Theme.tint-accent;
                                            border-width: 1px;
                                            border-color: Theme.accent-dim;
                                            Text {
                                                text: "+";
                                                color: Theme.accent;
                                                font-size: Theme.fs-headline;
                                                font-weight: 600;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                        Text {
                                            text: "Add Provider";
                                            color: Theme.accent;
                                            font-size: Theme.fs-caption;
                                            font-weight: 500;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }

                            // Provider list — data-driven
                            for provider[idx] in root.ai-providers : Rectangle {
                                background: Theme.bg-card;
                                border-radius: Theme.r-lg;
                                border-width: 1px;
                                border-color: provider.is-primary ? Theme.accent-dim
                                            : provider.is-fallback ? Theme.amber-dim
                                            : Theme.border-subtle;
                                height: prov-row-layout.preferred-height;

                                prov-row-layout := VerticalLayout {
                                    padding: 14px;
                                    padding-left: Theme.sp-4;
                                    padding-right: Theme.sp-4;
                                    spacing: Theme.sp-2;

                                    // Top row: name + type + status
                                    HorizontalLayout {
                                        spacing: Theme.sp-2;
                                        // Status dot
                                        Rectangle {
                                            width: 8px;
                                            height: 8px;
                                            y: (parent.height - 8px) / 2;
                                            border-radius: 4px;
                                            background: provider.status == "connected" ? Theme.color-success
                                                      : provider.status == "testing" ? Theme.amber
                                                      : provider.status == "error" ? Theme.color-emotional
                                                      : Theme.text-dim;
                                        }
                                        Text {
                                            text: provider.name;
                                            color: Theme.text-primary;
                                            font-size: Theme.fs-body;
                                            font-weight: 500;
                                            horizontal-stretch: 1;
                                        }
                                        // Type badge
                                        Rectangle {
                                            width: ptype-txt.preferred-width + 12px;
                                            height: 20px;
                                            border-radius: 10px;
                                            background: Theme.border-subtle;
                                            ptype-txt := Text {
                                                text: provider.provider-type;
                                                color: Theme.text-secondary;
                                                font-size: Theme.fs-micro;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                        // Primary/Fallback badges
                                        if provider.is-primary : Rectangle {
                                            width: pri-txt.preferred-width + 12px;
                                            height: 20px;
                                            border-radius: 10px;
                                            background: Theme.tint-accent;
                                            pri-txt := Text {
                                                text: "Primary";
                                                color: Theme.accent;
                                                font-size: Theme.fs-micro;
                                                font-weight: 600;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                        if provider.is-fallback : Rectangle {
                                            width: fb-txt.preferred-width + 12px;
                                            height: 20px;
                                            border-radius: 10px;
                                            background: Theme.tint-amber;
                                            fb-txt := Text {
                                                text: "Fallback";
                                                color: Theme.amber;
                                                font-size: Theme.fs-micro;
                                                font-weight: 600;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }

                                    // Detail row: URL + latency
                                    HorizontalLayout {
                                        spacing: Theme.sp-3;
                                        Text {
                                            text: provider.base-url;
                                            color: Theme.text-dim;
                                            font-size: Theme.fs-caption;
                                            overflow: elide;
                                            horizontal-stretch: 1;
                                        }
                                        if provider.latency-ms >= 0 : Text {
                                            text: provider.latency-ms + "ms";
                                            color: provider.latency-ms < 200 ? Theme.color-success
                                                 : provider.latency-ms < 500 ? Theme.amber
                                                 : Theme.color-emotional;
                                            font-size: Theme.fs-caption;
                                            font-weight: 500;
                                        }
                                    }

                                    // Error message (if any)
                                    if provider.error-message != "" : Text {
                                        text: provider.error-message;
                                        color: Theme.color-emotional;
                                        font-size: Theme.fs-caption;
                                        wrap: word-wrap;
                                    }

                                    // Action buttons row
                                    HorizontalLayout {
                                        spacing: Theme.sp-2;
                                        alignment: end;

                                        // Test
                                        TouchArea {
                                            width: test-btn-txt.preferred-width + 16px;
                                            height: 28px;
                                            clicked => { root.test-provider(provider.id); }
                                            Rectangle {
                                                border-radius: Theme.r-sm;
                                                background: Theme.hover-fill;
                                                border-width: 1px;
                                                border-color: Theme.border-subtle;
                                                test-btn-txt := Text {
                                                    text: "Test";
                                                    color: Theme.text-secondary;
                                                    font-size: Theme.fs-caption;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                            }
                                        }

                                        // Set Primary (if not already)
                                        if !provider.is-primary : TouchArea {
                                            width: set-pri-txt.preferred-width + 16px;
                                            height: 28px;
                                            clicked => { root.set-primary-provider(provider.id); }
                                            Rectangle {
                                                border-radius: Theme.r-sm;
                                                background: Theme.hover-fill;
                                                border-width: 1px;
                                                border-color: Theme.border-subtle;
                                                set-pri-txt := Text {
                                                    text: "Set Primary";
                                                    color: Theme.accent;
                                                    font-size: Theme.fs-caption;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                            }
                                        }

                                        // Set Fallback (if not already)
                                        if !provider.is-fallback && !provider.is-primary : TouchArea {
                                            width: set-fb-txt.preferred-width + 16px;
                                            height: 28px;
                                            clicked => { root.set-fallback-provider(provider.id); }
                                            Rectangle {
                                                border-radius: Theme.r-sm;
                                                background: Theme.hover-fill;
                                                border-width: 1px;
                                                border-color: Theme.border-subtle;
                                                set-fb-txt := Text {
                                                    text: "Set Fallback";
                                                    color: Theme.amber;
                                                    font-size: Theme.fs-caption;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                            }
                                        }

                                        // Delete
                                        TouchArea {
                                            width: del-btn-txt.preferred-width + 16px;
                                            height: 28px;
                                            clicked => { root.delete-provider(provider.id); }
                                            Rectangle {
                                                border-radius: Theme.r-sm;
                                                background: Theme.hover-fill;
                                                border-width: 1px;
                                                border-color: Theme.border-subtle;
                                                del-btn-txt := Text {
                                                    text: "Remove";
                                                    color: Theme.color-emotional;
                                                    font-size: Theme.fs-caption;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                            }
                                        }
                                    }
                                }
                            }

                            // Empty state when no providers
                            if root.ai-providers.length == 0 : Rectangle {
                                background: Theme.bg-card;
                                border-radius: Theme.r-lg;
                                border-width: 1px;
                                border-color: Theme.border-subtle;
                                height: 120px;

                                VerticalLayout {
                                    alignment: center;
                                    spacing: Theme.sp-2;
                                    Text {
                                        text: "No AI providers configured";
                                        color: Theme.text-secondary;
                                        font-size: Theme.fs-body;
                                        horizontal-alignment: center;
                                    }
                                    Text {
                                        text: "Add a provider to connect to Ollama, OpenAI, Anthropic, or any OpenAI-compatible API.";
                                        color: Theme.text-dim;
                                        font-size: Theme.fs-caption;
                                        horizontal-alignment: center;
                                        wrap: word-wrap;
                                    }
                                }
                            }

                            // ── MODELS ──
                            HorizontalLayout {
                                spacing: Theme.sp-2;
                                Rectangle {
                                    width: 3px; height: 14px;
                                    border-radius: 1.5px;
                                    background: Theme.accent;
                                    drop-shadow-blur: 4px;
                                    drop-shadow-color: Theme.accent-glow;
                                }
                                Text {
                                    text: "MODELS";
                                    color: Theme.accent;
                                    font-size: Theme.fs-caption;
                                    font-weight: 600;
                                    letter-spacing: 3px;
                                    vertical-alignment: center;
                                }
                                Rectangle { horizontal-stretch: 1; }
                                // Refresh button
                                TouchArea {
                                    width: 28px;
                                    height: 28px;
                                    clicked => { root.refresh-models(); }
                                    Rectangle {
                                        border-radius: 14px;
                                        background: Theme.hover-fill;
                                        border-width: 1px;
                                        border-color: Theme.border-subtle;
                                        Text {
                                            text: "\u{21BB}";
                                            color: Theme.accent;
                                            font-size: Theme.fs-body;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }

                            // Model list
                            for model[midx] in root.available-models : TouchArea {
                                height: 56px;
                                clicked => { root.select-model(model.id); }

                                Rectangle {
                                    background: model.is-active
                                        ? Theme.tint-accent
                                        : Theme.bg-card;
                                    border-radius: Theme.r-lg;
                                    border-width: 1px;
                                    border-color: model.is-active ? Theme.accent-dim : Theme.border-subtle;

                                    HorizontalLayout {
                                        padding-left: Theme.sp-4;
                                        padding-right: Theme.sp-4;
                                        spacing: Theme.sp-3;

                                        // Active indicator
                                        if model.is-active : Rectangle {
                                            width: 6px;
                                            height: 6px;
                                            y: (parent.height - 6px) / 2;
                                            border-radius: 3px;
                                            background: Theme.accent;
                                            drop-shadow-blur: 6px;
                                            drop-shadow-color: Theme.accent-glow;
                                        }

                                        VerticalLayout {
                                            spacing: 2px;
                                            horizontal-stretch: 1;
                                            alignment: center;
                                            Text {
                                                text: model.name;
                                                color: model.is-active ? Theme.accent : Theme.text-primary;
                                                font-size: Theme.fs-body;
                                                font-weight: model.is-active ? 600 : 400;
                                            }
                                            HorizontalLayout {
                                                spacing: Theme.sp-2;
                                                if model.param-count != "" : Text {
                                                    text: model.param-count;
                                                    color: Theme.text-dim;
                                                    font-size: Theme.fs-caption;
                                                }
                                                if model.context-length != "" : Text {
                                                    text: model.context-length + " ctx";
                                                    color: Theme.text-dim;
                                                    font-size: Theme.fs-caption;
                                                }
                                                if model.is-local : Text {
                                                    text: "local";
                                                    color: Theme.color-success;
                                                    font-size: Theme.fs-caption;
                                                    font-weight: 500;
                                                }
                                            }
                                        }

                                        // Tier badge
                                        if model.tier != "" : Rectangle {
                                            width: mtier-txt.preferred-width + 12px;
                                            height: 20px;
                                            y: (parent.height - 20px) / 2;
                                            border-radius: 10px;
                                            background: model.tier == "Large" ? Theme.tint-accent
                                                      : model.tier == "Medium" ? Theme.tint-cyan
                                                      : model.tier == "Small" ? Theme.tint-amber
                                                      : Theme.border-subtle;
                                            mtier-txt := Text {
                                                text: model.tier;
                                                color: model.tier == "Large" ? Theme.accent
                                                     : model.tier == "Medium" ? Theme.accent
                                                     : model.tier == "Small" ? Theme.amber
                                                     : Theme.text-secondary;
                                                font-size: Theme.fs-micro;
                                                font-weight: 600;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                }
                            }

                            // Empty model state
                            if root.available-models.length == 0 : Rectangle {
                                background: Theme.bg-card;
                                border-radius: Theme.r-lg;
                                border-width: 1px;
                                border-color: Theme.border-subtle;
                                height: 64px;

                                HorizontalLayout {
                                    padding-left: Theme.sp-4;
                                    padding-right: Theme.sp-4;
                                    Text {
                                        text: "No models available. Add a provider and refresh.";
                                        color: Theme.text-dim;
                                        font-size: Theme.fs-caption;
                                        horizontal-stretch: 1;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            // ── FALLBACK ──
                            HorizontalLayout {
                                spacing: Theme.sp-2;
                                Rectangle {
                                    width: 3px; height: 14px;
                                    border-radius: 1.5px;
                                    background: Theme.amber;
                                    drop-shadow-blur: 4px;
                                    drop-shadow-color: Theme.amber-glow;
                                }
                                Text {
                                    text: "FALLBACK";
                                    color: Theme.amber;
                                    font-size: Theme.fs-caption;
                                    font-weight: 600;
                                    letter-spacing: 3px;
                                    vertical-alignment: center;
                                }
                            }

                            Rectangle {
                                background: Theme.bg-card;
                                border-radius: Theme.r-lg;
                                border-width: 1px;
                                border-color: Theme.border-subtle;
                                height: fallback-layout.preferred-height;

                                fallback-layout := VerticalLayout {
                                    padding: Theme.sp-4;
                                    spacing: Theme.sp-3;

                                    HorizontalLayout {
                                        Text {
                                            text: "Auto-fallback";
                                            color: Theme.text-secondary;
                                            font-size: Theme.fs-body;
                                            horizontal-stretch: 1;
                                        }
                                        TouchArea {
                                            width: 44px;
                                            height: 24px;
                                            clicked => { root.toggle-auto-fallback(); }
                                            Rectangle {
                                                border-radius: Theme.r-lg;
                                                background: root.ai-status.using-fallback ? Theme.accent : Theme.border-default;
                                                border-width: 1px;
                                                border-color: root.ai-status.using-fallback ? Theme.accent-dim : Theme.border-subtle;
                                                // Toggle knob
                                                Rectangle {
                                                    width: 18px;
                                                    height: 18px;
                                                    x: root.ai-status.using-fallback ? parent.width - 21px : 3px;
                                                    y: 3px;
                                                    border-radius: 9px;
                                                    background: Theme.text-primary;
                                                    animate x { duration: Theme.dur-fast; easing: ease-in-out; }
                                                    animate background { duration: Theme.dur-fast; }
                                                }
                                            }
                                        }
                                    }

                                    Text {
                                        text: "When the primary provider fails 3 times, automatically switch to the fallback provider.";
                                        color: Theme.text-dim;
                                        font-size: Theme.fs-caption;
                                        wrap: word-wrap;
                                    }
                                }
                            }

                            // ── TASK ROUTING (V60) ──
                            HorizontalLayout {
                                spacing: Theme.sp-2;
                                Rectangle {
                                    width: 3px; height: 14px;
                                    border-radius: 1.5px;
                                    background: Theme.color-purple;
                                    drop-shadow-blur: 4px;
                                    drop-shadow-color: Theme.color-purple-dim;
                                }
                                Text {
                                    text: "TASK ROUTING";
                                    color: Theme.color-purple;
                                    font-size: Theme.fs-caption;
                                    font-weight: 600;
                                    letter-spacing: 3px;
                                    vertical-alignment: center;
                                }
                            }

                            Rectangle {
                                background: Theme.bg-card;
                                border-radius: Theme.r-lg;
                                border-width: 1px;
                                border-color: Theme.border-subtle;
                                height: routing-layout.preferred-height;

                                routing-layout := VerticalLayout {
                                    padding: Theme.sp-4;
                                    spacing: Theme.sp-3;

                                    Text {
                                        text: "Route tasks to different providers by speed tier.";
                                        color: Theme.text-dim;
                                        font-size: Theme.fs-caption;
                                    }

                                    // Fast tier
                                    HorizontalLayout {
                                        spacing: Theme.sp-2;
                                        Rectangle {
                                            width: 8px; height: 8px;
                                            y: (parent.height - 8px) / 2;
                                            border-radius: 4px;
                                            background: Theme.color-success;
                                        }
                                        Text {
                                            text: "Fast";
                                            color: Theme.text-secondary;
                                            font-size: Theme.fs-body;
                                            width: 80px;
                                            vertical-alignment: center;
                                        }
                                        Text {
                                            text: root.route-fast-provider != "" ? root.route-fast-provider : "Auto";
                                            color: Theme.accent;
                                            font-size: Theme.fs-body;
                                            font-weight: 500;
                                            horizontal-stretch: 1;
                                            vertical-alignment: center;
                                        }
                                    }

                                    Rectangle { height: 1px; background: Theme.border-subtle; }

                                    // Balanced tier
                                    HorizontalLayout {
                                        spacing: Theme.sp-2;
                                        Rectangle {
                                            width: 8px; height: 8px;
                                            y: (parent.height - 8px) / 2;
                                            border-radius: 4px;
                                            background: Theme.holo-blue;
                                        }
                                        Text {
                                            text: "Balanced";
                                            color: Theme.text-secondary;
                                            font-size: Theme.fs-body;
                                            width: 80px;
                                            vertical-alignment: center;
                                        }
                                        Text {
                                            text: root.route-balanced-provider != "" ? root.route-balanced-provider : "Auto";
                                            color: Theme.accent;
                                            font-size: Theme.fs-body;
                                            font-weight: 500;
                                            horizontal-stretch: 1;
                                            vertical-alignment: center;
                                        }
                                    }

                                    Rectangle { height: 1px; background: Theme.border-subtle; }

                                    // Powerful tier
                                    HorizontalLayout {
                                        spacing: Theme.sp-2;
                                        Rectangle {
                                            width: 8px; height: 8px;
                                            y: (parent.height - 8px) / 2;
                                            border-radius: 4px;
                                            background: Theme.color-purple;
                                        }
                                        Text {
                                            text: "Powerful";
                                            color: Theme.text-secondary;
                                            font-size: Theme.fs-body;
                                            width: 80px;
                                            vertical-alignment: center;
                                        }
                                        Text {
                                            text: root.route-powerful-provider != "" ? root.route-powerful-provider : "Auto";
                                            color: Theme.accent;
                                            font-size: Theme.fs-body;
                                            font-weight: 500;
                                            horizontal-stretch: 1;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }

                            // ── PRIVACY (V60) ──
                            HorizontalLayout {
                                spacing: Theme.sp-2;
                                Rectangle {
                                    width: 3px; height: 14px;
                                    border-radius: 1.5px;
                                    background: Theme.color-success;
                                    drop-shadow-blur: 4px;
                                    drop-shadow-color: Theme.color-success-dim;
                                }
                                Text {
                                    text: "PRIVACY";
                                    color: Theme.color-success;
                                    font-size: Theme.fs-caption;
                                    font-weight: 600;
                                    letter-spacing: 3px;
                                    vertical-alignment: center;
                                }
                            }

                            Rectangle {
                                background: Theme.bg-card;
                                border-radius: Theme.r-lg;
                                border-width: 1px;
                                border-color: Theme.border-subtle;
                                height: privacy-layout.preferred-height;

                                privacy-layout := VerticalLayout {
                                    padding: Theme.sp-4;
                                    spacing: Theme.sp-3;

                                    // Privacy presets
                                    Text {
                                        text: "Privacy Level";
                                        color: Theme.text-secondary;
                                        font-size: Theme.fs-body;
                                    }

                                    HorizontalLayout {
                                        spacing: Theme.sp-2;

                                        for preset-item in [
                                            { label: "Maximum", value: "maximum" },
                                            { label: "Balanced", value: "balanced" },
                                            { label: "Cloud-First", value: "cloud-first" }
                                        ] : TouchArea {
                                            horizontal-stretch: 1;
                                            height: 32px;
                                            clicked => {
                                                root.privacy-preset = preset-item.value;
                                                root.set-privacy-preset(preset-item.value);
                                            }
                                            Rectangle {
                                                border-radius: Theme.r-md;
                                                background: root.privacy-preset == preset-item.value ? Theme.color-success-dim : Theme.hover-fill;
                                                border-width: 1px;
                                                border-color: root.privacy-preset == preset-item.value ? Theme.color-success-dim : Theme.border-subtle;
                                                Text {
                                                    text: preset-item.label;
                                                    color: root.privacy-preset == preset-item.value ? Theme.color-success : Theme.text-secondary;
                                                    font-size: Theme.fs-caption;
                                                    font-weight: root.privacy-preset == preset-item.value ? 600 : 400;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                            }
                                        }
                                    }

                                    Rectangle { height: 1px; background: Theme.border-subtle; }

                                    // Local-only toggle
                                    HorizontalLayout {
                                        Text {
                                            text: "Local-only rules";
                                            color: Theme.text-secondary;
                                            font-size: Theme.fs-body;
                                            horizontal-stretch: 1;
                                            vertical-alignment: center;
                                        }
                                        Text {
                                            text: "Never send data to cloud";
                                            color: Theme.text-dim;
                                            font-size: Theme.fs-caption;
                                            vertical-alignment: center;
                                        }
                                        Rectangle { width: 8px; }
                                        TouchArea {
                                            width: 44px; height: 24px;
                                            clicked => { root.privacy-local-only = !root.privacy-local-only; }
                                            Rectangle {
                                                border-radius: Theme.r-lg;
                                                background: root.privacy-local-only ? Theme.color-success : Theme.border-default;
                                                border-width: 1px;
                                                border-color: root.privacy-local-only ? Theme.color-success-dim : Theme.border-subtle;
                                                Rectangle {
                                                    width: 18px; height: 18px;
                                                    x: root.privacy-local-only ? parent.width - 21px : 3px;
                                                    y: 3px;
                                                    border-radius: 9px;
                                                    background: Theme.text-primary;
                                                    animate x { duration: Theme.dur-fast; easing: ease-in-out; }
                                                }
                                            }
                                        }
                                    }

                                    // Cloud escalation confirmation toggle
                                    HorizontalLayout {
                                        Text {
                                            text: "Cloud escalation confirm";
                                            color: Theme.text-secondary;
                                            font-size: Theme.fs-body;
                                            horizontal-stretch: 1;
                                            vertical-alignment: center;
                                        }
                                        Text {
                                            text: "Ask before cloud send";
                                            color: Theme.text-dim;
                                            font-size: Theme.fs-caption;
                                            vertical-alignment: center;
                                        }
                                        Rectangle { width: 8px; }
                                        TouchArea {
                                            width: 44px; height: 24px;
                                            clicked => { root.privacy-cloud-confirm = !root.privacy-cloud-confirm; }
                                            Rectangle {
                                                border-radius: Theme.r-lg;
                                                background: root.privacy-cloud-confirm ? Theme.accent : Theme.border-default;
                                                border-width: 1px;
                                                border-color: root.privacy-cloud-confirm ? Theme.accent-dim : Theme.border-subtle;
                                                Rectangle {
                                                    width: 18px; height: 18px;
                                                    x: root.privacy-cloud-confirm ? parent.width - 21px : 3px;
                                                    y: 3px;
                                                    border-radius: 9px;
                                                    background: Theme.text-primary;
                                                    animate x { duration: Theme.dur-fast; easing: ease-in-out; }
                                                }
                                            }
                                        }
                                    }
                                }
                            }

                            // ── USAGE & COST (V62) ──
                            HorizontalLayout {
                                spacing: Theme.sp-2;
                                Rectangle {
                                    width: 3px; height: 14px;
                                    border-radius: 1.5px;
                                    background: Theme.holo-blue;
                                    drop-shadow-blur: 4px;
                                    drop-shadow-color: Theme.holo-blue-glow;
                                }
                                Text {
                                    text: "USAGE & COST";
                                    color: Theme.holo-blue;
                                    font-size: Theme.fs-caption;
                                    font-weight: 600;
                                    letter-spacing: 3px;
                                    vertical-alignment: center;
                                }
                            }

                            // Usage dashboard card
                            Rectangle {
                                background: Theme.bg-card;
                                border-radius: Theme.r-lg;
                                border-width: 1px;
                                border-color: Theme.border-subtle;
                                height: usage-layout.preferred-height;

                                usage-layout := VerticalLayout {
                                    padding: Theme.sp-4;
                                    spacing: Theme.sp-3;

                                    // Cost overview
                                    HorizontalLayout {
                                        spacing: Theme.sp-6;
                                        VerticalLayout {
                                            spacing: 2px;
                                            horizontal-stretch: 1;
                                            Text {
                                                text: "Daily Cost";
                                                color: Theme.text-dim;
                                                font-size: Theme.fs-caption;
                                            }
                                            Text {
                                                text: root.usage-daily-cost;
                                                color: Theme.text-primary;
                                                font-size: Theme.fs-headline;
                                                font-weight: 600;
                                            }
                                        }
                                        VerticalLayout {
                                            spacing: 2px;
                                            horizontal-stretch: 1;
                                            Text {
                                                text: "Monthly Cost";
                                                color: Theme.text-dim;
                                                font-size: Theme.fs-caption;
                                            }
                                            Text {
                                                text: root.usage-total-cost;
                                                color: Theme.text-primary;
                                                font-size: Theme.fs-headline;
                                                font-weight: 600;
                                            }
                                        }
                                        VerticalLayout {
                                            spacing: 2px;
                                            horizontal-stretch: 1;
                                            Text {
                                                text: "Tokens Today";
                                                color: Theme.text-dim;
                                                font-size: Theme.fs-caption;
                                            }
                                            Text {
                                                text: root.usage-tokens-today;
                                                color: Theme.text-primary;
                                                font-size: Theme.fs-headline;
                                                font-weight: 600;
                                            }
                                        }
                                    }

                                    Rectangle { height: 1px; background: Theme.border-subtle; }

                                    // Local vs Cloud bar
                                    Text {
                                        text: "Local vs Cloud";
                                        color: Theme.text-secondary;
                                        font-size: Theme.fs-caption;
                                    }

                                    usage-bar := Rectangle {
                                        height: 12px;
                                        border-radius: Theme.r-sm;
                                        background: Theme.border-subtle;
                                        clip: true;
                                        // Local segment (left)
                                        Rectangle {
                                            x: 0px;
                                            y: 0px;
                                            width: usage-bar.width * (root.usage-local-percent / 100.0);
                                            height: 12px;
                                            background: Theme.color-success;
                                            border-radius: Theme.r-sm;
                                        }
                                        // Cloud segment (right of local)
                                        Rectangle {
                                            x: usage-bar.width * (root.usage-local-percent / 100.0);
                                            y: 0px;
                                            width: usage-bar.width * (root.usage-cloud-percent / 100.0);
                                            height: 12px;
                                            background: Theme.holo-blue;
                                        }
                                    }

                                    HorizontalLayout {
                                        HorizontalLayout {
                                            spacing: Theme.sp-1;
                                            horizontal-stretch: 1;
                                            Rectangle {
                                                width: 8px; height: 8px;
                                                y: (parent.height - 8px) / 2;
                                                border-radius: 4px;
                                                background: Theme.color-success;
                                            }
                                            Text {
                                                text: "Local " + round(root.usage-local-percent) + "%";
                                                color: Theme.text-dim;
                                                font-size: Theme.fs-caption;
                                                vertical-alignment: center;
                                            }
                                        }
                                        HorizontalLayout {
                                            spacing: Theme.sp-1;
                                            Rectangle {
                                                width: 8px; height: 8px;
                                                y: (parent.height - 8px) / 2;
                                                border-radius: 4px;
                                                background: Theme.holo-blue;
                                            }
                                            Text {
                                                text: "Cloud " + round(root.usage-cloud-percent) + "%";
                                                color: Theme.text-dim;
                                                font-size: Theme.fs-caption;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }

                                    Rectangle { height: 1px; background: Theme.border-subtle; }

                                    // Budget controls
                                    Text {
                                        text: "MONTHLY BUDGET";
                                        color: Theme.text-dim;
                                        font-size: Theme.fs-micro;
                                        font-weight: 600;
                                        letter-spacing: 2px;
                                    }

                                    HorizontalLayout {
                                        spacing: Theme.sp-2;
                                        Rectangle {
                                            horizontal-stretch: 1;
                                            height: 32px;
                                            border-radius: Theme.r-md;
                                            background: Theme.bg-input;
                                            border-width: 1px;
                                            border-color: root.budget-warning ? Theme.amber-dim : Theme.border-subtle;
                                            clip: true;
                                            budget-input-field := TextInput {
                                                x: 8px;
                                                width: parent.width - 16px;
                                                height: 100%;
                                                text <=> root.budget-input;
                                                color: Theme.text-primary;
                                                font-size: Theme.fs-body;
                                                vertical-alignment: center;
                                                accepted => { root.save-budget(self.text); }
                                            }
                                            if root.budget-input == "" : Text {
                                                x: 8px;
                                                text: "e.g. $20.00";
                                                color: Theme.text-dim;
                                                font-size: Theme.fs-body;
                                                vertical-alignment: center;
                                                opacity: 0.5;
                                            }
                                        }
                                        TouchArea {
                                            width: 60px; height: 32px;
                                            clicked => { root.save-budget(root.budget-input); }
                                            Rectangle {
                                                border-radius: Theme.r-md;
                                                background: Theme.hover-fill;
                                                border-width: 1px;
                                                border-color: Theme.border-subtle;
                                                Text {
                                                    text: "Set";
                                                    color: Theme.accent;
                                                    font-size: Theme.fs-caption;
                                                    font-weight: 600;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                            }
                                        }
                                    }

                                    // Budget progress bar
                                    if root.budget-limit != "" : VerticalLayout {
                                        spacing: Theme.sp-1;
                                        HorizontalLayout {
                                            Text {
                                                text: "Used";
                                                color: Theme.text-dim;
                                                font-size: Theme.fs-caption;
                                                horizontal-stretch: 1;
                                            }
                                            Text {
                                                text: root.usage-total-cost + " / " + root.budget-limit;
                                                color: root.budget-warning ? Theme.amber : Theme.text-secondary;
                                                font-size: Theme.fs-caption;
                                                font-weight: 500;
                                            }
                                        }
                                        Rectangle {
                                            height: 6px;
                                            border-radius: 3px;
                                            background: Theme.border-subtle;
                                            Rectangle {
                                                width: parent.width * min(1.0, root.budget-used-percent / 100.0);
                                                height: 6px;
                                                border-radius: 3px;
                                                background: root.budget-used-percent > 90 ? Theme.color-emotional
                                                          : root.budget-used-percent > 70 ? Theme.amber
                                                          : Theme.accent;
                                            }
                                        }
                                        if root.budget-warning : Text {
                                            text: "\u{26A0} Approaching budget limit";
                                            color: Theme.amber;
                                            font-size: Theme.fs-caption;
                                            font-weight: 500;
                                        }
                                    }
                                }
                            }

                            // ── COMPANION ──
                            HorizontalLayout {
                                spacing: Theme.sp-2;
                                Rectangle {
                                    width: 3px; height: 14px;
                                    border-radius: 1.5px;
                                    background: Theme.amber;
                                    drop-shadow-blur: 4px;
                                    drop-shadow-color: Theme.amber-glow;
                                }
                                Text {
                                    text: "COMPANION";
                                    color: Theme.amber;
                                    font-size: Theme.fs-caption;
                                    font-weight: 600;
                                    letter-spacing: 3px;
                                    vertical-alignment: center;
                                }
                            }

                            // Account card
                            Rectangle {
                                background: Theme.bg-card;
                                border-radius: Theme.r-lg;
                                border-width: 1px;
                                border-color: Theme.border-subtle;
                                height: acct-layout.preferred-height;

                                acct-layout := VerticalLayout {
                                    padding: Theme.sp-4;
                                    spacing: Theme.sp-3;

                                    property <bool> editing-user: false;
                                    HorizontalLayout {
                                        Text {
                                            text: "User";
                                            color: Theme.text-secondary;
                                            font-size: Theme.fs-body;
                                            horizontal-stretch: 1;
                                        }
                                        if !acct-layout.editing-user: TouchArea {
                                            width: user-display.preferred-width;
                                            height: user-display.preferred-height;
                                            clicked => { acct-layout.editing-user = true; }
                                            user-display := HorizontalLayout {
                                                spacing: Theme.sp-2;
                                                Text {
                                                    text: root.user-name;
                                                    color: Theme.text-primary;
                                                    font-size: Theme.fs-body;
                                                }
                                                Text {
                                                    text: "\u{270E}";
                                                    color: Theme.text-dim;
                                                    font-size: Theme.fs-micro;
                                                    vertical-alignment: center;
                                                }
                                            }
                                        }
                                        if acct-layout.editing-user: Rectangle {
                                            width: 160px;
                                            height: 28px;
                                            border-radius: 4px;
                                            background: Theme.border-subtle;
                                            border-width: 1px;
                                            border-color: Theme.accent;
                                            clip: true;
                                            user-input := TextInput {
                                                text: root.user-name;
                                                color: Theme.text-primary;
                                                font-size: Theme.fs-body;
                                                vertical-alignment: center;
                                                accepted => {
                                                    root.user-name = self.text;
                                                    root.rename-user(self.text);
                                                    acct-layout.editing-user = false;
                                                }
                                            }
                                        }
                                    }

                                    Rectangle { height: 1px; background: Theme.border-subtle; }

                                    property <bool> editing-companion: false;
                                    HorizontalLayout {
                                        Text {
                                            text: "Companion";
                                            color: Theme.text-secondary;
                                            font-size: Theme.fs-body;
                                            horizontal-stretch: 1;
                                        }
                                        if !acct-layout.editing-companion: TouchArea {
                                            width: comp-display.preferred-width;
                                            height: comp-display.preferred-height;
                                            clicked => { acct-layout.editing-companion = true; }
                                            comp-display := HorizontalLayout {
                                                spacing: Theme.sp-2;
                                                Text {
                                                    text: root.companion-name;
                                                    color: Theme.amber;
                                                    font-size: Theme.fs-body;
                                                    font-weight: 500;
                                                }
                                                Text {
                                                    text: "\u{270E}";
                                                    color: Theme.text-dim;
                                                    font-size: Theme.fs-micro;
                                                    vertical-alignment: center;
                                                }
                                            }
                                        }
                                        if acct-layout.editing-companion: Rectangle {
                                            width: 160px;
                                            height: 28px;
                                            border-radius: 4px;
                                            background: Theme.border-subtle;
                                            border-width: 1px;
                                            border-color: Theme.amber;
                                            clip: true;
                                            comp-input := TextInput {
                                                text: root.companion-name;
                                                color: Theme.amber;
                                                font-size: Theme.fs-body;
                                                font-weight: 500;
                                                vertical-alignment: center;
                                                accepted => {
                                                    root.companion-name = self.text;
                                                    root.rename-companion(self.text);
                                                    acct-layout.editing-companion = false;
                                                }
                                            }
                                        }
                                    }
                                }
                            }

                            // Nav links: Bond, Personality, Memory
                            Rectangle {
                                background: Theme.bg-card;
                                border-radius: Theme.r-lg;
                                border-width: 1px;
                                border-color: Theme.border-subtle;
                                height: 52px;
                                TouchArea { clicked => { root.navigate-to(4); } }
                                HorizontalLayout {
                                    padding-left: Theme.sp-4;
                                    padding-right: Theme.sp-4;
                                    Text {
                                        text: "Bond";
                                        color: Theme.text-primary;
                                        font-size: Theme.fs-body;
                                        horizontal-stretch: 1;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: "\u{2192}";
                                        color: Theme.accent-dim;
                                        font-size: Theme.fs-headline;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            Rectangle {
                                background: Theme.bg-card;
                                border-radius: Theme.r-lg;
                                border-width: 1px;
                                border-color: Theme.border-subtle;
                                height: 52px;
                                TouchArea { clicked => { root.navigate-to(5); } }
                                HorizontalLayout {
                                    padding-left: Theme.sp-4;
                                    padding-right: Theme.sp-4;
                                    Text {
                                        text: "Personality";
                                        color: Theme.text-primary;
                                        font-size: Theme.fs-body;
                                        horizontal-stretch: 1;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: "\u{2192}";
                                        color: Theme.accent-dim;
                                        font-size: Theme.fs-headline;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            Rectangle {
                                background: Theme.bg-card;
                                border-radius: Theme.r-lg;
                                border-width: 1px;
                                border-color: Theme.border-subtle;
                                height: 52px;
                                TouchArea { clicked => { root.navigate-to(6); } }
                                HorizontalLayout {
                                    padding-left: Theme.sp-4;
                                    padding-right: Theme.sp-4;
                                    Text {
                                        text: "Memory Browser";
                                        color: Theme.text-primary;
                                        font-size: Theme.fs-body;
                                        horizontal-stretch: 1;
                                        vertical-alignment: center;
                                    }
                                    Rectangle {
                                        width: mem-count-txt.preferred-width + 14px;
                                        height: 20px;
                                        y: (parent.height - 20px) / 2;
                                        border-radius: 10px;
                                        background: Theme.tint-amber;
                                        mem-count-txt := Text {
                                            text: root.memory-count;
                                            color: Theme.amber;
                                            font-size: Theme.fs-micro;
                                            font-weight: 600;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                    Text {
                                        text: "  \u{2192}";
                                        color: Theme.accent-dim;
                                        font-size: Theme.fs-headline;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            // Bottom spacer
                            Rectangle { height: 40px; }
                        }
                    }

                    // ── ADD/EDIT PROVIDER OVERLAY ──
                    if root.provider-panel-open : Rectangle {
                        width: 100%;
                        height: 100%;
                        background: Theme.overlay-backdrop;

                        TouchArea {
                            clicked => { root.provider-panel-open = false; }
                        }

                        Rectangle {
                            x: (parent.width - 480px) / 2;
                            y: (parent.height - self.height) / 2;
                            width: 480px;
                            height: provider-panel-layout.preferred-height;
                            background: Theme.bg-deep;
                            border-radius: Theme.r-lg;
                            border-width: 1px;
                            border-color: Theme.accent-dim;
                            drop-shadow-blur: 40px;
                            drop-shadow-color: Theme.overlay-backdrop;
                            clip: true;

                            // Block clicks from propagating to backdrop
                            TouchArea {}

                            provider-panel-layout := VerticalLayout {
                                padding: Theme.sp-6;
                                spacing: Theme.sp-4;

                                // Title
                                Text {
                                    text: root.editing-provider-id == "" ? "Add Provider" : "Edit Provider";
                                    color: Theme.text-primary;
                                    font-size: Theme.fs-headline;
                                    font-weight: 700;
                                }

                                // Provider presets grid
                                Text {
                                    text: "Choose a preset or configure manually:";
                                    color: Theme.text-secondary;
                                    font-size: Theme.fs-caption;
                                }

                                // Preset buttons — 4x3 grid
                                VerticalLayout {
                                    spacing: Theme.sp-2;
                                    HorizontalLayout {
                                        spacing: Theme.sp-2;
                                        for preset-info[pidx] in [
                                            { label: "Ollama",     value: "ollama" },
                                            { label: "OpenAI",     value: "openai" },
                                            { label: "Anthropic",  value: "anthropic" },
                                            { label: "OpenRouter", value: "openrouter" }
                                        ] : TouchArea {
                                            horizontal-stretch: 1;
                                            height: 36px;
                                            clicked => {
                                                root.provider-panel-open = true;
                                            }
                                            Rectangle {
                                                border-radius: Theme.r-md;
                                                background: Theme.hover-fill;
                                                border-width: 1px;
                                                border-color: Theme.border-subtle;
                                                Text {
                                                    text: preset-info.label;
                                                    color: Theme.text-primary;
                                                    font-size: Theme.fs-caption;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                            }
                                        }
                                    }
                                    HorizontalLayout {
                                        spacing: Theme.sp-2;
                                        for preset-info2[pidx2] in [
                                            { label: "Gemini",    value: "gemini" },
                                            { label: "Together",  value: "together" },
                                            { label: "Groq",      value: "groq" },
                                            { label: "Fireworks", value: "fireworks" }
                                        ] : TouchArea {
                                            horizontal-stretch: 1;
                                            height: 36px;
                                            clicked => {
                                                root.provider-panel-open = true;
                                            }
                                            Rectangle {
                                                border-radius: Theme.r-md;
                                                background: Theme.hover-fill;
                                                border-width: 1px;
                                                border-color: Theme.border-subtle;
                                                Text {
                                                    text: preset-info2.label;
                                                    color: Theme.text-primary;
                                                    font-size: Theme.fs-caption;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                            }
                                        }
                                    }
                                    HorizontalLayout {
                                        spacing: Theme.sp-2;
                                        for preset-info3[pidx3] in [
                                            { label: "Mistral",     value: "mistral" },
                                            { label: "DeepSeek",    value: "deepseek" },
                                            { label: "HuggingFace", value: "huggingface" },
                                            { label: "Custom",      value: "custom" }
                                        ] : TouchArea {
                                            horizontal-stretch: 1;
                                            height: 36px;
                                            clicked => {
                                                root.provider-panel-open = true;
                                            }
                                            Rectangle {
                                                border-radius: Theme.r-md;
                                                background: Theme.hover-fill;
                                                border-width: 1px;
                                                border-color: Theme.border-subtle;
                                                Text {
                                                    text: preset-info3.label;
                                                    color: Theme.text-primary;
                                                    font-size: Theme.fs-caption;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                            }
                                        }
                                    }
                                }

                                Rectangle { height: 1px; background: Theme.border-subtle; }

                                // Form fields
                                VerticalLayout {
                                    spacing: Theme.sp-3;

                                    // Name
                                    VerticalLayout {
                                        spacing: Theme.sp-1;
                                        Text {
                                            text: "Name";
                                            color: Theme.text-secondary;
                                            font-size: Theme.fs-caption;
                                        }
                                        Rectangle {
                                            height: 36px;
                                            border-radius: Theme.r-md;
                                            background: Theme.bg-input;
                                            border-width: 1px;
                                            border-color: Theme.border-subtle;
                                            clip: true;
                                            prov-name-input := TextInput {
                                                color: Theme.text-primary;
                                                font-size: Theme.fs-body;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }

                                    // Base URL
                                    VerticalLayout {
                                        spacing: Theme.sp-1;
                                        Text {
                                            text: "Base URL";
                                            color: Theme.text-secondary;
                                            font-size: Theme.fs-caption;
                                        }
                                        Rectangle {
                                            height: 36px;
                                            border-radius: Theme.r-md;
                                            background: Theme.bg-input;
                                            border-width: 1px;
                                            border-color: Theme.border-subtle;
                                            clip: true;
                                            prov-url-input := TextInput {
                                                color: Theme.text-primary;
                                                font-size: Theme.fs-body;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }

                                    // API Key
                                    VerticalLayout {
                                        spacing: Theme.sp-1;
                                        Text {
                                            text: "API Key";
                                            color: Theme.text-secondary;
                                            font-size: Theme.fs-caption;
                                        }
                                        Rectangle {
                                            height: 36px;
                                            border-radius: Theme.r-md;
                                            background: Theme.bg-input;
                                            border-width: 1px;
                                            border-color: Theme.border-subtle;
                                            clip: true;
                                            prov-key-input := TextInput {
                                                color: Theme.text-primary;
                                                font-size: Theme.fs-body;
                                                vertical-alignment: center;
                                                input-type: password;
                                            }
                                        }
                                    }
                                }

                                // Test result
                                if root.provider-test-result != "" : Rectangle {
                                    height: 28px;
                                    border-radius: Theme.r-sm;
                                    background: root.provider-test-result == "success" ? Theme.color-success-dim
                                              : root.provider-test-result == "testing" ? Theme.tint-amber
                                              : Theme.color-danger-dim;
                                    Text {
                                        text: root.provider-test-result == "success" ? "\u{2713} Connection successful"
                                            : root.provider-test-result == "testing" ? "Testing connection..."
                                            : root.provider-test-result;
                                        color: root.provider-test-result == "success" ? Theme.color-success
                                             : root.provider-test-result == "testing" ? Theme.amber
                                             : Theme.color-emotional;
                                        font-size: Theme.fs-caption;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                // Action buttons
                                HorizontalLayout {
                                    spacing: Theme.sp-3;
                                    alignment: end;

                                    // Test Connection
                                    TouchArea {
                                        width: test-new-txt.preferred-width + 24px;
                                        height: 36px;
                                        clicked => {
                                            root.test-new-provider(prov-url-input.text, prov-key-input.text, "bearer");
                                        }
                                        Rectangle {
                                            border-radius: Theme.r-md;
                                            background: Theme.hover-fill;
                                            border-width: 1px;
                                            border-color: Theme.border-subtle;
                                            test-new-txt := Text {
                                                text: "Test Connection";
                                                color: Theme.accent;
                                                font-size: Theme.fs-body;
                                                font-weight: 500;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }

                                    // Cancel
                                    TouchArea {
                                        width: cancel-txt.preferred-width + 24px;
                                        height: 36px;
                                        clicked => { root.provider-panel-open = false; }
                                        Rectangle {
                                            border-radius: Theme.r-md;
                                            background: Theme.hover-fill;
                                            border-width: 1px;
                                            border-color: Theme.border-subtle;
                                            cancel-txt := Text {
                                                text: "Cancel";
                                                color: Theme.text-secondary;
                                                font-size: Theme.fs-body;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }

                                    // Save
                                    TouchArea {
                                        width: save-txt.preferred-width + 24px;
                                        height: 36px;
                                        clicked => {
                                            root.save-provider(prov-name-input.text, "custom", prov-url-input.text, prov-key-input.text, "bearer");
                                            root.provider-panel-open = false;
                                        }
                                        Rectangle {
                                            border-radius: Theme.r-md;
                                            background: Theme.accent;
                                            border-width: 1px;
                                            border-color: Theme.accent-light;
                                            save-txt := Text {
                                                text: "Save";
                                                color: Theme.text-on-accent;
                                                font-size: Theme.fs-body;
                                                font-weight: 600;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                // ===== CATEGORY 2: DESKTOP =====
                if root.active-category == 2 : Flickable {
                    width: 100%;
                    height: 100%;

                    VerticalLayout {
                        padding: Theme.sp-6;
                        spacing: Theme.sp-4;
                        alignment: start;

                        // Section header
                        HorizontalLayout {
                            spacing: Theme.sp-2;
                            Rectangle {
                                width: 3px; height: 14px;
                                border-radius: 1.5px;
                                background: Theme.holo-blue;
                                drop-shadow-blur: 4px;
                                drop-shadow-color: Theme.holo-blue-glow;
                            }
                            Text {
                                text: "DESKTOP";
                                color: Theme.holo-blue;
                                font-size: Theme.fs-caption;
                                font-weight: 600;
                                letter-spacing: 3px;
                                vertical-alignment: center;
                            }
                        }

                        // Wallpaper configuration placeholder — will be moved from Appearance
                        Rectangle {
                            background: Theme.bg-card;
                            border-radius: Theme.r-lg;
                            border-width: 1px;
                            border-color: Theme.border-subtle;
                            height: desktop-layout.preferred-height;

                            desktop-layout := VerticalLayout {
                                padding: Theme.sp-4;
                                spacing: Theme.sp-3;

                                HorizontalLayout {
                                    Text {
                                        text: "Window Management";
                                        color: Theme.text-secondary;
                                        font-size: Theme.fs-body;
                                        horizontal-stretch: 1;
                                    }
                                    Text {
                                        text: "labwc / Wayland";
                                        color: Theme.text-primary;
                                        font-size: Theme.fs-body;
                                    }
                                }

                                Rectangle { height: 1px; background: Theme.border-subtle; }

                                HorizontalLayout {
                                    Text {
                                        text: "Compositor";
                                        color: Theme.text-secondary;
                                        font-size: Theme.fs-body;
                                        horizontal-stretch: 1;
                                    }
                                    Text {
                                        text: "wlroots";
                                        color: Theme.text-primary;
                                        font-size: Theme.fs-body;
                                    }
                                }

                                Rectangle { height: 1px; background: Theme.border-subtle; }

                                HorizontalLayout {
                                    Text {
                                        text: "Display";
                                        color: Theme.text-secondary;
                                        font-size: Theme.fs-body;
                                        horizontal-stretch: 1;
                                    }
                                    Text {
                                        text: root.display-resolution != "" ? root.display-resolution : "auto";
                                        color: Theme.text-primary;
                                        font-size: Theme.fs-body;
                                    }
                                }
                            }
                        }

                        // Keyboard Shortcuts card
                        Rectangle {
                            background: Theme.bg-card;
                            border-radius: Theme.r-lg;
                            border-width: 1px;
                            border-color: Theme.border-subtle;
                            height: keys-layout.preferred-height;

                            keys-layout := VerticalLayout {
                                padding: Theme.sp-4;
                                spacing: Theme.sp-2;

                                Text {
                                    text: "Keyboard Shortcuts";
                                    color: Theme.text-primary;
                                    font-size: Theme.fs-body;
                                    font-weight: 600;
                                }

                                HorizontalLayout {
                                    Text { text: "Alt + Tab"; color: Theme.accent; font-size: Theme.fs-caption; width: 120px; }
                                    Text { text: "Switch windows"; color: Theme.text-secondary; font-size: Theme.fs-caption; }
                                }
                                HorizontalLayout {
                                    Text { text: "Win + T"; color: Theme.accent; font-size: Theme.fs-caption; width: 120px; }
                                    Text { text: "Open terminal"; color: Theme.text-secondary; font-size: Theme.fs-caption; }
                                }
                                HorizontalLayout {
                                    Text { text: "Win + Left/Right"; color: Theme.accent; font-size: Theme.fs-caption; width: 120px; }
                                    Text { text: "Snap window"; color: Theme.text-secondary; font-size: Theme.fs-caption; }
                                }
                                HorizontalLayout {
                                    Text { text: "Print Screen"; color: Theme.accent; font-size: Theme.fs-caption; width: 120px; }
                                    Text { text: "Screenshot"; color: Theme.text-secondary; font-size: Theme.fs-caption; }
                                }
                            }
                        }

                        // Bottom spacer
                        Rectangle { height: 40px; }
                    }
                }

                // ===== CATEGORY 3: NETWORK =====
                if root.active-category == 3 : Flickable {
                    width: 100%;
                    height: 100%;

                    VerticalLayout {
                        padding: Theme.sp-6;
                        spacing: Theme.sp-4;
                        alignment: start;

                        // Section header
                        HorizontalLayout {
                            spacing: Theme.sp-2;
                            Rectangle {
                                width: 3px; height: 14px;
                                border-radius: 1.5px;
                                background: Theme.accent;
                                drop-shadow-blur: 4px;
                                drop-shadow-color: Theme.accent-glow;
                            }
                            Text {
                                text: "NETWORK";
                                color: Theme.accent;
                                font-size: Theme.fs-caption;
                                font-weight: 600;
                                letter-spacing: 3px;
                                vertical-alignment: center;
                            }
                        }

                        Rectangle {
                            background: Theme.bg-card;
                            border-radius: Theme.r-lg;
                            border-width: 1px;
                            border-color: Theme.border-subtle;
                            height: net-layout.preferred-height;

                            net-layout := VerticalLayout {
                                padding: Theme.sp-4;
                                spacing: Theme.sp-3;

                                HorizontalLayout {
                                    Text {
                                        text: "WiFi";
                                        color: Theme.text-secondary;
                                        font-size: Theme.fs-body;
                                        horizontal-stretch: 1;
                                    }
                                    Text {
                                        text: root.wifi-connected
                                            ? (root.wifi-ssid != "" ? root.wifi-ssid : "Connected")
                                            : "Disconnected";
                                        color: root.wifi-connected ? Theme.accent : Theme.text-dim;
                                        font-size: Theme.fs-body;
                                    }
                                }

                                Rectangle { height: 1px; background: Theme.border-subtle; }

                                HorizontalLayout {
                                    Text {
                                        text: "IP address";
                                        color: Theme.text-secondary;
                                        font-size: Theme.fs-body;
                                        horizontal-stretch: 1;
                                    }
                                    Text {
                                        text: root.ip-address != "" ? root.ip-address : "\u{2014}";
                                        color: Theme.text-primary;
                                        font-size: Theme.fs-body;
                                    }
                                }
                            }
                        }

                        // Bottom spacer
                        Rectangle { height: 40px; }
                    }
                }

                // ===== CATEGORY 5: PRIVACY & SECURITY =====
                if root.active-category == 5 : Flickable {
                    width: 100%;
                    height: 100%;

                    VerticalLayout {
                        padding: Theme.sp-6;
                        spacing: Theme.sp-4;
                        alignment: start;

                        // Section header
                        HorizontalLayout {
                            spacing: Theme.sp-2;
                            Rectangle {
                                width: 3px; height: 14px;
                                border-radius: 1.5px;
                                background: Theme.color-emotional;
                                drop-shadow-blur: 4px;
                                drop-shadow-color: Theme.color-danger-dim;
                            }
                            Text {
                                text: "SECURITY & PRIVACY";
                                color: Theme.color-emotional;
                                font-size: Theme.fs-caption;
                                font-weight: 600;
                                letter-spacing: 3px;
                                vertical-alignment: center;
                            }
                        }

                        Rectangle {
                            background: Theme.bg-card;
                            border-radius: Theme.r-lg;
                            border-width: 1px;
                            border-color: Theme.border-subtle;
                            height: sec-layout.preferred-height;

                            sec-layout := VerticalLayout {
                                padding: Theme.sp-4;
                                spacing: Theme.sp-3;

                                lock-ta := TouchArea {
                                    height: 24px;
                                    clicked => { root.cycle-auto-lock(); }

                                    HorizontalLayout {
                                        Text {
                                            text: "Auto-lock";
                                            color: Theme.text-secondary;
                                            font-size: Theme.fs-body;
                                            horizontal-stretch: 1;
                                        }
                                        Rectangle {
                                            width: lock-tag.preferred-width + 16px;
                                            height: 24px;
                                            border-radius: Theme.r-lg;
                                            background: lock-ta.has-hover ? Theme.hover-fill-strong : Theme.hover-fill;
                                            border-width: 1px;
                                            border-color: Theme.border-subtle;

                                            lock-tag := Text {
                                                text: root.auto-lock-secs == 0 ? "Never"
                                                    : (root.auto-lock-secs >= 60
                                                        ? Math.floor(root.auto-lock-secs / 60) + " min"
                                                        : root.auto-lock-secs + " sec");
                                                color: Theme.text-primary;
                                                font-size: Theme.fs-micro;
                                                font-weight: 500;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                }

                                Rectangle { height: 1px; background: Theme.border-subtle; }

                                HorizontalLayout {
                                    Text {
                                        text: "PIN lock";
                                        color: Theme.text-secondary;
                                        font-size: Theme.fs-body;
                                        horizontal-stretch: 1;
                                    }
                                    // Active indicator with glow
                                    Rectangle {
                                        width: 8px; height: 8px;
                                        y: (parent.height - 8px) / 2;
                                        border-radius: 4px;
                                        background: Theme.color-reminder;
                                        drop-shadow-blur: 4px;
                                        drop-shadow-color: Theme.color-success-dim;
                                    }
                                    Text {
                                        text: " Enabled";
                                        color: Theme.color-reminder;
                                        font-size: Theme.fs-body;
                                    }
                                }

                                Rectangle { height: 1px; background: Theme.border-subtle; }

                                incognito-ta := TouchArea {
                                    height: 24px;
                                    clicked => { root.toggle-incognito-mode(); }

                                    HorizontalLayout {
                                        Text {
                                            text: "Incognito";
                                            color: Theme.text-secondary;
                                            font-size: Theme.fs-body;
                                            horizontal-stretch: 1;
                                        }
                                        Rectangle {
                                            width: incognito-tag.preferred-width + 16px;
                                            height: 24px;
                                            border-radius: Theme.r-lg;
                                            background: root.incognito-mode ? Theme.color-emotional : (incognito-ta.has-hover ? Theme.hover-fill-strong : Theme.hover-fill);
                                            border-width: 1px;
                                            border-color: root.incognito-mode ? Theme.color-emotional : Theme.border-subtle;
                                            drop-shadow-blur: root.incognito-mode ? 6px : 0;
                                            drop-shadow-color: root.incognito-mode ? Theme.color-danger-dim : transparent;

                                            incognito-tag := Text {
                                                text: root.incognito-mode ? "ON" : "OFF";
                                                color: root.incognito-mode ? Theme.text-on-accent : Theme.text-primary;
                                                font-size: Theme.fs-micro;
                                                font-weight: 600;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                }

                                Rectangle { height: 1px; background: Theme.border-subtle; }

                                dnd-ta := TouchArea {
                                    height: 24px;
                                    clicked => { root.toggle-dnd-mode(); }

                                    HorizontalLayout {
