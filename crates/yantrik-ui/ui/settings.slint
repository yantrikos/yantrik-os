// Settings panel — holographic system configuration.
// Screen 7. Glassmorphic cards with glowing borders.
// Section headers with scan-line animation.

import { Theme } from "theme.slint";

export component SettingsScreen inherits Rectangle {
    background: Theme.bg-deep;

    // Account
    in property <string> user-name: "";
    in property <string> companion-name: "Yantrik";

    // AI Model
    in property <string> model-name: "";
    in property <int> max-context: 4096;
    in property <int> max-tokens: 512;
    in property <string> tool-permission: "sensitive";

    // Security
    in property <int> auto-lock-secs: 300;

    // Network
    in property <bool> wifi-connected: false;
    in property <string> wifi-ssid: "";
    in property <string> ip-address: "";

    // Display
    in property <string> display-resolution: "";

    // LLM Backend
    in property <string> llm-backend: "candle";
    in property <string> llm-api-url: "";
    in property <string> llm-api-model: "";

    // System info
    in property <int> memory-count: 0;
    in property <string> version-text: "0.1.0";
    in property <int> notification-count: 0;

    // Appearance
    in-out property <bool> dark-mode: true;
    callback toggle-dark-mode();

    // Interactive settings
    callback cycle-tool-permission();
    callback cycle-auto-lock();

    callback back-pressed();
    callback navigate-to(int);

    // Ambient glow phase
    property <float> glow-phase: 0;
    Timer {
        interval: 16ms;
        running: true;
        triggered => {
            glow-phase = mod(glow-phase + 0.0015, 1.0);
        }
    }

    // Background nebula wash
    Rectangle {
        x: parent.width * 0.5;
        y: -parent.height * 0.1;
        width: 600px;
        height: 500px;
        background: @radial-gradient(circle,
            #5ac8d406 0%,
            transparent 60%
        );
    }

    VerticalLayout {
        spacing: 0px;

        // Header — glassmorphic
        Rectangle {
            height: 56px;
            background: @linear-gradient(180deg,
                #12111aa0 0%,
                #0c0b1080 100%
            );

            // Bottom glow
            Rectangle {
                y: parent.height - 1px;
                width: 100%;
                height: 1px;
                background: @linear-gradient(90deg,
                    transparent 10%,
                    Theme.cyan-glow 50%,
                    transparent 90%
                );
                opacity: 0.3;
            }

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                alignment: start;
                spacing: 12px;

                TouchArea {
                    width: Theme.touch-target;
                    height: Theme.touch-target;
                    clicked => { root.back-pressed(); }
                    Text {
                        text: "\u{2190}";
                        color: Theme.text-secondary;
                        font-size: 22px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Text {
                    text: "Settings";
                    color: Theme.text-primary;
                    font-size: Theme.font-title;
                    font-weight: 600;
                    letter-spacing: 1px;
                    vertical-alignment: center;
                }
            }
        }

        // Scrollable content
        Flickable {
            vertical-stretch: 1;

            VerticalLayout {
                padding: 20px;
                spacing: 16px;
                alignment: start;

                // ===== APPEARANCE =====
                HorizontalLayout {
                    spacing: 8px;
                    Rectangle {
                        width: 3px;
                        height: 14px;
                        y: 0;
                        border-radius: 1.5px;
                        background: Theme.cyan;
                        drop-shadow-blur: 4px;
                        drop-shadow-color: Theme.cyan-glow;
                    }
                    Text {
                        text: "APPEARANCE";
                        color: Theme.cyan;
                        font-size: 10px;
                        font-weight: 600;
                        letter-spacing: 3px;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    background: @linear-gradient(135deg, #12111a80 0%, #0c0b1060 100%);
                    border-radius: Theme.radius-card;
                    border-width: 1px;
                    border-color: #ffffff08;
                    height: 52px;

                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 16px;

                        Text {
                            text: "Theme";
                            color: Theme.text-secondary;
                            font-size: Theme.font-body;
                            horizontal-stretch: 1;
                            vertical-alignment: center;
                        }

                        // Pill toggle: Dark / Light — holographic
                        TouchArea {
                            width: 110px;
                            height: 36px;
                            clicked => { root.toggle-dark-mode(); }

                            Rectangle {
                                width: 110px;
                                height: 32px;
                                y: (parent.height - self.height) / 2;
                                border-radius: 16px;
                                background: #0808100a;
                                border-width: 1px;
                                border-color: root.dark-mode ? Theme.cyan-dim : Theme.amber-dim;

                                // Sliding pill indicator
                                Rectangle {
                                    x: root.dark-mode ? 2px : 56px;
                                    y: 2px;
                                    width: 52px;
                                    height: 28px;
                                    border-radius: 14px;
                                    background: root.dark-mode ? Theme.cyan-dim : Theme.amber-dim;
                                    drop-shadow-blur: 6px;
                                    drop-shadow-color: root.dark-mode ? Theme.cyan-glow : Theme.amber-glow;

                                    animate x { duration: 150ms; easing: ease-out; }
                                    animate background { duration: 150ms; }
                                    animate drop-shadow-color { duration: 150ms; }
                                }

                                HorizontalLayout {
                                    Rectangle {
                                        width: 55px;
                                        Text {
                                            text: "Dark";
                                            color: root.dark-mode ? Theme.cyan : Theme.text-dim;
                                            font-size: 11px;
                                            font-weight: root.dark-mode ? 600 : 400;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                            animate color { duration: 150ms; }
                                        }
                                    }
                                    Rectangle {
                                        width: 55px;
                                        Text {
                                            text: "Light";
                                            color: root.dark-mode ? Theme.text-dim : Theme.amber;
                                            font-size: 11px;
                                            font-weight: root.dark-mode ? 400 : 600;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                            animate color { duration: 150ms; }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                // ===== ACCOUNT =====
                HorizontalLayout {
                    spacing: 8px;
                    Rectangle {
                        width: 3px; height: 14px;
                        border-radius: 1.5px;
                        background: Theme.amber;
                        drop-shadow-blur: 4px;
                        drop-shadow-color: Theme.amber-glow;
                    }
                    Text {
                        text: "ACCOUNT";
                        color: Theme.amber;
                        font-size: 10px;
                        font-weight: 600;
                        letter-spacing: 3px;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    background: @linear-gradient(135deg, #12111a80 0%, #0c0b1060 100%);
                    border-radius: Theme.radius-card;
                    border-width: 1px;
                    border-color: #ffffff08;
                    height: acct-layout.preferred-height;

                    acct-layout := VerticalLayout {
                        padding: 16px;
                        spacing: 12px;

                        HorizontalLayout {
                            Text {
                                text: "User";
                                color: Theme.text-secondary;
                                font-size: Theme.font-body;
                                horizontal-stretch: 1;
                            }
                            Text {
                                text: root.user-name;
                                color: Theme.text-primary;
                                font-size: Theme.font-body;
                            }
                        }

                        Rectangle { height: 1px; background: #ffffff08; }

                        HorizontalLayout {
                            Text {
                                text: "Companion";
                                color: Theme.text-secondary;
                                font-size: Theme.font-body;
                                horizontal-stretch: 1;
                            }
                            Text {
                                text: root.companion-name;
                                color: Theme.amber;
                                font-size: Theme.font-body;
                                font-weight: 500;
                            }
                        }
                    }
                }

                // ===== AI MODEL =====
                HorizontalLayout {
                    spacing: 8px;
                    Rectangle {
                        width: 3px; height: 14px;
                        border-radius: 1.5px;
                        background: Theme.holo-blue;
                        drop-shadow-blur: 4px;
                        drop-shadow-color: Theme.holo-blue-glow;
                    }
                    Text {
                        text: "AI MODEL";
                        color: Theme.holo-blue;
                        font-size: 10px;
                        font-weight: 600;
                        letter-spacing: 3px;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    background: @linear-gradient(135deg, #12111a80 0%, #0c0b1060 100%);
                    border-radius: Theme.radius-card;
                    border-width: 1px;
                    border-color: #ffffff08;
                    height: model-layout.preferred-height;

                    model-layout := VerticalLayout {
                        padding: 16px;
                        spacing: 12px;

                        HorizontalLayout {
                            Text {
                                text: "Backend";
                                color: Theme.text-secondary;
                                font-size: Theme.font-body;
                                horizontal-stretch: 1;
                            }
                            Rectangle {
                                width: backend-tag.preferred-width + 16px;
                                height: 24px;
                                border-radius: 12px;
                                background: root.llm-backend == "api" ? Theme.tint-cyan : Theme.tint-amber;
                                border-width: 1px;
                                border-color: root.llm-backend == "api" ? Theme.cyan-dim : Theme.amber-dim;

                                backend-tag := Text {
                                    text: root.llm-backend == "api" ? "API" : "Candle";
                                    color: root.llm-backend == "api" ? Theme.cyan : Theme.amber;
                                    font-size: 11px;
                                    font-weight: 600;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        Rectangle { height: 1px; background: #ffffff08; }

                        HorizontalLayout {
                            Text {
                                text: "Model";
                                color: Theme.text-secondary;
                                font-size: Theme.font-body;
                                horizontal-stretch: 1;
                            }
                            Text {
                                text: root.llm-backend == "api" && root.llm-api-model != ""
                                    ? root.llm-api-model : root.model-name;
                                color: Theme.cyan;
                                font-size: Theme.font-small;
                            }
                        }

                        if root.llm-backend == "api" && root.llm-api-url != "" : Rectangle { height: 1px; background: #ffffff08; }
                        if root.llm-backend == "api" && root.llm-api-url != "" : HorizontalLayout {
                            Text {
                                text: "Endpoint";
                                color: Theme.text-secondary;
                                font-size: Theme.font-body;
                                horizontal-stretch: 1;
                            }
                            Text {
                                text: root.llm-api-url;
                                color: Theme.text-dim;
                                font-size: 11px;
                            }
                        }

                        Rectangle { height: 1px; background: #ffffff08; }

                        HorizontalLayout {
                            Text {
                                text: "Context window";
                                color: Theme.text-secondary;
                                font-size: Theme.font-body;
                                horizontal-stretch: 1;
                            }
                            Text {
                                text: root.max-context + " tokens";
                                color: Theme.text-primary;
                                font-size: Theme.font-body;
                            }
                        }

                        Rectangle { height: 1px; background: #ffffff08; }

                        HorizontalLayout {
                            Text {
                                text: "Max output";
                                color: Theme.text-secondary;
                                font-size: Theme.font-body;
                                horizontal-stretch: 1;
                            }
                            Text {
                                text: root.max-tokens + " tokens";
                                color: Theme.text-primary;
                                font-size: Theme.font-body;
                            }
                        }

                        Rectangle { height: 1px; background: #ffffff08; }

                        perm-ta := TouchArea {
                            height: 24px;
                            clicked => { root.cycle-tool-permission(); }

                            HorizontalLayout {
                                Text {
                                    text: "Tool permission";
                                    color: Theme.text-secondary;
                                    font-size: Theme.font-body;
                                    horizontal-stretch: 1;
                                }
                                Rectangle {
                                    width: perm-tag.preferred-width + 16px;
                                    height: 24px;
                                    border-radius: 12px;
                                    background: root.tool-permission == "safe" ? Theme.tint-cyan
                                        : (root.tool-permission == "standard" ? Theme.tint-amber
                                        : #e86b6b18);
                                    border-width: 1px;
                                    border-color: root.tool-permission == "safe" ? Theme.cyan-dim
                                        : (root.tool-permission == "standard" ? Theme.amber-dim
                                        : #e86b6b40);

                                    perm-tag := Text {
                                        text: root.tool-permission == "safe" ? "Safe"
                                            : (root.tool-permission == "standard" ? "Standard"
                                            : "Sensitive");
                                        color: root.tool-permission == "safe" ? Theme.cyan
                                            : (root.tool-permission == "standard" ? Theme.amber
                                            : Theme.color-emotional);
                                        font-size: 11px;
                                        font-weight: 600;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }

                // ===== NETWORK =====
                HorizontalLayout {
                    spacing: 8px;
                    Rectangle {
                        width: 3px; height: 14px;
                        border-radius: 1.5px;
                        background: Theme.cyan;
                        drop-shadow-blur: 4px;
                        drop-shadow-color: Theme.cyan-glow;
                    }
                    Text {
                        text: "NETWORK";
                        color: Theme.cyan;
                        font-size: 10px;
                        font-weight: 600;
                        letter-spacing: 3px;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    background: @linear-gradient(135deg, #12111a80 0%, #0c0b1060 100%);
                    border-radius: Theme.radius-card;
                    border-width: 1px;
                    border-color: #ffffff08;
                    height: net-layout.preferred-height;

                    net-layout := VerticalLayout {
                        padding: 16px;
                        spacing: 12px;

                        HorizontalLayout {
                            Text {
                                text: "WiFi";
                                color: Theme.text-secondary;
                                font-size: Theme.font-body;
                                horizontal-stretch: 1;
                            }
                            Text {
                                text: root.wifi-connected
                                    ? (root.wifi-ssid != "" ? root.wifi-ssid : "Connected")
                                    : "Disconnected";
                                color: root.wifi-connected ? Theme.cyan : Theme.text-dim;
                                font-size: Theme.font-body;
                            }
                        }

                        Rectangle { height: 1px; background: #ffffff08; }

                        HorizontalLayout {
                            Text {
                                text: "IP address";
                                color: Theme.text-secondary;
                                font-size: Theme.font-body;
                                horizontal-stretch: 1;
                            }
                            Text {
                                text: root.ip-address != "" ? root.ip-address : "\u{2014}";
                                color: Theme.text-primary;
                                font-size: Theme.font-body;
                            }
                        }
                    }
                }

                // ===== DISPLAY =====
                HorizontalLayout {
                    spacing: 8px;
                    Rectangle {
                        width: 3px; height: 14px;
                        border-radius: 1.5px;
                        background: Theme.color-pattern;
                        drop-shadow-blur: 4px;
                        drop-shadow-color: #c48bd440;
                    }
                    Text {
                        text: "DISPLAY";
                        color: Theme.color-pattern;
                        font-size: 10px;
                        font-weight: 600;
                        letter-spacing: 3px;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    background: @linear-gradient(135deg, #12111a80 0%, #0c0b1060 100%);
                    border-radius: Theme.radius-card;
                    border-width: 1px;
                    border-color: #ffffff08;
                    height: disp-layout.preferred-height;

                    disp-layout := VerticalLayout {
                        padding: 16px;
                        spacing: 12px;

                        HorizontalLayout {
                            Text {
                                text: "Resolution";
                                color: Theme.text-secondary;
                                font-size: Theme.font-body;
                                horizontal-stretch: 1;
                            }
                            Text {
                                text: root.display-resolution != "" ? root.display-resolution : "auto";
                                color: Theme.text-primary;
                                font-size: Theme.font-body;
                            }
                        }
                    }
                }

                // ===== SECURITY =====
                HorizontalLayout {
                    spacing: 8px;
                    Rectangle {
                        width: 3px; height: 14px;
                        border-radius: 1.5px;
                        background: Theme.color-emotional;
                        drop-shadow-blur: 4px;
                        drop-shadow-color: #e86b6b40;
                    }
                    Text {
                        text: "SECURITY";
                        color: Theme.color-emotional;
                        font-size: 10px;
                        font-weight: 600;
                        letter-spacing: 3px;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    background: @linear-gradient(135deg, #12111a80 0%, #0c0b1060 100%);
                    border-radius: Theme.radius-card;
                    border-width: 1px;
                    border-color: #ffffff08;
                    height: sec-layout.preferred-height;

                    sec-layout := VerticalLayout {
                        padding: 16px;
                        spacing: 12px;

                        lock-ta := TouchArea {
                            height: 24px;
                            clicked => { root.cycle-auto-lock(); }

                            HorizontalLayout {
                                Text {
                                    text: "Auto-lock";
                                    color: Theme.text-secondary;
                                    font-size: Theme.font-body;
                                    horizontal-stretch: 1;
                                }
                                Rectangle {
                                    width: lock-tag.preferred-width + 16px;
                                    height: 24px;
                                    border-radius: 12px;
                                    background: lock-ta.has-hover ? Theme.hover-fill-strong : Theme.hover-fill;
                                    border-width: 1px;
                                    border-color: Theme.border-subtle;

                                    lock-tag := Text {
                                        text: root.auto-lock-secs == 0 ? "Never"
                                            : (root.auto-lock-secs >= 60
                                                ? Math.floor(root.auto-lock-secs / 60) + " min"
                                                : root.auto-lock-secs + " sec");
                                        color: Theme.text-primary;
                                        font-size: 11px;
                                        font-weight: 500;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }

                        Rectangle { height: 1px; background: #ffffff08; }

                        HorizontalLayout {
                            Text {
                                text: "PIN lock";
                                color: Theme.text-secondary;
                                font-size: Theme.font-body;
                                horizontal-stretch: 1;
                            }
                            // Active indicator with glow
                            Rectangle {
                                width: 8px; height: 8px;
                                y: (parent.height - 8px) / 2;
                                border-radius: 4px;
                                background: Theme.color-reminder;
                                drop-shadow-blur: 4px;
                                drop-shadow-color: #8be86b40;
                            }
                            Text {
                                text: " Enabled";
                                color: Theme.color-reminder;
                                font-size: Theme.font-body;
                            }
                        }
                    }
                }

                // ===== COMPANION =====
                HorizontalLayout {
                    spacing: 8px;
                    Rectangle {
                        width: 3px; height: 14px;
                        border-radius: 1.5px;
                        background: Theme.amber;
                        drop-shadow-blur: 4px;
                        drop-shadow-color: Theme.amber-glow;
                    }
                    Text {
                        text: "COMPANION";
                        color: Theme.amber;
                        font-size: 10px;
                        font-weight: 600;
                        letter-spacing: 3px;
                        vertical-alignment: center;
                    }
                }

                // Bond link — glassmorphic nav card
                Rectangle {
                    background: @linear-gradient(135deg, #12111a80 0%, #0c0b1060 100%);
                    border-radius: Theme.radius-card;
                    border-width: 1px;
                    border-color: #ffffff08;
                    height: 52px;

                    TouchArea {
                        clicked => { root.navigate-to(4); }
                    }

                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 16px;

                        Text {
                            text: "Bond";
                            color: Theme.text-primary;
                            font-size: Theme.font-body;
                            horizontal-stretch: 1;
                            vertical-alignment: center;
                        }
                        Text {
                            text: "\u{2192}";
                            color: Theme.cyan-dim;
                            font-size: 18px;
                            vertical-alignment: center;
                        }
                    }
                }

                // Personality link
                Rectangle {
                    background: @linear-gradient(135deg, #12111a80 0%, #0c0b1060 100%);
                    border-radius: Theme.radius-card;
                    border-width: 1px;
                    border-color: #ffffff08;
                    height: 52px;

                    TouchArea {
                        clicked => { root.navigate-to(5); }
                    }

                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 16px;

                        Text {
                            text: "Personality";
                            color: Theme.text-primary;
                            font-size: Theme.font-body;
                            horizontal-stretch: 1;
                            vertical-alignment: center;
                        }
                        Text {
                            text: "\u{2192}";
                            color: Theme.cyan-dim;
                            font-size: 18px;
                            vertical-alignment: center;
                        }
                    }
                }

                // Memory browser link
                Rectangle {
                    background: @linear-gradient(135deg, #12111a80 0%, #0c0b1060 100%);
                    border-radius: Theme.radius-card;
                    border-width: 1px;
                    border-color: #ffffff08;
                    height: 52px;

                    TouchArea {
                        clicked => { root.navigate-to(6); }
                    }

                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 16px;

                        Text {
                            text: "Memory Browser";
                            color: Theme.text-primary;
                            font-size: Theme.font-body;
                            horizontal-stretch: 1;
                            vertical-alignment: center;
                        }
                        Rectangle {
                            width: mem-count-txt.preferred-width + 14px;
                            height: 20px;
                            y: (parent.height - 20px) / 2;
                            border-radius: 10px;
                            background: Theme.tint-amber;

                            mem-count-txt := Text {
                                text: root.memory-count;
                                color: Theme.amber;
                                font-size: 10px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        Text {
                            text: "  \u{2192}";
                            color: Theme.cyan-dim;
                            font-size: 18px;
                            vertical-alignment: center;
                        }
                    }
                }

                // ===== SYSTEM =====
                HorizontalLayout {
                    spacing: 8px;
                    Rectangle {
                        width: 3px; height: 14px;
                        border-radius: 1.5px;
                        background: Theme.color-follow-up;
                        drop-shadow-blur: 4px;
                        drop-shadow-color: #6bb8e840;
                    }
                    Text {
                        text: "SYSTEM";
                        color: Theme.color-follow-up;
                        font-size: 10px;
                        font-weight: 600;
                        letter-spacing: 3px;
                        vertical-alignment: center;
                    }
                }

                // Notifications link
                Rectangle {
                    background: @linear-gradient(135deg, #12111a80 0%, #0c0b1060 100%);
                    border-radius: Theme.radius-card;
                    border-width: 1px;
                    border-color: #ffffff08;
                    height: 52px;

                    TouchArea {
                        clicked => { root.navigate-to(9); }
                    }

                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 16px;

                        Text {
                            text: "Notifications";
                            color: Theme.text-primary;
                            font-size: Theme.font-body;
                            horizontal-stretch: 1;
                            vertical-alignment: center;
                        }
                        if root.notification-count > 0 : Rectangle {
                            width: max(22px, notif-count-text.preferred-width + 12px);
                            height: 20px;
                            y: (parent.height - 20px) / 2;
                            border-radius: 10px;
                            background: Theme.amber-dim;
                            drop-shadow-blur: 4px;
                            drop-shadow-color: Theme.amber-glow;

                            notif-count-text := Text {
                                text: root.notification-count;
                                color: Theme.bg-deep;
                                font-size: 10px;
                                font-weight: 700;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        Text {
                            text: "  \u{2192}";
                            color: Theme.cyan-dim;
                            font-size: 18px;
                            vertical-alignment: center;
                        }
                    }
                }

                // System Dashboard link
                Rectangle {
                    background: @linear-gradient(135deg, #12111a80 0%, #0c0b1060 100%);
                    border-radius: Theme.radius-card;
                    border-width: 1px;
                    border-color: #ffffff08;
                    height: 52px;

                    TouchArea {
                        clicked => { root.navigate-to(10); }
                    }

                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 16px;

                        Text {
                            text: "System Monitor";
                            color: Theme.text-primary;
                            font-size: Theme.font-body;
                            horizontal-stretch: 1;
                            vertical-alignment: center;
                        }
                        Text {
                            text: "\u{2192}";
                            color: Theme.cyan-dim;
                            font-size: 18px;
                            vertical-alignment: center;
                        }
                    }
                }

                // ===== ABOUT =====
                HorizontalLayout {
                    spacing: 8px;
                    Rectangle {
                        width: 3px; height: 14px;
                        border-radius: 1.5px;
                        background: Theme.text-dim;
                    }
                    Text {
                        text: "ABOUT";
                        color: Theme.text-dim;
                        font-size: 10px;
                        font-weight: 600;
                        letter-spacing: 3px;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    background: @linear-gradient(135deg, #12111a80 0%, #0c0b1060 100%);
                    border-radius: Theme.radius-card;
                    border-width: 1px;
                    border-color: #ffffff08;
                    height: about-layout.preferred-height;

                    about-layout := VerticalLayout {
                        padding: 16px;
                        spacing: 12px;

                        HorizontalLayout {
                            // Logo text with glow
                            Text {
                                text: "Yantrik OS";
                                color: Theme.amber;
                                font-size: Theme.font-body;
                                font-weight: 700;
                                letter-spacing: 1px;
                                horizontal-stretch: 1;
                            }
                            Rectangle {
                                width: ver-text.preferred-width + 14px;
                                height: 22px;
                                border-radius: 11px;
                                background: Theme.tint-cyan;
                                border-width: 1px;
                                border-color: Theme.cyan-dim;

                                ver-text := Text {
                                    text: "v" + root.version-text;
                                    color: Theme.cyan;
                                    font-size: 10px;
                                    font-weight: 600;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        Rectangle { height: 1px; background: #ffffff08; }

                        Text {
                            text: "AI-native desktop shell. The AI IS the shell.";
                            color: Theme.text-dim;
                            font-size: Theme.font-small;
                            wrap: word-wrap;
                        }
                    }
                }

                // Bottom spacer
                Rectangle {
                    height: 40px;
                }
            }
        }
    }
}
