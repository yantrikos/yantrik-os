// Quick Settings — glassmorphic slide-down panel.
// Holographic WiFi toggle, glowing sliders, battery visualization.

import { Theme } from "../theme.slint";

export component QuickSettings inherits Rectangle {
    in-out property <bool> is-open: false;
    in property <int> battery-level: 100;
    in property <bool> battery-charging: false;
    in property <bool> wifi-connected: false;
    in property <string> wifi-ssid: "";
    in-out property <int> brightness-level: 80;
    in-out property <int> volume-level: 50;

    callback toggle-wifi();
    callback brightness-changed(int);
    callback volume-changed(int);
    callback close();

    width: 100%;
    height: 100%;

    // Backdrop (click to close)
    if root.is-open : TouchArea {
        width: 100%;
        height: 100%;
        clicked => { root.is-open = false; root.close(); }

        Rectangle {
            width: 100%;
            height: 100%;
            background: Theme.overlay-backdrop;
        }
    }

    // Panel — glassmorphic, slides down from status bar
    if root.is-open : Rectangle {
        x: (parent.width - 380px) / 2;
        y: Theme.status-bar-height;
        width: 380px;
        height: qs-content.preferred-height;
        border-radius: 0px;
        border-bottom-left-radius: 20px;
        border-bottom-right-radius: 20px;
        clip: true;

        // Glass background
        background: @linear-gradient(180deg,
            #12111ae0 0%,
            #0c0b10d0 50%,
            #080810c0 100%
        );

        // Glass border
        border-width: 1px;
        border-color: @linear-gradient(180deg,
            #ffffff14 0%,
            #ffffff08 100%
        );

        drop-shadow-blur: 32px;
        drop-shadow-color: #00000060;

        // Bottom holographic edge
        Rectangle {
            y: parent.height - 1px;
            width: 100%;
            height: 1px;
            background: @linear-gradient(90deg,
                transparent 10%,
                Theme.cyan-glow 50%,
                transparent 90%
            );
            opacity: 0.4;
        }

        qs-content := VerticalLayout {
            padding: 20px;
            spacing: 16px;

            // -- WiFi toggle --
            HorizontalLayout {
                spacing: 14px;

                TouchArea {
                    width: 68px;
                    height: 56px;
                    clicked => { root.toggle-wifi(); }

                    Rectangle {
                        width: 100%;
                        height: 100%;
                        border-radius: 14px;
                        background: root.wifi-connected
                            ? @linear-gradient(135deg, #5ac8d418 0%, #5ac8d408 100%)
                            : @linear-gradient(135deg, #12111a 0%, #0c0b10 100%);
                        border-width: 1px;
                        border-color: root.wifi-connected ? Theme.cyan-dim : #ffffff08;
                        drop-shadow-blur: root.wifi-connected ? 8px : 0;
                        drop-shadow-color: Theme.cyan-glow;

                        VerticalLayout {
                            alignment: center;
                            spacing: 3px;

                            // WiFi icon (concentric arcs)
                            Rectangle {
                                width: 22px; height: 18px;
                                x: (parent.width - 22px) / 2;
                                background: transparent;

                                Rectangle {
                                    x: 3px; y: 0;
                                    width: 16px; height: 16px;
                                    border-radius: 8px;
                                    border-width: 2px;
                                    border-color: root.wifi-connected ? Theme.cyan : Theme.text-dim;
                                    background: transparent;
                                    opacity: root.wifi-connected ? 0.8 : 0.3;
                                }
                                Rectangle {
                                    x: 6px; y: 5px;
                                    width: 10px; height: 10px;
                                    border-radius: 5px;
                                    border-width: 2px;
                                    border-color: root.wifi-connected ? Theme.cyan : Theme.text-dim;
                                    background: transparent;
                                    opacity: root.wifi-connected ? 0.6 : 0.2;
                                }
                                Rectangle {
                                    x: 9px; y: 11px;
                                    width: 4px; height: 4px;
                                    border-radius: 2px;
                                    background: root.wifi-connected ? Theme.cyan : Theme.text-dim;
                                    drop-shadow-blur: root.wifi-connected ? 4px : 0;
                                    drop-shadow-color: Theme.cyan-glow;
                                }
                            }
                            Text {
                                text: "WiFi";
                                color: root.wifi-connected ? Theme.text-primary : Theme.text-dim;
                                font-size: 9px;
                                font-weight: 600;
                                horizontal-alignment: center;
                            }
                        }
                    }
                }

                VerticalLayout {
                    alignment: center;
                    horizontal-stretch: 1;

                    Text {
                        text: root.wifi-connected ?
                              (root.wifi-ssid != "" ? root.wifi-ssid : "Connected") :
                              "Disconnected";
                        color: Theme.text-primary;
                        font-size: Theme.font-body;
                    }
                    Text {
                        text: root.wifi-connected ? "Tap to disconnect" : "Tap to connect";
                        color: Theme.text-dim;
                        font-size: 10px;
                    }
                }
            }

            Rectangle { height: 1px; background: #ffffff08; }

            // -- Brightness slider --
            VerticalLayout {
                spacing: 8px;

                HorizontalLayout {
                    Text {
                        text: "\u{2600} Brightness";
                        color: Theme.text-secondary;
                        font-size: Theme.font-small;
                        horizontal-stretch: 1;
                        vertical-alignment: center;
                    }
                    Text {
                        text: root.brightness-level + "%";
                        color: Theme.amber;
                        font-size: Theme.font-small;
                        font-weight: 600;
                    }
                }

                TouchArea {
                    width: 100%;
                    height: 28px;
                    moved => {
                        if self.pressed {
                            root.brightness-level = max(5, min(100,
                                Math.round(self.mouse-x / self.width * 100)));
                            root.brightness-changed(root.brightness-level);
                        }
                    }
                    clicked => {
                        root.brightness-level = max(5, min(100,
                            Math.round(self.mouse-x / self.width * 100)));
                        root.brightness-changed(root.brightness-level);
                    }

                    Rectangle {
                        y: (parent.height - 6px) / 2;
                        width: 100%;
                        height: 6px;
                        border-radius: 3px;
                        background: #0808100a;

                        Rectangle {
                            width: max(0px, parent.width * root.brightness-level / 100);
                            height: 100%;
                            border-radius: 3px;
                            background: @linear-gradient(90deg, Theme.amber-dim 0%, Theme.amber 100%);
                            drop-shadow-blur: 4px;
                            drop-shadow-color: Theme.amber-glow;
                        }

                        Rectangle {
                            x: max(0px, min(parent.width - 16px,
                                parent.width * root.brightness-level / 100 - 8px));
                            y: -5px;
                            width: 16px;
                            height: 16px;
                            border-radius: 8px;
                            background: Theme.amber;
                            border-width: 2px;
                            border-color: Theme.amber-light;
                            drop-shadow-blur: 8px;
                            drop-shadow-color: Theme.amber-glow;
                        }
                    }
                }
            }

            // -- Volume slider --
            VerticalLayout {
                spacing: 8px;

                HorizontalLayout {
                    Text {
                        text: "\u{266a} Volume";
                        color: Theme.text-secondary;
                        font-size: Theme.font-small;
                        horizontal-stretch: 1;
                        vertical-alignment: center;
                    }
                    Text {
                        text: root.volume-level + "%";
                        color: Theme.cyan;
                        font-size: Theme.font-small;
                        font-weight: 600;
                    }
                }

                TouchArea {
                    width: 100%;
                    height: 28px;
                    moved => {
                        if self.pressed {
                            root.volume-level = max(0, min(100,
                                Math.round(self.mouse-x / self.width * 100)));
                            root.volume-changed(root.volume-level);
                        }
                    }
                    clicked => {
                        root.volume-level = max(0, min(100,
                            Math.round(self.mouse-x / self.width * 100)));
                        root.volume-changed(root.volume-level);
                    }

                    Rectangle {
                        y: (parent.height - 6px) / 2;
                        width: 100%;
                        height: 6px;
                        border-radius: 3px;
                        background: #0808100a;

                        Rectangle {
                            width: max(0px, parent.width * root.volume-level / 100);
                            height: 100%;
                            border-radius: 3px;
                            background: @linear-gradient(90deg, Theme.cyan-dim 0%, Theme.cyan 100%);
                            drop-shadow-blur: 4px;
                            drop-shadow-color: Theme.cyan-glow;
                        }

                        Rectangle {
                            x: max(0px, min(parent.width - 16px,
                                parent.width * root.volume-level / 100 - 8px));
                            y: -5px;
                            width: 16px;
                            height: 16px;
                            border-radius: 8px;
                            background: Theme.cyan;
                            border-width: 2px;
                            border-color: Theme.cyan-light;
                            drop-shadow-blur: 8px;
                            drop-shadow-color: Theme.cyan-glow;
                        }
                    }
                }
            }

            Rectangle { height: 1px; background: #ffffff08; }

            // -- Battery info — holographic --
            HorizontalLayout {
                spacing: 10px;

                // Battery icon with glow fill
                Rectangle {
                    width: 32px;
                    height: 16px;
                    y: (parent.height - 16px) / 2;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: root.battery-level <= 20 ? Theme.color-emotional : Theme.text-dim;

                    Rectangle {
                        x: 2px; y: 2px;
                        width: max(0px, (parent.width - 6px) * root.battery-level / 100);
                        height: parent.height - 6px;
                        border-radius: 2px;
                        background: root.battery-charging ? Theme.cyan :
                                    root.battery-level <= 20 ? Theme.color-emotional :
                                    root.battery-level <= 50 ? Theme.amber : Theme.cyan;
                        drop-shadow-blur: 4px;
                        drop-shadow-color: root.battery-charging ? Theme.cyan-glow :
                                           root.battery-level <= 20 ? #e86b6b40 :
                                           Theme.amber-glow;
                    }

                    Rectangle {
                        x: parent.width;
                        y: 4px;
                        width: 2px;
                        height: parent.height - 8px;
                        border-radius: 1px;
                        background: Theme.text-dim;
                        opacity: 0.5;
                    }
                }

                Text {
                    text: root.battery-level + "%" +
                          (root.battery-charging ? " \u{2014} Charging" : "");
                    color: root.battery-level <= 20 ? Theme.color-emotional : Theme.text-primary;
                    font-size: Theme.font-body;
                    horizontal-stretch: 1;
                    vertical-alignment: center;
                }
            }
        }
    }
}
