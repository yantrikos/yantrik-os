// Intent Lens — the primary interaction primitive of Yantrik OS.
// Centered 720px panel. Single input + unified ranked result feed.
// Replaces chat panel, app launcher, search, and settings access.
//
// States:
//   closed → open (input + results) → chat (multi-turn conversation)
//
// Invoke: Super key or click anchor dot / orb.
// Dismiss: Escape or click outside.

import { Theme } from "../theme.slint";
import { MessageData, MessageBubble } from "message_bubble.slint";
import { ListView } from "std-widgets.slint";

// A single result in the Intent Feed.
export struct LensResult {
    result-type: string,     // "do", "find", "ask", "memory", "setting", "tool",
                             // "clipboard", "divider", "context", "recent", "answer"
    title: string,           // Main display text
    subtitle: string,        // "Why" rationale line
    icon-char: string,       // Single-char badge
    action-id: string,       // Identifier for callback
    score: float,            // 0.0-1.0 ranking confidence
    is-loading: bool,        // When true, render as skeleton shimmer
    inline-value: string,    // For "answer" type: computed value shown prominently
}

export component IntentLens inherits Rectangle {
    in property <bool> is-open: false;
    in property <bool> is-thinking: false;
    in property <[LensResult]> results: [];
    in property <string> companion-status: "idle";
    in property <bool> companion-online: true;

    // Contextual suggestions (shown when query is empty)
    in property <[LensResult]> suggestions: [];
    in property <[LensResult]> recents: [];

    // Chat mode (multi-turn conversation within the Lens)
    in property <bool> chat-mode: false;
    in property <[MessageData]> messages: [];
    in property <bool> is-generating: false;

    // Callbacks
    callback query-changed(string);
    callback submit-query(string);
    callback result-selected(string);    // action-id
    callback close-lens();
    callback send-message(string);
    callback mic-pressed();

    // Internal state
    in-out property <string> input-text: "";
    in-out property <int> selected-index: 0;   // keyboard-navigable cursor

    // Right-side panel — no full-screen overlay, desktop stays visible
    width: 100%;
    height: 100%;
    background: transparent;

    // Holographic scan phase
    property <float> lens-glow-phase: 0;
    Timer {
        interval: 16ms;
        running: root.is-open;
        triggered => {
            lens-glow-phase = mod(lens-glow-phase + 0.003, 1.0);
        }
    }

    // Click-outside area (left side only, not covering the panel)
    // Wrapped in `if` so the TouchArea is removed from the tree when closed,
    // preventing it from swallowing clicks meant for the dock/desktop.
    if root.is-open : TouchArea {
        x: 0;
        y: 0;
        width: root.width - Theme.chat-panel-width;
        height: root.height;
        clicked => { root.close-lens(); }
    }

    // The Lens panel — right-docked glassmorphic side panel
    Rectangle {
        x: root.is-open ? root.width - Theme.chat-panel-width : root.width;
        y: 0;
        width: Theme.chat-panel-width;
        height: root.height;
        border-radius: 0;
        clip: true;
        visible: root.is-open;

        animate x { duration: 200ms; easing: ease-out; }

        // Glass background — semi-transparent for side panel
        background: @linear-gradient(180deg,
            Theme.bg-deep.transparentize(9%) 0%,
            Theme.bg-deep.transparentize(12%) 50%,
            Theme.bg-deep.transparentize(9%) 100%
        );

        // Left edge glow (panel border)
        Rectangle {
            x: 0; y: 0;
            width: 1px;
            height: 100%;
            background: @linear-gradient(180deg,
                Theme.cyan-glow 0%,
                Theme.cyan.transparentize(87%) 30%,
                Theme.amber.transparentize(87%) 70%,
                Theme.cyan-glow 100%
            );
        }

        // Deep shadow on left side
        drop-shadow-blur: 30px;
        drop-shadow-color: Theme.overlay-backdrop;
        drop-shadow-offset-x: -8px;

        // Block click-through to the outside TouchArea
        TouchArea { width: 100%; height: 100%; }

        lens-content := VerticalLayout {
            padding: 0;

            // ── Input area ──
            Rectangle {
                height: Theme.lens-input-height;
                background: Theme.bg-surface;

                HorizontalLayout {
                    padding-left: 20px;
                    padding-right: 16px;
                    spacing: 12px;

                    // Thinking indicator / search icon
                    Rectangle {
                        width: 20px;
                        height: 20px;
                        y: (parent.height - 20px) / 2;

                        // Search circle
                        Rectangle {
                            width: 14px;
                            height: 14px;
                            border-radius: 7px;
                            border-width: 2px;
                            border-color: root.is-thinking ? Theme.amber : Theme.text-dim;
                            background: transparent;

                            animate border-color { duration: 300ms; }
                        }

                        // Search handle
                        Rectangle {
                            x: 12px;
                            y: 12px;
                            width: 6px;
                            height: 2px;
                            background: root.is-thinking ? Theme.amber : Theme.text-dim;
                            // Rotated 45deg approximation
                            border-radius: 1px;

                            animate background { duration: 300ms; }
                        }
                    }

                    // Text input
                    Rectangle {
                        horizontal-stretch: 1;
                        height: Theme.lens-input-height;
                        forward-focus: lens-input;
                        clip: true;

                        lens-input := TextInput {
                            y: (parent.height - self.preferred-height) / 2;
                            width: parent.width;
                            color: Theme.text-primary;
                            font-size: 18px;
                            text <=> root.input-text;
                            accepted => {
                                if root.input-text != "" {
                                    // Active search: Enter selects the highlighted result.
                                    if root.results.length > 0 {
                                        root.result-selected(
                                            root.results[clamp(root.selected-index, 0, root.results.length - 1)].action-id
                                        );
                                    } else {
                                        root.submit-query(root.input-text);
                                    }
                                } else {
                                    // Idle state: Enter executes first suggestion
                                    if root.suggestions.length > 0 {
                                        root.result-selected(root.suggestions[0].action-id);
                                    }
                                }
                            }
                        }

                        // Placeholder
                        if root.input-text == "" : Text {
                            y: (parent.height - self.preferred-height) / 2;
                            text: "Search, ask, or do anything...";
                            color: Theme.text-dim;
                            font-size: 18px;
                        }
                    }

                    // Escape hint
                    Rectangle {
                        width: 36px;
                        height: 22px;
                        y: (parent.height - 22px) / 2;
                        border-radius: 4px;
                        background: Theme.bg-card;
                        border-width: 1px;
                        border-color: Theme.border-subtle;

                        Text {
                            text: "esc";
                            color: Theme.text-dim;
                            font-size: 10px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                // Bottom divider
                Rectangle {
                    y: parent.height - 1px;
                    width: 100%;
                    height: 1px;
                    background: Theme.separator;
                }
            }

            // ── Thinking indicator bar ──
            if root.is-thinking : Rectangle {
                height: 2px;
                width: 100%;

                // Scanning gradient
                property <float> scan-phase: 0;
                Timer {
                    interval: 16ms;
                    running: root.is-thinking;
                    triggered => { parent.scan-phase = mod(parent.scan-phase + 0.008, 1.0); }
                }

                Rectangle {
                    x: parent.width * scan-phase - parent.width * 0.3;
                    width: parent.width * 0.3;
                    height: 2px;
                    background: @linear-gradient(90deg,
                        transparent 0%,
                        Theme.amber 50%,
                        Theme.cyan 100%
                    );
                    opacity: 0.8;
                }
            }

            // ── Results feed (non-chat mode) ──
            if !root.chat-mode : VerticalLayout {
                padding: 4px;
                padding-bottom: 8px;

                // ── Active search results (when user has typed something) ──
                for result[idx] in root.results : Rectangle {
                    height: result.is-loading ? Theme.lens-result-height
                        : result.result-type == "divider" ? 24px
                        : result.result-type == "answer" ? Theme.lens-answer-height
                        : Theme.lens-result-height;
                    property <bool> row-selected: idx == root.selected-index;

                    // ── Skeleton shimmer row (loading placeholder) ──
                    if result.is-loading : Rectangle {
                        width: 100%;
                        height: Theme.lens-result-height;
                        border-radius: 8px;

                        property <float> shimmer-phase: 0;
                        Timer {
                            interval: 16ms;
                            running: result.is-loading;
                            triggered => {
                                parent.shimmer-phase = mod(parent.shimmer-phase + 0.01, 1.0);
                            }
                        }

                        HorizontalLayout {
                            padding-left: 16px;
                            padding-right: 16px;
                            spacing: 12px;

                            // Shimmer badge
                            Rectangle {
                                width: 28px;
                                height: 20px;
                                y: (parent.height - 20px) / 2;
                                border-radius: 4px;
                                background: Theme.color-skeleton;
                                opacity: 0.4 + 0.3 * sin(shimmer-phase * 6.2832 * 1rad);
                            }

                            // Shimmer text bars
                            VerticalLayout {
                                horizontal-stretch: 1;
                                alignment: center;
                                spacing: 6px;

                                Rectangle {
                                    width: 60%;
                                    height: 12px;
                                    border-radius: 3px;
                                    background: Theme.color-skeleton;
                                    opacity: 0.3 + 0.3 * sin(shimmer-phase * 6.2832 * 1rad);
                                }
                                Rectangle {
                                    width: 40%;
                                    height: 8px;
                                    border-radius: 2px;
                                    background: Theme.color-skeleton;
                                    opacity: 0.2 + 0.2 * sin((shimmer-phase + 0.15) * 6.2832 * 1rad);
                                }
                            }
                        }
                    }

                    // ── Divider row ──
                    if result.result-type == "divider" && !result.is-loading : Rectangle {
                        width: 100%;
                        height: 24px;

                        HorizontalLayout {
                            padding-left: 16px;
                            padding-right: 16px;
                            spacing: 8px;
                            alignment: center;

                            Rectangle { horizontal-stretch: 1; height: 1px; background: Theme.separator; }
                            Text {
                                text: result.title;
                                color: Theme.text-dim;
                                font-size: 9px;
                                letter-spacing: 1px;
                            }
                            Rectangle { horizontal-stretch: 1; height: 1px; background: Theme.separator; }
                        }
                    }

                    // ── Answer row (inline computed result, e.g. math, time) ──
                    if result.result-type == "answer" && !result.is-loading : TouchArea {
                        height: Theme.lens-answer-height;
                        property <bool> hovered: self.has-hover;
                        clicked => {
                            root.selected-index = idx;
                            if result.action-id != "" {
                                root.result-selected(result.action-id);
                            }
                        }

                        Rectangle {
                            width: 100%;
                            height: Theme.lens-answer-height;
                            border-radius: 8px;
                            background: row-selected ? Theme.bg-selected
                                : parent.hovered ? Theme.bg-card
                                : transparent;

                            animate background { duration: 100ms; }

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;
                                spacing: 12px;

                                // Answer badge (holographic blue with glow)
                                Rectangle {
                                    width: 32px;
                                    height: 24px;
                                    y: (parent.height - 24px) / 2;
                                    border-radius: 6px;
                                    background: Theme.color-answer;
                                    opacity: 0.2;
                                    drop-shadow-blur: 8px;
                                    drop-shadow-color: Theme.holo-blue.transparentize(81%);

                                    Text {
                                        text: result.icon-char;
                                        color: Theme.color-answer;
                                        font-size: 13px;
                                        font-weight: 700;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                // Title + large inline value
                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    alignment: center;
                                    spacing: 4px;

                                    Text {
                                        text: result.title;
                                        color: Theme.text-dim;
                                        font-size: 11px;
                                        letter-spacing: 1px;
                                    }

                                    Text {
                                        text: result.inline-value;
                                        color: Theme.color-answer;
                                        font-size: 22px;
                                        font-weight: 600;
                                    }
                                }
                            }
                        }
                    }

                    // ── Normal result row ──
                    if result.result-type != "divider" && result.result-type != "answer" && !result.is-loading : TouchArea {
                        height: Theme.lens-result-height;
                        property <bool> hovered: self.has-hover;
                        clicked => {
                            root.selected-index = idx;
                            root.result-selected(result.action-id);
                        }

                    Rectangle {
                        property <bool> is-hovered: parent.hovered;
                        property <bool> is-sel: row-selected;
                        width: 100%;
                        height: Theme.lens-result-height;
                        border-radius: 8px;
                        background: is-sel ? Theme.bg-selected
                            : is-hovered ? Theme.bg-card
                            : transparent;
                        border-width: is-sel ? 1px : 0;
                        border-color: is-sel ? Theme.hover-fill-strong : transparent;

                        animate background { duration: 100ms; }

                        HorizontalLayout {
                            padding-left: 16px;
                            padding-right: 16px;
                            spacing: 12px;

                            // Type badge
                            Rectangle {
                                width: 28px;
                                height: 20px;
                                y: (parent.height - 20px) / 2;
                                border-radius: 4px;
                                background:
                                    result.result-type == "do"        ? Theme.color-do :
                                    result.result-type == "find"      ? Theme.color-find :
                                    result.result-type == "ask"       ? Theme.color-ask :
                                    result.result-type == "memory"    ? Theme.color-memory :
                                    result.result-type == "tool"      ? Theme.color-tool :
                                    result.result-type == "clipboard" ? Theme.color-clipboard :
                                    result.result-type == "context"   ? Theme.color-context :
                                    result.result-type == "recent"    ? Theme.color-recent :
                                    Theme.color-setting;
                                opacity: 0.15;

                                Text {
                                    text: result.icon-char;
                                    color:
                                        result.result-type == "do"        ? Theme.color-do :
                                        result.result-type == "find"      ? Theme.color-find :
                                        result.result-type == "ask"       ? Theme.color-ask :
                                        result.result-type == "memory"    ? Theme.color-memory :
                                        result.result-type == "tool"      ? Theme.color-tool :
                                        result.result-type == "clipboard" ? Theme.color-clipboard :
                                        result.result-type == "context"   ? Theme.color-context :
                                        result.result-type == "recent"    ? Theme.color-recent :
                                        Theme.color-setting;
                                    font-size: 11px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            // Title + subtitle
                            VerticalLayout {
                                horizontal-stretch: 1;
                                alignment: center;
                                spacing: 2px;

                                Text {
                                    text: result.title;
                                    color: Theme.text-primary;
                                    font-size: 14px;
                                    overflow: elide;
                                }

                                if result.subtitle != "" : Text {
                                    text: result.subtitle;
                                    color: Theme.text-dim;
                                    font-size: 11px;
                                    overflow: elide;
                                }
                            }

                            // Score indicator bar (3px on right side)
                            if result.score > 0.0 : Rectangle {
                                width: 3px;
                                height: parent.height * 0.6;
                                y: (parent.height - self.height) / 2;
                                border-radius: 1.5px;
                                background: Theme.cyan;
                                opacity: result.score;
                            }

                            // "Enter" hint on selected result
                            if row-selected : Rectangle {
                                width: 36px;
                                height: 18px;
                                y: (parent.height - 18px) / 2;
                                border-radius: 4px;
                                background: Theme.hover-fill;

                                Text {
                                    text: "↵";
                                    color: Theme.text-dim;
                                    font-size: 12px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        } // HorizontalLayout
                    } // Rectangle (result card)
                    } // TouchArea (normal result)
                } // for loop container

                // Offline banner — shown when AI backend is unreachable
                if !root.companion-online : Rectangle {
                    height: 32px;

                    HorizontalLayout {
                        alignment: center;
                        spacing: 8px;
                        padding-left: 16px;

                        Rectangle {
                            width: 6px; height: 6px; border-radius: 3px;
                            y: (parent.height - 6px) / 2;
                            background: Theme.color-emotional;
                        }
                        Text {
                            text: "AI offline — apps and tools still work";
                            color: Theme.text-dim;
                            font-size: 11px;
                        }
                    }
                }

                // ── Idle state: Suggestions + Recents (empty query, no results) ──
                if root.results.length == 0 && root.input-text == "" : VerticalLayout {
                    spacing: 4px;

                    // ── SUGGESTED section ──
                    if root.suggestions.length > 0 : VerticalLayout {
                        spacing: 0;

                        // Section header
                        Rectangle {
                            height: Theme.section-header-height;
                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;
                                alignment: start;

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 4px;

                                    Text {
                                        text: "SUGGESTED";
                                        color: Theme.color-context;
                                        font-size: 9px;
                                        font-weight: 700;
                                        letter-spacing: 2px;
                                    }
                                    // Animated underline
                                    Rectangle {
                                        width: 60px;
                                        height: 1px;
                                        background: Theme.color-context;
                                        opacity: 0.4;
                                    }
                                }
                            }
                        }

                        for sg[sg-idx] in root.suggestions : TouchArea {
                            height: Theme.lens-result-height;
                            property <bool> hovered: self.has-hover;
                            clicked => { root.result-selected(sg.action-id); }

                            Rectangle {
                                width: 100%;
                                height: Theme.lens-result-height;
                                border-radius: 8px;
                                background: parent.hovered ? Theme.bg-card : transparent;
                                animate background { duration: 100ms; }

                                HorizontalLayout {
                                    padding-left: 16px;
                                    padding-right: 16px;
                                    spacing: 12px;

                                    // Context badge with pulsing dot
                                    Rectangle {
                                        width: 28px;
                                        height: 20px;
                                        y: (parent.height - 20px) / 2;
                                        border-radius: 4px;
                                        background: Theme.color-context;
                                        opacity: 0.12;

                                        // Pulsing ambient dot
                                        Rectangle {
                                            x: 20px;
                                            y: 0;
                                            width: 5px;
                                            height: 5px;
                                            border-radius: 2.5px;
                                            background: Theme.color-context;
                                            opacity: 0.5 + 0.5 * sin(root.lens-glow-phase * 6.2832 * 1rad);
                                        }

                                        Text {
                                            text: sg.icon-char;
                                            color: Theme.color-context;
                                            font-size: 11px;
                                            font-weight: 700;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }

                                    VerticalLayout {
                                        horizontal-stretch: 1;
                                        alignment: center;
                                        spacing: 2px;

                                        Text {
                                            text: sg.title;
                                            color: Theme.text-primary;
                                            font-size: 14px;
                                            overflow: elide;
                                        }
                                        if sg.subtitle != "" : Text {
                                            text: sg.subtitle;
                                            color: Theme.text-dim;
                                            font-size: 11px;
                                            overflow: elide;
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // ── RECENT section ──
                    if root.recents.length > 0 : VerticalLayout {
                        spacing: 0;

                        // Section header
                        Rectangle {
                            height: Theme.section-header-height;
                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;
                                alignment: start;

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 4px;

                                    Text {
                                        text: "RECENT";
                                        color: Theme.color-recent;
                                        font-size: 9px;
                                        font-weight: 700;
                                        letter-spacing: 2px;
                                    }
                                    Rectangle {
                                        width: 44px;
                                        height: 1px;
                                        background: Theme.color-recent;
                                        opacity: 0.3;
                                    }
                                }
                            }
                        }

                        for rc[rc-idx] in root.recents : TouchArea {
                            height: Theme.lens-result-height;
                            property <bool> hovered: self.has-hover;
                            clicked => { root.result-selected(rc.action-id); }

                            Rectangle {
                                width: 100%;
                                height: Theme.lens-result-height;
                                border-radius: 8px;
                                background: parent.hovered ? Theme.bg-card : transparent;
                                animate background { duration: 100ms; }

                                HorizontalLayout {
                                    padding-left: 16px;
                                    padding-right: 16px;
                                    spacing: 12px;

                                    // Recent badge (dimmer steel)
                                    Rectangle {
                                        width: 28px;
                                        height: 20px;
                                        y: (parent.height - 20px) / 2;
                                        border-radius: 4px;
                                        background: Theme.color-recent;
                                        opacity: 0.12;

                                        Text {
                                            text: rc.icon-char;
                                            color: Theme.color-recent;
                                            font-size: 11px;
                                            font-weight: 700;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }

                                    VerticalLayout {
                                        horizontal-stretch: 1;
                                        alignment: center;
                                        spacing: 2px;

                                        Text {
                                            text: rc.title;
                                            color: Theme.text-secondary;
                                            font-size: 14px;
                                            overflow: elide;
                                            opacity: 0.8;
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // Fallback empty state (no suggestions, no recents)
                    if root.suggestions.length == 0 && root.recents.length == 0 : Rectangle {
                        height: 64px;
                        VerticalLayout {
                            alignment: center;
                            padding-left: 20px;

                            Text {
                                text: root.companion-online
                                    ? "Type to search, ask, or command"
                                    : "Type to search apps and tools";
                                color: Theme.text-dim;
                                font-size: 13px;
                            }
                        }
                    }
                }
            }

            // ── Chat mode (multi-turn conversation) ──
            if root.chat-mode : VerticalLayout {
                // Messages — fills available panel height
                ListView {
                    vertical-stretch: 1;
                    min-height: 200px;

                    for msg[idx] in root.messages : MessageBubble {
                        data: msg;
                    }
                }

                // Typing indicator
                if root.is-generating : HorizontalLayout {
                    padding-left: 20px;
                    padding-bottom: 8px;
                    spacing: 6px;

                    property <float> dot-phase: 0;
                    Timer {
                        interval: 16ms;
                        running: root.is-generating;
                        triggered => {
                            parent.dot-phase = mod(parent.dot-phase + 0.005, 1.0);
                        }
                    }

                    Rectangle {
                        width: 5px; height: 5px; border-radius: 2.5px;
                        background: Theme.cyan;
                        opacity: 0.3 + 0.7 * sin(dot-phase * 6.2832 * 1rad);
                    }
                    Rectangle {
                        width: 5px; height: 5px; border-radius: 2.5px;
                        background: Theme.cyan;
                        opacity: 0.3 + 0.7 * sin((dot-phase + 0.12) * 6.2832 * 1rad);
                    }
                    Rectangle {
                        width: 5px; height: 5px; border-radius: 2.5px;
                        background: Theme.cyan;
                        opacity: 0.3 + 0.7 * sin((dot-phase + 0.24) * 6.2832 * 1rad);
                    }
                }

                // Input bar for chat mode
                Rectangle {
                    height: 48px;
                    background: Theme.bg-deep;

                    Rectangle {
                        y: 0; width: 100%; height: 1px;
                        background: Theme.separator;
                    }

                    HorizontalLayout {
                        padding: 8px;
                        padding-left: 12px;
                        padding-right: 12px;
                        spacing: 8px;

                        // Mic button
                        TouchArea {
                            width: 32px;
                            height: 32px;
                            clicked => { root.mic-pressed(); }

                            Rectangle {
                                width: 32px; height: 32px;
                                border-radius: 16px;
                                background: Theme.bg-card;
                                border-width: 1px;
                                border-color: Theme.cyan-dim;

                                Rectangle {
                                    x: (parent.width - 8px) / 2;
                                    y: 8px;
                                    width: 8px; height: 10px;
                                    border-radius: 4px;
                                    background: Theme.cyan;
                                }
                            }
                        }

                        // Chat input
                        Rectangle {
                            horizontal-stretch: 1;
                            height: 32px;
                            border-radius: 16px;
                            background: Theme.bg-input;
                            border-width: 1px;
                            border-color: chat-input.has-focus ? Theme.cyan-dim : Theme.border-subtle;
                            forward-focus: chat-input;
                            clip: true;

                            animate border-color { duration: 200ms; }

                            chat-input := TextInput {
                                property <string> chat-text: "";
                                x: 12px;
                                y: (parent.height - self.preferred-height) / 2;
                                width: parent.width - 24px;
                                color: Theme.text-primary;
                                font-size: 14px;
                                text <=> chat-text;
                                accepted => {
                                    if chat-text != "" {
                                        root.send-message(chat-text);
                                        chat-text = "";
                                    }
                                }
                            }

                            if chat-input.chat-text == "" : Text {
                                x: 12px;
                                y: (parent.height - self.preferred-height) / 2;
                                text: "Continue conversation...";
                                color: Theme.text-dim;
                                font-size: 14px;
                            }
                        }

                        // Send
                        TouchArea {
                            width: 32px;
                            height: 32px;
                            clicked => {
                                if chat-input.chat-text != "" {
                                    root.send-message(chat-input.chat-text);
                                    chat-input.chat-text = "";
                                }
                            }

                            Rectangle {
                                width: 32px; height: 32px;
                                border-radius: 16px;
                                background: chat-input.chat-text != "" ? Theme.amber : Theme.bg-card;

                                animate background { duration: 150ms; }

                                Text {
                                    text: ">";
                                    color: chat-input.chat-text != "" ? Theme.bg-deep : Theme.text-dim;
                                    font-size: 16px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    // Reset selection when results change
    changed results => { root.selected-index = 0; }

    // Keyboard navigation — Up/Down/Tab move selection, Escape closes.
    // Skips divider rows automatically.
    key-handler := FocusScope {
        width: 0; height: 0;
        key-pressed(event) => {
            if event.text == Key.DownArrow || event.text == Key.Tab {
                if root.results.length > 0 {
                    root.selected-index = clamp(
                        root.selected-index + 1, 0, root.results.length - 1
                    );
                    // Skip divider
                    if root.results[root.selected-index].result-type == "divider" {
                        root.selected-index = clamp(
                            root.selected-index + 1, 0, root.results.length - 1
                        );
                    }
                }
                return accept;
            }
            if event.text == Key.UpArrow {
                if root.results.length > 0 {
                    root.selected-index = clamp(
                        root.selected-index - 1, 0, root.results.length - 1
                    );
                    // Skip divider
                    if root.results[root.selected-index].result-type == "divider" {
                        root.selected-index = clamp(
                            root.selected-index - 1, 0, root.results.length - 1
                        );
                    }
                }
                return accept;
            }
            if event.text == Key.Escape {
                root.close-lens();
                return accept;
            }
            return reject;
        }
    }

    // Auto-focus input when lens opens
    forward-focus: lens-input;
}
