// Radar chart — 4-axis personality visualization.
// Axes: formality, humor, opinion strength, question ratio.
// Uses bar representation since Slint doesn't support Path-based polygons easily.

import { Theme } from "../theme.slint";

export component RadarChart inherits Rectangle {
    in property <float> formality: 0.5;
    in property <float> humor: 0.5;
    in property <float> opinion: 0.5;
    in property <float> question: 0.5;
    in property <float> size-px: 200;

    width: 1px * size-px;
    height: 1px * size-px;
    background: transparent;

    // Background grid (concentric squares approximation)
    Rectangle {
        x: (parent.width - parent.width * 0.8) / 2;
        y: (parent.height - parent.height * 0.8) / 2;
        width: parent.width * 0.8;
        height: parent.height * 0.8;
        border-radius: 4px;
        background: transparent;
        border-width: 1px;
        border-color: Theme.text-dim;
        opacity: 0.3;
    }

    Rectangle {
        x: (parent.width - parent.width * 0.5) / 2;
        y: (parent.height - parent.height * 0.5) / 2;
        width: parent.width * 0.5;
        height: parent.height * 0.5;
        border-radius: 4px;
        background: transparent;
        border-width: 1px;
        border-color: Theme.text-dim;
        opacity: 0.2;
    }

    // Axis bars — 4 directions from center

    // Top: Formality
    Rectangle {
        x: (parent.width - 4px) / 2;
        y: parent.height / 2 - parent.height * 0.4 * formality;
        width: 4px;
        height: parent.height * 0.4 * formality;
        border-radius: 2px;
        background: Theme.amber;
        opacity: 0.8;
    }

    // Right: Humor
    Rectangle {
        x: parent.width / 2;
        y: (parent.height - 4px) / 2;
        width: parent.width * 0.4 * humor;
        height: 4px;
        border-radius: 2px;
        background: Theme.amber-light;
        opacity: 0.8;
    }

    // Bottom: Opinion
    Rectangle {
        x: (parent.width - 4px) / 2;
        y: parent.height / 2;
        width: 4px;
        height: parent.height * 0.4 * opinion;
        border-radius: 2px;
        background: Theme.color-emotional;
        opacity: 0.8;
    }

    // Left: Question
    Rectangle {
        x: parent.width / 2 - parent.width * 0.4 * question;
        y: (parent.height - 4px) / 2;
        width: parent.width * 0.4 * question;
        height: 4px;
        border-radius: 2px;
        background: Theme.color-check-in;
        opacity: 0.8;
    }

    // Center dot
    Rectangle {
        x: (parent.width - 6px) / 2;
        y: (parent.height - 6px) / 2;
        width: 6px;
        height: 6px;
        border-radius: 3px;
        background: Theme.amber;
    }

    // Labels
    Text {
        text: "formal";
        color: Theme.text-secondary;
        font-size: 10px;
        x: (parent.width - self.preferred-width) / 2;
        y: 2px;
        horizontal-alignment: center;
    }

    Text {
        text: "humor";
        color: Theme.text-secondary;
        font-size: 10px;
        x: parent.width - self.preferred-width - 2px;
        y: (parent.height - self.preferred-height) / 2;
    }

    Text {
        text: "opinion";
        color: Theme.text-secondary;
        font-size: 10px;
        x: (parent.width - self.preferred-width) / 2;
        y: parent.height - self.preferred-height - 2px;
        horizontal-alignment: center;
    }

    Text {
        text: "question";
        color: Theme.text-secondary;
        font-size: 10px;
        x: 2px;
        y: (parent.height - self.preferred-height) / 2;
    }
}
