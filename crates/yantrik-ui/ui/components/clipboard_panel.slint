// Clipboard History Panel — overlay showing recent clipboard entries.
// Triggered by Super+V or dock button. Click entry to paste.
// Follows QuickSettings overlay pattern (backdrop + floating panel).
// Search input filters entries Rust-side via search-changed callback.

import { Theme } from "theme.slint";

export struct ClipboardEntryData {
    index: int,
    preview: string,
    time-ago: string,
}

export component ClipboardPanel inherits Rectangle {
    in-out property <bool> is-open: false;
    in property <[ClipboardEntryData]> entries: [];
    in-out property <string> search-query: "";

    callback paste-entry(int);
    callback close();
    callback search-changed(string);

    width: 100%;
    height: 100%;

    // Backdrop (click to close)
    if root.is-open : TouchArea {
        width: 100%;
        height: 100%;
        clicked => {
            root.search-query = "";
            root.is-open = false;
            root.close();
        }

        Rectangle {
            width: 100%;
            height: 100%;
            background: Theme.overlay-backdrop;
        }
    }

    // Panel — center screen
    if root.is-open : Rectangle {
        x: (parent.width - 420px) / 2;
        y: (parent.height - panel-layout.preferred-height - 20px) / 2;
        width: 420px;
        height: min(panel-layout.preferred-height + 20px, parent.height - 80px);
        background: Theme.bg-elevated;
        border-radius: 16px;
        border-width: 1px;
        border-color: Theme.border-subtle;
        drop-shadow-blur: 32px;
        drop-shadow-color: Theme.overlay-shadow;
        clip: true;

        panel-layout := VerticalLayout {
            padding: 16px;
            spacing: 6px;

            // Header
            HorizontalLayout {
                spacing: 8px;
                height: 32px;

                Text {
                    text: "Clipboard History";
                    color: Theme.text-primary;
                    font-size: Theme.font-title;
                    font-weight: 600;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                Rectangle {
                    width: pill-text.preferred-width + 16px;
                    height: 22px;
                    y: (parent.height - 22px) / 2;
                    border-radius: 11px;
                    background: Theme.tint-accent;

                    pill-text := Text {
                        text: root.entries.length + " items";
                        color: Theme.accent;
                        font-size: 11px;
                        font-weight: 500;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            // Search input
            Rectangle {
                height: 36px;
                border-radius: 10px;
                background: Theme.bg-input;
                border-width: 1px;
                border-color: search-input.has-focus ? Theme.accent-dim : Theme.border-subtle;
                clip: true;

                HorizontalLayout {
                    padding-left: 10px;
                    padding-right: 10px;
                    spacing: 8px;

                    // Search icon
                    Text {
                        text: "/";
                        color: Theme.text-dim;
                        font-size: 14px;
                        font-weight: 600;
                        vertical-alignment: center;
                        width: 16px;
                    }

                    search-input := TextInput {
                        horizontal-stretch: 1;
                        vertical-alignment: center;
                        font-size: 13px;
                        color: Theme.text-primary;
                        text <=> root.search-query;
                        accepted => { /* enter does nothing special */ }
                        edited => {
                            root.search-changed(root.search-query);
                        }
                    }
                }
            }

            Rectangle { height: 1px; background: Theme.separator; }

            // Empty state
            if root.entries.length == 0 : Rectangle {
                height: 80px;

                Text {
                    text: root.search-query != "" ? "No matches" : "Nothing copied yet";
                    color: Theme.text-dim;
                    font-size: Theme.font-body;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            // Entry list
            for entry[i] in root.entries : TouchArea {
                height: 56px;

                clicked => {
                    root.paste-entry(entry.index);
                    root.search-query = "";
                    root.is-open = false;
                    root.close();
                }

                Rectangle {
                    width: 100%;
                    height: 100%;
                    border-radius: 10px;
                    background: parent.has-hover ? Theme.hover-fill : transparent;

                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        spacing: 10px;

                        // Index badge
                        Rectangle {
                            width: 24px;
                            height: 24px;
                            y: (parent.height - 24px) / 2;
                            border-radius: 7px;
                            background: i < 9 ? Theme.tint-accent : Theme.bg-card;
                            border-width: i < 9 ? 0px : 1px;
                            border-color: Theme.text-dim;

                            Text {
                                text: i < 9 ? (i + 1) + "" : "\u{00B7}";
                                color: i < 9 ? Theme.accent : Theme.text-dim;
                                font-size: 11px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        // Preview text
                        VerticalLayout {
                            horizontal-stretch: 1;
                            alignment: center;
                            spacing: 2px;

                            Text {
                                text: entry.preview;
                                color: Theme.text-primary;
                                font-size: 13px;
                                overflow: elide;
                            }

                            Text {
                                text: entry.time-ago;
                                color: Theme.text-dim;
                                font-size: 10px;
                            }
                        }
                    }
                }
            }

            // Keyboard shortcut hint (bottom of panel)
            Rectangle {
                height: 24px;

                HorizontalLayout {
                    alignment: center;
                    spacing: 4px;

                    Text {
                        text: "Super+V";
                        color: Theme.text-dim;
                        font-size: 10px;
                        vertical-alignment: center;
                    }

                    Text {
                        text: "to toggle";
                        color: Theme.text-dim;
                        font-size: 10px;
                        vertical-alignment: center;
                        opacity: 0.6;
                    }
                }
            }
        }
    }
}
