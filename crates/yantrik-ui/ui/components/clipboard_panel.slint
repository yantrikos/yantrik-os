// Clipboard History Panel — overlay showing recent clipboard entries.
// Triggered by Super+V or dock button. Click entry to paste.
// Follows QuickSettings overlay pattern (backdrop + floating panel).

import { Theme } from "../theme.slint";

export struct ClipboardEntryData {
    index: int,
    preview: string,
    time-ago: string,
}

export component ClipboardPanel inherits Rectangle {
    in-out property <bool> is-open: false;
    in property <[ClipboardEntryData]> entries: [];

    callback paste-entry(int);
    callback close();

    width: 100%;
    height: 100%;

    // Backdrop (click to close)
    if root.is-open : TouchArea {
        width: 100%;
        height: 100%;
        clicked => { root.is-open = false; root.close(); }

        Rectangle {
            width: 100%;
            height: 100%;
            background: Theme.overlay-backdrop;
        }
    }

    // Panel — center screen
    if root.is-open : Rectangle {
        x: (parent.width - 400px) / 2;
        y: (parent.height - panel-layout.preferred-height - 16px) / 2;
        width: 400px;
        height: min(panel-layout.preferred-height + 16px, parent.height - 80px);
        background: Theme.bg-elevated;
        border-radius: 16px;
        border-width: 1px;
        border-color: Theme.border-subtle;
        drop-shadow-blur: 24px;
        drop-shadow-color: Theme.overlay-shadow;
        clip: true;

        panel-layout := VerticalLayout {
            padding: 16px;
            spacing: 4px;

            // Header
            HorizontalLayout {
                spacing: 8px;
                height: 32px;

                Text {
                    text: "Clipboard History";
                    color: Theme.text-primary;
                    font-size: Theme.font-title;
                    font-weight: 500;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                Text {
                    text: root.entries.length + " items";
                    color: Theme.text-dim;
                    font-size: Theme.font-small;
                    vertical-alignment: center;
                }
            }

            Rectangle { height: 1px; background: Theme.separator; }

            // Empty state
            if root.entries.length == 0 : Rectangle {
                height: 80px;

                Text {
                    text: "Nothing copied yet";
                    color: Theme.text-dim;
                    font-size: Theme.font-body;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            // Entry list
            for entry[i] in root.entries : TouchArea {
                height: 52px;

                clicked => {
                    root.paste-entry(entry.index);
                    root.is-open = false;
                    root.close();
                }

                Rectangle {
                    width: 100%;
                    height: 100%;
                    border-radius: 8px;
                    background: parent.has-hover ? Theme.hover-fill : transparent;

                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        spacing: 8px;

                        // Index badge
                        Rectangle {
                            width: 22px;
                            height: 22px;
                            y: (parent.height - 22px) / 2;
                            border-radius: 6px;
                            background: Theme.bg-card;
                            border-width: 1px;
                            border-color: Theme.text-dim;

                            Text {
                                text: i < 9 ? (i + 1) + "" : "·";
                                color: Theme.text-dim;
                                font-size: 11px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        // Preview text
                        VerticalLayout {
                            horizontal-stretch: 1;
                            alignment: center;
                            spacing: 2px;

                            Text {
                                text: entry.preview;
                                color: Theme.text-primary;
                                font-size: 13px;
                                overflow: elide;
                            }

                            Text {
                                text: entry.time-ago;
                                color: Theme.text-dim;
                                font-size: 10px;
                            }
                        }
                    }
                }
            }
        }
    }
}
