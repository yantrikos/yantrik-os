// App dock — centered floating glass bar.
// Always visible at the bottom of the desktop. Glass background with holographic glow.
// Icons lift on hover with glow and tooltip labels.
// Anchor orb at center — holographic mini-orb.

import { Theme } from "../theme.slint";

export struct DockItem {
    app-id: string,
    label: string,
    icon-char: string,
    is-running: bool,
}

export component AppDock inherits Rectangle {
    in property <[DockItem]> items: [
        { app-id: "terminal",      label: "Terminal", icon-char: ">_", is-running: false },
        { app-id: "browser",       label: "Browser",  icon-char: "W",  is-running: false },
        { app-id: "files",         label: "Files",    icon-char: "F",  is-running: false },
        { app-id: "editor",        label: "Editor",   icon-char: "≡",  is-running: false },
        { app-id: "bond",          label: "Bond",     icon-char: "♥",  is-running: false },
        { app-id: "memory",        label: "Memory",   icon-char: "◈",  is-running: false },
        { app-id: "notifications", label: "Alerts",   icon-char: "N",  is-running: false },
        { app-id: "system",        label: "System",   icon-char: "◉",  is-running: false },
        { app-id: "media",         label: "Media",    icon-char: "♪",  is-running: false },
        { app-id: "settings",      label: "Settings", icon-char: "⚙",  is-running: false },
    ];

    callback launch-app(string);
    callback anchor-pressed();

    property <float> glow-phase: 0;

    height: 60px;
    background: transparent;

    // Glow animation
    Timer {
        interval: 16ms;
        running: true;
        triggered => {
            glow-phase = mod(glow-phase + 0.002, 1.0);
        }
    }

    // Dock surface — centered floating glass pill
    Rectangle {
        property <int> item-count: root.items.length;
        // Each icon is 44px + 12px spacing, plus anchor (44px) + separator (20px)
        property <length> dock-width: max(280px, item-count * 56px + 64px + 24px);
        x: (parent.width - dock-width) / 2;
        width: dock-width;
        height: 52px;
        y: parent.height - 58px;
        border-radius: 16px;
        clip: false;

        // Glass background layers
        Rectangle {
            width: 100%; height: 100%;
            border-radius: 16px;
            background: @linear-gradient(180deg,
                #12111a90 0%,
                #0c0b10a0 50%,
                #080810b0 100%
            );
        }

        // Glass border (holographic edge)
        Rectangle {
            width: 100%; height: 100%;
            border-radius: 16px;
            border-width: 1px;
            border-color: @linear-gradient(180deg,
                #ffffff14 0%,
                #ffffff08 50%,
                #ffffff04 100%
            );
            background: transparent;
        }

        // Top highlight (glass reflection)
        Rectangle {
            x: 16px; y: 1px;
            width: parent.width - 32px;
            height: 1px;
            border-radius: 0.5px;
            background: @linear-gradient(90deg,
                transparent 0%,
                #ffffff10 30%,
                #ffffff18 50%,
                #ffffff10 70%,
                transparent 100%
            );
        }

        // Bottom glow
        Rectangle {
            y: parent.height - 1px;
            width: 100%;
            height: 1px;
            background: @linear-gradient(90deg, transparent 10%, Theme.cyan-glow 50%, transparent 90%);
            opacity: 0.5;
        }

        // Shadow
        drop-shadow-blur: 24px;
        drop-shadow-color: #00000060;

        HorizontalLayout {
            alignment: center;
            spacing: 12px;
            padding-left: 12px;
            padding-right: 12px;
            padding-top: 6px;
            padding-bottom: 6px;

            for item[idx] in root.items : TouchArea {
                width: 44px;
                height: 44px;
                property <bool> hovered: self.has-hover;
                clicked => {
                    root.launch-app(item.app-id);
                }

                // Tooltip label — glass pill above icon
                if hovered : Rectangle {
                    property <length> label-width: tooltip-text.preferred-width + 16px;
                    x: (parent.width - self.label-width) / 2;
                    y: -30px;
                    width: self.label-width;
                    height: 22px;
                    border-radius: 6px;
                    background: @linear-gradient(180deg, #12111ae0 0%, #0c0b10d0 100%);
                    border-width: 1px;
                    border-color: #ffffff10;
                    drop-shadow-blur: 8px;
                    drop-shadow-color: #00000040;

                    tooltip-text := Text {
                        text: item.label;
                        color: Theme.text-secondary;
                        font-size: 11px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                // Icon container — lifts on hover
                Rectangle {
                    property <bool> is-hovered: parent.hovered;
                    width: 40px;
                    height: 40px;
                    x: (parent.width - self.width) / 2;
                    y: is-hovered ? -4px : 0;
                    border-radius: 12px;
                    background: is-hovered
                        ? @radial-gradient(circle, #5ac8d418 0%, #12111a 100%)
                        : Theme.bg-card;
                    border-width: 1px;
                    border-color: is-hovered ? Theme.cyan-dim : #ffffff08;
                    drop-shadow-blur: is-hovered ? 12px : 0;
                    drop-shadow-color: Theme.cyan-glow;

                    animate y { duration: 150ms; easing: ease-out; }
                    animate background { duration: 150ms; }
                    animate border-color { duration: 150ms; }
                    animate drop-shadow-blur { duration: 150ms; }

                    Text {
                        text: item.icon-char;
                        color: parent.is-hovered ? Theme.cyan : Theme.text-secondary;
                        font-size: 15px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;

                        animate color { duration: 150ms; }
                    }
                }

                // Running indicator dot + glow
                if item.is-running : Rectangle {
                    width: 4px;
                    height: 4px;
                    x: (parent.width - 4px) / 2;
                    y: 42px;
                    border-radius: 2px;
                    background: Theme.cyan;
                    drop-shadow-blur: 4px;
                    drop-shadow-color: Theme.cyan-glow;
                }
            }

            // Glass separator
            Rectangle {
                width: 1px;
                height: 32px;
                y: 4px;
                background: @linear-gradient(180deg,
                    transparent 0%,
                    #ffffff18 50%,
                    transparent 100%
                );
            }

            // Anchor orb button — holographic mini-orb
            TouchArea {
                width: 44px;
                height: 44px;
                clicked => { root.anchor-pressed(); }

                Rectangle {
                    width: 40px;
                    height: 40px;
                    x: (parent.width - self.width) / 2;
                    y: parent.has-hover ? -4px : 0;
                    border-radius: 20px;
                    background: @radial-gradient(circle,
                        Theme.amber-glow-strong 0%,
                        Theme.amber-glow 40%,
                        #12111a80 100%
                    );
                    border-width: 1px;
                    border-color: Theme.amber-dim;
                    drop-shadow-blur: parent.has-hover ? 14px : 8px;
                    drop-shadow-color: Theme.amber-glow;

                    animate y { duration: 150ms; easing: ease-out; }
                    animate drop-shadow-blur { duration: 150ms; }

                    // Mini holographic core
                    Rectangle {
                        x: (parent.width - 18px) / 2;
                        y: (parent.height - 18px) / 2;
                        width: 18px;
                        height: 18px;
                        border-radius: 9px;
                        background: @radial-gradient(circle,
                            #ffffff30 0%,
                            Theme.amber-light 30%,
                            Theme.amber 60%,
                            Theme.cyan-dim 100%
                        );
                    }

                    // Orbital ring
                    Rectangle {
                        x: (parent.width - 32px) / 2;
                        y: (parent.height - 14px) / 2;
                        width: 32px;
                        height: 14px;
                        border-radius: 16px;
                        border-width: 0.5px;
                        border-color: Theme.amber-dim;
                        background: transparent;
                        opacity: 0.4 + 0.2 * sin(glow-phase * 6.2832 * 1rad);
                    }
                }
            }
        }
    }
}
