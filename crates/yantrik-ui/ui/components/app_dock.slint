// AppDock — centered bottom bar with app icons.
// Clean plate with 1px top border. Icons lift on hover with scale.
// Running indicator: 4px accent dot. Active app: brighter plate tint.
// Anchor button at end — calm accent treatment.

import { Theme } from "../theme.slint";

export struct DockItem {
    app-id: string,
    label: string,
    icon-char: string,
    is-running: bool,
}

export component AppDock inherits Rectangle {
    in property <[DockItem]> items: [
        { app-id: "terminal",      label: "Terminal", icon-char: ">_", is-running: false },
        { app-id: "browser",       label: "Browser",  icon-char: "W",  is-running: false },
        { app-id: "files",         label: "Files",    icon-char: "F",  is-running: false },
        { app-id: "editor",        label: "Editor",   icon-char: "≡",  is-running: false },
        { app-id: "bond",          label: "Bond",     icon-char: "♥",  is-running: false },
        { app-id: "memory",        label: "Memory",   icon-char: "◈",  is-running: false },
        { app-id: "notifications", label: "Alerts",   icon-char: "N",  is-running: false },
        { app-id: "system",        label: "System",   icon-char: "◉",  is-running: false },
        { app-id: "media",         label: "Media",    icon-char: "♪",  is-running: false },
        { app-id: "settings",      label: "Settings", icon-char: "⚙",  is-running: false },
    ];

    callback launch-app(string);
    callback anchor-pressed();

    height: Theme.dock-height;
    background: transparent;

    // Dock plate — centered, solid surface
    Rectangle {
        property <int> item-count: root.items.length;
        x: Theme.sp-4;
        width: parent.width - Theme.sp-4 * 2;
        height: Theme.dock-height - 8px;
        y: 4px;
        border-radius: Theme.r-lg;
        background: Theme.bg-surface;
        border-width: 1px;
        border-color: Theme.border-subtle;

        HorizontalLayout {
            alignment: center;
            spacing: Theme.sp-2;
            padding-left: Theme.sp-3;
            padding-right: Theme.sp-3;
            padding-top: Theme.sp-2;
            padding-bottom: Theme.sp-2;

            for item[idx] in root.items : Rectangle {
                width: Theme.dock-item-size;
                height: Theme.dock-item-size;

                property <bool> hovered: dock-ta.has-hover;

                dock-ta := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.launch-app(item.app-id); }
                }

                // Tooltip — appears on hover with 300ms-ish feel (instant for now, Slint has no hover delay)
                if hovered : Rectangle {
                    property <length> label-width: tooltip-text.preferred-width + Theme.sp-4;
                    x: (parent.width - self.label-width) / 2;
                    y: -28px;
                    width: self.label-width;
                    height: 22px;
                    border-radius: Theme.r-sm;
                    background: Theme.bg-elevated;
                    border-width: 1px;
                    border-color: Theme.border-default;

                    tooltip-text := Text {
                        text: item.label;
                        color: Theme.text-secondary;
                        font-size: Theme.fs-micro;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                // Icon — scales on hover via slight size increase
                Rectangle {
                    property <bool> is-hovered: parent.hovered;
                    property <length> scale-offset: is-hovered ? 2px : 0;
                    width: Theme.dock-icon-size + scale-offset;
                    height: Theme.dock-icon-size + scale-offset;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2 - (is-hovered ? 2px : 0);
                    border-radius: Theme.r-md;
                    background: is-hovered ? Theme.hover-fill-strong : Theme.bg-card;
                    border-width: 1px;
                    border-color: is-hovered ? Theme.border-strong : Theme.border-subtle;

                    animate width { duration: 150ms; easing: ease-out; }
                    animate height { duration: 150ms; easing: ease-out; }
                    animate y { duration: 150ms; easing: ease-out; }
                    animate background { duration: Theme.dur-fast; }
                    animate border-color { duration: Theme.dur-fast; }

                    Text {
                        text: item.icon-char;
                        color: parent.is-hovered ? Theme.accent : Theme.text-secondary;
                        font-size: 14px;
                        font-weight: 600;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        animate color { duration: Theme.dur-fast; }
                    }
                }

                // Running indicator — 4px accent dot below icon
                if item.is-running : Rectangle {
                    width: 4px;
                    height: 4px;
                    x: (parent.width - 4px) / 2;
                    y: parent.height - 2px;
                    border-radius: 2px;
                    background: Theme.accent;
                }
            }

            // Separator before anchor
            Rectangle {
                width: 1px;
                height: 28px;
                y: (parent.height - 28px) / 2;
                background: Theme.separator;
            }

            // Anchor button — calm accent circle
            TouchArea {
                width: Theme.dock-item-size;
                height: Theme.dock-item-size;
                mouse-cursor: pointer;
                property <bool> hovered: self.has-hover;
                clicked => { root.anchor-pressed(); }

                Rectangle {
                    width: Theme.dock-icon-size + 4px;
                    height: Theme.dock-icon-size + 4px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2 - (parent.hovered ? 2px : 0);
                    border-radius: (Theme.dock-icon-size + 4px) / 2;
                    background: parent.hovered ? Theme.tint-accent : Theme.bg-card;
                    border-width: 1px;
                    border-color: parent.hovered ? Theme.accent-dim : Theme.border-subtle;

                    animate y { duration: 150ms; easing: ease-out; }
                    animate background { duration: Theme.dur-fast; }
                    animate border-color { duration: Theme.dur-fast; }

                    // Accent-colored Y icon
                    Text {
                        text: "Y";
                        color: Theme.accent;
                        font-size: 16px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}
