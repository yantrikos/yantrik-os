// WindowFrame — reusable window chrome with glass title bar.
// Holographic glow, glass gradient background, animated controls.
// Semi-transparent body for depth. Use @children to place content inside.
// Supports drag-to-move (title bar) and drag-to-resize (edges/corners).

import { Theme } from "../theme.slint";

// Invisible resize handle — placed on window edges/corners.
// Updates win-x/y/w/h based on which edges are active.
component ResizeHandle inherits TouchArea {
    in property <bool> resize-top: false;
    in property <bool> resize-bottom: false;
    in property <bool> resize-left: false;
    in property <bool> resize-right: false;
    in-out property <length> win-x;
    in-out property <length> win-y;
    in-out property <length> win-w;
    in-out property <length> win-h;
    in property <length> min-w: 400px;
    in property <length> min-h: 300px;

    property <length> press-mx;
    property <length> press-my;

    pointer-event(event) => {
        if event.button == PointerEventButton.left && event.kind == PointerEventKind.down {
            press-mx = self.mouse-x;
            press-my = self.mouse-y;
        }
    }

    moved => {
        if self.pressed {
            if root.resize-right {
                root.win-w = max(root.min-w, root.win-w + self.mouse-x - root.press-mx);
            }
            if root.resize-bottom {
                root.win-h = max(root.min-h, root.win-h + self.mouse-y - root.press-my);
            }
            if root.resize-left {
                if root.win-w - (self.mouse-x - root.press-mx) >= root.min-w {
                    root.win-x = root.win-x + (self.mouse-x - root.press-mx);
                    root.win-w = root.win-w - (self.mouse-x - root.press-mx);
                }
            }
            if root.resize-top {
                if root.win-h - (self.mouse-y - root.press-my) >= root.min-h {
                    root.win-y = root.win-y + (self.mouse-y - root.press-my);
                    root.win-h = root.win-h - (self.mouse-y - root.press-my);
                }
            }
        }
    }
}

export component WindowFrame inherits Rectangle {
    in property <string> title: "";
    in property <string> icon-char: "";
    in property <color> icon-color: Theme.cyan;
    in-out property <bool> is-maximized: true;

    // Window geometry (when not maximized) — bind with <=> from parent
    in-out property <length> win-x: 80px;
    in-out property <length> win-y: 40px;
    in-out property <length> win-w: 1000px;
    in-out property <length> win-h: 650px;

    property <length> min-w: 400px;
    property <length> min-h: 300px;
    property <length> hs: 6px;   // edge handle thickness
    property <length> cs: 14px;  // corner handle size

    callback close();
    callback minimize();

    // Glass body — semi-transparent deep background
    background: @linear-gradient(180deg,
        #0a0a18e8 0%,
        #080814e0 50%,
        #0a0a18e8 100%
    );
    border-radius: root.is-maximized ? 0px : 12px;
    clip: true;
    drop-shadow-blur: root.is-maximized ? 0px : 24px;
    drop-shadow-color: root.is-maximized ? transparent : #000000cc;
    border-width: root.is-maximized ? 0px : 1px;
    border-color: root.is-maximized ? transparent : @linear-gradient(180deg,
        #ffffff14 0%,
        #ffffff08 50%,
        #ffffff04 100%
    );

    animate border-radius, drop-shadow-blur, border-width { duration: 200ms; easing: ease-out; }

    VerticalLayout {
        spacing: 0px;

        // ── Title bar — glass gradient ──
        Rectangle {
            height: 36px;
            background: @linear-gradient(180deg,
                #14122290 0%,
                #0e0d18a0 100%
            );

            // Top edge reflection
            Rectangle {
                x: 12px; y: 0;
                width: parent.width - 24px;
                height: 1px;
                border-radius: 0.5px;
                background: @linear-gradient(90deg,
                    transparent 0%,
                    #ffffff0c 30%,
                    #ffffff14 50%,
                    #ffffff0c 70%,
                    transparent 100%
                );
            }

            // Drag TouchArea — covers entire title bar, behind buttons
            title-drag := TouchArea {
                width: 100%;
                height: 100%;
                mouse-cursor: root.is-maximized ? default : move;

                property <length> press-mx;
                property <length> press-my;

                pointer-event(event) => {
                    if event.button == PointerEventButton.left && event.kind == PointerEventKind.down {
                        press-mx = self.mouse-x;
                        press-my = self.mouse-y;
                    }
                }

                moved => {
                    if self.pressed && !root.is-maximized {
                        root.win-x += self.mouse-x - press-mx;
                        root.win-y += self.mouse-y - press-my;
                    }
                }
            }

            // Visual layout on top of drag area
            HorizontalLayout {
                padding-left: 12px;
                padding-right: 0px;

                // Left: icon + title
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    horizontal-stretch: 1;

                    if root.icon-char != "" : Rectangle {
                        width: 22px;
                        height: 22px;
                        border-radius: 5px;
                        background: @radial-gradient(circle, root.icon-color, #00000040);
                        drop-shadow-blur: 6px;
                        drop-shadow-color: root.icon-color;

                        Text {
                            text: root.icon-char;
                            color: #ffffffd0;
                            font-size: 12px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    if root.title != "" : Text {
                        text: root.title;
                        color: Theme.text-secondary;
                        font-size: 13px;
                        font-weight: 500;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }

                // Right: window controls
                HorizontalLayout {
                    spacing: 0px;
                    alignment: end;

                    // Minimize
                    min-btn := TouchArea {
                        width: 36px;
                        height: 36px;
                        clicked => { root.minimize(); }
                        Rectangle {
                            width: 100%; height: 100%;
                            background: min-btn.has-hover ? Theme.hover-fill-strong : transparent;

                            animate background { duration: 120ms; }

                            Text {
                                text: "\u{2500}";
                                color: min-btn.has-hover ? Theme.cyan : Theme.text-secondary;
                                font-size: 14px;
                                horizontal-alignment: center;
                                vertical-alignment: center;

                                animate color { duration: 120ms; }
                            }
                        }
                    }

                    // Maximize / Restore
                    max-btn := TouchArea {
                        width: 36px;
                        height: 36px;
                        clicked => { root.is-maximized = !root.is-maximized; }
                        Rectangle {
                            width: 100%; height: 100%;
                            background: max-btn.has-hover ? Theme.hover-fill-strong : transparent;

                            animate background { duration: 120ms; }

                            Text {
                                text: root.is-maximized ? "\u{2750}" : "\u{25a1}";
                                color: max-btn.has-hover ? Theme.cyan : Theme.text-secondary;
                                font-size: 14px;
                                horizontal-alignment: center;
                                vertical-alignment: center;

                                animate color { duration: 120ms; }
                            }
                        }
                    }

                    // Close — red glow on hover
                    close-btn := TouchArea {
                        width: 36px;
                        height: 36px;
                        clicked => { root.close(); }
                        Rectangle {
                            width: 100%; height: 100%;
                            background: close-btn.has-hover ? #e05252 : transparent;
                            drop-shadow-blur: close-btn.has-hover ? 6px : 0;
                            drop-shadow-color: #e0525260;

                            animate background { duration: 120ms; }
                            animate drop-shadow-blur { duration: 120ms; }

                            Text {
                                text: "\u{2715}";
                                color: close-btn.has-hover ? #ffffff : Theme.text-secondary;
                                font-size: 14px;
                                horizontal-alignment: center;
                                vertical-alignment: center;

                                animate color { duration: 120ms; }
                            }
                        }
                    }
                }
            }
        }

        // Separator — holographic edge
        Rectangle {
            height: 1px;
            background: @linear-gradient(90deg,
                transparent 5%,
                Theme.separator 20%,
                Theme.cyan-glow 50%,
                Theme.separator 80%,
                transparent 95%
            );
            opacity: 0.6;
        }

        // Content area — slightly translucent
        Rectangle {
            vertical-stretch: 1;
            clip: true;
            background: #080814d8;
            @children
        }
    }

    // ── Resize handles (only when not maximized) ──

    // N (top edge)
    if !root.is-maximized : ResizeHandle {
        x: root.cs; y: 0;
        width: root.width - 2 * root.cs; height: root.hs;
        mouse-cursor: n-resize;
        resize-top: true;
        win-x <=> root.win-x; win-y <=> root.win-y;
        win-w <=> root.win-w; win-h <=> root.win-h;
        min-w: root.min-w; min-h: root.min-h;
    }

    // S (bottom edge)
    if !root.is-maximized : ResizeHandle {
        x: root.cs; y: root.height - root.hs;
        width: root.width - 2 * root.cs; height: root.hs;
        mouse-cursor: s-resize;
        resize-bottom: true;
        win-x <=> root.win-x; win-y <=> root.win-y;
        win-w <=> root.win-w; win-h <=> root.win-h;
        min-w: root.min-w; min-h: root.min-h;
    }

    // E (right edge)
    if !root.is-maximized : ResizeHandle {
        x: root.width - root.hs; y: root.cs;
        width: root.hs; height: root.height - 2 * root.cs;
        mouse-cursor: e-resize;
        resize-right: true;
        win-x <=> root.win-x; win-y <=> root.win-y;
        win-w <=> root.win-w; win-h <=> root.win-h;
        min-w: root.min-w; min-h: root.min-h;
    }

    // W (left edge)
    if !root.is-maximized : ResizeHandle {
        x: 0; y: root.cs;
        width: root.hs; height: root.height - 2 * root.cs;
        mouse-cursor: w-resize;
        resize-left: true;
        win-x <=> root.win-x; win-y <=> root.win-y;
        win-w <=> root.win-w; win-h <=> root.win-h;
        min-w: root.min-w; min-h: root.min-h;
    }

    // NE corner
    if !root.is-maximized : ResizeHandle {
        x: root.width - root.cs; y: 0;
        width: root.cs; height: root.cs;
        mouse-cursor: ne-resize;
        resize-top: true; resize-right: true;
        win-x <=> root.win-x; win-y <=> root.win-y;
        win-w <=> root.win-w; win-h <=> root.win-h;
        min-w: root.min-w; min-h: root.min-h;
    }

    // SE corner
    if !root.is-maximized : ResizeHandle {
        x: root.width - root.cs; y: root.height - root.cs;
        width: root.cs; height: root.cs;
        mouse-cursor: se-resize;
        resize-bottom: true; resize-right: true;
        win-x <=> root.win-x; win-y <=> root.win-y;
        win-w <=> root.win-w; win-h <=> root.win-h;
        min-w: root.min-w; min-h: root.min-h;
    }

    // SW corner
    if !root.is-maximized : ResizeHandle {
        x: 0; y: root.height - root.cs;
        width: root.cs; height: root.cs;
        mouse-cursor: sw-resize;
        resize-bottom: true; resize-left: true;
        win-x <=> root.win-x; win-y <=> root.win-y;
        win-w <=> root.win-w; win-h <=> root.win-h;
        min-w: root.min-w; min-h: root.min-h;
    }

    // NW corner
    if !root.is-maximized : ResizeHandle {
        x: 0; y: 0;
        width: root.cs; height: root.cs;
        mouse-cursor: nw-resize;
        resize-top: true; resize-left: true;
        win-x <=> root.win-x; win-y <=> root.win-y;
        win-w <=> root.win-w; win-h <=> root.win-h;
        min-w: root.min-w; min-h: root.min-h;
    }
}
