// WindowFrame — reusable window chrome with title bar and controls.
// Provides minimize, maximize/restore, and close buttons.
// Use @children to place content inside.

import { Theme } from "../theme.slint";

export component WindowFrame inherits Rectangle {
    in property <string> title: "";
    in property <string> icon-char: "";
    in property <color> icon-color: Theme.cyan;
    in-out property <bool> is-maximized: true;

    callback close();
    callback minimize();

    background: Theme.bg-deep;
    border-radius: root.is-maximized ? 0px : 10px;
    clip: true;
    drop-shadow-blur: root.is-maximized ? 0px : 20px;
    drop-shadow-color: root.is-maximized ? transparent : #000000aa;
    border-width: root.is-maximized ? 0px : 1px;
    border-color: root.is-maximized ? transparent : Theme.bg-elevated;

    animate border-radius, drop-shadow-blur, border-width { duration: 200ms; easing: ease-out; }

    VerticalLayout {
        spacing: 0px;

        // ── Title bar ──
        Rectangle {
            height: 36px;
            background: Theme.bg-surface;

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 0px;

                // Left: icon + title
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    horizontal-stretch: 1;

                    if root.icon-char != "" : Rectangle {
                        width: 22px;
                        height: 22px;
                        border-radius: 5px;
                        background: root.icon-color;

                        Text {
                            text: root.icon-char;
                            color: #ffffff;
                            font-size: 12px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    if root.title != "" : Text {
                        text: root.title;
                        color: Theme.text-secondary;
                        font-size: 13px;
                        font-weight: 500;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }

                // Right: window controls
                HorizontalLayout {
                    spacing: 0px;
                    alignment: end;

                    // Minimize
                    TouchArea {
                        width: 36px;
                        height: 36px;
                        clicked => { root.minimize(); }
                        Rectangle {
                            width: 100%; height: 100%;
                            background: parent.has-hover ? Theme.hover-fill-strong : transparent;
                            Text {
                                text: "─";
                                color: Theme.text-secondary;
                                font-size: 14px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Maximize / Restore
                    TouchArea {
                        width: 36px;
                        height: 36px;
                        clicked => { root.is-maximized = !root.is-maximized; }
                        Rectangle {
                            width: 100%; height: 100%;
                            background: parent.has-hover ? Theme.hover-fill-strong : transparent;
                            Text {
                                text: root.is-maximized ? "❐" : "□";
                                color: Theme.text-secondary;
                                font-size: 14px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Close
                    close-btn := TouchArea {
                        width: 36px;
                        height: 36px;
                        clicked => { root.close(); }
                        Rectangle {
                            width: 100%; height: 100%;
                            background: close-btn.has-hover ? #e05252 : transparent;
                            Text {
                                text: "✕";
                                color: close-btn.has-hover ? #ffffff : Theme.text-secondary;
                                font-size: 14px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }

        // Separator
        Rectangle { height: 1px; background: Theme.separator; }

        // Content area
        Rectangle {
            vertical-stretch: 1;
            clip: true;
            @children
        }
    }
}
