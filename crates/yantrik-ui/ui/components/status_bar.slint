// Status bar — 28px holographic top edge.
// Glassmorphic glass panel with breathing AI anchor, scanning glow line,
// holographic indicators. The neural network's always-visible spine.

import { Theme } from "../theme.slint";

export component StatusBar inherits Rectangle {
    in property <string> clock-text: "00:00";
    in property <string> companion-status: "idle";
    in property <bool> companion-online: true;
    in property <int> battery-level: 100;
    in property <bool> battery-charging: false;
    in property <bool> wifi-connected: false;
    in property <int> pending-count: 0;
    in property <int> whisper-hint-count: 0;

    callback anchor-clicked();
    callback queue-clicked();
    callback whisper-hint-clicked();
    callback settings-tapped();
    callback power-pressed();

    height: Theme.status-bar-height;

    // Glass background — translucent with depth
    background: @linear-gradient(180deg,
        #0c0b1090 0%,
        #0608100a 100%
    );

    // Animated scan phase
    property <float> scan-phase: 0;
    Timer {
        interval: 16ms;
        running: true;
        triggered => {
            scan-phase = mod(scan-phase + 0.002, 1.0);
        }
    }

    // Top edge highlight (glass rim)
    Rectangle {
        y: 0;
        width: 100%;
        height: 1px;
        background: @linear-gradient(90deg,
            transparent 5%,
            #ffffff08 30%,
            #ffffff10 50%,
            #ffffff08 70%,
            transparent 95%
        );
    }

    // Bottom glow line (holographic signature — animated)
    Rectangle {
        y: parent.height - 1px;
        width: 100%;
        height: 1px;
        background: @linear-gradient(90deg, transparent 5%, Theme.cyan-glow 50%, transparent 95%);
    }

    // Glow bloom behind the line
    Rectangle {
        y: parent.height - 4px;
        width: 100%;
        height: 8px;
        background: @linear-gradient(90deg, transparent 10%, Theme.tint-cyan 50%, transparent 90%);
    }

    // Scanning glow sweep — subtle holographic scanner
    Rectangle {
        y: parent.height - 2px;
        x: parent.width * scan-phase - parent.width * 0.15;
        width: parent.width * 0.15;
        height: 2px;
        background: @linear-gradient(90deg,
            transparent 0%,
            Theme.cyan 40%,
            Theme.holo-core 70%,
            transparent 100%
        );
        opacity: 0.5;
    }

    HorizontalLayout {
        padding-left: 14px;
        padding-right: 14px;

        // -- Left: Anchor dot + Clock --
        HorizontalLayout {
            horizontal-stretch: 1;
            spacing: 10px;
            alignment: start;

            // Anchor dot — holographic AI state indicator
            TouchArea {
                width: 24px;
                height: Theme.status-bar-height;
                clicked => { root.anchor-clicked(); }

                Rectangle {
                    property <float> breath-phase: 0;
                    Timer {
                        interval: 16ms;
                        running: true;
                        triggered => {
                            parent.breath-phase = mod(parent.breath-phase + 0.003, 1.0);
                        }
                    }

                    // Outer glow ring (breathing)
                    x: (parent.width - 18px) / 2;
                    y: (parent.height - 18px) / 2;
                    width: 18px;
                    height: 18px;
                    border-radius: 9px;
                    background: transparent;
                    border-width: root.companion-status == "thinking" ? 2px : 1px;
                    border-color: !root.companion-online ? Theme.color-emotional :
                                  root.companion-status == "thinking" ? Theme.amber :
                                  root.companion-status == "listening" ? Theme.cyan-light :
                                  Theme.cyan-dim;
                    opacity: !root.companion-online ? 0.6
                        : 0.4 + 0.3 * sin(breath-phase * 6.2832 * 1rad);
                    drop-shadow-blur: root.companion-status == "thinking" ? 8px : 4px;
                    drop-shadow-color: !root.companion-online ? #e86b6b40 :
                                       root.companion-status == "thinking" ? Theme.amber-glow : Theme.cyan-glow;

                    animate border-width { duration: 300ms; }
                    animate border-color { duration: 300ms; }
                    animate drop-shadow-blur { duration: 300ms; }

                    // Core dot
                    Rectangle {
                        x: (parent.width - 8px) / 2;
                        y: (parent.height - 8px) / 2;
                        width: 8px;
                        height: 8px;
                        border-radius: 4px;
                        background: !root.companion-online ? Theme.color-emotional :
                                    root.companion-status == "thinking" ? Theme.amber :
                                    root.companion-status == "listening" ? Theme.cyan-light :
                                    Theme.cyan;
                        drop-shadow-blur: 6px;
                        drop-shadow-color: !root.companion-online ? #e86b6b40 :
                                           root.companion-status == "thinking" ? Theme.amber-glow : Theme.cyan-glow;

                        animate background { duration: 300ms; }
                    }

                    // Secondary orbit dot (visible when thinking)
                    Rectangle {
                        property <float> orbit: breath-phase;
                        x: parent.width / 2 + 7px * cos(orbit * 6.2832 * 3.0 * 1rad) - 1.5px;
                        y: parent.height / 2 + 7px * sin(orbit * 6.2832 * 3.0 * 1rad) - 1.5px;
                        width: 3px;
                        height: 3px;
                        border-radius: 1.5px;
                        background: Theme.amber;
                        opacity: root.companion-status == "thinking" ? 0.7 : 0;
                        drop-shadow-blur: 4px;
                        drop-shadow-color: Theme.amber-glow;

                        animate opacity { duration: 200ms; }
                    }
                }
            }

            // Clock — holographic numerals
            Text {
                text: root.clock-text;
                color: Theme.text-secondary;
                font-size: 12px;
                font-weight: 600;
                letter-spacing: 2px;
                vertical-alignment: center;
            }
        }

        // -- Right: Power + Pending count + WiFi + Battery --
        HorizontalLayout {
            spacing: 14px;
            alignment: end;

            // Power button — holographic
            TouchArea {
                width: 22px;
                height: Theme.status-bar-height;
                clicked => { root.power-pressed(); }

                Rectangle {
                    x: (parent.width - 16px) / 2;
                    y: (parent.height - 16px) / 2;
                    width: 16px;
                    height: 16px;
                    border-radius: 8px;
                    background: transparent;
                    border-width: 1px;
                    border-color: parent.has-hover ? Theme.text-secondary : Theme.text-dim;

                    animate border-color { duration: 120ms; }

                    Text {
                        text: "\u{23fb}";
                        color: Theme.text-dim;
                        font-size: 9px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            // Whisper hint badge (low-pressure urges)
            if root.whisper-hint-count > 0 : TouchArea {
                width: whisper-badge.preferred-width + 4px;
                height: Theme.status-bar-height;
                clicked => { root.whisper-hint-clicked(); }

                whisper-badge := Rectangle {
                    width: max(18px, whisper-text.preferred-width + 10px);
                    height: 16px;
                    y: (parent.height - 16px) / 2;
                    border-radius: 8px;
                    background: Theme.cyan-dim;
                    drop-shadow-blur: 6px;
                    drop-shadow-color: Theme.cyan-glow;

                    whisper-text := Text {
                        text: root.whisper-hint-count;
                        color: Theme.bg-deep;
                        font-size: 9px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            // Pending count badge (Quiet Queue)
            if root.pending-count > 0 : TouchArea {
                width: queue-badge.preferred-width + 4px;
                height: Theme.status-bar-height;
                clicked => { root.queue-clicked(); }

                queue-badge := Rectangle {
                    width: max(18px, queue-text.preferred-width + 10px);
                    height: 16px;
                    y: (parent.height - 16px) / 2;
                    border-radius: 8px;
                    background: Theme.amber-dim;
                    drop-shadow-blur: 6px;
                    drop-shadow-color: Theme.amber-glow;

                    queue-text := Text {
                        text: root.pending-count;
                        color: Theme.bg-deep;
                        font-size: 9px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            // WiFi + Battery — tappable area opens Quick Settings
            TouchArea {
                height: Theme.status-bar-height;
                clicked => { root.settings-tapped(); }

                HorizontalLayout {
                    spacing: 12px;

                    // WiFi indicator — holographic rings
                    Rectangle {
                        width: 14px;
                        height: 14px;
                        y: (parent.height - 14px) / 2;
                        background: transparent;

                        // Outer arc
                        Rectangle {
                            x: 1px; y: 0;
                            width: 12px; height: 12px;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: root.wifi-connected ? Theme.cyan : Theme.text-dim;
                            background: transparent;
                            opacity: root.wifi-connected ? 0.7 : 0.2;
                        }
                        // Inner arc
                        Rectangle {
                            x: 3.5px; y: 3px;
                            width: 7px; height: 7px;
                            border-radius: 3.5px;
                            border-width: 1px;
                            border-color: root.wifi-connected ? Theme.cyan : Theme.text-dim;
                            background: transparent;
                            opacity: root.wifi-connected ? 0.6 : 0.15;
                        }
                        // Center dot
                        Rectangle {
                            x: 5.5px; y: 6px;
                            width: 3px; height: 3px;
                            border-radius: 1.5px;
                            background: root.wifi-connected ? Theme.cyan : Theme.text-dim;
                            opacity: root.wifi-connected ? 1.0 : 0.3;
                            drop-shadow-blur: root.wifi-connected ? 3px : 0;
                            drop-shadow-color: Theme.cyan-glow;
                        }
                    }

                    // Battery — holographic bar
                    HorizontalLayout {
                        spacing: 3px;

                        Rectangle {
                            width: 22px;
                            height: 10px;
                            y: (parent.height - 10px) / 2;
                            border-radius: 2px;
                            border-width: 1px;
                            border-color: root.battery-level <= 20 ? Theme.color-emotional : Theme.text-dim;
                            background: transparent;

                            // Fill
                            Rectangle {
                                x: 1.5px; y: 1.5px;
                                width: max(0px, (parent.width - 5px) * root.battery-level / 100);
                                height: parent.height - 5px;
                                border-radius: 1px;
                                background: root.battery-charging ? Theme.cyan :
                                            root.battery-level <= 20 ? Theme.color-emotional :
                                            root.battery-level <= 50 ? Theme.amber :
                                            Theme.cyan;
                                drop-shadow-blur: 2px;
                                drop-shadow-color: root.battery-charging ? Theme.cyan-glow :
                                                   root.battery-level <= 20 ? #e86b6b40 :
                                                   Theme.amber-glow;
                            }

                            // Terminal nub
                            Rectangle {
                                x: parent.width;
                                y: 2.5px;
                                width: 1.5px;
                                height: parent.height - 6px;
                                border-radius: 0.5px;
                                background: Theme.text-dim;
                                opacity: 0.5;
                            }
                        }

                        Text {
                            text: root.battery-level + "%";
                            color: root.battery-level <= 20 ? Theme.color-emotional : Theme.text-dim;
                            font-size: 9px;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}
