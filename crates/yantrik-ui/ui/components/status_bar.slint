// StatusBar — 32px precision instrument panel.
// 3-zone layout: Left (workspace/app context) | Center (AI ambient lane) | Right (indicators + clock)
// Design: calm, quiet, precise. No continuous animations, no glows.
// AI presence via a small accent dot — dormant/available/active states.

import { Theme } from "../theme.slint";

export component StatusBar inherits Rectangle {
    in property <string> clock-text: "00:00";
    in property <string> companion-status: "idle";       // idle, thinking, listening
    in property <bool> companion-online: true;
    in property <bool> battery-available: false;
    in property <int> battery-level: 100;
    in property <bool> battery-charging: false;
    in property <bool> wifi-connected: false;
    in property <int> pending-count: 0;
    in property <int> whisper-hint-count: 0;
    in property <bool> incognito-enabled: false;
    in property <bool> dnd-enabled: false;
    in property <string> active-project: "";
    // V61 — AI privacy indicator
    in property <string> ai-privacy-mode: "local";       // "local", "cloud", "hybrid"
    in property <string> ai-provider-label: "";
    in property <string> ai-fallback-banner: "";
    // V63 — AI context lane
    in property <string> ai-context-text: "";             // Center lane: "Processing...", "2 suggestions", etc.

    callback anchor-clicked();
    callback queue-clicked();
    callback whisper-hint-clicked();
    callback settings-tapped();
    callback power-pressed();
    callback ai-privacy-clicked();

    height: Theme.status-bar-height;
    background: Theme.bg-surface;

    // Bottom border — single subtle line
    Rectangle {
        y: parent.height - 1px;
        width: 100%;
        height: 1px;
        background: Theme.separator;
    }

    HorizontalLayout {
        padding-left: Theme.sp-4;
        padding-right: Theme.sp-4;

        // ── LEFT ZONE: AI dot + Project context ──
        HorizontalLayout {
            horizontal-stretch: 1;
            spacing: Theme.sp-3;
            alignment: start;

            // AI status dot — 6px, simple state-based coloring
            TouchArea {
                width: 24px;
                height: Theme.status-bar-height;
                mouse-cursor: pointer;
                clicked => { root.anchor-clicked(); }

                Rectangle {
                    x: (parent.width - 6px) / 2;
                    y: (parent.height - 6px) / 2;
                    width: 6px;
                    height: 6px;
                    border-radius: 3px;
                    background: !root.companion-online ? Theme.color-danger
                              : root.companion-status == "thinking" ? Theme.accent
                              : root.companion-status == "listening" ? Theme.accent-light
                              : Theme.text-dim;  // dormant: neutral

                    // Gentle pulse only when actively thinking
                    opacity: root.companion-status == "thinking" ? ai-pulse-opacity : 1.0;
                    property <float> ai-pulse-opacity: 0.6;
                    animate ai-pulse-opacity { duration: 2000ms; }
                    // Pulse driven by timer only when thinking
                    Timer {
                        interval: 2000ms;
                        running: root.companion-status == "thinking";
                        triggered => {
                            parent.ai-pulse-opacity = parent.ai-pulse-opacity > 0.8 ? 0.5 : 1.0;
                        }
                    }

                    animate background { duration: Theme.dur-normal; }
                }
            }

            // Project indicator
            if root.active-project != "" : Rectangle {
                width: proj-text.preferred-width + Theme.sp-3;
                height: 18px;
                y: (Theme.status-bar-height - self.height) / 2;
                border-radius: Theme.r-pill;
                background: Theme.tint-accent;
                border-width: 1px;
                border-color: Theme.border-subtle;

                proj-text := Text {
                    text: root.active-project;
                    color: Theme.accent;
                    font-size: Theme.fs-micro;
                    font-weight: Theme.fw-micro;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        // ── CENTER ZONE: AI context lane ──
        HorizontalLayout {
            horizontal-stretch: 1;
            alignment: center;

            // Show AI context only when there's something to say
            if root.ai-context-text != "" : Text {
                text: root.ai-context-text;
                color: Theme.text-dim;
                font-size: Theme.fs-caption;
                font-weight: Theme.fw-caption;
                horizontal-alignment: center;
                vertical-alignment: center;
                overflow: elide;
                max-width: 300px;
            }
        }

        // ── RIGHT ZONE: Badges + Indicators + Clock ──
        HorizontalLayout {
            horizontal-stretch: 1;
            spacing: Theme.sp-3;
            alignment: end;

            // AI Privacy badge
            TouchArea {
                width: ai-priv-row.preferred-width + Theme.sp-3;
                height: Theme.status-bar-height;
                mouse-cursor: pointer;
                clicked => { root.ai-privacy-clicked(); }

                Rectangle {
                    width: parent.width;
                    height: 18px;
                    y: (parent.height - 18px) / 2;
                    border-radius: Theme.r-pill;
                    background: root.ai-privacy-mode == "local" ? Theme.color-success.transparentize(92%)
                              : root.ai-privacy-mode == "cloud" ? Theme.holo-blue.transparentize(92%)
                              : Theme.color-warning.transparentize(92%);
                    border-width: 1px;
                    border-color: root.ai-privacy-mode == "local" ? Theme.color-success.transparentize(81%)
                                : root.ai-privacy-mode == "cloud" ? Theme.holo-blue.transparentize(81%)
                                : Theme.color-warning.transparentize(81%);

                    ai-priv-row := HorizontalLayout {
                        padding-left: 6px;
                        padding-right: 6px;
                        spacing: 3px;
                        alignment: center;

                        Text {
                            text: root.ai-privacy-mode == "local" ? "🔒"
                                : root.ai-privacy-mode == "cloud" ? "☁"
                                : "🔄";
                            font-size: 8px;
                            vertical-alignment: center;
                        }
                        Text {
                            text: root.ai-privacy-mode == "local" ? "Local"
                                : root.ai-privacy-mode == "cloud" ? "Cloud"
                                : "Hybrid";
                            color: root.ai-privacy-mode == "local" ? Theme.color-success
                                 : root.ai-privacy-mode == "cloud" ? Theme.holo-blue
                                 : Theme.color-warning;
                            font-size: 8px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }
                }
            }

            // Power button
            TouchArea {
                width: 24px;
                height: Theme.status-bar-height;
                mouse-cursor: pointer;
                property <bool> hovered: self.has-hover;
                clicked => { root.power-pressed(); }

                Rectangle {
                    x: (parent.width - 18px) / 2;
                    y: (parent.height - 18px) / 2;
                    width: 18px;
                    height: 18px;
                    border-radius: 9px;
                    background: parent.hovered ? Theme.hover-fill : transparent;
                    border-width: 1px;
                    border-color: parent.hovered ? Theme.text-secondary : Theme.border-default;
                    animate background { duration: Theme.dur-fast; }
                    animate border-color { duration: Theme.dur-fast; }

                    Text {
                        text: "⏻";
                        color: Theme.text-dim;
                        font-size: 10px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            // Whisper hint badge
            if root.whisper-hint-count > 0 : TouchArea {
                width: whisper-badge.preferred-width + 4px;
                height: Theme.status-bar-height;
                mouse-cursor: pointer;
                clicked => { root.whisper-hint-clicked(); }

                whisper-badge := Rectangle {
                    width: max(18px, whisper-text.preferred-width + 10px);
                    height: 18px;
                    y: (parent.height - 18px) / 2;
                    border-radius: Theme.r-pill;
                    background: Theme.accent-dim;

                    whisper-text := Text {
                        text: root.whisper-hint-count;
                        color: Theme.text-on-accent;
                        font-size: Theme.fs-micro;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            // Incognito badge
            if root.incognito-enabled : Rectangle {
                width: inc-text.preferred-width + 10px;
                height: 18px;
                y: (Theme.status-bar-height - 18px) / 2;
                border-radius: Theme.r-pill;
                background: Theme.color-danger-dim;

                inc-text := Text {
                    text: "INC";
                    color: Theme.color-danger;
                    font-size: 8px;
                    font-weight: 700;
                    letter-spacing: 0.5px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            // DND badge
            if root.dnd-enabled : Rectangle {
                width: dnd-text.preferred-width + 10px;
                height: 18px;
                y: (Theme.status-bar-height - 18px) / 2;
                border-radius: Theme.r-pill;
                background: Theme.color-warning-dim;

                dnd-text := Text {
                    text: "DND";
                    color: Theme.color-warning;
                    font-size: 8px;
                    font-weight: 700;
                    letter-spacing: 0.5px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            // Pending queue badge
            if root.pending-count > 0 : TouchArea {
                width: queue-badge.preferred-width + 4px;
                height: Theme.status-bar-height;
                mouse-cursor: pointer;
                clicked => { root.queue-clicked(); }

                queue-badge := Rectangle {
                    width: max(18px, queue-text.preferred-width + 10px);
                    height: 18px;
                    y: (parent.height - 18px) / 2;
                    border-radius: Theme.r-pill;
                    background: Theme.amber-dim;

                    queue-text := Text {
                        text: root.pending-count;
                        color: Theme.amber;
                        font-size: Theme.fs-micro;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            // WiFi + Battery → opens Quick Settings
            TouchArea {
                height: Theme.status-bar-height;
                mouse-cursor: pointer;
                clicked => { root.settings-tapped(); }

                HorizontalLayout {
                    spacing: Theme.sp-2;

                    // WiFi indicator — simple icon
                    Text {
                        text: root.wifi-connected ? "📶" : "📵";
                        color: root.wifi-connected ? Theme.text-secondary : Theme.text-dim;
                        font-size: 11px;
                        vertical-alignment: center;
                    }

                    // Battery (when hardware present)
                    if root.battery-available : HorizontalLayout {
                        spacing: 3px;

                        Rectangle {
                            width: 20px;
                            height: 10px;
                            y: (parent.height - 10px) / 2;
                            border-radius: 2px;
                            border-width: 1px;
                            border-color: root.battery-level <= 20 ? Theme.color-danger : Theme.text-dim;
                            background: transparent;

                            // Fill bar
                            Rectangle {
                                x: 1.5px; y: 1.5px;
                                width: max(0px, (parent.width - 5px) * root.battery-level / 100);
                                height: parent.height - 5px;
                                border-radius: 1px;
                                background: root.battery-charging ? Theme.color-success
                                          : root.battery-level <= 20 ? Theme.color-danger
                                          : root.battery-level <= 50 ? Theme.color-warning
                                          : Theme.text-secondary;
                            }

                            // Terminal nub
                            Rectangle {
                                x: parent.width;
                                y: 2.5px;
                                width: 1.5px;
                                height: parent.height - 6px;
                                border-radius: 0.5px;
                                background: Theme.text-dim;
                            }
                        }

                        Text {
                            text: root.battery-level + "%";
                            color: root.battery-level <= 20 ? Theme.color-danger : Theme.text-dim;
                            font-size: 9px;
                            vertical-alignment: center;
                        }
                    }
                }
            }

            // Clock — right-most element
            Text {
                text: root.clock-text;
                color: Theme.text-secondary;
                font-size: Theme.fs-caption;
                font-weight: Theme.fw-body-strong;
                vertical-alignment: center;
            }
        }
    }
}
