// Status pill — memory count + online indicator.

import { Theme } from "../theme.slint";

export component StatusPill inherits Rectangle {
    in property <int> memory-count: 0;
    in property <bool> is-online: true;

    height: 28px;
    width: self.preferred-width;
    border-radius: Theme.radius-pill;
    background: Theme.bg-card;
    border-width: 1px;
    border-color: #ffffff08;

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 6px;
        alignment: center;

        // Status dot (cyan glow when online)
        Rectangle {
            width: 6px;
            height: 6px;
            border-radius: 3px;
            background: is-online ? Theme.cyan : Theme.text-dim;
            drop-shadow-blur: is-online ? 4px : 0;
            drop-shadow-color: Theme.cyan-glow;

            property <float> pulse-phase: 0;
            opacity: is-online ? 0.5 + 0.5 * sin(pulse-phase * 6.2832 * 1rad) : 1.0;

            Timer {
                interval: 16ms;
                running: is-online;
                triggered => {
                    parent.pulse-phase = mod(parent.pulse-phase + 0.002, 1.0);
                }
            }
        }

        // Memory count
        Text {
            text: memory-count + " mem";
            color: Theme.text-secondary;
            font-size: Theme.font-small;
            vertical-alignment: center;
        }
    }
}
