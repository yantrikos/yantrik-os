// App Grid — full-screen app launcher overlay.
// Shows all installed apps in a scrollable grid with search.
// Triggered by Super+A or dock gesture.

import { Theme } from "../theme.slint";

export struct AppGridItem {
    app-id: string,
    name: string,
    icon-char: string,
}

export component AppGrid inherits Rectangle {
    in-out property <bool> is-open: false;
    in property <[AppGridItem]> apps: [];

    callback launch-app(string);
    callback close();
    callback search-changed(string);

    width: 100%;
    height: 100%;

    property <int> columns: 4;
    property <length> cell-size: 140px;
    property <length> grid-width: root.columns * root.cell-size + (root.columns - 1) * 16px + 48px;

    // Backdrop (click to close)
    if root.is-open : TouchArea {
        width: 100%;
        height: 100%;
        clicked => { root.is-open = false; root.close(); }

        Rectangle {
            width: 100%;
            height: 100%;
            background: Theme.overlay-backdrop;
        }
    }

    // Centered panel
    if root.is-open : Rectangle {
        x: (parent.width - root.grid-width) / 2;
        y: (parent.height - panel-height) / 2;
        property <int> rows: (root.apps.length + root.columns - 1) / root.columns;
        property <length> panel-height: min(self.rows * (root.cell-size + 12px) + 190px, parent.height - 80px);
        width: root.grid-width;
        height: panel-height;
        background: Theme.bg-elevated;
        border-radius: 16px;
        border-width: 1px;
        border-color: Theme.border-subtle;
        drop-shadow-blur: 32px;
        drop-shadow-color: Theme.overlay-shadow;
        clip: true;

        // Block click-through
        TouchArea { width: 100%; height: 100%; }

        VerticalLayout {
            padding: 20px;
            spacing: 12px;

            // Header
            Text {
                text: "Applications";
                color: Theme.text-primary;
                font-size: Theme.font-title;
                font-weight: 500;
                horizontal-alignment: center;
            }

            // Search bar
            Rectangle {
                height: 40px;
                background: Theme.bg-deep;
                border-radius: 12px;
                border-width: 1px;
                border-color: search-input.has-focus ? Theme.cyan-dim : Theme.border-subtle;

                HorizontalLayout {
                    padding-left: 14px;
                    padding-right: 14px;
                    spacing: 10px;

                    // Search icon
                    Text {
                        text: "\u{2315}";
                        color: Theme.text-dim;
                        font-size: 16px;
                        vertical-alignment: center;
                    }

                    search-input := TextInput {
                        vertical-alignment: center;
                        font-size: Theme.font-body;
                        color: Theme.text-primary;
                        horizontal-stretch: 1;

                        edited => {
                            root.search-changed(self.text);
                        }

                        // Clear on close
                    }

                    // Result count
                    Text {
                        text: root.apps.length + " apps";
                        color: Theme.text-dim;
                        font-size: 11px;
                        vertical-alignment: center;
                    }
                }
            }

            Rectangle { height: 1px; background: Theme.separator; }

            // Empty state
            if root.apps.length == 0 : VerticalLayout {
                vertical-stretch: 1;
                alignment: center;
                spacing: 8px;

                Text {
                    text: "No apps found";
                    color: Theme.text-dim;
                    font-size: Theme.font-body;
                    horizontal-alignment: center;
                }
                Text {
                    text: "Try a different search term";
                    color: Theme.text-dim;
                    font-size: Theme.font-small;
                    horizontal-alignment: center;
                }
            }

            // Scrollable app grid
            if root.apps.length > 0 : Flickable {
                vertical-stretch: 1;
                viewport-height: ((root.apps.length + root.columns - 1) / root.columns) * (root.cell-size + 12px);

                for app[idx] in root.apps : TouchArea {
                    x: Math.mod(idx, root.columns) * (root.cell-size + 16px) + 4px;
                    y: Math.floor(idx / root.columns) * (root.cell-size + 12px);
                    width: root.cell-size;
                    height: root.cell-size;

                    clicked => {
                        root.launch-app(app.app-id);
                        root.is-open = false;
                        root.close();
                    }

                    cell := Rectangle {
                        width: 100%;
                        height: 100%;
                        border-radius: 14px;
                        background: parent.has-hover ? Theme.hover-fill : transparent;
                        property <bool> hovered: parent.has-hover;

                        VerticalLayout {
                            alignment: center;
                            spacing: 10px;
                            padding: 12px;

                            // Icon badge
                            Rectangle {
                                width: 52px;
                                height: 52px;
                                border-radius: 14px;
                                background: Theme.bg-card;
                                border-width: 1px;
                                border-color: cell.hovered ? Theme.cyan-dim : Theme.border-subtle;

                                Text {
                                    text: app.icon-char;
                                    color: Theme.cyan;
                                    font-size: 20px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            // App name
                            Text {
                                text: app.name;
                                color: Theme.text-primary;
                                font-size: 12px;
                                font-weight: 500;
                                horizontal-alignment: center;
                                overflow: elide;
                                max-width: root.cell-size - 24px;
                            }
                        }
                    }
                }
            }
        }
    }
}
