// Neural Particle Field — drifting neurons with living glow.
// Deep-space neural network backdrop. Visible nebula clouds + bright neuron dots.
// The AI's nervous system, rendered as ambient light.
//
// State-driven behaviors:
//   is-thinking → phase 2.7x faster, neuron amplitude tightens to 30%
//   has-urges   → amber nebulae glow brighter
//   intensity   → master opacity (dims when Lens opens, focus mode)

import { Theme } from "../theme.slint";

export component ParticleField inherits Rectangle {
    in property <bool> active: true;
    in property <float> intensity: 1.0;
    in property <bool> is-thinking: false;
    in property <bool> has-urges: false;

    // Ambient Intelligence inputs
    in property <float> sentiment: 0.0;        // -1.0 (frustrated) to 1.0 (happy)
    in property <float> cognitive-load: 0.0;    // 0.0 (idle) to 1.0 (overloaded)
    in property <float> time-of-day: 0.5;      // 0.0 (midnight) to 1.0 (noon)

    // Derived: amplitude scale (1.0 normal, 0.3 when thinking → neurons tighten)
    // Cognitive load also tightens orbits
    property <float> amp: is-thinking ? 0.3 : (1.0 - cognitive-load * 0.4);
    // Derived: amber boost when urges pending
    property <float> urge-glow: has-urges ? 0.15 : 0.0;

    // Ambient: sentiment-driven color modifiers
    property <float> cyan-boost: Math.max(0.0, sentiment * 0.3);
    property <float> amber-warmth: sentiment > 0.3 ? 0.2 : (sentiment < -0.3 ? -0.1 : 0.0);
    property <float> purple-shift: sentiment < -0.3 ? 0.25 : 0.0;

    // Ambient: time-of-day brightness (dim at night, bright at noon)
    property <float> day-brightness: 0.6 + time-of-day * 0.4;  // 0.6 at night → 1.0 at noon

    // Ambient: cognitive load speed multiplier
    property <float> load-speed: 1.0 + cognitive-load * 0.8;  // 1.0x to 1.8x

    background: transparent;
    clip: true;

    property <float> phase: 0;

    Timer {
        interval: 16ms;
        running: root.active;
        triggered => {
            // 2.7x faster when thinking, cognitive load also speeds up
            phase = mod(phase + (is-thinking ? 0.004 : 0.0015 * load-speed), 1.0);
        }
    }

    // ══════════════════════════════════════════════
    // Layer 1: Nebula clouds (large soft glow regions)
    // These give the background depth and color.
    // ══════════════════════════════════════════════

    // Nebula A — upper-left (cyan — brightens with positive sentiment)
    Rectangle {
        x: parent.width * 0.18 - 200px;
        y: parent.height * 0.12 - 175px;
        width: 400px; height: 350px;
        border-radius: 175px;
        background: @radial-gradient(circle, Theme.cyan.transparentize(90%) 0%, Theme.cyan.transparentize(96%) 40%, transparent 70%);
        opacity: intensity * day-brightness * (0.6 + cyan-boost + 0.3 * sin(phase * 4.398 * 1rad));
    }

    // Nebula B — right-center (amber — glows with urges, warms with positive sentiment)
    Rectangle {
        x: parent.width * 0.72 - 200px;
        y: parent.height * 0.4 - 225px;
        width: 400px; height: 450px;
        border-radius: 200px;
        background: @radial-gradient(circle, Theme.amber.transparentize(90%) 0%, Theme.amber.transparentize(96%) 40%, transparent 70%);
        opacity: intensity * day-brightness * (0.5 + urge-glow + amber-warmth + 0.3 * sin(phase * 5.655 * 1rad));
    }

    // Nebula C — lower-left (cyan — brightens with positive sentiment)
    Rectangle {
        x: parent.width * 0.08 - 175px;
        y: parent.height * 0.65 - 200px;
        width: 350px; height: 400px;
        border-radius: 175px;
        background: @radial-gradient(circle, Theme.cyan.transparentize(91%) 0%, Theme.cyan.transparentize(97%) 40%, transparent 70%);
        opacity: intensity * day-brightness * (0.5 + cyan-boost + 0.25 * sin(phase * 6.912 * 1rad));
    }

    // Nebula D — top-right (purple — grows with negative sentiment, frustration glow)
    Rectangle {
        x: parent.width * 0.82 - 175px;
        y: parent.height * 0.05 - 100px;
        width: 350px; height: 200px;
        border-radius: 100px;
        background: @radial-gradient(circle, Theme.color-pattern.transparentize(94%) 0%, transparent 60%);
        opacity: intensity * day-brightness * (0.45 + purple-shift + 0.2 * sin(phase * 3.770 * 1rad));
    }

    // Nebula E — bottom-center (amber — urges + sentiment warmth near orb)
    Rectangle {
        x: parent.width * 0.42 - 225px;
        y: parent.height * 0.75 - 175px;
        width: 450px; height: 350px;
        border-radius: 175px;
        background: @radial-gradient(circle, Theme.tint-amber 0%, Theme.amber.transparentize(97%) 30%, transparent 65%);
        opacity: intensity * day-brightness * (0.5 + urge-glow + amber-warmth + 0.3 * sin(phase * 5.027 * 1rad));
    }

    // Nebula F — center-wide (very subtle cyan wash — brightens with positivity)
    Rectangle {
        x: parent.width * 0.35 - 300px;
        y: parent.height * 0.30 - 200px;
        width: 600px; height: 400px;
        border-radius: 200px;
        background: @radial-gradient(circle, Theme.cyan.transparentize(95%) 0%, transparent 65%);
        opacity: intensity * day-brightness * (0.4 + cyan-boost * 0.5 + 0.2 * sin(phase * 4.712 * 1rad));
    }

    // Nebula G — stress glow (deep red, only visible when frustrated + high load)
    Rectangle {
        x: parent.width * 0.50 - 250px;
        y: parent.height * 0.50 - 200px;
        width: 500px; height: 400px;
        border-radius: 200px;
        background: @radial-gradient(circle, Theme.color-emotional.transparentize(95%) 0%, transparent 60%);
        opacity: intensity * Math.max(0.0, -sentiment) * cognitive-load * (0.4 + 0.2 * sin(phase * 7.854 * 1rad));
    }

    // ══════════════════════════════════════════════
    // Layer 2: Neurons (bright glowing dots with halos)
    // Each is a small dot with a large soft drop-shadow.
    // When thinking: amplitude tightens (amp=0.3), neurons cluster.
    // ══════════════════════════════════════════════

    // Neuron 1 — upper left
    Rectangle {
        x: parent.width * (0.15 + 0.06 * amp * sin(phase * 6.283 * 1rad));
        y: parent.height * (0.12 + 0.04 * amp * cos(phase * 8.168 * 1rad));
        width: 5px; height: 5px; border-radius: 2.5px;
        background: Theme.cyan;
        opacity: intensity * (0.35 + 0.3 * sin(phase * 12.566 * 1rad));
        drop-shadow-blur: 20px;
        drop-shadow-color: Theme.cyan.transparentize(62%);
    }

    // Neuron 2 — upper right
    Rectangle {
        x: parent.width * (0.78 + 0.05 * amp * sin(phase * 7.540 * 1rad));
        y: parent.height * (0.08 + 0.05 * amp * cos(phase * 5.027 * 1rad));
        width: 4px; height: 4px; border-radius: 2px;
        background: Theme.amber;
        opacity: intensity * (0.3 + 0.25 * sin(phase * 10.996 * 1rad));
        drop-shadow-blur: 16px;
        drop-shadow-color: Theme.amber.transparentize(62%);
    }

    // Neuron 3 — mid left (larger)
    Rectangle {
        x: parent.width * (0.08 + 0.04 * amp * cos(phase * 4.712 * 1rad));
        y: parent.height * (0.42 + 0.06 * amp * sin(phase * 6.912 * 1rad));
        width: 6px; height: 6px; border-radius: 3px;
        background: Theme.cyan;
        opacity: intensity * (0.4 + 0.3 * sin(phase * 8.796 * 1rad));
        drop-shadow-blur: 24px;
        drop-shadow-color: Theme.cyan.transparentize(62%);
    }

    // Neuron 4 — center-high
    Rectangle {
        x: parent.width * (0.45 + 0.07 * amp * sin(phase * 5.341 * 1rad));
        y: parent.height * (0.22 + 0.03 * amp * cos(phase * 9.425 * 1rad));
        width: 5px; height: 5px; border-radius: 2.5px;
        background: Theme.amber;
        opacity: intensity * (0.3 + 0.25 * sin(phase * 7.225 * 1rad));
        drop-shadow-blur: 18px;
        drop-shadow-color: Theme.amber.transparentize(62%);
    }

    // Neuron 5 — right side
    Rectangle {
        x: parent.width * (0.88 + 0.03 * amp * sin(phase * 8.482 * 1rad));
        y: parent.height * (0.55 + 0.05 * amp * cos(phase * 6.283 * 1rad));
        width: 4px; height: 4px; border-radius: 2px;
        background: Theme.cyan;
        opacity: intensity * (0.35 + 0.25 * sin(phase * 11.310 * 1rad));
        drop-shadow-blur: 16px;
        drop-shadow-color: Theme.cyan.transparentize(62%);
    }

    // Neuron 6 — lower-left
    Rectangle {
        x: parent.width * (0.22 + 0.05 * amp * cos(phase * 7.854 * 1rad));
        y: parent.height * (0.72 + 0.04 * amp * sin(phase * 5.655 * 1rad));
        width: 5px; height: 5px; border-radius: 2.5px;
        background: Theme.cyan-light;
        opacity: intensity * (0.35 + 0.3 * sin(phase * 9.111 * 1rad));
        drop-shadow-blur: 22px;
        drop-shadow-color: Theme.cyan.transparentize(62%);
    }

    // Neuron 7 — bottom center
    Rectangle {
        x: parent.width * (0.52 + 0.06 * amp * sin(phase * 4.398 * 1rad));
        y: parent.height * (0.82 + 0.03 * amp * cos(phase * 7.540 * 1rad));
        width: 4px; height: 4px; border-radius: 2px;
        background: Theme.amber;
        opacity: intensity * (0.25 + 0.2 * sin(phase * 13.195 * 1rad));
        drop-shadow-blur: 14px;
        drop-shadow-color: Theme.amber.transparentize(62%);
    }

    // Neuron 8 — lower right (larger, prominent)
    Rectangle {
        x: parent.width * (0.75 + 0.04 * amp * cos(phase * 6.597 * 1rad));
        y: parent.height * (0.68 + 0.05 * amp * sin(phase * 8.168 * 1rad));
        width: 7px; height: 7px; border-radius: 3.5px;
        background: Theme.cyan;
        opacity: intensity * (0.4 + 0.3 * sin(phase * 6.597 * 1rad));
        drop-shadow-blur: 28px;
        drop-shadow-color: Theme.cyan.transparentize(62%);
    }

    // Neuron 9 — far right
    Rectangle {
        x: parent.width * (0.92 + 0.02 * amp * sin(phase * 5.969 * 1rad));
        y: parent.height * (0.35 + 0.04 * amp * cos(phase * 7.225 * 1rad));
        width: 4px; height: 4px; border-radius: 2px;
        background: Theme.amber;
        opacity: intensity * (0.25 + 0.2 * sin(phase * 10.367 * 1rad));
        drop-shadow-blur: 14px;
        drop-shadow-color: Theme.amber.transparentize(62%);
    }

    // Neuron 10 — center (hero neuron, biggest glow)
    Rectangle {
        x: parent.width * (0.50 + 0.08 * amp * sin(phase * 3.770 * 1rad));
        y: parent.height * (0.50 + 0.06 * amp * cos(phase * 4.712 * 1rad));
        width: 8px; height: 8px; border-radius: 4px;
        background: Theme.cyan-light;
        opacity: intensity * (0.25 + 0.2 * sin(phase * 5.027 * 1rad));
        drop-shadow-blur: 35px;
        drop-shadow-color: Theme.cyan.transparentize(69%);
    }

    // Neuron 11 — upper drift
    Rectangle {
        x: parent.width * (0.32 + 0.05 * amp * cos(phase * 9.111 * 1rad));
        y: parent.height * (0.05 + 0.03 * amp * sin(phase * 6.283 * 1rad));
        width: 4px; height: 4px; border-radius: 2px;
        background: Theme.cyan;
        opacity: intensity * (0.3 + 0.2 * sin(phase * 8.482 * 1rad));
        drop-shadow-blur: 14px;
        drop-shadow-color: Theme.cyan.transparentize(69%);
    }

    // Neuron 12 — mid right low
    Rectangle {
        x: parent.width * (0.65 + 0.04 * amp * sin(phase * 7.854 * 1rad));
        y: parent.height * (0.88 + 0.02 * amp * cos(phase * 5.341 * 1rad));
        width: 5px; height: 5px; border-radius: 2.5px;
        background: Theme.amber;
        opacity: intensity * (0.3 + 0.25 * sin(phase * 7.540 * 1rad));
        drop-shadow-blur: 18px;
        drop-shadow-color: Theme.amber.transparentize(62%);
    }

    // Neuron 13 — left center
    Rectangle {
        x: parent.width * (0.03 + 0.03 * amp * sin(phase * 5.341 * 1rad));
        y: parent.height * (0.28 + 0.05 * amp * cos(phase * 7.854 * 1rad));
        width: 4px; height: 4px; border-radius: 2px;
        background: Theme.amber;
        opacity: intensity * (0.25 + 0.2 * sin(phase * 9.425 * 1rad));
        drop-shadow-blur: 14px;
        drop-shadow-color: Theme.amber.transparentize(69%);
    }

    // Neuron 14 — center-right high
    Rectangle {
        x: parent.width * (0.62 + 0.04 * amp * cos(phase * 6.283 * 1rad));
        y: parent.height * (0.18 + 0.04 * amp * sin(phase * 8.168 * 1rad));
        width: 5px; height: 5px; border-radius: 2.5px;
        background: Theme.cyan;
        opacity: intensity * (0.3 + 0.25 * sin(phase * 7.540 * 1rad));
        drop-shadow-blur: 20px;
        drop-shadow-color: Theme.cyan.transparentize(69%);
    }

    // Neuron 15 — lower center-left
    Rectangle {
        x: parent.width * (0.35 + 0.05 * amp * sin(phase * 7.225 * 1rad));
        y: parent.height * (0.78 + 0.03 * amp * cos(phase * 5.655 * 1rad));
        width: 6px; height: 6px; border-radius: 3px;
        background: Theme.cyan;
        opacity: intensity * (0.35 + 0.25 * sin(phase * 6.597 * 1rad));
        drop-shadow-blur: 22px;
        drop-shadow-color: Theme.cyan.transparentize(62%);
    }

    // ══════════════════════════════════════════════
    // Layer 3: Stress neurons (appear under high cognitive load)
    // Small red-amber dots that pulse rapidly when overloaded.
    // ══════════════════════════════════════════════

    // Stress neuron 1 — upper center
    Rectangle {
        x: parent.width * (0.40 + 0.03 * sin(phase * 11.310 * 1rad));
        y: parent.height * (0.30 + 0.02 * cos(phase * 13.195 * 1rad));
        width: 4px; height: 4px; border-radius: 2px;
        background: Theme.color-conflict;
        opacity: intensity * cognitive-load * Math.max(0.0, cognitive-load - 0.5) * 2.0 * (0.5 + 0.5 * sin(phase * 18.850 * 1rad));
        drop-shadow-blur: 12px;
        drop-shadow-color: Theme.color-emotional.transparentize(69%);
    }

    // Stress neuron 2 — right mid
    Rectangle {
        x: parent.width * (0.68 + 0.02 * cos(phase * 12.566 * 1rad));
        y: parent.height * (0.45 + 0.03 * sin(phase * 10.996 * 1rad));
        width: 3px; height: 3px; border-radius: 1.5px;
        background: Theme.color-emotional;
        opacity: intensity * cognitive-load * Math.max(0.0, cognitive-load - 0.6) * 2.5 * (0.4 + 0.6 * sin(phase * 20.420 * 1rad));
        drop-shadow-blur: 10px;
        drop-shadow-color: Theme.color-emotional.transparentize(75%);
    }

    // Stress neuron 3 — lower left (only at extreme load)
    Rectangle {
        x: parent.width * (0.25 + 0.02 * sin(phase * 14.137 * 1rad));
        y: parent.height * (0.60 + 0.02 * cos(phase * 11.938 * 1rad));
        width: 3px; height: 3px; border-radius: 1.5px;
        background: Theme.color-conflict;
        opacity: intensity * cognitive-load * Math.max(0.0, cognitive-load - 0.7) * 3.3 * (0.3 + 0.7 * sin(phase * 22.000 * 1rad));
        drop-shadow-blur: 10px;
        drop-shadow-color: Theme.color-emotional.transparentize(75%);
    }
}
