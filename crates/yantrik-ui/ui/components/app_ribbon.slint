// App Ribbon — shared toolbar components for office apps (yDoc, ySheets, yPresent).
// Compact 2-row adaptive ribbon inspired by modern productivity apps.
// Row 1 (36px): Tab strip + quick actions (Save, Undo, Redo)
// Row 2 (44px): Grouped command band that swaps based on active tab

import { Theme } from "../theme.slint";

// ── Ribbon Tool Button — standard 32x32 icon button ──
export component RibbonToolButton inherits Rectangle {
    in property <string> label;
    in property <bool> is-active: false;
    in property <bool> is-toggle: false;
    in property <string> tooltip-text: "";
    callback clicked();

    width: 32px;
    height: 32px;
    border-radius: 6px;
    background: is-active ? Theme.cyan.transparentize(81%)
        : ta.has-hover ? Theme.tint-cyan
        : transparent;

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    // Tooltip
    if ta.has-hover && tooltip-text != "" : Rectangle {
        property <length> tw: tt.preferred-width + 14px;
        x: (parent.width - self.tw) / 2;
        y: -28px;
        width: self.tw;
        height: 22px;
        border-radius: 5px;
        background: Theme.bg-deep.transparentize(12%);
        border-width: 1px;
        border-color: Theme.hover-fill-strong;
        drop-shadow-blur: 6px;
        drop-shadow-color: Theme.overlay-backdrop;

        tt := Text {
            text: root.tooltip-text;
            color: Theme.text-secondary;
            font-size: 10px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    Text {
        text: root.label;
        color: root.is-active ? Theme.accent : (ta.has-hover ? Theme.text-primary : Theme.text-secondary);
        font-size: 13px;
        font-weight: root.is-active ? 700 : 500;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

// ── Ribbon Tool Button Wide — for text labels like "Table", "Export" ──
export component RibbonToolButtonWide inherits Rectangle {
    in property <string> label;
    in property <bool> is-active: false;
    in property <string> tooltip-text: "";
    callback clicked();

    horizontal-stretch: 0;
    min-width: 40px;
    height: 32px;
    border-radius: 6px;
    background: is-active ? Theme.cyan.transparentize(81%)
        : ta.has-hover ? Theme.tint-cyan
        : transparent;

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding-left: 9px;
        padding-right: 9px;
        alignment: center;

        lbl := Text {
            text: root.label;
            color: root.is-active ? Theme.accent : (ta.has-hover ? Theme.text-primary : Theme.text-secondary);
            font-size: 12px;
            font-weight: root.is-active ? 600 : 500;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

// ── Group Separator — thin vertical divider between tool groups ──
export component RibbonSeparator inherits Rectangle {
    width: 1px;
    height: 28px;
    background: Theme.border-default;
}

// ── Tab Button — for the tab strip row ──
export component RibbonTabButton inherits Rectangle {
    in property <string> label;
    in property <bool> is-active: false;
    callback clicked();

    horizontal-stretch: 0;
    min-width: 44px;
    height: 36px;
    background: transparent;

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        alignment: center;

        tab-label := Text {
            text: root.label;
            color: root.is-active ? Theme.text-primary
                : ta.has-hover ? Theme.text-secondary
                : Theme.text-dim;
            font-size: 12px;
            font-weight: root.is-active ? 600 : 400;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    // Active underline — 2px cyan
    Rectangle {
        y: parent.height - 2px;
        width: 100%;
        height: 2px;
        background: root.is-active ? Theme.accent : transparent;
        border-radius: 1px;
    }
}

// ── Quick Action Button — compact 28x28 for Save/Undo/Redo in tab row ──
export component RibbonQuickAction inherits Rectangle {
    in property <string> label;
    in property <string> tooltip-text: "";
    callback clicked();

    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: ta.has-hover ? Theme.hover-fill-strong : transparent;

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    // Tooltip
    if ta.has-hover && tooltip-text != "" : Rectangle {
        property <length> tw: tt.preferred-width + 14px;
        x: (parent.width - self.tw) / 2;
        y: -28px;
        width: self.tw;
        height: 22px;
        border-radius: 5px;
        background: Theme.bg-deep.transparentize(12%);
        border-width: 1px;
        border-color: Theme.hover-fill-strong;

        tt := Text {
            text: root.tooltip-text;
            color: Theme.text-secondary;
            font-size: 10px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    Text {
        text: root.label;
        color: ta.has-hover ? Theme.text-primary : Theme.text-dim;
        font-size: 12px;
        font-weight: 500;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

// ── Accent Action Button — colored CTA (Present, Export PDF, etc.) ──
export component RibbonAccentButton inherits Rectangle {
    in property <string> label;
    in property <string> icon: "";
    in property <color> accent-color: Theme.accent;
    callback clicked();

    horizontal-stretch: 0;
    min-width: 72px;
    height: 30px;
    border-radius: 6px;
    background: ta.has-hover ? root.accent-color.brighter(15%) : root.accent-color;

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    btn-layout := HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 5px;
        alignment: center;

        if icon != "" : Text {
            text: root.icon;
            color: Theme.text-on-accent;
            font-size: 11px;
            vertical-alignment: center;
        }

        Text {
            text: root.label;
            color: Theme.text-on-accent;
            font-size: 12px;
            font-weight: 600;
            vertical-alignment: center;
        }
    }
}

// ── Dropdown-style Button — shows current value, cycles on click ──
export component RibbonDropdown inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <string> tooltip-text: "";
    callback clicked();

    horizontal-stretch: 0;
    min-width: 72px;
    height: 30px;
    border-radius: 6px;
    background: ta.has-hover ? Theme.hover-fill : Theme.bg-card;
    border-width: 1px;
    border-color: Theme.border-subtle;

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    dd-layout := HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 4px;
        alignment: center;

        if label != "" : Text {
            text: root.label;
            color: Theme.text-dim;
            font-size: 10px;
            vertical-alignment: center;
        }

        Text {
            text: root.value;
            color: Theme.text-primary;
            font-size: 11px;
            font-weight: 500;
            vertical-alignment: center;
        }

        Text {
            text: "▾";
            color: Theme.text-dim;
            font-size: 9px;
            vertical-alignment: center;
        }
    }
}

// ── Color Swatch Button — small color indicator with dropdown ──
export component RibbonColorButton inherits Rectangle {
    in property <string> label;
    in property <color> swatch-color: Theme.amber;
    in property <bool> is-open: false;
    in property <string> tooltip-text: "";
    callback clicked();

    width: 32px;
    height: 32px;
    border-radius: 6px;
    background: ta.has-hover ? Theme.tint-cyan : transparent;

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    VerticalLayout {
        alignment: center;
        spacing: 1px;

        Text {
            text: root.label;
            font-size: 12px;
            font-weight: 700;
            color: Theme.text-primary;
            horizontal-alignment: center;
        }

        Rectangle {
            width: 16px;
            height: 3px;
            x: (parent.width - 16px) / 2;
            background: root.swatch-color;
            border-radius: 1px;
        }
    }
}

// ── Group Label — tiny uppercase label above a tool group ──
export component RibbonGroupLabel inherits Rectangle {
    in property <string> label;

    horizontal-stretch: 0;
    min-width: 20px;
    height: 32px;

    HorizontalLayout {
        padding-left: 2px;
        padding-right: 2px;
        alignment: center;

        gl := Text {
            text: root.label;
            color: Theme.text-dim;
            font-size: 9px;
            font-weight: 600;
            letter-spacing: 0.5px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}
