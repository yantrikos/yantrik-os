// Music Player — enterprise-grade music library, playlists, queue, and playback.
// Screen 20. Four-panel layout: Playlists | Library | Now Playing | Queue.
// Uses mpv as backend via IPC socket.

import { Theme } from "theme.slint";

// Data model for a track in the library or queue
export struct MusicTrackData {
    title: string,
    artist: string,
    album: string,
    genre: string,
    duration-text: string,
    duration-secs: float,
    path: string,
    is-current: bool,
    format-info: string,    // e.g. "FLAC 44.1kHz"
    bitrate: string,        // e.g. "320 kbps"
}

// Playlist data
export struct MusicPlaylistData {
    name: string,
    track-count: int,
    total-duration: string,
    is-active: bool,
}

// Album data for grid view
export struct MusicAlbumData {
    name: string,
    artist: string,
    track-count: int,
    year: string,
}

// Artist data
export struct MusicArtistData {
    name: string,
    album-count: int,
    track-count: int,
}

// Genre data
export struct MusicGenreData {
    name: string,
    track-count: int,
}

// Scan folder data
export struct MusicScanFolderData {
    path: string,
    track-count: int,
    is-scanning: bool,
}

// Library browse categories
export enum MusicCategory {
    all-songs,
    artists,
    albums,
    genres,
}

// Repeat mode
export enum MusicRepeatMode {
    off,
    one,
    all,
}

export component MusicPlayerScreen inherits Rectangle {
    background: Theme.bg-deep;

    // Library data
    in property <[MusicTrackData]> library-tracks: [];
    in property <[MusicArtistData]> library-artists: [];
    in property <[MusicAlbumData]> library-albums: [];
    in property <[MusicGenreData]> library-genres: [];
    in property <int> library-track-count: 0;

    // Browse state
    in-out property <int> browse-category: 0;  // 0=songs, 1=artists, 2=albums, 3=genres
    in-out property <string> browse-filter: "";
    in property <string> browse-sub-header: "";

    // Now playing
    in property <string> now-title: "";
    in property <string> now-artist: "";
    in property <string> now-album: "";
    in property <string> now-genre: "";
    in property <string> now-format-info: "";
    in property <string> now-bitrate: "";
    in property <bool> is-playing: false;
    in property <float> progress: 0.0;
    in property <string> time-current: "0:00";
    in property <string> time-total: "0:00";
    in property <float> volume: 0.8;
    in property <bool> volume-muted: false;

    // Queue
    in property <[MusicTrackData]> queue-tracks: [];
    in property <int> queue-current-index: -1;

    // Modes
    in property <bool> shuffle-on: false;
    in property <int> repeat-mode: 0;  // 0=off, 1=one, 2=all
    in property <float> playback-speed: 1.0;

    // Playlists
    in property <[MusicPlaylistData]> playlists: [];
    in property <int> active-playlist-index: -1;
    in-out property <bool> playlist-panel-open: true;

    // Scan folders
    in property <[MusicScanFolderData]> scan-folders: [];
    in property <bool> is-scanning: false;
    in property <float> scan-progress: 0.0;
    in property <string> scan-status: "";

    // Folder watch
    in property <bool> music-folder-watch-active: false;
    in property <string> music-folder-watch-status: "";

    // Equalizer presets
    in property <int> music-equalizer-preset: 0;  // 0=flat, 1=bass boost, 2=vocal, 3=treble
    in-out property <bool> music-show-equalizer: false;

    // Internal UI state
    in-out property <bool> show-add-playlist-dialog: false;
    in-out property <string> new-playlist-name: "";
    in-out property <bool> show-scan-folders-dialog: false;
    in-out property <bool> show-speed-popup: false;
    in-out property <int> rename-playlist-index: -1;
    in-out property <string> rename-playlist-text: "";

    // Callbacks — playback
    callback play-pause();
    callback stop();
    callback next-track();
    callback prev-track();
    callback seek(float);
    callback volume-changed(float);
    callback toggle-mute();
    callback toggle-shuffle();
    callback cycle-repeat();     // cycles off -> all -> one -> off
    callback set-playback-speed(float);
    callback play-track-index(int);
    callback queue-play-index(int);

    // Callbacks — library browse
    callback browse-category-changed(int);
    callback browse-filter-changed(string);
    callback browse-item-selected(string);

    // Callbacks — queue management
    callback add-to-queue(int);
    callback play-next(int);              // insert after current in queue
    callback queue-remove(int);
    callback queue-move-up(int);
    callback queue-move-down(int);
    callback queue-clear();

    // Callbacks — playlists
    callback playlist-create(string);
    callback playlist-rename(int, string);
    callback playlist-delete(int);
    callback playlist-select(int);
    callback playlist-add-track(int, int);   // playlist-idx, library-track-idx
    callback playlist-remove-track(int, int); // playlist-idx, track-idx

    // Callbacks — scan folders
    callback scan-add-folder(string);
    callback scan-remove-folder(int);
    callback scan-rescan();

    // Callbacks — folder watch + equalizer
    callback music-toggle-folder-watch();
    callback music-set-equalizer(int);

    // AI Assist
    in property <bool> ai-is-working: false;
    in property <string> ai-response: "";
    in-out property <bool> ai-panel-open: false;
    callback ai-explain-pressed();
    callback ai-dismiss();

    // ─────── Main Layout ───────
    VerticalLayout {
        spacing: 0px;

        // Top bar with scan status
        if root.is-scanning : Rectangle {
            height: 28px;
            background: Theme.tint-accent;

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                spacing: 8px;

                Text {
                    text: root.scan-status != "" ? root.scan-status : "Scanning library...";
                    color: Theme.accent;
                    font-size: 11px;
                    vertical-alignment: center;
                }

                Rectangle { horizontal-stretch: 1; }

                // Progress bar
                Rectangle {
                    width: 120px;
                    height: 4px;
                    y: 12px;
                    border-radius: 2px;
                    background: Theme.bg-elevated;

                    Rectangle {
                        width: parent.width * root.scan-progress;
                        height: 100%;
                        border-radius: 2px;
                        background: Theme.accent;
                    }
                }
            }
        }

        HorizontalLayout {
            spacing: 0px;

            // ═══ Playlist sidebar ═══
            if root.playlist-panel-open : Rectangle {
                width: 180px;
                background: Theme.bg-surface;

                VerticalLayout {
                    spacing: 0px;

                    // Playlist header
                    Rectangle {
                        height: 44px;
                        background: Theme.bg-card;

                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 8px;
                            spacing: 6px;

                            Text {
                                text: "Playlists";
                                color: Theme.text-primary;
                                font-size: 13px;
                                font-weight: 600;
                                vertical-alignment: center;
                            }

                            Rectangle { horizontal-stretch: 1; }

                            // Add playlist button
                            TouchArea {
                                width: 28px;
                                height: 28px;
                                clicked => {
                                    root.new-playlist-name = "";
                                    root.show-add-playlist-dialog = true;
                                }

                                Rectangle {
                                    width: 28px; height: 28px;
                                    border-radius: 14px;
                                    background: parent.has-hover ? Theme.hover-fill-strong : transparent;

                                    Text {
                                        text: "+";
                                        color: Theme.accent;
                                        font-size: 16px;
                                        font-weight: 700;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            // Scan folders button
                            TouchArea {
                                width: 28px;
                                height: 28px;
                                clicked => { root.show-scan-folders-dialog = !root.show-scan-folders-dialog; }

                                Rectangle {
                                    width: 28px; height: 28px;
                                    border-radius: 14px;
                                    background: parent.has-hover ? Theme.hover-fill-strong : transparent;

                                    Text {
                                        text: "F";
                                        color: Theme.text-secondary;
                                        font-size: 11px;
                                        font-weight: 600;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }

                    Rectangle { height: 1px; background: Theme.separator; }

                    // "All Music" item
                    TouchArea {
                        height: 36px;
                        clicked => { root.playlist-select(-1); }

                        Rectangle {
                            background: root.active-playlist-index == -1 ? Theme.tint-accent : (parent.has-hover ? Theme.hover-fill : transparent);

                            HorizontalLayout {
                                padding-left: 12px;
                                padding-right: 12px;
                                spacing: 8px;

                                Text {
                                    text: "M";
                                    color: root.active-playlist-index == -1 ? Theme.accent : Theme.text-dim;
                                    font-size: 12px;
                                    width: 18px;
                                    vertical-alignment: center;
                                    horizontal-alignment: center;
                                }

                                Text {
                                    text: "All Music";
                                    color: root.active-playlist-index == -1 ? Theme.accent : Theme.text-primary;
                                    font-size: 12px;
                                    font-weight: root.active-playlist-index == -1 ? 600 : 400;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                            }
                        }
                    }

                    Rectangle { height: 1px; background: Theme.separator; }

                    // Playlist list
                    Flickable {
                        viewport-height: pl-col.preferred-height;

                        pl-col := VerticalLayout {
                            spacing: 0px;

                            for playlist[pidx] in root.playlists :
                            TouchArea {
                                height: 52px;
                                clicked => { root.playlist-select(pidx); }

                                Rectangle {
                                    background: root.active-playlist-index == pidx
                                        ? Theme.tint-accent
                                        : (parent.has-hover ? Theme.hover-fill : transparent);

                                    HorizontalLayout {
                                        padding-left: 12px;
                                        padding-right: 8px;
                                        spacing: 8px;

                                        // Playlist icon
                                        Rectangle {
                                            width: 24px;
                                            height: 24px;
                                            y: 14px;
                                            border-radius: 4px;
                                            background: root.active-playlist-index == pidx ? Theme.accent-dim : Theme.bg-elevated;

                                            Text {
                                                text: "L";
                                                color: root.active-playlist-index == pidx ? Theme.text-primary : Theme.text-dim;
                                                font-size: 11px;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }

                                        // Name + info
                                        VerticalLayout {
                                            alignment: center;
                                            spacing: 2px;

                                            // Inline rename or display
                                            if root.rename-playlist-index == pidx : TextInput {
                                                font-size: 12px;
                                                color: Theme.text-primary;
                                                text <=> root.rename-playlist-text;
                                                accepted => {
                                                    root.playlist-rename(pidx, root.rename-playlist-text);
                                                    root.rename-playlist-index = -1;
                                                }
                                            }

                                            if root.rename-playlist-index != pidx : Text {
                                                text: playlist.name;
                                                color: root.active-playlist-index == pidx ? Theme.accent : Theme.text-primary;
                                                font-size: 12px;
                                                font-weight: root.active-playlist-index == pidx ? 600 : 400;
                                                overflow: elide;
                                            }

                                            Text {
                                                text: playlist.track-count > 0
                                                    ? "\{playlist.track-count} tracks \u{2022} \{playlist.total-duration}"
                                                    : "Empty";
                                                color: Theme.text-dim;
                                                font-size: 10px;
                                                overflow: elide;
                                            }
                                        }

                                        // Action buttons (visible on active)
                                        if root.active-playlist-index == pidx : VerticalLayout {
                                            alignment: center;
                                            spacing: 2px;

                                            HorizontalLayout {
                                                spacing: 2px;

                                                // Rename
                                                TouchArea {
                                                    width: 20px;
                                                    height: 20px;
                                                    clicked => {
                                                        root.rename-playlist-text = playlist.name;
                                                        root.rename-playlist-index = pidx;
                                                    }

                                                    Rectangle {
                                                        width: 20px; height: 20px;
                                                        border-radius: 4px;
                                                        background: parent.has-hover ? Theme.hover-fill-strong : transparent;
                                                        Text {
                                                            text: "E";
                                                            color: Theme.text-secondary;
                                                            font-size: 9px;
                                                            horizontal-alignment: center;
                                                            vertical-alignment: center;
                                                        }
                                                    }
                                                }

                                                // Delete
                                                TouchArea {
                                                    width: 20px;
                                                    height: 20px;
                                                    clicked => { root.playlist-delete(pidx); }

                                                    Rectangle {
                                                        width: 20px; height: 20px;
                                                        border-radius: 4px;
                                                        background: parent.has-hover ? #ff444430 : transparent;
                                                        Text {
                                                            text: "\u{2715}";
                                                            color: Theme.text-dim;
                                                            font-size: 9px;
                                                            horizontal-alignment: center;
                                                            vertical-alignment: center;
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // Add playlist dialog (inline)
                    if root.show-add-playlist-dialog : Rectangle {
                        height: 64px;
                        background: Theme.bg-card;
                        border-width: 1px;
                        border-color: Theme.accent.transparentize(70%);

                        VerticalLayout {
                            padding: 8px;
                            spacing: 6px;

                            Rectangle {
                                height: 28px;
                                border-radius: 6px;
                                background: Theme.bg-input;

                                pl-name-input := TextInput {
                                    x: 8px;
                                    width: parent.width - 16px;
                                    font-size: 12px;
                                    color: Theme.text-primary;
                                    vertical-alignment: center;
                                    text <=> root.new-playlist-name;
                                    accepted => {
                                        if root.new-playlist-name != "" {
                                            root.playlist-create(root.new-playlist-name);
                                            root.show-add-playlist-dialog = false;
                                        }
                                    }
                                }
                            }

                            HorizontalLayout {
                                spacing: 6px;
                                alignment: end;

                                TouchArea {
                                    width: 48px;
                                    height: 22px;
                                    clicked => { root.show-add-playlist-dialog = false; }

                                    Rectangle {
                                        border-radius: 4px;
                                        background: parent.has-hover ? Theme.hover-fill : transparent;
                                        Text {
                                            text: "Cancel";
                                            color: Theme.text-secondary;
                                            font-size: 10px;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }

                                TouchArea {
                                    width: 48px;
                                    height: 22px;
                                    clicked => {
                                        if root.new-playlist-name != "" {
                                            root.playlist-create(root.new-playlist-name);
                                            root.show-add-playlist-dialog = false;
                                        }
                                    }

                                    Rectangle {
                                        border-radius: 4px;
                                        background: Theme.accent;
                                        Text {
                                            text: "Create";
                                            color: Theme.bg-deep;
                                            font-size: 10px;
                                            font-weight: 600;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // Scan folders dialog
                    if root.show-scan-folders-dialog : Rectangle {
                        background: Theme.bg-card;
                        border-width: 1px;
                        border-color: Theme.border-subtle;
                        max-height: 200px;

                        VerticalLayout {
                            padding: 8px;
                            spacing: 6px;

                            HorizontalLayout {
                                spacing: 6px;

                                Text {
                                    text: "Music Folders";
                                    color: Theme.text-primary;
                                    font-size: 12px;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                }

                                Rectangle { horizontal-stretch: 1; }

                                TouchArea {
                                    width: 52px;
                                    height: 22px;
                                    clicked => { root.scan-rescan(); }

                                    Rectangle {
                                        border-radius: 4px;
                                        background: Theme.accent;
                                        Text {
                                            text: "Rescan";
                                            color: Theme.bg-deep;
                                            font-size: 10px;
                                            font-weight: 600;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }

                            for sfolder[sidx] in root.scan-folders :
                            Rectangle {
                                height: 28px;
                                border-radius: 4px;
                                background: Theme.bg-elevated;

                                HorizontalLayout {
                                    padding-left: 8px;
                                    padding-right: 4px;
                                    spacing: 6px;

                                    Text {
                                        text: sfolder.path;
                                        color: Theme.text-primary;
                                        font-size: 11px;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }

                                    Text {
                                        text: "\{sfolder.track-count}";
                                        color: Theme.text-dim;
                                        font-size: 10px;
                                        vertical-alignment: center;
                                        width: 28px;
                                        horizontal-alignment: right;
                                    }

                                    TouchArea {
                                        width: 20px;
                                        height: 20px;
                                        clicked => { root.scan-remove-folder(sidx); }
                                        Rectangle {
                                            width: 20px; height: 20px;
                                            border-radius: 4px;
                                            background: parent.has-hover ? #ff444430 : transparent;
                                            Text {
                                                text: "\u{2715}";
                                                color: Theme.text-dim;
                                                font-size: 9px;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                }
                            }

                            // Add folder input
                            Rectangle {
                                height: 28px;
                                border-radius: 6px;
                                background: Theme.bg-input;

                                scan-folder-input := TextInput {
                                    x: 8px;
                                    width: parent.width - 16px;
                                    font-size: 11px;
                                    color: Theme.text-primary;
                                    vertical-alignment: center;
                                    accepted => {
                                        if self.text != "" {
                                            root.scan-add-folder(self.text);
                                            self.text = "";
                                        }
                                    }
                                }
                            }

                            // Folder watch toggle
                            Rectangle {
                                height: 32px;
                                border-radius: 4px;
                                background: Theme.bg-elevated;

                                HorizontalLayout {
                                    padding-left: 8px;
                                    padding-right: 8px;
                                    spacing: 8px;

                                    Text {
                                        text: "Watch folders";
                                        color: Theme.text-primary;
                                        font-size: 11px;
                                        vertical-alignment: center;
                                    }

                                    Rectangle { horizontal-stretch: 1; }

                                    // Toggle switch
                                    TouchArea {
                                        width: 36px;
                                        height: 20px;
                                        clicked => { root.music-toggle-folder-watch(); }

                                        Rectangle {
                                            width: 36px; height: 18px; y: 1px;
                                            border-radius: 9px;
                                            background: root.music-folder-watch-active ? Theme.accent : Theme.bg-card;
                                            border-width: 1px;
                                            border-color: root.music-folder-watch-active ? Theme.accent : Theme.border-subtle;

                                            Rectangle {
                                                x: root.music-folder-watch-active ? 18px : 2px;
                                                y: 2px;
                                                width: 14px;
                                                height: 14px;
                                                border-radius: 7px;
                                                background: root.music-folder-watch-active ? Theme.text-primary : Theme.text-dim;
                                                animate x { duration: 150ms; }
                                            }
                                        }
                                    }
                                }
                            }

                            // Watch status
                            if root.music-folder-watch-status != "" : Text {
                                text: root.music-folder-watch-status;
                                color: Theme.text-dim;
                                font-size: 10px;
                                horizontal-alignment: left;
                            }
                        }
                    }
                }
            }

            // Playlist panel toggle
            TouchArea {
                width: 14px;
                clicked => { root.playlist-panel-open = !root.playlist-panel-open; }

                Rectangle {
                    width: 14px;
                    background: parent.has-hover ? Theme.hover-fill : Theme.bg-surface;
                    border-width: 0px;

                    Text {
                        text: root.playlist-panel-open ? "<" : ">";
                        color: Theme.text-dim;
                        font-size: 10px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            // Separator
            Rectangle { width: 1px; background: Theme.separator; }

            // ═══ Left panel: Library Browser ═══
            Rectangle {
                width: 260px;
                background: Theme.bg-surface;

                VerticalLayout {
                    spacing: 0px;

                    // Search bar
                    Rectangle {
                        height: 44px;
                        background: Theme.bg-card;

                        Rectangle {
                            x: 10px;
                            y: 7px;
                            width: parent.width - 20px;
                            height: 30px;
                            border-radius: 15px;
                            background: Theme.bg-input;

                            HorizontalLayout {
                                padding-left: 12px;
                                padding-right: 8px;
                                spacing: 8px;

                                Text {
                                    text: "Q";
                                    color: Theme.text-dim;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                    width: 14px;
                                }

                                lib-search := TextInput {
                                    font-size: 12px;
                                    color: Theme.text-primary;
                                    vertical-alignment: center;
                                    text <=> root.browse-filter;
                                    accepted => { root.browse-filter-changed(self.text); }
                                    edited => { root.browse-filter-changed(self.text); }
                                }

                                // Clear search
                                if root.browse-filter != "" : TouchArea {
                                    width: 20px;
                                    height: 20px;
                                    clicked => {
                                        root.browse-filter = "";
                                        root.browse-filter-changed("");
                                    }

                                    Rectangle {
                                        width: 20px; height: 20px;
                                        border-radius: 10px;
                                        background: parent.has-hover ? Theme.hover-fill-strong : transparent;
                                        Text {
                                            text: "\u{2715}";
                                            color: Theme.text-dim;
                                            font-size: 10px;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // Category tabs
                    Rectangle {
                        height: 34px;
                        background: Theme.bg-card;

                        HorizontalLayout {
                            padding-left: 6px;
                            padding-right: 6px;
                            spacing: 3px;

                            for cat-label[idx] in ["Songs", "Artists", "Albums", "Genres"]:
                            TouchArea {
                                height: 34px;
                                clicked => { root.browse-category = idx; root.browse-category-changed(idx); }

                                Rectangle {
                                    height: 26px;
                                    y: 4px;
                                    border-radius: 13px;
                                    background: root.browse-category == idx ? Theme.accent : transparent;

                                    Text {
                                        text: cat-label;
                                        color: root.browse-category == idx ? Theme.bg-deep : Theme.text-secondary;
                                        font-size: 11px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        font-weight: root.browse-category == idx ? 600 : 400;
                                    }
                                }
                            }
                        }
                    }

                    Rectangle { height: 1px; background: Theme.separator; }

                    // Sub-header (when browsing artist/album/genre)
                    if root.browse-sub-header != "" : Rectangle {
                        height: 32px;
                        background: Theme.bg-card;

                        HorizontalLayout {
                            padding-left: 12px;
                            spacing: 8px;

                            TouchArea {
                                width: 24px;
                                height: 32px;
                                clicked => { root.browse-item-selected(""); }
                                Text {
                                    text: "<";
                                    color: Theme.accent;
                                    font-size: 14px;
                                    vertical-alignment: center;
                                    horizontal-alignment: center;
                                }
                            }

                            Text {
                                text: root.browse-sub-header;
                                color: Theme.text-primary;
                                font-size: 12px;
                                vertical-alignment: center;
                                overflow: elide;
                                font-weight: 500;
                            }
                        }
                    }

                    // Track count
                    Rectangle {
                        height: 22px;
                        background: Theme.bg-surface;

                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;

                            Text {
                                text: root.library-track-count > 0
                                    ? "\{root.library-track-count} tracks"
                                    : "No tracks found";
                                color: Theme.text-dim;
                                font-size: 10px;
                                vertical-alignment: center;
                            }

                            Rectangle { horizontal-stretch: 1; }

                            // Add all to queue
                            if root.library-track-count > 0 : TouchArea {
                                width: 40px;
                                height: 22px;
                                clicked => { root.add-to-queue(-1); } // -1 = add all

                                Text {
                                    text: "+All";
                                    color: parent.has-hover ? Theme.accent : Theme.text-dim;
                                    font-size: 10px;
                                    horizontal-alignment: right;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    // Track/item list (scrollable)
                    Flickable {
                        viewport-height: lib-col.preferred-height;

                        lib-col := VerticalLayout {
                            spacing: 0px;

                            // ── Artists list ──
                            if root.browse-category == 1 && root.browse-sub-header == "" :
                            VerticalLayout {
                                spacing: 0px;
                                for artist-item[idx] in root.library-artists :
                                TouchArea {
                                    height: 44px;
                                    clicked => { root.browse-item-selected(artist-item.name); }

                                    Rectangle {
                                        background: parent.has-hover ? Theme.hover-fill : transparent;

                                        HorizontalLayout {
                                            padding-left: 12px;
                                            padding-right: 12px;
                                            spacing: 8px;

                                            Rectangle {
                                                width: 30px;
                                                height: 30px;
                                                y: 7px;
                                                border-radius: 15px;
                                                background: Theme.accent-dim;

                                                Text {
                                                    text: "A";
                                                    color: Theme.text-primary;
                                                    font-size: 12px;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                            }

                                            VerticalLayout {
                                                alignment: center;
                                                spacing: 2px;

                                                Text {
                                                    text: artist-item.name;
                                                    color: Theme.text-primary;
                                                    font-size: 12px;
                                                    overflow: elide;
                                                }

                                                Text {
                                                    text: artist-item.album-count > 0
                                                        ? "\{artist-item.track-count} tracks \u{2022} \{artist-item.album-count} albums"
                                                        : "\{artist-item.track-count} tracks";
                                                    color: Theme.text-dim;
                                                    font-size: 10px;
                                                    overflow: elide;
                                                }
                                            }
                                        }
                                    }
                                }
                            }

                            // ── Albums grid ──
                            if root.browse-category == 2 && root.browse-sub-header == "" :
                            VerticalLayout {
                                spacing: 0px;
                                for album-item[idx] in root.library-albums :
                                TouchArea {
                                    height: 56px;
                                    clicked => { root.browse-item-selected(album-item.name); }

                                    Rectangle {
                                        background: parent.has-hover ? Theme.hover-fill : transparent;

                                        HorizontalLayout {
                                            padding-left: 12px;
                                            padding-right: 12px;
                                            spacing: 10px;

                                            // Album art placeholder
                                            Rectangle {
                                                width: 40px;
                                                height: 40px;
                                                y: 8px;
                                                border-radius: 4px;
                                                background: Theme.bg-elevated;
                                                border-width: 1px;
                                                border-color: Theme.border-subtle;

                                                Text {
                                                    text: "D";
                                                    color: Theme.accent-dim;
                                                    font-size: 16px;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                            }

                                            VerticalLayout {
                                                alignment: center;
                                                spacing: 2px;

                                                Text {
                                                    text: album-item.name;
                                                    color: Theme.text-primary;
                                                    font-size: 12px;
                                                    overflow: elide;
                                                    font-weight: 500;
                                                }

                                                Text {
                                                    text: album-item.artist;
                                                    color: Theme.text-secondary;
                                                    font-size: 11px;
                                                    overflow: elide;
                                                }

                                                Text {
                                                    text: album-item.track-count > 0
                                                        ? "\{album-item.track-count} tracks"
                                                        : "";
                                                    color: Theme.text-dim;
                                                    font-size: 10px;
                                                }
                                            }
                                        }
                                    }
                                }
                            }

                            // ── Genres list ──
                            if root.browse-category == 3 && root.browse-sub-header == "" :
                            VerticalLayout {
                                spacing: 0px;
                                for genre-item[idx] in root.library-genres :
                                TouchArea {
                                    height: 38px;
                                    clicked => { root.browse-item-selected(genre-item.name); }

                                    Rectangle {
                                        background: parent.has-hover ? Theme.hover-fill : transparent;

                                        HorizontalLayout {
                                            padding-left: 12px;
                                            padding-right: 12px;
                                            spacing: 8px;

                                            Rectangle {
                                                width: 24px;
                                                height: 24px;
                                                y: 7px;
                                                border-radius: 12px;
                                                background: Theme.bg-elevated;

                                                Text {
                                                    text: "G";
                                                    color: Theme.accent-dim;
                                                    font-size: 11px;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                            }

                                            Text {
                                                text: genre-item.name;
                                                color: Theme.text-primary;
                                                font-size: 12px;
                                                vertical-alignment: center;
                                                overflow: elide;
                                            }

                                            Rectangle { horizontal-stretch: 1; }

                                            // Count badge
                                            Rectangle {
                                                width: 32px;
                                                height: 18px;
                                                y: 10px;
                                                border-radius: 9px;
                                                background: Theme.bg-elevated;

                                                Text {
                                                    text: "\{genre-item.track-count}";
                                                    color: Theme.text-dim;
                                                    font-size: 10px;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                            }
                                        }
                                    }
                                }
                            }

                            // ── Songs list (All Songs, or filtered by artist/album/genre) ──
                            if root.browse-category == 0 || root.browse-sub-header != "" :
                            VerticalLayout {
                                spacing: 0px;
                                for track[idx] in root.library-tracks :
                                TouchArea {
                                    height: 48px;
                                    clicked => { root.play-track-index(idx); }

                                    Rectangle {
                                        background: track.is-current
                                            ? Theme.tint-accent
                                            : (parent.has-hover ? Theme.hover-fill : transparent);

                                        HorizontalLayout {
                                            padding-left: 10px;
                                            padding-right: 6px;
                                            spacing: 6px;

                                            // Track number / playing indicator
                                            Rectangle {
                                                width: 22px;
                                                height: 48px;

                                                Text {
                                                    text: track.is-current ? ">" : "\{idx + 1}";
                                                    color: track.is-current ? Theme.accent : Theme.text-dim;
                                                    font-size: 11px;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                            }

                                            // Title + artist
                                            VerticalLayout {
                                                alignment: center;
                                                spacing: 2px;

                                                Text {
                                                    text: track.title;
                                                    color: track.is-current ? Theme.accent : Theme.text-primary;
                                                    font-size: 12px;
                                                    overflow: elide;
                                                    font-weight: track.is-current ? 600 : 400;
                                                }
                                                Text {
                                                    text: track.artist;
                                                    color: Theme.text-secondary;
                                                    font-size: 10px;
                                                    overflow: elide;
                                                }
                                            }

                                            // Action buttons
                                            VerticalLayout {
                                                alignment: center;

                                                HorizontalLayout {
                                                    spacing: 2px;

                                                    // Play next
                                                    TouchArea {
                                                        width: 20px;
                                                        height: 20px;
                                                        clicked => { root.play-next(idx); }

                                                        Rectangle {
                                                            width: 20px; height: 20px;
                                                            border-radius: 4px;
                                                            background: parent.has-hover ? Theme.hover-fill-strong : transparent;
                                                            Text {
                                                                text: "N";
                                                                color: Theme.text-dim;
                                                                font-size: 9px;
                                                                horizontal-alignment: center;
                                                                vertical-alignment: center;
                                                            }
                                                        }
                                                    }

                                                    // Add to queue
                                                    TouchArea {
                                                        width: 20px;
                                                        height: 20px;
                                                        clicked => { root.add-to-queue(idx); }

                                                        Rectangle {
                                                            width: 20px; height: 20px;
                                                            border-radius: 4px;
                                                            background: parent.has-hover ? Theme.hover-fill-strong : transparent;
                                                            Text {
                                                                text: "+";
                                                                color: Theme.text-dim;
                                                                font-size: 12px;
                                                                horizontal-alignment: center;
                                                                vertical-alignment: center;
                                                            }
                                                        }
                                                    }
                                                }
                                            }

                                            // Duration
                                            Text {
                                                text: track.duration-text;
                                                color: Theme.text-dim;
                                                font-size: 10px;
                                                width: 34px;
                                                horizontal-alignment: right;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }

            // Separator
            Rectangle { width: 1px; background: Theme.separator; }

            // ═══ Center panel: Now Playing ═══
            Rectangle {
                horizontal-stretch: 1;
                background: Theme.bg-deep;

                VerticalLayout {
                    spacing: 0px;

                    // Hero area
                    Rectangle {
                        vertical-stretch: 1;

                        VerticalLayout {
                            alignment: center;
                            spacing: 12px;
                            padding: 24px;

                            // Album art placeholder
                            Rectangle {
                                width: 180px;
                                height: 180px;
                                x: (parent.width - 180px) / 2;
                                border-radius: 12px;
                                background: Theme.bg-card;
                                border-width: 1px;
                                border-color: Theme.border-subtle;

                                // Pulsing glow when playing
                                property <float> pulse-phase: 0;
                                Timer {
                                    interval: 16ms;
                                    running: root.is-playing;
                                    triggered => {
                                        parent.pulse-phase = mod(parent.pulse-phase + 0.02, 1.0);
                                    }
                                }

                                Rectangle {
                                    width: 180px;
                                    height: 180px;
                                    border-radius: 12px;
                                    background: @radial-gradient(circle,
                                        Theme.accent-glow 0%,
                                        transparent 70%
                                    );
                                    opacity: root.is-playing
                                        ? 0.4 + 0.2 * sin(parent.pulse-phase * 6.2832 * 1rad)
                                        : 0.1;
                                }

                                // Vinyl record icon
                                Rectangle {
                                    x: 40px; y: 40px;
                                    width: 100px;
                                    height: 100px;
                                    border-radius: 50px;
                                    background: Theme.bg-elevated;
                                    border-width: 2px;
                                    border-color: Theme.border-subtle;

                                    Rectangle {
                                        x: 30px; y: 30px;
                                        width: 40px;
                                        height: 40px;
                                        border-radius: 20px;
                                        background: Theme.accent-dim;

                                        Text {
                                            text: "M";
                                            color: Theme.text-primary;
                                            font-size: 18px;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                            font-weight: 700;
                                        }
                                    }
                                }
                            }

                            // Song title
                            Text {
                                text: root.now-title != "" ? root.now-title : "No track selected";
                                color: Theme.text-primary;
                                font-size: 20px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                overflow: elide;
                            }

                            // Artist
                            Text {
                                text: root.now-artist;
                                color: Theme.text-secondary;
                                font-size: 14px;
                                horizontal-alignment: center;
                                overflow: elide;
                            }

                            // Album
                            if root.now-album != "" : Text {
                                text: root.now-album;
                                color: Theme.text-dim;
                                font-size: 12px;
                                horizontal-alignment: center;
                                overflow: elide;
                            }

                            // Metadata row (genre + format + bitrate)
                            if root.now-title != "" : HorizontalLayout {
                                alignment: center;
                                spacing: 12px;

                                if root.now-genre != "" : Rectangle {
                                    width: genre-text.preferred-width + 12px;
                                    height: 18px;
                                    border-radius: 9px;
                                    background: Theme.bg-elevated;

                                    genre-text := Text {
                                        text: root.now-genre;
                                        color: Theme.text-dim;
                                        font-size: 10px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                if root.now-format-info != "" : Rectangle {
                                    width: fmt-text.preferred-width + 12px;
                                    height: 18px;
                                    border-radius: 9px;
                                    background: Theme.bg-elevated;

                                    fmt-text := Text {
                                        text: root.now-format-info;
                                        color: Theme.text-dim;
                                        font-size: 10px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                if root.now-bitrate != "" : Rectangle {
                                    width: br-text.preferred-width + 12px;
                                    height: 18px;
                                    border-radius: 9px;
                                    background: Theme.bg-elevated;

                                    br-text := Text {
                                        text: root.now-bitrate;
                                        color: Theme.text-dim;
                                        font-size: 10px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }

                    // ── Progress bar ──
                    Rectangle {
                        height: 44px;

                        HorizontalLayout {
                            padding-left: 28px;
                            padding-right: 28px;
                            spacing: 10px;

                            Text {
                                text: root.time-current;
                                color: Theme.text-dim;
                                font-size: Theme.font-small;
                                vertical-alignment: center;
                                width: 42px;
                            }

                            // Seekable progress bar
                            TouchArea {
                                height: 44px;
                                clicked => {
                                    root.seek(self.mouse-x / self.width);
                                }

                                Rectangle {
                                    y: 19px;
                                    height: 6px;
                                    border-radius: 3px;
                                    background: Theme.bg-elevated;

                                    Rectangle {
                                        width: parent.width * root.progress;
                                        height: 100%;
                                        border-radius: 3px;
                                        background: Theme.accent;
                                    }

                                    Rectangle {
                                        x: parent.width * root.progress - 7px;
                                        y: -4px;
                                        width: 14px;
                                        height: 14px;
                                        border-radius: 7px;
                                        background: Theme.accent-light;
                                        drop-shadow-blur: 4px;
                                        drop-shadow-color: Theme.accent-glow;
                                    }
                                }
                            }

                            Text {
                                text: root.time-total;
                                color: Theme.text-dim;
                                font-size: Theme.font-small;
                                vertical-alignment: center;
                                width: 42px;
                                horizontal-alignment: right;
                            }
                        }
                    }

                    // ── Transport controls ──
                    Rectangle {
                        height: 72px;

                        HorizontalLayout {
                            alignment: center;
                            spacing: 16px;

                            // Shuffle
                            TouchArea {
                                width: 36px;
                                height: 36px;
                                clicked => { root.toggle-shuffle(); }

                                Rectangle {
                                    width: 36px;
                                    height: 36px;
                                    border-radius: 18px;
                                    background: root.shuffle-on ? Theme.tint-accent : transparent;

                                    Text {
                                        text: "S";
                                        color: root.shuffle-on ? Theme.accent : Theme.text-dim;
                                        font-size: 12px;
                                        font-weight: 600;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            // Previous
                            TouchArea {
                                width: 44px;
                                height: 44px;
                                clicked => { root.prev-track(); }

                                Rectangle {
                                    width: 44px;
                                    height: 44px;
                                    border-radius: 22px;
                                    background: parent.has-hover ? Theme.hover-fill-strong : Theme.hover-fill;
                                    border-width: 1px;
                                    border-color: Theme.border-subtle;

                                    Text {
                                        text: "<<";
                                        color: Theme.text-secondary;
                                        font-size: 15px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            // Play/Pause
                            TouchArea {
                                width: 56px;
                                height: 56px;
                                clicked => { root.play-pause(); }

                                Rectangle {
                                    width: 56px;
                                    height: 56px;
                                    border-radius: 28px;
                                    background: Theme.accent;
                                    drop-shadow-blur: root.is-playing ? 14px : 0px;
                                    drop-shadow-color: Theme.accent-glow-strong;

                                    Text {
                                        text: root.is-playing ? "||" : ">";
                                        color: Theme.bg-deep;
                                        font-size: 20px;
                                        font-weight: 700;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            // Next
                            TouchArea {
                                width: 44px;
                                height: 44px;
                                clicked => { root.next-track(); }

                                Rectangle {
                                    width: 44px;
                                    height: 44px;
                                    border-radius: 22px;
                                    background: parent.has-hover ? Theme.hover-fill-strong : Theme.hover-fill;
                                    border-width: 1px;
                                    border-color: Theme.border-subtle;

                                    Text {
                                        text: ">>";
                                        color: Theme.text-secondary;
                                        font-size: 15px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            // Repeat — cycles through off / all / one
                            TouchArea {
                                width: 36px;
                                height: 36px;
                                clicked => { root.cycle-repeat(); }

                                Rectangle {
                                    width: 36px;
                                    height: 36px;
                                    border-radius: 18px;
                                    background: root.repeat-mode > 0 ? Theme.tint-accent : transparent;

                                    Text {
                                        text: root.repeat-mode == 1 ? "R1" : "R";
                                        color: root.repeat-mode > 0 ? Theme.accent : Theme.text-dim;
                                        font-size: 12px;
                                        font-weight: 600;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }

                    // ── Volume + Speed row ──
                    Rectangle {
                        height: 38px;

                        HorizontalLayout {
                            padding-left: 28px;
                            padding-right: 28px;
                            spacing: 10px;

                            // Mute toggle
                            TouchArea {
                                width: 28px;
                                height: 38px;
                                clicked => { root.toggle-mute(); }

                                Text {
                                    text: root.volume-muted ? "X" : (root.volume > 0.5 ? "V+" : "V");
                                    color: root.volume-muted ? #ff6666 : Theme.text-dim;
                                    font-size: 11px;
                                    font-weight: 500;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            // Volume slider
                            TouchArea {
                                height: 38px;
                                horizontal-stretch: 1;
                                clicked => {
                                    root.volume-changed(self.mouse-x / self.width);
                                }

                                Rectangle {
                                    y: 16px;
                                    height: 6px;
                                    border-radius: 3px;
                                    background: Theme.bg-elevated;

                                    Rectangle {
                                        width: root.volume-muted ? 0px : parent.width * root.volume;
                                        height: 100%;
                                        border-radius: 3px;
                                        background: root.volume-muted ? Theme.text-dim : Theme.accent-dim;
                                    }

                                    Rectangle {
                                        x: (root.volume-muted ? 0 : parent.width * root.volume) - 5px;
                                        y: -2px;
                                        width: 10px;
                                        height: 10px;
                                        border-radius: 5px;
                                        background: root.volume-muted ? Theme.text-dim : Theme.accent-light;
                                    }
                                }
                            }

                            // Volume percentage
                            Text {
                                text: root.volume-muted ? "Muted" : "\{round(root.volume * 100)}%";
                                color: Theme.text-dim;
                                font-size: 10px;
                                vertical-alignment: center;
                                width: 40px;
                                horizontal-alignment: right;
                            }

                            // Separator
                            Rectangle { width: 1px; height: 20px; y: 9px; background: Theme.separator; }

                            // Speed control
                            TouchArea {
                                width: 42px;
                                height: 38px;
                                clicked => { root.show-speed-popup = !root.show-speed-popup; }

                                Rectangle {
                                    width: 42px; height: 24px; y: 7px;
                                    border-radius: 6px;
                                    background: root.playback-speed != 1.0 ? Theme.tint-accent
                                        : (parent.has-hover ? Theme.hover-fill : transparent);

                                    Text {
                                        text: root.playback-speed == 1.0 ? "1x"
                                            : root.playback-speed == 0.5 ? "0.5x"
                                            : root.playback-speed == 0.75 ? ".75x"
                                            : root.playback-speed == 1.25 ? "1.2x"
                                            : root.playback-speed == 1.5 ? "1.5x"
                                            : root.playback-speed == 2.0 ? "2x"
                                            : "\{root.playback-speed}x";
                                        color: root.playback-speed != 1.0 ? Theme.accent : Theme.text-dim;
                                        font-size: 11px;
                                        font-weight: 500;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            // Separator
                            Rectangle { width: 1px; height: 20px; y: 9px; background: Theme.separator; }

                            // EQ button
                            TouchArea {
                                width: 36px;
                                height: 38px;
                                clicked => { root.music-show-equalizer = !root.music-show-equalizer; }

                                Rectangle {
                                    width: 36px; height: 24px; y: 7px;
                                    border-radius: 6px;
                                    background: root.music-equalizer-preset > 0 ? Theme.tint-accent
                                        : (parent.has-hover ? Theme.hover-fill : transparent);

                                    Text {
                                        text: "EQ";
                                        color: root.music-equalizer-preset > 0 ? Theme.accent : Theme.text-dim;
                                        font-size: 11px;
                                        font-weight: 600;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }

                    // Speed popup
                    if root.show-speed-popup : Rectangle {
                        height: 36px;
                        background: Theme.bg-card;
                        border-width: 1px;
                        border-color: Theme.border-subtle;

                        HorizontalLayout {
                            padding-left: 16px;
                            padding-right: 16px;
                            spacing: 4px;
                            alignment: center;

                            for speed-val in [0.5, 0.75, 1.0, 1.25, 1.5, 2.0] :
                            TouchArea {
                                width: 40px;
                                height: 28px;
                                clicked => {
                                    root.set-playback-speed(speed-val);
                                    root.show-speed-popup = false;
                                }

                                Rectangle {
                                    width: 40px; height: 24px; y: 2px;
                                    border-radius: 6px;
                                    background: root.playback-speed == speed-val ? Theme.accent : (parent.has-hover ? Theme.hover-fill : transparent);

                                    Text {
                                        text: speed-val == 1.0 ? "1x"
                                            : speed-val == 0.5 ? "0.5x"
                                            : speed-val == 0.75 ? ".75"
                                            : speed-val == 1.25 ? "1.25"
                                            : speed-val == 1.5 ? "1.5x"
                                            : "2x";
                                        color: root.playback-speed == speed-val ? Theme.bg-deep : Theme.text-secondary;
                                        font-size: 11px;
                                        font-weight: root.playback-speed == speed-val ? 600 : 400;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }

                    // Equalizer preset popup
                    if root.music-show-equalizer : Rectangle {
                        height: 36px;
                        background: Theme.bg-card;
                        border-width: 1px;
                        border-color: Theme.border-subtle;

                        HorizontalLayout {
                            padding-left: 16px;
                            padding-right: 16px;
                            spacing: 4px;
                            alignment: center;

                            for eq-label[eq-idx] in ["Flat", "Bass+", "Vocal", "Treble"]:
                            TouchArea {
                                width: 52px;
                                height: 28px;
                                clicked => {
                                    root.music-set-equalizer(eq-idx);
                                    root.music-show-equalizer = false;
                                }

                                Rectangle {
                                    width: 52px; height: 24px; y: 2px;
                                    border-radius: 6px;
                                    background: root.music-equalizer-preset == eq-idx ? Theme.accent : (parent.has-hover ? Theme.hover-fill : transparent);

                                    Text {
                                        text: eq-label;
                                        color: root.music-equalizer-preset == eq-idx ? Theme.bg-deep : Theme.text-secondary;
                                        font-size: 11px;
                                        font-weight: root.music-equalizer-preset == eq-idx ? 600 : 400;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }

                    // Bottom padding
                    Rectangle { height: 6px; }
                }
            }

            // Separator
            Rectangle { width: 1px; background: Theme.separator; }

            // ═══ Right panel: Queue / Up Next ═══
            Rectangle {
                width: 240px;
                background: Theme.bg-surface;

                VerticalLayout {
                    spacing: 0px;

                    // Queue header
                    Rectangle {
                        height: 44px;
                        background: Theme.bg-card;

                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 10px;
                            spacing: 6px;

                            Text {
                                text: "Up Next";
                                color: Theme.text-primary;
                                font-size: 13px;
                                font-weight: 600;
                                vertical-alignment: center;
                            }

                            Rectangle { horizontal-stretch: 1; }

                            Text {
                                text: root.queue-tracks.length > 0
                                    ? "\{root.queue-tracks.length} tracks"
                                    : "";
                                color: Theme.text-dim;
                                font-size: 10px;
                                vertical-alignment: center;
                            }

                            // Clear queue
                            if root.queue-tracks.length > 0 : TouchArea {
                                width: 28px;
                                height: 28px;
                                clicked => { root.queue-clear(); }

                                Rectangle {
                                    width: 28px; height: 28px;
                                    border-radius: 6px;
                                    background: parent.has-hover ? #ff444420 : transparent;
                                    Text {
                                        text: "C";
                                        color: Theme.text-dim;
                                        font-size: 11px;
                                        font-weight: 500;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            // AI button
                            if root.now-title != "" : TouchArea {
                                width: 36px;
                                height: 28px;
                                clicked => {
                                    root.ai-explain-pressed();
                                    root.ai-panel-open = true;
                                }
                                Rectangle {
                                    width: 36px; height: 28px;
                                    border-radius: 8px;
                                    background: root.ai-is-working ? Theme.accent
                                        : (parent.has-hover ? Theme.hover-fill-strong : Theme.hover-fill);
                                    border-width: root.ai-is-working ? 0px : 1px;
                                    border-color: Theme.border-subtle;
                                    HorizontalLayout {
                                        alignment: center;
                                        spacing: 2px;
                                        Text {
                                            text: "\u{2728}";
                                            font-size: 10px;
                                            vertical-alignment: center;
                                        }
                                        Text {
                                            text: root.ai-is-working ? ".." : "AI";
                                            color: root.ai-is-working ? #ffffff : Theme.text-secondary;
                                            font-size: 10px;
                                            font-weight: 500;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                        }
                    }

                    Rectangle { height: 1px; background: Theme.separator; }

                    // AI Response Panel
                    if root.ai-panel-open && root.ai-response != "" : Rectangle {
                        max-height: 140px;
                        background: #1a2332;
                        border-width: 1px;
                        border-color: Theme.accent.transparentize(70%);

                        Flickable {
                            viewport-height: ai-music-resp.preferred-height + 16px;

                            ai-music-resp := VerticalLayout {
                                padding: 10px;
                                spacing: 6px;

                                HorizontalLayout {
                                    spacing: 6px;
                                    Text {
                                        text: "\u{2728}";
                                        font-size: 11px;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: "AI";
                                        color: Theme.accent;
                                        font-size: 11px;
                                        font-weight: 600;
                                        vertical-alignment: center;
                                    }
                                    Rectangle { horizontal-stretch: 1; }

                                    TouchArea {
                                        width: 22px;
                                        height: 22px;
                                        clicked => {
                                            root.ai-panel-open = false;
                                            root.ai-dismiss();
                                        }
                                        Rectangle {
                                            width: 22px; height: 22px;
                                            border-radius: 11px;
                                            background: parent.has-hover ? Theme.hover-fill : transparent;
                                            Text {
                                                text: "\u{2715}";
                                                font-size: 10px;
                                                color: Theme.text-dim;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                }

                                Text {
                                    text: root.ai-response;
                                    color: Theme.text-primary;
                                    font-size: 11px;
                                    wrap: word-wrap;
                                }
                            }
                        }
                    }

                    // Queue list
                    Flickable {
                        viewport-height: queue-col.preferred-height;

                        queue-col := VerticalLayout {
                            spacing: 0px;

                            if root.queue-tracks.length == 0 : Rectangle {
                                height: 80px;

                                Text {
                                    text: "Queue is empty\nPlay a track to start";
                                    color: Theme.text-dim;
                                    font-size: 12px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            for qtrack[qidx] in root.queue-tracks :
                            Rectangle {
                                height: 52px;
                                background: qtrack.is-current
                                    ? Theme.tint-accent
                                    : transparent;

                                HorizontalLayout {
                                    padding-left: 6px;
                                    padding-right: 6px;
                                    spacing: 4px;

                                    // Reorder buttons
                                    VerticalLayout {
                                        width: 16px;
                                        alignment: center;
                                        spacing: 1px;

                                        TouchArea {
                                            width: 16px;
                                            height: 14px;
                                            clicked => { root.queue-move-up(qidx); }

                                            Rectangle {
                                                width: 16px; height: 14px;
                                                border-radius: 3px;
                                                background: parent.has-hover ? Theme.hover-fill-strong : transparent;
                                                Text {
                                                    text: "^";
                                                    color: Theme.text-dim;
                                                    font-size: 9px;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                            }
                                        }

                                        TouchArea {
                                            width: 16px;
                                            height: 14px;
                                            clicked => { root.queue-move-down(qidx); }

                                            Rectangle {
                                                width: 16px; height: 14px;
                                                border-radius: 3px;
                                                background: parent.has-hover ? Theme.hover-fill-strong : transparent;
                                                Text {
                                                    text: "v";
                                                    color: Theme.text-dim;
                                                    font-size: 9px;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                            }
                                        }
                                    }

                                    // Play this track
                                    TouchArea {
                                        width: 18px;
                                        height: 52px;
                                        clicked => { root.queue-play-index(qidx); }

                                        Text {
                                            text: qtrack.is-current ? ">" : "\{qidx + 1}";
                                            color: qtrack.is-current ? Theme.accent : Theme.text-dim;
                                            font-size: 10px;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }

                                    // Title + artist (clickable to play)
                                    TouchArea {
                                        horizontal-stretch: 1;
                                        height: 52px;
                                        clicked => { root.queue-play-index(qidx); }

                                        VerticalLayout {
                                            alignment: center;
                                            spacing: 2px;

                                            Text {
                                                text: qtrack.title;
                                                color: qtrack.is-current ? Theme.accent : Theme.text-primary;
                                                font-size: 11px;
                                                overflow: elide;
                                                font-weight: qtrack.is-current ? 600 : 400;
                                            }
                                            Text {
                                                text: qtrack.artist;
                                                color: Theme.text-secondary;
                                                font-size: 10px;
                                                overflow: elide;
                                            }
                                        }
                                    }

                                    // Duration
                                    Text {
                                        text: qtrack.duration-text;
                                        color: Theme.text-dim;
                                        font-size: 10px;
                                        width: 30px;
                                        horizontal-alignment: right;
                                        vertical-alignment: center;
                                    }

                                    // Remove from queue
                                    TouchArea {
                                        width: 20px;
                                        height: 20px;
                                        clicked => { root.queue-remove(qidx); }

                                        Rectangle {
                                            width: 20px; height: 20px;
                                            y: 16px;
                                            border-radius: 4px;
                                            background: parent.has-hover ? #ff444420 : transparent;
                                            Text {
                                                text: "\u{2715}";
                                                color: Theme.text-dim;
                                                font-size: 9px;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
