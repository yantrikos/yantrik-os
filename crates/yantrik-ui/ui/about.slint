// About screen — system info panel for Yantrik OS.
// Screen 16. Read-only info cards showing hardware & OS details.

import { Theme } from "theme.slint";

export struct ComponentVersionData {
    name: string,
    current-version: string,
    latest-version: string,
    has-update: bool,
    is-checking: bool,
}

export component AboutScreen inherits Rectangle {
    background: Theme.bg-deep;

    // Data fields (all read-only, populated from Rust)
    in property <string> hostname: "";
    in property <string> kernel: "";
    in property <string> cpu-model: "";
    in property <string> ram-total: "";
    in property <string> disk-info: "";
    in property <string> uptime-text: "";
    in property <string> version-text: "0.3.0";
    in property <string> build-date: "";

    // Component versions
    in property <[ComponentVersionData]> components: [];
    in property <int> update-count: 0;
    in property <string> update-status: "";

    // AI Readiness
    in property <string> ai-model-name: "";
    in property <string> ai-model-tier: "";
    in property <string> ai-provider-status: "";
    in property <string> ai-capability-summary: "";

    callback back-pressed();
    callback check-updates();
    callback open-ai-settings();

    VerticalLayout {
        width: 100%;
        height: 100%;

        // ── Header bar (56px) ──
        Rectangle {
            height: 56px;
            background: Theme.bg-surface;

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 16px;
                spacing: 12px;

                // Back button
                Rectangle {
                    width: 36px;
                    height: 36px;
                    y: (parent.height - 36px) / 2;
                    border-radius: 18px;
                    background: ta-back.has-hover ? Theme.hover-fill-strong : transparent;

                    ta-back := TouchArea {
                        clicked => { root.back-pressed(); }
                    }

                    Text {
                        text: "\u{2190}";
                        color: Theme.text-primary;
                        font-size: 20px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                // Title
                Text {
                    text: "About";
                    color: Theme.text-primary;
                    font-size: Theme.font-title;
                    font-weight: 600;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
            }
        }

        // ── Scrollable content ──
        Flickable {
            viewport-height: content-col.preferred-height + 40px;

            content-col := VerticalLayout {
                padding: 20px;
                spacing: 20px;

                // ── Logo / Identity section ──
                Rectangle {
                    background: Theme.bg-card;
                    border-radius: Theme.radius-card;
                    border-width: 1px;
                    border-color: Theme.separator;
                    height: logo-col.preferred-height;

                    logo-col := VerticalLayout {
                        padding: 24px;
                        spacing: 12px;
                        alignment: center;

                        Text {
                            text: "Yantrik OS";
                            color: Theme.amber;
                            font-size: 28px;
                            font-weight: 700;
                            letter-spacing: 2px;
                            horizontal-alignment: center;
                        }

                        HorizontalLayout {
                            alignment: center;
                            spacing: 8px;

                            Rectangle {
                                width: v-label.preferred-width + 16px;
                                height: 24px;
                                border-radius: 12px;
                                background: Theme.tint-cyan;
                                border-width: 1px;
                                border-color: Theme.cyan-dim;

                                v-label := Text {
                                    text: "v" + root.version-text;
                                    color: Theme.cyan;
                                    font-size: 11px;
                                    font-weight: 600;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        Text {
                            text: "AI-native desktop shell";
                            color: Theme.text-dim;
                            font-size: Theme.font-small;
                            horizontal-alignment: center;
                        }
                    }
                }

                // ── DEVICE section header ──
                HorizontalLayout {
                    spacing: 8px;
                    Rectangle {
                        width: 3px; height: 14px;
                        border-radius: 1.5px;
                        background: Theme.cyan;
                        drop-shadow-blur: 4px;
                        drop-shadow-color: Theme.cyan-glow;
                    }
                    Text {
                        text: "DEVICE";
                        color: Theme.text-dim;
                        font-size: 11px;
                        letter-spacing: 2px;
                        vertical-alignment: center;
                    }
                }

                // ── Device info card ──
                Rectangle {
                    background: Theme.bg-card;
                    border-radius: Theme.radius-card;
                    border-width: 1px;
                    border-color: Theme.separator;
                    height: device-col.preferred-height;

                    device-col := VerticalLayout {
                        padding: 16px;
                        spacing: 0px;

                        // Hostname row
                        Rectangle {
                            height: 44px;
                            HorizontalLayout {
                                padding-left: 4px;
                                padding-right: 4px;
                                Text {
                                    text: "Hostname";
                                    color: Theme.text-secondary;
                                    font-size: Theme.font-body;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                                Text {
                                    text: root.hostname;
                                    color: Theme.text-primary;
                                    font-size: Theme.font-body;
                                    vertical-alignment: center;
                                }
                            }
                        }
                        Rectangle { height: 1px; background: Theme.border-subtle; }

                        // Kernel row
                        Rectangle {
                            height: 44px;
                            HorizontalLayout {
                                padding-left: 4px;
                                padding-right: 4px;
                                Text {
                                    text: "Kernel";
                                    color: Theme.text-secondary;
                                    font-size: Theme.font-body;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                                Text {
                                    text: root.kernel;
                                    color: Theme.text-primary;
                                    font-size: Theme.font-body;
                                    vertical-alignment: center;
                                }
                            }
                        }
                        Rectangle { height: 1px; background: Theme.border-subtle; }

                        // CPU row
                        Rectangle {
                            height: 44px;
                            HorizontalLayout {
                                padding-left: 4px;
                                padding-right: 4px;
                                Text {
                                    text: "CPU";
                                    color: Theme.text-secondary;
                                    font-size: Theme.font-body;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                                Text {
                                    text: root.cpu-model;
                                    color: Theme.text-primary;
                                    font-size: Theme.font-small;
                                    vertical-alignment: center;
                                    overflow: elide;
                                    max-width: 500px;
                                }
                            }
                        }
                        Rectangle { height: 1px; background: Theme.border-subtle; }

                        // RAM row
                        Rectangle {
                            height: 44px;
                            HorizontalLayout {
                                padding-left: 4px;
                                padding-right: 4px;
                                Text {
                                    text: "RAM";
                                    color: Theme.text-secondary;
                                    font-size: Theme.font-body;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                                Text {
                                    text: root.ram-total;
                                    color: Theme.text-primary;
                                    font-size: Theme.font-body;
                                    vertical-alignment: center;
                                }
                            }
                        }
                        Rectangle { height: 1px; background: Theme.border-subtle; }

                        // Disk row
                        Rectangle {
                            height: 44px;
                            HorizontalLayout {
                                padding-left: 4px;
                                padding-right: 4px;
                                Text {
                                    text: "Disk";
                                    color: Theme.text-secondary;
                                    font-size: Theme.font-body;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                                Text {
                                    text: root.disk-info;
                                    color: Theme.text-primary;
                                    font-size: Theme.font-body;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }

                // ── RUNTIME section header ──
                HorizontalLayout {
                    spacing: 8px;
                    Rectangle {
                        width: 3px; height: 14px;
                        border-radius: 1.5px;
                        background: Theme.amber;
                        drop-shadow-blur: 4px;
                        drop-shadow-color: Theme.amber-glow;
                    }
                    Text {
                        text: "RUNTIME";
                        color: Theme.text-dim;
                        font-size: 11px;
                        letter-spacing: 2px;
                        vertical-alignment: center;
                    }
                }

                // ── Runtime info card ──
                Rectangle {
                    background: Theme.bg-card;
                    border-radius: Theme.radius-card;
                    border-width: 1px;
                    border-color: Theme.separator;
                    height: runtime-col.preferred-height;

                    runtime-col := VerticalLayout {
                        padding: 16px;
                        spacing: 0px;

                        // Uptime row
                        Rectangle {
                            height: 44px;
                            HorizontalLayout {
                                padding-left: 4px;
                                padding-right: 4px;
                                Text {
                                    text: "Uptime";
                                    color: Theme.text-secondary;
                                    font-size: Theme.font-body;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                                Text {
                                    text: root.uptime-text;
                                    color: Theme.text-primary;
                                    font-size: Theme.font-body;
                                    vertical-alignment: center;
                                }
                            }
                        }
                        Rectangle { height: 1px; background: Theme.border-subtle; }

                        // Build date row
                        Rectangle {
                            height: 44px;
                            HorizontalLayout {
                                padding-left: 4px;
                                padding-right: 4px;
                                Text {
                                    text: "Build Date";
                                    color: Theme.text-secondary;
                                    font-size: Theme.font-body;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                                Text {
                                    text: root.build-date;
                                    color: Theme.text-primary;
                                    font-size: Theme.font-body;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }

                // ── AI READINESS section header ──
                HorizontalLayout {
                    spacing: 8px;
                    Rectangle {
                        width: 3px; height: 14px;
                        border-radius: 1.5px;
                        background: Theme.accent;
                        drop-shadow-blur: 4px;
                        drop-shadow-color: Theme.accent-glow;
                    }
                    Text {
                        text: "AI READINESS";
                        color: Theme.text-dim;
                        font-size: 11px;
                        letter-spacing: 2px;
                        vertical-alignment: center;
                    }
                }

                // AI Readiness card
                Rectangle {
                    background: Theme.bg-card;
                    border-radius: Theme.radius-card;
                    border-width: 1px;
                    border-color: Theme.separator;
                    height: ai-ready-col.preferred-height;

                    ai-ready-col := VerticalLayout {
                        padding: 16px;
                        spacing: 0px;

                        // Model row
                        Rectangle {
                            height: 44px;
                            HorizontalLayout {
                                padding-left: 4px;
                                padding-right: 4px;
                                Text {
                                    text: "AI Model";
                                    color: Theme.text-secondary;
                                    font-size: Theme.font-body;
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                }
                                HorizontalLayout {
                                    spacing: 8px;
                                    Text {
                                        text: root.ai-model-name != "" ? root.ai-model-name : "Not configured";
                                        color: root.ai-model-name != "" ? Theme.accent : Theme.text-dim;
                                        font-size: Theme.font-body;
                                        font-weight: 500;
                                        vertical-alignment: center;
                                    }
                                    if root.ai-model-tier != "" : Rectangle {
                                        width: about-tier-txt.preferred-width + 12px;
                                        height: 20px;
                                        y: (parent.height - 20px) / 2;
                                        border-radius: 10px;
                                        background: root.ai-model-tier == "Large" ? Theme.tint-accent
                                                  : root.ai-model-tier == "Medium" ? Theme.tint-cyan
                                                  : root.ai-model-tier == "Small" ? Theme.tint-amber
                                                  : Theme.border-default;
                                        about-tier-txt := Text {
                                            text: root.ai-model-tier;
                                            color: root.ai-model-tier == "Large" ? Theme.accent
                                                 : root.ai-model-tier == "Medium" ? Theme.cyan
                                                 : root.ai-model-tier == "Small" ? Theme.amber
                                                 : Theme.text-secondary;
                                            font-size: 10px;
                                            font-weight: 600;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                        }
                        Rectangle { height: 1px; background: Theme.border-subtle; }

                        // Provider status row
                        Rectangle {
                            height: 44px;
                            HorizontalLayout {
                                padding-left: 4px;
                                padding-right: 4px;
                                Text {
                                    text: "Provider";
                                    color: Theme.text-secondary;
                                    font-size: Theme.font-body;
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                }
                                HorizontalLayout {
                                    spacing: 8px;
                                    Rectangle {
                                        width: 8px;
                                        height: 8px;
                                        y: (parent.height - 8px) / 2;
                                        border-radius: 4px;
                                        background: root.ai-provider-status == "Connected" ? Theme.color-reminder
                                                  : root.ai-provider-status == "Disconnected" ? Theme.color-emotional
                                                  : Theme.text-dim;
                                    }
                                    Text {
                                        text: root.ai-provider-status != "" ? root.ai-provider-status : "Unknown";
                                        color: root.ai-provider-status == "Connected" ? Theme.color-reminder
                                             : root.ai-provider-status == "Disconnected" ? Theme.color-emotional
                                             : Theme.text-dim;
                                        font-size: Theme.font-body;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                        Rectangle { height: 1px; background: Theme.border-subtle; }

                        // Capability summary row
                        Rectangle {
                            height: 44px;
                            HorizontalLayout {
                                padding-left: 4px;
                                padding-right: 4px;
                                Text {
                                    text: "Capabilities";
                                    color: Theme.text-secondary;
                                    font-size: Theme.font-body;
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: root.ai-capability-summary != "" ? root.ai-capability-summary : "—";
                                    color: Theme.text-primary;
                                    font-size: Theme.font-small;
                                    vertical-alignment: center;
                                }
                            }
                        }
                        Rectangle { height: 1px; background: Theme.border-subtle; }

                        // Open AI Settings link
                        TouchArea {
                            height: 44px;
                            clicked => { root.open-ai-settings(); }
                            HorizontalLayout {
                                padding-left: 4px;
                                padding-right: 4px;
                                Text {
                                    text: "Open AI Settings";
                                    color: Theme.accent;
                                    font-size: Theme.font-body;
                                    font-weight: 500;
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: "\u{2192}";
                                    color: Theme.accent-dim;
                                    font-size: 18px;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }

                // ── COMPONENTS section header ──
                HorizontalLayout {
                    spacing: 8px;
                    Rectangle {
                        width: 3px; height: 14px;
                        border-radius: 1.5px;
                        background: Theme.holo-blue;
                        drop-shadow-blur: 4px;
                        drop-shadow-color: Theme.holo-blue.transparentize(75%);
                    }
                    Text {
                        text: "COMPONENTS";
                        color: Theme.text-dim;
                        font-size: 11px;
                        letter-spacing: 2px;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }

                    // Check for updates button
                    Rectangle {
                        width: update-btn-text.preferred-width + 20px;
                        height: 28px;
                        border-radius: 14px;
                        background: update-ta.has-hover ? Theme.hover-fill-strong : Theme.hover-fill;
                        border-width: 1px;
                        border-color: root.update-count > 0 ? Theme.holo-blue : Theme.border-subtle;

                        update-btn-text := Text {
                            text: root.update-count > 0
                                ? root.update-count + " update(s)"
                                : "Check Updates";
                            font-size: 11px;
                            color: root.update-count > 0 ? Theme.holo-blue : Theme.text-secondary;
                            font-weight: 500;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        update-ta := TouchArea {
                            clicked => { root.check-updates(); }
                        }
                    }
                }

                // ── Components card ──
                Rectangle {
                    background: Theme.bg-card;
                    border-radius: Theme.radius-card;
                    border-width: 1px;
                    border-color: Theme.separator;
                    height: comp-col.preferred-height;

                    comp-col := VerticalLayout {
                        padding: 16px;
                        spacing: 0px;

                        for comp[idx] in root.components : VerticalLayout {
                            spacing: 0px;

                            Rectangle {
                                height: 48px;

                                HorizontalLayout {
                                    padding-left: 4px;
                                    padding-right: 4px;
                                    spacing: 8px;

                                    // Component name
                                    Text {
                                        text: comp.name;
                                        color: Theme.text-primary;
                                        font-size: Theme.font-body;
                                        font-weight: 500;
                                        vertical-alignment: center;
                                        horizontal-stretch: 1;
                                    }

                                    // Current version
                                    Text {
                                        text: comp.current-version;
                                        color: Theme.text-secondary;
                                        font-size: Theme.font-small;
                                        vertical-alignment: center;
                                    }

                                    // Update indicator
                                    if comp.has-update : Rectangle {
                                        width: upd-text.preferred-width + 12px;
                                        height: 20px;
                                        border-radius: 10px;
                                        background: Theme.holo-blue.transparentize(87%);
                                        border-width: 1px;
                                        border-color: Theme.holo-blue.transparentize(75%);

                                        upd-text := Text {
                                            text: comp.latest-version;
                                            font-size: 10px;
                                            color: Theme.holo-blue;
                                            font-weight: 600;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }

                                    if comp.is-checking : Text {
                                        text: "...";
                                        font-size: Theme.font-small;
                                        color: Theme.text-dim;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            // Separator between items (not after last)
                            if idx < root.components.length - 1 : Rectangle {
                                height: 1px;
                                background: Theme.border-subtle;
                            }
                        }
                    }
                }

                // Update status text
                if root.update-status != "" : Text {
                    text: root.update-status;
                    font-size: Theme.font-small;
                    color: root.update-count > 0 ? Theme.holo-blue : Theme.text-dim;
                    horizontal-alignment: center;
                }

                // Bottom spacer
                Rectangle {
                    height: 40px;
                }
            }
        }
    }
}
