// Onboarding — "Hey. I'm Yantrik."
// First-boot experience. The AI introduces itself, then teaches the user
// to use the Intent Lens through guided steps. No tutorial modals —
// the AI is the teacher.

import { Theme } from "theme.slint";
import { Orb } from "components/orb.slint";
import { ParticleField } from "components/particle_field.slint";

export component OnboardingScreen inherits Rectangle {
    callback ready();   // User tapped orb or pressed Super
    callback skip();    // User wants to skip onboarding

    background: Theme.bg-deep;
    clip: true;

    // Phase tracking: 0=dim, 1=orb kindles, 2=greeting, 3=instruction, 4=waiting
    property <int> phase: 0;
    property <float> timer-elapsed: 0;

    Timer {
        interval: 16ms;
        running: phase < 4;
        triggered => {
            timer-elapsed += 0.016;
            if timer-elapsed > 0.5 && phase == 0 { phase = 1; }
            if timer-elapsed > 2.0 && phase == 1 { phase = 2; }
            if timer-elapsed > 4.0 && phase == 2 { phase = 3; }
            if timer-elapsed > 6.0 && phase == 3 { phase = 4; }
        }
    }

    // Dim particle field backdrop
    ParticleField {
        width: 100%; height: 100%;
        active: true;
        intensity: phase >= 1 ? 0.4 : 0.1;
        animate intensity { duration: 2000ms; }
    }

    // Deep space gradient
    Rectangle {
        width: 100%; height: 100%;
        background: @radial-gradient(circle, #0a0a1800 0%, #06060e60 50%, #030306a0 100%);
    }

    // Center content
    VerticalLayout {
        alignment: center;
        spacing: 24px;

        // Orb (kindles at phase 1)
        HorizontalLayout {
            alignment: center;

            TouchArea {
                width: 160px; height: 160px;
                clicked => { root.ready(); }

                Orb {
                    width: 100%; height: 100%;
                    size-px: 160;
                    opacity: phase >= 1 ? 1.0 : 0;
                    animate opacity { duration: 2000ms; easing: ease-out; }
                }
            }
        }

        // Greeting text
        Text {
            text: "Hey. I'm Yantrik.";
            color: Theme.cyan;
            font-size: 28px;
            font-weight: 300;
            letter-spacing: 2px;
            horizontal-alignment: center;
            opacity: phase >= 2 ? 1.0 : 0;
            animate opacity { duration: 1500ms; easing: ease-out; }
        }

        // Instruction text
        Text {
            text: "Press Super to talk to me about anything.";
            color: Theme.text-dim;
            font-size: 14px;
            letter-spacing: 1px;
            horizontal-alignment: center;
            opacity: phase >= 3 ? 0.7 : 0;
            animate opacity { duration: 1200ms; easing: ease-out; }
        }

        // Subtle hint below
        Text {
            text: "or tap the orb";
            color: Theme.text-dim;
            font-size: 11px;
            letter-spacing: 2px;
            horizontal-alignment: center;
            opacity: phase >= 4 ? 0.4 : 0;
            animate opacity { duration: 800ms; easing: ease-out; }
        }
    }

    // Skip link — bottom right
    TouchArea {
        x: root.width - 80px;
        y: root.height - 40px;
        width: 60px;
        height: 24px;
        clicked => { root.skip(); }

        Text {
            text: "Skip";
            color: Theme.text-dim;
            font-size: 11px;
            horizontal-alignment: right;
            vertical-alignment: center;
            opacity: phase >= 4 ? 0.4 : 0;
            animate opacity { duration: 600ms; }
        }
    }
}
