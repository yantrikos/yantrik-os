// Download Manager — screen 24
// Firelight treatment: glassmorphism, holographic glows, gradient accents.
// Wrapped in WindowFrame by app.slint — no internal window header needed.

import { Theme } from "theme.slint";
import { ListView } from "std-widgets.slint";
import { YButton, YIconButton } from "components/y_button.slint";
import { YInput } from "components/y_input.slint";
import { YEmptyState } from "components/y_empty_state.slint";
import { YTabs, YTabItem } from "components/y_tabs.slint";

export struct DownloadItem {
    id: int,
    filename: string,
    url: string,
    progress: float,       // 0.0 to 1.0
    speed-text: string,    // "2.4 MB/s"
    size-text: string,     // "45.2 / 128.0 MB"
    status: string,        // "downloading", "paused", "completed", "failed", "queued"
    eta-text: string,      // "2m 30s"
    is-selected: bool,
    // Checksum fields
    checksum-expected: string,   // user-supplied expected hash
    checksum-status: string,     // "none", "verifying", "pass", "fail"
    // Per-download save location
    save-dir: string,            // custom save directory
    // Detail fields
    start-time: string,          // "2026-03-09 14:32:01"
    end-time: string,            // "2026-03-09 14:35:12"
    file-hash: string,           // computed hash after download
    file-type: string,           // "application/zip", "image/png", etc.
}

export component DownloadManagerScreen inherits Rectangle {
    background: transparent;

    in property <[DownloadItem]> downloads: [];
    in property <int> active-count: 0;
    in property <string> total-speed: "0 B/s";
    in property <int> completed-today: 0;
    in property <string> error-text: "";

    in-out property <int> active-filter: 0;  // 0=All, 1=Active, 2=Completed, 3=Failed

    callback dl-add(/* url */ string, /* checksum */ string, /* save-dir */ string);
    callback dl-pause(int);
    callback dl-resume(int);
    callback dl-cancel(int);
    callback dl-retry(int);
    callback dl-open-folder(int);
    callback dl-clear-completed();
    callback dl-filter(int);
    callback dl-verify-checksum(int);
    callback dl-toggle-select(int);
    callback dl-select-all(bool);
    callback dl-pause-all();
    callback dl-resume-all();
    callback dl-search(string);
    callback dl-sort(int);  // 0=date, 1=name, 2=size, 3=status

    // State for the add-URL input
    in-out property <bool> add-url-open: false;
    in-out property <string> add-url-text: "";
    in-out property <string> add-checksum-text: "";
    in-out property <string> add-save-dir-text: "";

    // Search / filter
    in-out property <string> dl-search-text: "";
    in property <int> dl-search-match-count: 0;

    // Sort
    in-out property <int> dl-sort-mode: 0;  // 0=date, 1=name, 2=size, 3=status

    // Bulk selection
    in-out property <bool> dl-all-selected: false;

    // Expanded row tracking (which download id is expanded, -1 = none)
    in-out property <int> dl-expanded-id: -1;

    // Resume support & checksum result
    in property <bool> dl-resume-supported: false;
    in property <string> dl-checksum-result: "";

    // AI Assist
    in property <bool> ai-is-working: false;
    in property <string> ai-response: "";
    in-out property <bool> ai-panel-open: false;
    callback ai-explain-pressed();
    callback ai-dismiss();

    VerticalLayout {
        // ── Top Stats Bar ──
        Rectangle {
            height: 56px;
            background: Theme.bg-card;

            HorizontalLayout {
                padding-left: Theme.sp-5;
                padding-right: Theme.sp-5;
                spacing: Theme.sp-6;
                alignment: center;

                // Active downloads stat
                HorizontalLayout {
                    spacing: 8px;
                    alignment: center;

                    Rectangle {
                        width: 8px;
                        height: 8px;
                        border-radius: 4px;
                        background: root.active-count > 0 ? Theme.accent : Theme.text-dim;
                        y: (parent.height - self.height) / 2;
                    }

                    Text {
                        text: root.active-count;
                        font-size: 18px;
                        font-weight: 700;
                        color: Theme.text-primary;
                        vertical-alignment: center;
                    }

                    Text {
                        text: "active";
                        font-size: Theme.fs-caption;
                        color: Theme.text-secondary;
                        vertical-alignment: center;
                    }
                }

                // Speed stat
                HorizontalLayout {
                    spacing: 6px;
                    alignment: center;

                    Text {
                        text: "\u{2193}";
                        font-size: 16px;
                        color: Theme.accent;
                        vertical-alignment: center;
                    }

                    Text {
                        text: root.total-speed;
                        font-size: 15px;
                        font-weight: 600;
                        color: Theme.accent;
                        vertical-alignment: center;
                    }
                }

                // Completed today stat
                HorizontalLayout {
                    spacing: 6px;
                    alignment: center;

                    Text {
                        text: "\u{2713}";
                        font-size: 16px;
                        color: Theme.color-success;
                        vertical-alignment: center;
                    }

                    Text {
                        text: root.completed-today;
                        font-size: 15px;
                        font-weight: 600;
                        color: Theme.text-primary;
                        vertical-alignment: center;
                    }

                    Text {
                        text: "today";
                        font-size: Theme.fs-caption;
                        color: Theme.text-secondary;
                        vertical-alignment: center;
                    }
                }

                // Spacer
                Rectangle { horizontal-stretch: 1; }

                // Pause All button
                YButton {
                    label: "Pause All";
                    icon: "\u{23F8}";
                    variant: 1;
                    size: 0;
                    clicked => { root.dl-pause-all(); }
                }

                // Resume All button
                YButton {
                    label: "Resume All";
                    icon: "\u{25B6}";
                    variant: 1;
                    size: 0;
                    clicked => { root.dl-resume-all(); }
                }

                // Clear Completed button
                YButton {
                    label: "Clear Completed";
                    variant: 2;
                    size: 0;
                    clicked => { root.dl-clear-completed(); }
                }

                // AI button
                YButton {
                    label: root.ai-is-working ? "Analyzing..." : "AI";
                    icon: "\u{2728}";
                    variant: root.ai-is-working ? 0 : 1;
                    size: 0;
                    loading: root.ai-is-working;
                    clicked => {
                        if root.ai-panel-open {
                            root.ai-dismiss();
                            root.ai-panel-open = false;
                        } else {
                            root.ai-explain-pressed();
                            root.ai-panel-open = true;
                        }
                    }
                }

                // + Add URL button
                YButton {
                    label: "+ Add URL";
                    variant: 0;
                    size: 1;
                    clicked => {
                        root.add-url-open = !root.add-url-open;
                    }
                }
            }
        }

        // ── AI Response Panel ──
        if root.ai-panel-open && root.ai-response != "" : Rectangle {
            max-height: 160px;
            background: Theme.bg-overlay-panel;
            border-width: 1px;
            border-color: Theme.accent.transparentize(70%);

            Flickable {
                viewport-height: ai-dl-resp.preferred-height + 16px;

                ai-dl-resp := VerticalLayout {
                    padding: Theme.sp-3;
                    spacing: Theme.sp-2;

                    HorizontalLayout {
                        spacing: 6px;
                        Text {
                            text: "\u{2728}";
                            font-size: 12px;
                            vertical-alignment: center;
                        }
                        Text {
                            text: "AI Analysis";
                            color: Theme.accent;
                            font-size: 12px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                        Rectangle { horizontal-stretch: 1; }
                        YIconButton {
                            icon: "\u{2715}";
                            variant: 2;
                            clicked => {
                                root.ai-panel-open = false;
                                root.ai-dismiss();
                            }
                        }
                    }

                    Text {
                        text: root.ai-response;
                        color: Theme.text-primary;
                        font-size: 12px;
                        wrap: word-wrap;
                    }
                }
            }
        }

        // ── Add URL Input Row (collapsible) ──
        if root.add-url-open : Rectangle {
            height: 110px;
            background: Theme.bg-elevated;
            border-width: 0;

            VerticalLayout {
                padding: Theme.sp-3;
                padding-left: Theme.sp-5;
                padding-right: Theme.sp-5;
                spacing: Theme.sp-2;

                // Row 1: URL input + submit + cancel
                HorizontalLayout {
                    spacing: 10px;
                    alignment: center;

                    Rectangle {
                        horizontal-stretch: 1;
                        height: 36px;
                        background: Theme.bg-input;
                        border-radius: Theme.r-pill;
                        border-width: 1px;
                        border-color: url-input-ta.has-focus ? Theme.accent : Theme.border-subtle;
                        clip: true;

                        HorizontalLayout {
                            padding-left: 14px;
                            padding-right: 14px;
                            alignment: center;

                            url-input-ta := TextInput {
                                horizontal-stretch: 1;
                                text <=> root.add-url-text;
                                font-size: Theme.fs-body;
                                color: Theme.text-primary;
                                accepted => {
                                    if root.add-url-text != "" {
                                        root.dl-add(root.add-url-text, root.add-checksum-text, root.add-save-dir-text);
                                        root.add-url-text = "";
                                        root.add-checksum-text = "";
                                        root.add-save-dir-text = "";
                                        root.add-url-open = false;
                                    }
                                }
                            }
                        }
                    }

                    // Submit button
                    YButton {
                        label: "Download";
                        variant: 0;
                        size: 1;
                        clicked => {
                            if root.add-url-text != "" {
                                root.dl-add(root.add-url-text, root.add-checksum-text, root.add-save-dir-text);
                                root.add-url-text = "";
                                root.add-checksum-text = "";
                                root.add-save-dir-text = "";
                                root.add-url-open = false;
                            }
                        }
                    }

                    // Cancel
                    YIconButton {
                        icon: "\u{2715}";
                        variant: 2;
                        clicked => {
                            root.add-url-open = false;
                            root.add-url-text = "";
                            root.add-checksum-text = "";
                            root.add-save-dir-text = "";
                        }
                    }
                }

                // Row 2: Checksum + Save directory inputs
                HorizontalLayout {
                    spacing: 10px;
                    alignment: center;

                    // Checksum input
                    Rectangle {
                        horizontal-stretch: 1;
                        height: 32px;
                        background: Theme.bg-input;
                        border-radius: Theme.r-pill;
                        border-width: 1px;
                        border-color: checksum-input.has-focus ? Theme.accent : Theme.border-subtle;
                        clip: true;

                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;
                            spacing: 6px;
                            alignment: center;

                            Text {
                                text: "#";
                                font-size: 12px;
                                color: Theme.text-dim;
                                vertical-alignment: center;
                            }

                            checksum-input := TextInput {
                                horizontal-stretch: 1;
                                text <=> root.add-checksum-text;
                                font-size: 11px;
                                color: Theme.text-primary;
                                input-type: text;
                            }
                        }
                    }

                    // Placeholder label when empty
                    if root.add-checksum-text == "" : Text {
                        text: "Expected hash (optional)";
                        font-size: 11px;
                        color: Theme.text-dim;
                        vertical-alignment: center;
                    }

                    // Save directory input
                    Rectangle {
                        horizontal-stretch: 1;
                        height: 32px;
                        background: Theme.bg-input;
                        border-radius: Theme.r-pill;
                        border-width: 1px;
                        border-color: savedir-input.has-focus ? Theme.accent : Theme.border-subtle;
                        clip: true;

                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;
                            spacing: 6px;
                            alignment: center;

                            Text {
                                text: "\u{1F4C1}";
                                font-size: 11px;
                                color: Theme.text-dim;
                                vertical-alignment: center;
                            }

                            savedir-input := TextInput {
                                horizontal-stretch: 1;
                                text <=> root.add-save-dir-text;
                                font-size: 11px;
                                color: Theme.text-primary;
                                input-type: text;
                            }
                        }
                    }

                    if root.add-save-dir-text == "" : Text {
                        text: "Save to... (optional)";
                        font-size: 11px;
                        color: Theme.text-dim;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // ── Separator ──
        Rectangle { height: 1px; background: Theme.separator; }

        // ── Search bar + Sort + Select All ──
        Rectangle {
            height: 42px;
            background: Theme.bg-elevated;

            HorizontalLayout {
                padding-left: 20px;
                padding-right: 20px;
                spacing: 10px;
                alignment: center;

                // Select All checkbox
                Rectangle {
                    width: 28px;
                    height: 28px;
                    background: select-all-ta.has-hover ? Theme.hover-fill-strong : Theme.hover-fill;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: root.dl-all-selected ? Theme.accent : Theme.border-subtle;

                    Rectangle {
                        width: 14px;
                        height: 14px;
                        x: 7px;
                        y: 7px;
                        border-radius: 3px;
                        background: root.dl-all-selected ? Theme.accent : transparent;
                        border-width: root.dl-all-selected ? 0 : 1px;
                        border-color: Theme.text-dim;

                        if root.dl-all-selected : Text {
                            text: "\u{2713}";
                            font-size: 10px;
                            color: Theme.text-on-accent;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    select-all-ta := TouchArea {
                        clicked => {
                            root.dl-all-selected = !root.dl-all-selected;
                            root.dl-select-all(root.dl-all-selected);
                        }
                    }
                }

                // Search bar
                Rectangle {
                    horizontal-stretch: 1;
                    height: 32px;
                    background: Theme.bg-input;
                    border-radius: Theme.r-pill;
                    border-width: 1px;
                    border-color: search-input.has-focus ? Theme.accent : Theme.border-subtle;
                    clip: true;

                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        spacing: 6px;
                        alignment: center;

                        Text {
                            text: "\u{1F50D}";
                            font-size: 12px;
                            color: Theme.text-dim;
                            vertical-alignment: center;
                        }

                        search-input := TextInput {
                            horizontal-stretch: 1;
                            text <=> root.dl-search-text;
                            font-size: Theme.fs-caption;
                            color: Theme.text-primary;
                            edited => {
                                root.dl-search(root.dl-search-text);
                            }
                        }

                        // Match count
                        if root.dl-search-text != "" : Text {
                            text: root.dl-search-match-count + " found";
                            font-size: 10px;
                            color: Theme.text-dim;
                            vertical-alignment: center;
                        }

                        // Clear search
                        if root.dl-search-text != "" : TouchArea {
                            width: 20px;
                            height: 20px;
                            clicked => {
                                root.dl-search-text = "";
                                root.dl-search("");
                            }
                            Rectangle {
                                width: 20px; height: 20px;
                                border-radius: 10px;
                                background: parent.has-hover ? Theme.hover-fill : transparent;
                                Text {
                                    text: "\u{2715}";
                                    font-size: 10px;
                                    color: Theme.text-dim;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }

                // Sort selector
                Rectangle {
                    width: sort-label.preferred-width + 24px;
                    height: 30px;
                    background: sort-ta.has-hover ? Theme.hover-fill-strong : Theme.hover-fill;
                    border-radius: Theme.r-pill;
                    border-width: 1px;
                    border-color: Theme.border-subtle;

                    sort-label := HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        spacing: 4px;
                        alignment: center;

                        Text {
                            text: "\u{2195}";
                            font-size: 11px;
                            color: Theme.text-dim;
                            vertical-alignment: center;
                        }

                        Text {
                            text: root.dl-sort-mode == 0 ? "Date"
                                : root.dl-sort-mode == 1 ? "Name"
                                : root.dl-sort-mode == 2 ? "Size"
                                : "Status";
                            font-size: 11px;
                            color: Theme.text-secondary;
                            vertical-alignment: center;
                        }
                    }

                    sort-ta := TouchArea {
                        clicked => {
                            // Cycle through sort modes: 0->1->2->3->0
                            if root.dl-sort-mode >= 3 {
                                root.dl-sort-mode = 0;
                            } else {
                                root.dl-sort-mode = root.dl-sort-mode + 1;
                            }
                            root.dl-sort(root.dl-sort-mode);
                        }
                    }
                }
            }
        }

        // ── Separator ──
        Rectangle { height: 1px; background: Theme.separator; }

        // ── Main Download List ──
        Rectangle {
            vertical-stretch: 1;
            background: Theme.bg-surface;

            VerticalLayout {
                // Empty state
                if root.downloads.length == 0 : Rectangle {
                    vertical-stretch: 1;

                    VerticalLayout {
                        alignment: center;
                        spacing: 12px;

                        Text {
                            text: "\u{2193}";
                            font-size: 48px;
                            color: Theme.text-dim;
                            horizontal-alignment: center;
                        }

                        Text {
                            text: root.dl-search-text != "" ? "No matching downloads" : "No downloads";
                            font-size: Theme.fs-headline;
                            color: Theme.text-dim;
                            horizontal-alignment: center;
                        }

                        Text {
                            text: root.dl-search-text != "" ? "Try a different search term" : "Add a URL to start downloading";
                            font-size: Theme.fs-caption;
                            color: Theme.text-dim;
                            horizontal-alignment: center;
                        }
                    }
                }

                // Download list
                if root.downloads.length > 0 : ListView {
                    vertical-stretch: 1;

                    for dl[idx] in root.downloads : Rectangle {
                        height: root.dl-expanded-id == dl.id ? 210px : 80px;
                        background: dl-row-ta.has-hover ? Theme.hover-fill : transparent;
                        animate height { duration: 150ms; easing: ease-out; }

                        VerticalLayout {
                            padding: 12px;
                            padding-left: 20px;
                            padding-right: 20px;
                            spacing: 6px;

                            // Row 1: checkbox + filename + status + actions
                            HorizontalLayout {
                                spacing: 12px;

                                // Selection checkbox
                                Rectangle {
                                    width: 18px;
                                    height: 18px;
                                    border-radius: 4px;
                                    border-width: 1px;
                                    border-color: dl.is-selected ? Theme.accent : Theme.text-dim;
                                    background: dl.is-selected ? Theme.accent : transparent;
                                    y: (parent.height - self.height) / 2;

                                    if dl.is-selected : Text {
                                        text: "\u{2713}";
                                        font-size: 10px;
                                        color: Theme.text-on-accent;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }

                                    TouchArea {
                                        clicked => { root.dl-toggle-select(dl.id); }
                                    }
                                }

                                // Status icon
                                Rectangle {
                                    width: 10px;
                                    height: 10px;
                                    border-radius: 5px;
                                    y: (parent.height - self.height) / 2;
                                    background:
                                        dl.status == "downloading" ? Theme.accent
                                      : dl.status == "paused" ? Theme.amber
                                      : dl.status == "completed" ? Theme.color-success
                                      : dl.status == "failed" ? Theme.color-emotional
                                      : Theme.text-dim;  // queued
                                }

                                // Filename
                                Text {
                                    text: dl.filename;
                                    font-size: Theme.fs-body;
                                    font-weight: 600;
                                    color: Theme.text-primary;
                                    overflow: elide;
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                }

                                // Checksum badge (for completed downloads)
                                if dl.status == "completed" && dl.checksum-status != "none" : Rectangle {
                                    width: 70px;
                                    height: 20px;
                                    border-radius: 10px;
                                    background:
                                        dl.checksum-status == "pass" ? Theme.color-success-dim
                                      : dl.checksum-status == "fail" ? Theme.color-danger-dim
                                      : Theme.hover-fill-strong;

                                    Text {
                                        text: dl.checksum-status == "pass" ? "\u{2713} Hash OK"
                                            : dl.checksum-status == "fail" ? "\u{2715} Mismatch"
                                            : "\u{231B} Verifying";
                                        font-size: 9px;
                                        font-weight: 500;
                                        color:
                                            dl.checksum-status == "pass" ? Theme.color-success
                                          : dl.checksum-status == "fail" ? Theme.color-danger
                                          : Theme.text-dim;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                // Verify button (for ALL completed downloads — no checksum needed)
                                if dl.status == "completed" && dl.checksum-status == "none" : Rectangle {
                                    width: 56px;
                                    height: 22px;
                                    background: verify-ta.has-hover ? Theme.hover-fill-strong : Theme.hover-fill;
                                    border-radius: 11px;
                                    border-width: 1px;
                                    border-color: Theme.border-subtle;

                                    Text {
                                        text: "Verify";
                                        font-size: 10px;
                                        color: Theme.text-secondary;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }

                                    verify-ta := TouchArea {
                                        clicked => { root.dl-verify-checksum(dl.id); }
                                    }
                                }

                                // Checksum result text (when verified without an expected checksum)
                                if dl.status == "completed" && root.dl-checksum-result != "" && dl.checksum-expected == "" && dl.checksum-status != "none" : Text {
                                    text: "SHA-256: " + root.dl-checksum-result;
                                    font-size: 9px;
                                    color: Theme.text-dim;
                                    overflow: elide;
                                    max-width: 200px;
                                    vertical-alignment: center;
                                }

                                // Speed (only when downloading)
                                if dl.status == "downloading" : Text {
                                    text: dl.speed-text;
                                    font-size: Theme.fs-caption;
                                    font-weight: 500;
                                    color: Theme.accent;
                                    vertical-alignment: center;
                                }

                                // ETA (only when downloading)
                                if dl.status == "downloading" && dl.eta-text != "" : Text {
                                    text: dl.eta-text;
                                    font-size: Theme.fs-caption;
                                    color: Theme.text-dim;
                                    vertical-alignment: center;
                                }

                                // Size text
                                Text {
                                    text: dl.size-text;
                                    font-size: Theme.fs-caption;
                                    color: Theme.text-secondary;
                                    vertical-alignment: center;
                                }

                                // Status badge
                                Rectangle {
                                    width: 80px;
                                    height: 22px;
                                    border-radius: 11px;
                                    background:
                                        dl.status == "downloading" ? Theme.accent-glow
                                      : dl.status == "paused" ? Theme.amber-glow
                                      : dl.status == "completed" ? Theme.color-success-dim
                                      : dl.status == "failed" ? Theme.color-danger-dim
                                      : Theme.hover-fill;

                                    Text {
                                        text: dl.status == "downloading" ? "Downloading"
                                            : dl.status == "paused" ? "Paused"
                                            : dl.status == "completed" ? "Completed"
                                            : dl.status == "failed" ? "Failed"
                                            : "Queued";
                                        font-size: 10px;
                                        font-weight: 500;
                                        color:
                                            dl.status == "downloading" ? Theme.accent
                                          : dl.status == "paused" ? Theme.amber
                                          : dl.status == "completed" ? Theme.color-success
                                          : dl.status == "failed" ? Theme.color-emotional
                                          : Theme.text-dim;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                // Action: Pause/Resume
                                if dl.status == "downloading" || dl.status == "paused" : Rectangle {
                                    width: 28px;
                                    height: 28px;
                                    background: pause-ta.has-hover ? Theme.hover-fill-strong : Theme.hover-fill;
                                    border-radius: 14px;

                                    Text {
                                        text: dl.status == "paused" ? "\u{25B6}" : "\u{23F8}";
                                        font-size: 12px;
                                        color: Theme.text-secondary;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }

                                    pause-ta := TouchArea {
                                        clicked => {
                                            if dl.status == "paused" {
                                                root.dl-resume(dl.id);
                                            } else {
                                                root.dl-pause(dl.id);
                                            }
                                        }
                                    }
                                }

                                // Action: Cancel (for active/paused/queued)
                                if dl.status == "downloading" || dl.status == "paused" || dl.status == "queued" : Rectangle {
                                    width: 28px;
                                    height: 28px;
                                    background: cancel-dl-ta.has-hover ? Theme.color-danger-dim : Theme.hover-fill;
                                    border-radius: 14px;

                                    Text {
                                        text: "\u{2715}";
                                        font-size: 12px;
                                        color: cancel-dl-ta.has-hover ? Theme.color-emotional : Theme.text-dim;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }

                                    cancel-dl-ta := TouchArea {
                                        clicked => { root.dl-cancel(dl.id); }
                                    }
                                }

                                // Action: Retry (for failed)
                                if dl.status == "failed" : Rectangle {
                                    width: 28px;
                                    height: 28px;
                                    background: retry-ta.has-hover ? Theme.hover-fill-strong : Theme.hover-fill;
                                    border-radius: 14px;

                                    Text {
                                        text: "\u{21BB}";
                                        font-size: 14px;
                                        color: Theme.text-secondary;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }

                                    retry-ta := TouchArea {
                                        clicked => { root.dl-retry(dl.id); }
                                    }
                                }

                                // Action: Open folder (for completed)
                                if dl.status == "completed" : Rectangle {
                                    width: 28px;
                                    height: 28px;
                                    background: folder-ta.has-hover ? Theme.hover-fill-strong : Theme.hover-fill;
                                    border-radius: 14px;

                                    Text {
                                        text: "\u{1F4C2}";
                                        font-size: 14px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }

                                    folder-ta := TouchArea {
                                        clicked => { root.dl-open-folder(dl.id); }
                                    }
                                }

                                // Expand/collapse toggle
                                Rectangle {
                                    width: 24px;
                                    height: 24px;
                                    background: expand-ta.has-hover ? Theme.hover-fill-strong : transparent;
                                    border-radius: 12px;

                                    Text {
                                        text: root.dl-expanded-id == dl.id ? "\u{25B2}" : "\u{25BC}";
                                        font-size: 10px;
                                        color: Theme.text-dim;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }

                                    expand-ta := TouchArea {
                                        clicked => {
                                            if root.dl-expanded-id == dl.id {
                                                root.dl-expanded-id = -1;
                                            } else {
                                                root.dl-expanded-id = dl.id;
                                            }
                                        }
                                    }
                                }
                            }

                            // Row 2: URL preview + save dir
                            HorizontalLayout {
                                spacing: 12px;

                                // URL preview (truncated)
                                Text {
                                    text: dl.url;
                                    font-size: 11px;
                                    color: Theme.text-dim;
                                    overflow: elide;
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                }

                                // Save directory indicator
                                if dl.save-dir != "" : HorizontalLayout {
                                    spacing: 4px;
                                    Text {
                                        text: "\u{1F4C1}";
                                        font-size: 10px;
                                        color: Theme.text-dim;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: dl.save-dir;
                                        font-size: 10px;
                                        color: Theme.text-dim;
                                        overflow: elide;
                                        max-width: 200px;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            // Row 3: Progress bar (only for non-completed states)
                            if dl.status != "completed" && dl.status != "failed" : Rectangle {
                                height: 4px;
                                border-radius: 2px;
                                background: Theme.bg-deep;

                                Rectangle {
                                    width: max(0px, parent.width * dl.progress);
                                    height: 100%;
                                    border-radius: 2px;
                                    background:
                                        dl.status == "downloading" ? Theme.accent
                                      : dl.status == "paused" ? Theme.amber
                                      : Theme.text-dim;
                                    animate width { duration: 300ms; }
                                }
                            }

                            // Completed: full green bar
                            if dl.status == "completed" : Rectangle {
                                height: 4px;
                                border-radius: 2px;
                                background: Theme.color-success;
                            }

                            // Failed: red bar
                            if dl.status == "failed" : Rectangle {
                                height: 4px;
                                border-radius: 2px;
                                background: Theme.color-emotional;
                                opacity: 0.6;
                            }

                            // ── Expanded Details Panel ──
                            if root.dl-expanded-id == dl.id : Rectangle {
                                height: 100px;
                                background: Theme.bg-deep;
                                border-radius: 8px;

                                VerticalLayout {
                                    padding: 10px;
                                    padding-left: 14px;
                                    padding-right: 14px;
                                    spacing: 4px;

                                    // Full URL
                                    HorizontalLayout {
                                        spacing: 8px;
                                        Text {
                                            text: "URL:";
                                            font-size: 10px;
                                            font-weight: 600;
                                            color: Theme.text-dim;
                                            width: 70px;
                                            vertical-alignment: center;
                                        }
                                        Text {
                                            text: dl.url;
                                            font-size: 10px;
                                            color: Theme.text-secondary;
                                            overflow: elide;
                                            horizontal-stretch: 1;
                                            vertical-alignment: center;
                                        }
                                    }

                                    // Save path
                                    HorizontalLayout {
                                        spacing: 8px;
                                        Text {
                                            text: "Save Path:";
                                            font-size: 10px;
                                            font-weight: 600;
                                            color: Theme.text-dim;
                                            width: 70px;
                                            vertical-alignment: center;
                                        }
                                        Text {
                                            text: dl.save-dir != "" ? dl.save-dir : "~/Downloads";
                                            font-size: 10px;
                                            color: Theme.text-secondary;
                                            overflow: elide;
                                            horizontal-stretch: 1;
                                            vertical-alignment: center;
                                        }
                                    }

                                    // Start time
                                    HorizontalLayout {
                                        spacing: 8px;
                                        Text {
                                            text: "Started:";
                                            font-size: 10px;
                                            font-weight: 600;
                                            color: Theme.text-dim;
                                            width: 70px;
                                            vertical-alignment: center;
                                        }
                                        Text {
                                            text: dl.start-time != "" ? dl.start-time : "-";
                                            font-size: 10px;
                                            color: Theme.text-secondary;
                                            vertical-alignment: center;
                                        }

                                        Rectangle { width: 20px; }

                                        Text {
                                            text: "Ended:";
                                            font-size: 10px;
                                            font-weight: 600;
                                            color: Theme.text-dim;
                                            width: 50px;
                                            vertical-alignment: center;
                                        }
                                        Text {
                                            text: dl.end-time != "" ? dl.end-time : "-";
                                            font-size: 10px;
                                            color: Theme.text-secondary;
                                            vertical-alignment: center;
                                        }
                                    }

                                    // File type + hash
                                    HorizontalLayout {
                                        spacing: 8px;
                                        Text {
                                            text: "Type:";
                                            font-size: 10px;
                                            font-weight: 600;
                                            color: Theme.text-dim;
                                            width: 70px;
                                            vertical-alignment: center;
                                        }
                                        Text {
                                            text: dl.file-type != "" ? dl.file-type : "unknown";
                                            font-size: 10px;
                                            color: Theme.text-secondary;
                                            vertical-alignment: center;
                                        }

                                        Rectangle { width: 20px; }

                                        Text {
                                            text: "SHA-256:";
                                            font-size: 10px;
                                            font-weight: 600;
                                            color: Theme.text-dim;
                                            width: 50px;
                                            vertical-alignment: center;
                                        }
                                        Text {
                                            text: dl.file-hash != "" ? dl.file-hash : "-";
                                            font-size: 10px;
                                            color: Theme.text-secondary;
                                            overflow: elide;
                                            horizontal-stretch: 1;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                        }

                        // Separator
                        Rectangle {
                            y: parent.height - 1px;
                            height: 1px;
                            background: Theme.separator;
                        }

                        dl-row-ta := TouchArea {
                            double-clicked => {
                                // Double-click to expand/collapse
                                if root.dl-expanded-id == dl.id {
                                    root.dl-expanded-id = -1;
                                } else {
                                    root.dl-expanded-id = dl.id;
                                }
                            }
                        }
                    }
                }
            }
        }

        // ── Error bar ──
        if root.error-text != "" : Rectangle {
            height: 36px;
            background: Theme.color-danger.with-alpha(0.09);
            border-width: 1px;
            border-color: Theme.color-danger.with-alpha(0.25);

            HorizontalLayout {
                padding-left: 16px;
                padding-right: 16px;
                alignment: center;

                Text {
                    text: root.error-text;
                    font-size: Theme.fs-caption;
                    color: Theme.color-danger;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                    overflow: elide;
                }
            }
        }

        // ── Bottom Filter Tabs ──
        Rectangle {
            height: 40px;
            background: Theme.bg-elevated;

            HorizontalLayout {
                padding-left: 20px;
                padding-right: 20px;
                spacing: 4px;
                alignment: center;

                // All
                Rectangle {
                    width: 64px;
                    height: 30px;
                    background: root.active-filter == 0 ? Theme.accent-glow : transparent;
                    border-radius: Theme.r-pill;
                    border-width: root.active-filter == 0 ? 1px : 0;
                    border-color: root.active-filter == 0 ? Theme.accent-dim : transparent;

                    Text {
                        text: "All";
                        font-size: Theme.fs-caption;
                        font-weight: root.active-filter == 0 ? 600 : 400;
                        color: root.active-filter == 0 ? Theme.accent : Theme.text-secondary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    TouchArea {
                        clicked => {
                            root.active-filter = 0;
                            root.dl-filter(0);
                        }
                    }
                }

                // Active
                Rectangle {
                    width: 76px;
                    height: 30px;
                    background: root.active-filter == 1 ? Theme.accent-glow : transparent;
                    border-radius: Theme.r-pill;
                    border-width: root.active-filter == 1 ? 1px : 0;
                    border-color: root.active-filter == 1 ? Theme.accent-dim : transparent;

                    Text {
                        text: "Active";
                        font-size: Theme.fs-caption;
                        font-weight: root.active-filter == 1 ? 600 : 400;
                        color: root.active-filter == 1 ? Theme.accent : Theme.text-secondary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    TouchArea {
                        clicked => {
                            root.active-filter = 1;
                            root.dl-filter(1);
                        }
                    }
                }

                // Completed
                Rectangle {
                    width: 92px;
                    height: 30px;
                    background: root.active-filter == 2 ? Theme.accent-glow : transparent;
                    border-radius: Theme.r-pill;
                    border-width: root.active-filter == 2 ? 1px : 0;
                    border-color: root.active-filter == 2 ? Theme.accent-dim : transparent;

                    Text {
                        text: "Completed";
                        font-size: Theme.fs-caption;
                        font-weight: root.active-filter == 2 ? 600 : 400;
                        color: root.active-filter == 2 ? Theme.accent : Theme.text-secondary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    TouchArea {
                        clicked => {
                            root.active-filter = 2;
                            root.dl-filter(2);
                        }
                    }
                }

                // Failed
                Rectangle {
                    width: 72px;
                    height: 30px;
                    background: root.active-filter == 3 ? Theme.accent-glow : transparent;
                    border-radius: Theme.r-pill;
                    border-width: root.active-filter == 3 ? 1px : 0;
                    border-color: root.active-filter == 3 ? Theme.accent-dim : transparent;

                    Text {
                        text: "Failed";
                        font-size: Theme.fs-caption;
                        font-weight: root.active-filter == 3 ? 600 : 400;
                        color: root.active-filter == 3 ? Theme.accent : Theme.text-secondary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    TouchArea {
                        clicked => {
                            root.active-filter = 3;
                            root.dl-filter(3);
                        }
                    }
                }
            }
        }
    }
}
