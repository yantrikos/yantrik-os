    Rectangle {
        clip: true;
        width: 100%;
        height: 100%;

        // Boot screen
        if current-screen == 0 : BootScreen {
            width: 100%; height: 100%;
            status-text: root.boot-status;
            memory-count: root.memory-count;
            boot-complete => {
                if root.onboarding-step > 0 {
                    root.current-screen = 2;
                    root.navigate(2);
                } else {
                    root.current-screen = 1;
                    root.navigate(1);
                }
            }
        }

        // Onboarding (first boot only)
        if current-screen == 2 : OnboardingScreen {
            width: 100%; height: 100%;
            companion-name: root.settings-companion-name;
            // AI hardware scan properties
            ai-hw-cpu-ok: root.onboard-ai-hw-cpu-ok;
            ai-hw-ram-ok: root.onboard-ai-hw-ram-ok;
            ai-hw-gpu-ok: root.onboard-ai-hw-gpu-ok;
            ai-hw-disk-ok: root.onboard-ai-hw-disk-ok;
            ai-hw-network-ok: root.onboard-ai-hw-network-ok;
            ai-hw-runtime-ok: root.onboard-ai-hw-runtime-ok;
            ai-hw-cpu-label: root.onboard-ai-hw-cpu-label;
            ai-hw-ram-label: root.onboard-ai-hw-ram-label;
            ai-hw-gpu-label: root.onboard-ai-hw-gpu-label;
            ai-hw-disk-label: root.onboard-ai-hw-disk-label;
            ai-hw-recommend: root.onboard-ai-hw-recommend;
            ai-test-status: root.onboard-ai-test-status;
            ai-test-model: root.onboard-ai-test-model;
            ai-test-latency-ms: root.onboard-ai-test-latency-ms;
            ai-test-privacy: root.onboard-ai-test-privacy;
            set-names(user-name, comp-name) => {
                if user-name != "" {
                    root.rename-user(user-name);
                    root.settings-user-name = user-name;
