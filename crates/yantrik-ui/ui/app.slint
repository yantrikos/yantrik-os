// Yantrik OS — AI-native desktop shell.
// Screen states: 0=boot, 1=desktop, 2=onboarding, 3=lock, 4=bond, 5=personality,
//   6=memory, 7=settings, 8=files, 9=notifications, 10=system,
//   11=image_viewer, 12=text_editor, 13=media_player, 14=terminal, 15=notes, 16=about.
// The AI IS the shell — Intent Lens is the primary interaction.

import { Theme, ThemeMode, ThemeOverrides, AccentPreset } from "theme.slint";
import { BootScreen } from "boot.slint";
import { OnboardingScreen } from "onboarding.slint";
import { DesktopScreen } from "desktop.slint";
import { BondScreen, BondData } from "bond.slint";
import { PersonalityScreen, OpinionData, SharedRefData } from "personality.slint";
import { LockScreen } from "lock.slint";
import { SettingsScreen } from "settings.slint";
import { MemoryBrowser, MemoryItem } from "memory_browser.slint";
import { FileBrowser, FileEntry, BreadcrumbSegment, FileDetailData } from "file_browser.slint";
import { NotificationCenter, NotificationData } from "notification_center.slint";
import { SystemDashboard, ProcessData } from "system_dashboard.slint";
import { VoiceOverlay } from "voice_overlay.slint";
import { ImageViewer } from "image_viewer.slint";
import { TextEditorScreen } from "text_editor.slint";
import { MediaPlayer } from "media_player.slint";
import { TerminalScreen, TerminalTabData } from "terminal.slint";
import { NotesEditor, NoteEntry } from "notes_editor.slint";
import { AboutScreen } from "about.slint";
import { ToastBanner, ToastData } from "components/toast_banner.slint";
import { ContentBlock, MessageData } from "components/message_bubble.slint";
import { UrgeCardData } from "components/glance_card.slint";
import { LensResult } from "components/intent_lens.slint";
import { WhisperCardItem } from "components/whisper_card.slint";
import { ClipboardEntryData } from "components/clipboard_panel.slint";
import { AppGridItem } from "components/app_grid.slint";
import { WindowItem } from "components/window_switcher.slint";
import { DockItem, AppDock } from "components/app_dock.slint";
import { WindowFrame } from "components/window_frame.slint";

export { ThemeMode, ThemeOverrides, AccentPreset, ContentBlock, MessageData, UrgeCardData, BondData, OpinionData, SharedRefData, MemoryItem, LensResult, WhisperCardItem, FileEntry, BreadcrumbSegment, FileDetailData, NotificationData, ProcessData, ClipboardEntryData, AppGridItem, WindowItem, DockItem, NoteEntry, ToastData, TerminalTabData }

export component App inherits Window {
    title: "Yantrik OS";
    default-font-size: 14px;
    background: Theme.bg-deep;

    // Screen state: 0=boot, 1=desktop, 2=onboarding, 3=lock, 4=bond, 5=personality,
    //   6=memory, 7=settings, 8=files, 9=notifications, 10=system
    in-out property <int> current-screen: 0;

    // Window chrome state (shared across all windowed screens)
    in-out property <bool> window-maximized: true;

    // Boot state
    in property <string> boot-status: "remembering...";

    // Companion state
    in property <int> memory-count: 0;
    in property <bool> is-thinking: false;
    in property <bool> has-urges: false;
    in property <bool> is-speaking: false;
    in property <bool> is-listening: false;
    in property <bool> companion-online: true;  // LLM backend reachable

    // Chat state
    in property <[MessageData]> messages: [];
    in property <bool> is-generating: false;

    // Desktop state
    in property <[UrgeCardData]> urges: [];
    in property <string> clock-text: "00:00";
    in property <string> companion-status: "idle";
    in property <int> battery-level: 100;
    in property <bool> battery-charging: false;
    in property <bool> wifi-connected: false;
    in property <int> pending-count: 0;
    in property <string> greeting-text: "Hello";

    // Intent Lens state
    in-out property <bool> lens-open: false;
    in property <[LensResult]> lens-results: [];
    in property <bool> lens-chat-mode: false;
    in property <[LensResult]> lens-suggestions: [];
    in property <[LensResult]> lens-recents: [];

    // Bond state
    in property <BondData> bond-data: {
        bond-score: 0.0,
        bond-level: "Stranger",
        total-interactions: 0,
        days-together: 0,
        current-streak: 0,
        humor-rate: 0.0,
        vulnerability-events: 0,
        shared-references: 0,
    };

    // Personality state
    in property <float> formality: 0.5;
    in property <float> humor-ratio: 0.0;
    in property <float> opinion-strength: 0.0;
    in property <float> question-ratio: 0.5;
    in property <[OpinionData]> opinions: [];
    in property <[SharedRefData]> shared-refs: [];

    // Memory browser state
    in property <[MemoryItem]> memory-results: [];
    in property <bool> is-searching-memories: false;

    // Voice state
    in-out property <bool> voice-active: false;
    in property <int> voice-state: 0;
    in property <string> voice-transcribed: "";
    in property <string> voice-response: "";

    // Whisper Cards (floating notifications)
    in property <[WhisperCardItem]> whisper-cards: [];
    in property <int> whisper-hint-count: 0;

    // Clipboard panel state
    in-out property <bool> clip-panel-open: false;
    in property <[ClipboardEntryData]> clip-panel-entries: [];
    in-out property <string> clip-search-query: "";
    callback clipboard-paste(int);
    callback clipboard-search(string);

    // Power menu state
    in-out property <bool> power-menu-open: false;
    callback power-action(string);

    // App grid state
    in-out property <bool> app-grid-open: false;
    in property <[AppGridItem]> grid-apps: [];
    callback grid-launch-app(string);

    // Window switcher state
    in-out property <bool> window-switcher-open: false;
    in property <[WindowItem]> window-list: [];
    callback switch-window(string);

    // Dock items (for running indicators)
    in property <[DockItem]> dock-items: [];

    // Quick Settings state
    in-out property <bool> quick-settings-open: false;
    in-out property <int> brightness-level: 80;
    in-out property <int> volume-level: 50;
    callback toggle-wifi();
    callback brightness-changed(int);
    callback volume-changed(int);

    // Notification toast (legacy — kept for backward compatibility)
    in property <string> notification-text: "";
    in-out property <bool> show-notification: false;

    // Toast notification banners (stacking, glassmorphic)
    in property <[ToastData]> toast-queue: [];
    callback toast-clicked(int);
    callback toast-dismissed(int);

    // Ambient Intelligence state
    in property <float> particle-sentiment: 0.0;
    in property <float> particle-cognitive-load: 0.0;
    in property <float> particle-time-of-day: 0.5;

    // Project Consciousness
    in property <string> active-project: "";

    // Do Not Disturb mode
    in-out property <bool> dnd-mode: false;
    callback toggle-dnd-mode();

    // Focus mode (Workspace Morph)
    in-out property <bool> focus-mode: false;
    in property <string> focus-remaining: "";
    callback end-focus-mode();

    // Lock screen state
    in property <string> lock-error: "";
    in property <string> lock-date-text: "";
    in property <string> lock-greeting: "";
    callback try-unlock(string);
    callback lock-screen();

    // Settings state (screen 7)
    in property <string> settings-user-name: "";
    in property <string> settings-companion-name: "Yantrik";
    in property <string> settings-model-name: "";
    in property <int> settings-max-context: 4096;
    in property <int> settings-max-tokens: 512;
    in property <string> settings-tool-permission: "sensitive";
    in property <int> settings-auto-lock-secs: 300;
    in property <string> settings-version: "0.1.0";
    in property <string> settings-ip-address: "";
    in property <string> settings-display-resolution: "";
    in property <string> settings-llm-backend: "candle";
    in property <string> settings-llm-api-url: "";
    in property <string> settings-llm-api-model: "";
    in-out property <bool> settings-dark-mode: true;
    in-out property <bool> settings-incognito-mode: false;
    in-out property <string> settings-accent-color: "cyan";
    callback toggle-dark-mode();
    callback toggle-incognito-mode();
    callback cycle-accent-color();
    callback cycle-tool-permission();
    callback cycle-auto-lock();

    // File browser state (screen 8)
    in property <string> file-browser-path: "~";
    in property <[FileEntry]> file-browser-entries: [];
    in property <bool> file-browser-loading: false;
    in property <[BreadcrumbSegment]> file-breadcrumbs: [];
    in property <bool> file-has-clipboard: false;
    in-out property <bool> file-show-hidden: false;
    in-out property <bool> file-grid-view: false;
    callback file-navigate-dir(string);
    callback file-open(string);
    callback file-go-up();
    callback file-navigate-to-path(string);
    callback file-toggle-hidden();
    callback file-delete(string);
    callback file-rename(string, string);
    callback file-copy(string);
    callback file-cut(string);
    callback file-paste();
    callback file-create-folder(string);
    in property <FileDetailData> file-detail-data;
    in property <string> file-free-space-text: "";
    in property <bool> file-can-go-back: false;
    in property <bool> file-can-go-forward: false;
    callback file-selection-changed(string);
    callback file-go-back();
    callback file-go-forward();
    callback file-sort-changed(string, bool);
    callback file-filter-changed(string);
    // File browser AI features
    in property <string> file-ai-summary: "";
    in property <bool> file-is-summarizing: false;
    in property <string> file-dir-type-badge: "";
    callback file-request-summarize();
    callback file-request-ask-ai();

    // Notification Center state (screen 9)
    in property <[NotificationData]> notification-list: [];
    in property <int> notification-unread-count: 0;
    callback notification-clear-all();
    callback notification-mark-all-read();
    callback notification-tapped(string);
    callback notification-clear-group(string);

    // System Dashboard state (screen 10)
    in property <float> sys-cpu-usage: 0.0;
    in property <float> sys-memory-usage: 0.0;
    in property <string> sys-memory-text: "0 / 0 MB";
    in property <string> sys-uptime-text: "";
    in property <string> sys-wifi-ssid: "";
    in property <int> sys-wifi-signal: 0;
    in property <[ProcessData]> sys-top-processes: [];
    in property <[float]> sys-cpu-history: [];
    in property <[float]> sys-memory-history: [];

    // Image Viewer state (screen 11)
    in property <image> viewer-image;
    in property <string> viewer-file-name: "";
    in property <string> viewer-counter: "";
    in-out property <bool> viewer-fit-contain: true;
    callback viewer-nav-prev();
    callback viewer-nav-next();
    callback viewer-toggle-fit();

    // Text Editor state (screen 12)
    in property <string> editor-file-name: "untitled";
    in-out property <string> editor-file-content: "";
    in property <bool> editor-is-modified: false;
    in property <bool> editor-is-readonly: false;
    in-out property <bool> editor-show-save-dialog: false;
    in-out property <string> editor-save-dir: "~/";
    in-out property <string> editor-save-filename: "untitled.txt";
    in property <string> editor-save-error: "";
    callback editor-save();
    callback editor-save-as(string, string);
    callback editor-content-changed(string);
    // Editor AI assist
    in-out property <bool> editor-show-ai-panel: false;
    in-out property <string> editor-ai-prompt: "";
    in property <string> editor-ai-response: "";
    in property <bool> editor-ai-is-working: false;
    callback editor-ai-request(string);
    callback editor-ai-insert();
    callback editor-ai-dismiss();

    // Media Player state (screen 13)
    in property <string> player-track-name: "";
    in property <bool> player-is-playing: false;
    in property <float> player-progress: 0.0;
    in property <string> player-time-current: "0:00";
    in property <string> player-time-total: "0:00";
    callback player-play-pause();
    callback player-stop();
    callback player-seek(float);

    // Terminal state (screen 14)
    in property <string> terminal-output: "";
    in property <int> terminal-cursor-row: 0;
    in property <int> terminal-cursor-col: 0;
    in property <bool> terminal-is-alive: true;
    in property <string> terminal-ai-suggestion: "";
    in property <bool> terminal-has-suggestion: false;
    in property <int> terminal-tab-count: 1;
    in property <int> terminal-active-tab: 0;
    in property <[TerminalTabData]> terminal-tabs: [];
    callback terminal-key-pressed(KeyEvent) -> EventResult;
    callback terminal-request-ai-help();
    callback terminal-dismiss-suggestion();
    callback terminal-restart();
    callback terminal-switch-tab(int);
    callback terminal-new-tab();
    callback terminal-close-tab(int);

    // Notes Editor state (screen 15)
    in-out property <string> notes-current-content: "";
    in property <string> notes-current-title: "";
    in property <bool> notes-is-modified: false;
    in property <[NoteEntry]> notes-list: [];
    in property <int> notes-selected-index: -1;
    in-out property <string> notes-search-query: "";
    in property <int> notes-note-count: 0;
    callback notes-new();
    callback notes-save();
    callback notes-delete();
    callback notes-select(int);
    callback notes-search(string);
    callback notes-content-changed(string);

    // About screen state (screen 16)
    in property <string> about-hostname: "";
    in property <string> about-kernel: "";
    in property <string> about-cpu: "";
    in property <string> about-ram: "";
    in property <string> about-disk: "";
    in property <string> about-uptime: "";
    in property <string> about-version: "0.3.0";
    in property <string> about-build-date: "";

    // Onboarding state (0=not onboarding, 1=step:terminal, 2=step:focus, 3=done)
    in-out property <int> onboarding-step: 0;
    callback onboarding-ready();
    callback onboarding-skip();

    // Callbacks to Rust
    callback send-message(string);
    callback mic-pressed();
    callback navigate(int);
    callback search-memories(string);
    callback cancel-voice();
    callback launch-app(string);
    callback lens-query(string);
    callback lens-submit(string);
    callback lens-result-selected(string);
    callback open-lens();
    callback close-lens();
    callback whisper-card-dismissed(string);
    callback whisper-card-action(string);
    callback whisper-hint-clicked();

    Rectangle {
        clip: true;
        width: 100%;
        height: 100%;

        // Boot screen
        if current-screen == 0 : BootScreen {
            width: 100%; height: 100%;
            status-text: root.boot-status;
            memory-count: root.memory-count;
            boot-complete => {
                if root.onboarding-step > 0 {
                    root.current-screen = 2;
                    root.navigate(2);
                } else {
                    root.current-screen = 1;
                    root.navigate(1);
                }
            }
        }

        // Onboarding (first boot only)
        if current-screen == 2 : OnboardingScreen {
            width: 100%; height: 100%;
            ready => {
                root.current-screen = 1;
                root.navigate(1);
                root.onboarding-ready();
            }
            skip => {
                root.current-screen = 1;
                root.navigate(1);
                root.onboarding-skip();
            }
        }

        // Lock screen
        if current-screen == 3 : LockScreen {
            width: 100%; height: 100%;
            clock-text: root.clock-text;
            date-text: root.lock-date-text;
            greeting-text: root.lock-greeting;
            error-text: root.lock-error;
            try-unlock(pin) => { root.try-unlock(pin); }
        }

        // Desktop (the main experience)
        if current-screen == 1 : DesktopScreen {
            width: 100%; height: 100%;
            // Status bar
            clock-text: root.clock-text;
            companion-status: root.companion-status;
            companion-online: root.companion-online;
            battery-level: root.battery-level;
            battery-charging: root.battery-charging;
            wifi-connected: root.wifi-connected;
            pending-count: root.pending-count;
            settings-incognito-mode: root.settings-incognito-mode;
            dnd-mode: root.dnd-mode;
            // Companion
            is-thinking: root.is-thinking;
            has-urges: root.has-urges;
            is-speaking: root.is-speaking;
            is-listening: root.is-listening;
            greeting-text: root.greeting-text;
            memory-count: root.memory-count;
            // Ambient Intelligence
            particle-sentiment: root.particle-sentiment;
            particle-cognitive-load: root.particle-cognitive-load;
            particle-time-of-day: root.particle-time-of-day;
            // Project Consciousness
            active-project: root.active-project;
            // Intent Lens
            lens-open <=> root.lens-open;
            lens-results: root.lens-results;
            lens-chat-mode: root.lens-chat-mode;
            lens-suggestions: root.lens-suggestions;
            lens-recents: root.lens-recents;
            // Chat
            messages: root.messages;
            is-generating: root.is-generating;
            // Urges
            urges: root.urges;
            // Whisper Cards
            whisper-cards: root.whisper-cards;
            whisper-hint-count: root.whisper-hint-count;
            whisper-card-dismissed(id) => { root.whisper-card-dismissed(id); }
            whisper-card-action(id) => { root.whisper-card-action(id); }
            whisper-hint-clicked => { root.whisper-hint-clicked(); }
            // Clipboard panel
            clip-panel-open <=> root.clip-panel-open;
            clip-panel-entries: root.clip-panel-entries;
            clip-search-query <=> root.clip-search-query;
            clipboard-paste(idx) => { root.clipboard-paste(idx); }
            clipboard-search(query) => { root.clipboard-search(query); }
            // Power menu
            power-menu-open <=> root.power-menu-open;
            power-action(action) => { root.power-action(action); }
            // App grid
            app-grid-open <=> root.app-grid-open;
            grid-apps: root.grid-apps;
            grid-launch-app(app-id) => { root.grid-launch-app(app-id); }
            // Window switcher
            window-switcher-open <=> root.window-switcher-open;
            window-list: root.window-list;
            switch-window(title) => { root.switch-window(title); }
            // Dock items
            dock-items: root.dock-items;
            // Quick Settings
            quick-settings-open <=> root.quick-settings-open;
            brightness-level <=> root.brightness-level;
            volume-level <=> root.volume-level;
            toggle-wifi => { root.toggle-wifi(); }
            brightness-changed(val) => { root.brightness-changed(val); }
            volume-changed(val) => { root.volume-changed(val); }
            // Focus mode
            focus-mode <=> root.focus-mode;
            focus-remaining: root.focus-remaining;
            end-focus-mode => { root.end-focus-mode(); }
            // Callbacks
            send-message(text) => { root.send-message(text); }
            mic-pressed => { root.mic-pressed(); }
            launch-app(app-id) => { root.launch-app(app-id); }
            navigate-to(screen) => {
                root.current-screen = screen;
                root.navigate(screen);
            }
            lens-query(text) => { root.lens-query(text); }
            lens-submit(text) => { root.lens-submit(text); }
            lens-result-selected(id) => { root.lens-result-selected(id); }
            open-lens => { root.open-lens(); }
            close-lens => { root.close-lens(); }
        }

        // ═══ Windowed app screens (4-13) — wrapped in WindowFrame ═══

        // Bond screen
        if current-screen == 4 : WindowFrame {
            x: root.window-maximized ? 0px : parent.width * 0.05;
            y: root.window-maximized ? 0px : parent.height * 0.04;
            width: root.window-maximized ? parent.width : parent.width * 0.90;
            height: root.window-maximized ? parent.height - 60px : parent.height * 0.92;
            is-maximized <=> root.window-maximized;
            icon-char: "♥";
            icon-color: Theme.color-emotional;
            title: "Bond";
            close => { root.current-screen = 1; root.navigate(1); }
            minimize => { root.current-screen = 1; root.navigate(1); }
            animate x, y, width, height { duration: 200ms; easing: ease-out; }

            BondScreen {
                width: 100%; height: 100%;
                data: root.bond-data;
                back-pressed => {
                    root.current-screen = 1;
                    root.navigate(1);
                }
            }
        }

        // Personality screen
        if current-screen == 5 : WindowFrame {
            x: root.window-maximized ? 0px : parent.width * 0.05;
            y: root.window-maximized ? 0px : parent.height * 0.04;
            width: root.window-maximized ? parent.width : parent.width * 0.90;
            height: root.window-maximized ? parent.height - 60px : parent.height * 0.92;
            is-maximized <=> root.window-maximized;
            icon-char: "✧";
            icon-color: Theme.color-pattern;
            title: "Personality";
            close => { root.current-screen = 1; root.navigate(1); }
            minimize => { root.current-screen = 1; root.navigate(1); }
            animate x, y, width, height { duration: 200ms; easing: ease-out; }

            PersonalityScreen {
                width: 100%; height: 100%;
                formality: root.formality;
                humor-ratio: root.humor-ratio;
                opinion-strength: root.opinion-strength;
                question-ratio: root.question-ratio;
                opinions: root.opinions;
                shared-refs: root.shared-refs;
                back-pressed => {
                    root.current-screen = 1;
                    root.navigate(1);
                }
            }
        }

        // Memory browser
        if current-screen == 6 : WindowFrame {
            x: root.window-maximized ? 0px : parent.width * 0.05;
            y: root.window-maximized ? 0px : parent.height * 0.04;
            width: root.window-maximized ? parent.width : parent.width * 0.90;
            height: root.window-maximized ? parent.height - 60px : parent.height * 0.92;
            is-maximized <=> root.window-maximized;
            icon-char: "◈";
            icon-color: Theme.amber;
            title: "Memory";
            close => { root.current-screen = 1; root.navigate(1); }
            minimize => { root.current-screen = 1; root.navigate(1); }
            animate x, y, width, height { duration: 200ms; easing: ease-out; }

            MemoryBrowser {
                width: 100%; height: 100%;
                results: root.memory-results;
                is-searching: root.is-searching-memories;
                total-memories: root.memory-count;
                search(query) => { root.search-memories(query); }
                back-pressed => {
                    root.current-screen = 1;
                    root.navigate(1);
                }
            }
        }

        // Settings screen
        if current-screen == 7 : WindowFrame {
            x: root.window-maximized ? 0px : parent.width * 0.05;
            y: root.window-maximized ? 0px : parent.height * 0.04;
            width: root.window-maximized ? parent.width : parent.width * 0.90;
            height: root.window-maximized ? parent.height - 60px : parent.height * 0.92;
            is-maximized <=> root.window-maximized;
            icon-char: "⚙";
            icon-color: Theme.text-secondary;
            title: "Settings";
            close => { root.current-screen = 1; root.navigate(1); }
            minimize => { root.current-screen = 1; root.navigate(1); }
            animate x, y, width, height { duration: 200ms; easing: ease-out; }

            SettingsScreen {
                width: 100%; height: 100%;
                user-name: root.settings-user-name;
                companion-name: root.settings-companion-name;
                model-name: root.settings-model-name;
                max-context: root.settings-max-context;
                max-tokens: root.settings-max-tokens;
                tool-permission: root.settings-tool-permission;
                auto-lock-secs: root.settings-auto-lock-secs;
                wifi-connected: root.wifi-connected;
                wifi-ssid: root.sys-wifi-ssid;
                ip-address: root.settings-ip-address;
                display-resolution: root.settings-display-resolution;
                llm-backend: root.settings-llm-backend;
                llm-api-url: root.settings-llm-api-url;
                llm-api-model: root.settings-llm-api-model;
                memory-count: root.memory-count;
                version-text: root.settings-version;
                notification-count: root.notification-unread-count;
                dark-mode <=> root.settings-dark-mode;
                incognito-mode <=> root.settings-incognito-mode;
                dnd-mode <=> root.dnd-mode;
                accent-color <=> root.settings-accent-color;
                toggle-dark-mode => { root.toggle-dark-mode(); }
                toggle-incognito-mode => { root.toggle-incognito-mode(); }
                toggle-dnd-mode => { root.toggle-dnd-mode(); }
                cycle-accent-color => { root.cycle-accent-color(); }
                cycle-tool-permission => { root.cycle-tool-permission(); }
                cycle-auto-lock => { root.cycle-auto-lock(); }
                back-pressed => {
                    root.current-screen = 1;
                    root.navigate(1);
                }
                navigate-to(screen) => {
                    root.current-screen = screen;
                    root.navigate(screen);
                }
            }
        }

        // File browser
        if current-screen == 8 : WindowFrame {
            x: root.window-maximized ? 0px : parent.width * 0.05;
            y: root.window-maximized ? 0px : parent.height * 0.04;
            width: root.window-maximized ? parent.width : parent.width * 0.90;
            height: root.window-maximized ? parent.height - 60px : parent.height * 0.92;
            is-maximized <=> root.window-maximized;
            icon-char: "F";
            icon-color: Theme.cyan;
            title: "Files";
            close => { root.current-screen = 1; root.navigate(1); }
            minimize => { root.current-screen = 1; root.navigate(1); }
            animate x, y, width, height { duration: 200ms; easing: ease-out; }

            FileBrowser {
                width: 100%; height: 100%;
                current-path: root.file-browser-path;
                entries: root.file-browser-entries;
                is-loading: root.file-browser-loading;
                breadcrumbs: root.file-breadcrumbs;
                has-clipboard: root.file-has-clipboard;
                show-hidden <=> root.file-show-hidden;
                grid-view <=> root.file-grid-view;
                file-details: root.file-detail-data;
                free-space-text: root.file-free-space-text;
                can-go-back: root.file-can-go-back;
                can-go-forward: root.file-can-go-forward;
                navigate-dir(name) => { root.file-navigate-dir(name); }
                open-file(name) => { root.file-open(name); }
                go-up => { root.file-go-up(); }
                go-back => { root.file-go-back(); }
                go-forward => { root.file-go-forward(); }
                navigate-to-path(p) => { root.file-navigate-to-path(p); }
                toggle-hidden => { root.file-toggle-hidden(); }
                file-delete(name) => { root.file-delete(name); }
                file-rename(old, new) => { root.file-rename(old, new); }
                file-copy(name) => { root.file-copy(name); }
                file-cut(name) => { root.file-cut(name); }
                file-paste => { root.file-paste(); }
                create-folder(name) => { root.file-create-folder(name); }
                file-selection-changed(name) => { root.file-selection-changed(name); }
                file-sort-changed(field, ascending) => { root.file-sort-changed(field, ascending); }
                file-filter-changed(text) => { root.file-filter-changed(text); }
                ai-summary: root.file-ai-summary;
                is-summarizing: root.file-is-summarizing;
                dir-type-badge: root.file-dir-type-badge;
                request-summarize => { root.file-request-summarize(); }
                request-ask-ai => { root.file-request-ask-ai(); }
            }
        }

        // Notification Center
        if current-screen == 9 : WindowFrame {
            x: root.window-maximized ? 0px : parent.width * 0.05;
            y: root.window-maximized ? 0px : parent.height * 0.04;
            width: root.window-maximized ? parent.width : parent.width * 0.90;
            height: root.window-maximized ? parent.height - 60px : parent.height * 0.92;
            is-maximized <=> root.window-maximized;
            icon-char: "N";
            icon-color: Theme.color-follow-up;
            title: "Notifications";
            close => { root.current-screen = 1; root.navigate(1); }
            minimize => { root.current-screen = 1; root.navigate(1); }
            animate x, y, width, height { duration: 200ms; easing: ease-out; }

            NotificationCenter {
                width: 100%; height: 100%;
                notifications: root.notification-list;
                unread-count: root.notification-unread-count;
                back-pressed => {
                    root.current-screen = 1;
                    root.navigate(1);
                }
                clear-all => { root.notification-clear-all(); }
                mark-all-read => { root.notification-mark-all-read(); }
                notification-tapped(id) => { root.notification-tapped(id); }
                clear-group(name) => { root.notification-clear-group(name); }
            }
        }

        // System Dashboard
        if current-screen == 10 : WindowFrame {
            x: root.window-maximized ? 0px : parent.width * 0.05;
            y: root.window-maximized ? 0px : parent.height * 0.04;
            width: root.window-maximized ? parent.width : parent.width * 0.90;
            height: root.window-maximized ? parent.height - 60px : parent.height * 0.92;
            is-maximized <=> root.window-maximized;
            icon-char: "◉";
            icon-color: Theme.color-reminder;
            title: "System";
            close => { root.current-screen = 1; root.navigate(1); }
            minimize => { root.current-screen = 1; root.navigate(1); }
            animate x, y, width, height { duration: 200ms; easing: ease-out; }

            SystemDashboard {
                width: 100%; height: 100%;
                cpu-usage: root.sys-cpu-usage;
                memory-usage: root.sys-memory-usage;
                memory-text: root.sys-memory-text;
                battery-level: root.battery-level;
                battery-charging: root.battery-charging;
                wifi-connected: root.wifi-connected;
                wifi-ssid: root.sys-wifi-ssid;
                wifi-signal: root.sys-wifi-signal;
                uptime-text: root.sys-uptime-text;
                top-processes: root.sys-top-processes;
                cpu-history: root.sys-cpu-history;
                memory-history: root.sys-memory-history;
                back-pressed => {
                    root.current-screen = 1;
                    root.navigate(1);
                }
            }
        }

        // Image Viewer
        if current-screen == 11 : WindowFrame {
            x: root.window-maximized ? 0px : parent.width * 0.05;
            y: root.window-maximized ? 0px : parent.height * 0.04;
            width: root.window-maximized ? parent.width : parent.width * 0.90;
            height: root.window-maximized ? parent.height - 60px : parent.height * 0.92;
            is-maximized <=> root.window-maximized;
            icon-char: "▣";
            icon-color: #6a2d6a;
            title: "Image Viewer";
            close => { root.current-screen = 8; root.navigate(8); }
            minimize => { root.current-screen = 1; root.navigate(1); }
            animate x, y, width, height { duration: 200ms; easing: ease-out; }

            ImageViewer {
                width: 100%; height: 100%;
                current-image: root.viewer-image;
                file-name: root.viewer-file-name;
                counter-text: root.viewer-counter;
                fit-contain <=> root.viewer-fit-contain;
                nav-prev => { root.viewer-nav-prev(); }
                nav-next => { root.viewer-nav-next(); }
                toggle-fit => { root.viewer-toggle-fit(); }
            }
        }

        // Text Editor
        if current-screen == 12 : WindowFrame {
            x: root.window-maximized ? 0px : parent.width * 0.05;
            y: root.window-maximized ? 0px : parent.height * 0.04;
            width: root.window-maximized ? parent.width : parent.width * 0.90;
            height: root.window-maximized ? parent.height - 60px : parent.height * 0.92;
            is-maximized <=> root.window-maximized;
            icon-char: "≡";
            icon-color: #3a4a6a;
            title: "Editor";
            close => { root.current-screen = 8; root.navigate(8); }
            minimize => { root.current-screen = 1; root.navigate(1); }
            animate x, y, width, height { duration: 200ms; easing: ease-out; }

            TextEditorScreen {
                width: 100%; height: 100%;
                file-name: root.editor-file-name;
                file-content <=> root.editor-file-content;
                is-modified: root.editor-is-modified;
                is-readonly: root.editor-is-readonly;
                show-save-dialog <=> root.editor-show-save-dialog;
                save-dir <=> root.editor-save-dir;
                save-filename <=> root.editor-save-filename;
                save-error: root.editor-save-error;
                save-file => { root.editor-save(); }
                save-file-as(dir, name) => { root.editor-save-as(dir, name); }
                content-changed(text) => { root.editor-content-changed(text); }
                show-ai-panel <=> root.editor-show-ai-panel;
                ai-prompt <=> root.editor-ai-prompt;
                ai-response: root.editor-ai-response;
                ai-is-working: root.editor-ai-is-working;
                ai-request(prompt) => { root.editor-ai-request(prompt); }
                ai-insert => { root.editor-ai-insert(); }
                ai-dismiss => { root.editor-ai-dismiss(); }
            }
        }

        // Media Player
        if current-screen == 13 : WindowFrame {
            x: root.window-maximized ? 0px : parent.width * 0.05;
            y: root.window-maximized ? 0px : parent.height * 0.04;
            width: root.window-maximized ? parent.width : parent.width * 0.90;
            height: root.window-maximized ? parent.height - 60px : parent.height * 0.92;
            is-maximized <=> root.window-maximized;
            icon-char: "♪";
            icon-color: #6a5a2d;
            title: "Now Playing";
            close => { root.current-screen = 8; root.navigate(8); }
            minimize => { root.current-screen = 1; root.navigate(1); }
            animate x, y, width, height { duration: 200ms; easing: ease-out; }

            MediaPlayer {
                width: 100%; height: 100%;
                track-name: root.player-track-name;
                is-playing: root.player-is-playing;
                progress: root.player-progress;
                time-current: root.player-time-current;
                time-total: root.player-time-total;
                play-pause => { root.player-play-pause(); }
                stop => { root.player-stop(); }
                seek(pos) => { root.player-seek(pos); }
            }
        }

        // Terminal
        if current-screen == 14 : WindowFrame {
            x: root.window-maximized ? 0px : parent.width * 0.05;
            y: root.window-maximized ? 0px : parent.height * 0.04;
            width: root.window-maximized ? parent.width : parent.width * 0.90;
            height: root.window-maximized ? parent.height - 60px : parent.height * 0.92;
            is-maximized <=> root.window-maximized;
            icon-char: ">_";
            icon-color: Theme.cyan;
            title: "Terminal";
            close => { root.current-screen = 1; root.navigate(1); }
            minimize => { root.current-screen = 1; root.navigate(1); }
            animate x, y, width, height { duration: 200ms; easing: ease-out; }

            TerminalScreen {
                width: 100%; height: 100%;
                terminal-output: root.terminal-output;
                cursor-row: root.terminal-cursor-row;
                cursor-col: root.terminal-cursor-col;
                is-alive: root.terminal-is-alive;
                ai-suggestion: root.terminal-ai-suggestion;
                has-suggestion: root.terminal-has-suggestion;
                tab-count: root.terminal-tab-count;
                active-tab: root.terminal-active-tab;
                tabs: root.terminal-tabs;
                terminal-key-pressed(event) => { return root.terminal-key-pressed(event); }
                request-ai-help => { root.terminal-request-ai-help(); }
                dismiss-suggestion => { root.terminal-dismiss-suggestion(); }
                restart-terminal => { root.terminal-restart(); }
                switch-tab(idx) => { root.terminal-switch-tab(idx); }
                new-tab => { root.terminal-new-tab(); }
                close-tab(idx) => { root.terminal-close-tab(idx); }
            }
        }

        // Notes Editor screen
        if current-screen == 15 : WindowFrame {
            x: root.window-maximized ? 0px : parent.width * 0.05;
            y: root.window-maximized ? 0px : parent.height * 0.04;
            width: root.window-maximized ? parent.width : parent.width * 0.90;
            height: root.window-maximized ? parent.height - 60px : parent.height * 0.92;
            is-maximized <=> root.window-maximized;
            icon-char: "\u{270E}";
            icon-color: Theme.amber;
            title: "Notes";
            close => { root.current-screen = 1; root.navigate(1); }
            minimize => { root.current-screen = 1; root.navigate(1); }
            animate x, y, width, height { duration: 200ms; easing: ease-out; }

            NotesEditor {
                width: 100%; height: 100%;
                notes-list: root.notes-list;
                selected-index: root.notes-selected-index;
                current-content <=> root.notes-current-content;
                current-title: root.notes-current-title;
                is-modified: root.notes-is-modified;
                note-count: root.notes-note-count;
                search-query <=> root.notes-search-query;
                new-note => { root.notes-new(); }
                save-note => { root.notes-save(); }
                delete-note => { root.notes-delete(); }
                select-note(idx) => { root.notes-select(idx); }
                search-notes(query) => { root.notes-search(query); }
                content-changed(text) => { root.notes-content-changed(text); }
            }
        }

        // About screen
        if current-screen == 16 : WindowFrame {
            x: root.window-maximized ? 0px : parent.width * 0.05;
            y: root.window-maximized ? 0px : parent.height * 0.04;
            width: root.window-maximized ? parent.width : parent.width * 0.90;
            height: root.window-maximized ? parent.height - 60px : parent.height * 0.92;
            is-maximized <=> root.window-maximized;
            icon-char: "\u{2139}";
            icon-color: Theme.cyan;
            title: "About";
            close => { root.current-screen = 7; root.navigate(7); }
            minimize => { root.current-screen = 1; root.navigate(1); }
            animate x, y, width, height { duration: 200ms; easing: ease-out; }

            AboutScreen {
                width: 100%; height: 100%;
                hostname: root.about-hostname;
                kernel: root.about-kernel;
                cpu-model: root.about-cpu;
                ram-total: root.about-ram;
                disk-info: root.about-disk;
                uptime-text: root.about-uptime;
                version-text: root.about-version;
                build-date: root.about-build-date;
                back-pressed => {
                    root.current-screen = 7;
                    root.navigate(7);
                }
            }
        }

        // ── Persistent dock for windowed app screens ──
        if current-screen >= 4 && current-screen <= 16 : AppDock {
            y: parent.height - self.height;
            width: 100%;
            items: root.dock-items.length > 0 ? root.dock-items : [
                { app-id: "terminal",      label: "Terminal", icon-char: ">_", is-running: false },
                { app-id: "browser",       label: "Browser",  icon-char: "W",  is-running: false },
                { app-id: "files",         label: "Files",    icon-char: "F",  is-running: false },
                { app-id: "notes",         label: "Notes",    icon-char: "✎",  is-running: false },
                { app-id: "editor",        label: "Editor",   icon-char: "≡",  is-running: false },
                { app-id: "bond",          label: "Bond",     icon-char: "♥",  is-running: false },
                { app-id: "memory",        label: "Memory",   icon-char: "◈",  is-running: false },
                { app-id: "notifications", label: "Alerts",   icon-char: "N",  is-running: false },
                { app-id: "system",        label: "System",   icon-char: "◉",  is-running: false },
                { app-id: "media",         label: "Media",    icon-char: "♪",  is-running: false },
                { app-id: "settings",      label: "Settings", icon-char: "⚙",  is-running: false },
            ];
            launch-app(app-id) => { root.launch-app(app-id); }
            anchor-pressed => {
                root.current-screen = 1;
                root.navigate(1);
            }
        }

        // Voice overlay
        if voice-active : VoiceOverlay {
            width: 100%; height: 100%;
            voice-state: root.voice-state;
            transcribed-text: root.voice-transcribed;
            response-text: root.voice-response;
            cancel-pressed => {
                root.voice-active = false;
                root.cancel-voice();
            }
        }

        // Toast notification banners (top-right, stacking)
        if toast-queue.length > 0 : ToastBanner {
            width: 100%; height: 100%;
            toasts: root.toast-queue;
            toast-clicked(id) => { root.toast-clicked(id); }
            toast-dismissed(id) => { root.toast-dismissed(id); }
        }
    }
}
