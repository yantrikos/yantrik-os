// Yantrik OS — AI-native desktop shell.
// Screen states: 0=boot, 1=desktop, 2=onboarding, 3=lock, 4=bond, 5=personality,
//   6=memory, 7=settings, 8=files, 9=notifications, 10=system.
// The AI IS the shell — Intent Lens is the primary interaction.

import { Theme, ThemeMode } from "theme.slint";
import { BootScreen } from "boot.slint";
import { OnboardingScreen } from "onboarding.slint";
import { DesktopScreen } from "desktop.slint";
import { BondScreen, BondData } from "bond.slint";
import { PersonalityScreen, OpinionData, SharedRefData } from "personality.slint";
import { LockScreen } from "lock.slint";
import { SettingsScreen } from "settings.slint";
import { MemoryBrowser, MemoryItem } from "memory_browser.slint";
import { FileBrowser, FileEntry } from "file_browser.slint";
import { NotificationCenter, NotificationData } from "notification_center.slint";
import { SystemDashboard, ProcessData } from "system_dashboard.slint";
import { VoiceOverlay } from "voice_overlay.slint";
import { MessageData } from "components/message_bubble.slint";
import { UrgeCardData } from "components/glance_card.slint";
import { LensResult } from "components/intent_lens.slint";
import { WhisperCardItem } from "components/whisper_card.slint";
import { ClipboardEntryData } from "components/clipboard_panel.slint";
import { AppGridItem } from "components/app_grid.slint";
import { WindowItem } from "components/window_switcher.slint";
import { DockItem } from "components/app_dock.slint";

export { ThemeMode, MessageData, UrgeCardData, BondData, OpinionData, SharedRefData, MemoryItem, LensResult, WhisperCardItem, FileEntry, NotificationData, ProcessData, ClipboardEntryData, AppGridItem, WindowItem, DockItem }

export component App inherits Window {
    title: "Yantrik OS";
    default-font-size: 14px;
    background: Theme.bg-deep;

    // Screen state: 0=boot, 1=desktop, 2=onboarding, 3=lock, 4=bond, 5=personality,
    //   6=memory, 7=settings, 8=files, 9=notifications, 10=system
    in-out property <int> current-screen: 0;

    // Boot state
    in property <string> boot-status: "remembering...";

    // Companion state
    in property <int> memory-count: 0;
    in property <bool> is-thinking: false;
    in property <bool> has-urges: false;
    in property <bool> is-speaking: false;
    in property <bool> is-listening: false;
    in property <bool> companion-online: true;  // LLM backend reachable

    // Chat state
    in property <[MessageData]> messages: [];
    in property <bool> is-generating: false;

    // Desktop state
    in property <[UrgeCardData]> urges: [];
    in property <string> clock-text: "00:00";
    in property <string> companion-status: "idle";
    in property <int> battery-level: 100;
    in property <bool> battery-charging: false;
    in property <bool> wifi-connected: false;
    in property <int> pending-count: 0;
    in property <string> greeting-text: "Hello";

    // Intent Lens state
    in-out property <bool> lens-open: false;
    in property <[LensResult]> lens-results: [];
    in property <bool> lens-chat-mode: false;

    // Bond state
    in property <BondData> bond-data: {
        bond-score: 0.0,
        bond-level: "Stranger",
        total-interactions: 0,
        days-together: 0,
        current-streak: 0,
        humor-rate: 0.0,
        vulnerability-events: 0,
        shared-references: 0,
    };

    // Personality state
    in property <float> formality: 0.5;
    in property <float> humor-ratio: 0.0;
    in property <float> opinion-strength: 0.0;
    in property <float> question-ratio: 0.5;
    in property <[OpinionData]> opinions: [];
    in property <[SharedRefData]> shared-refs: [];

    // Memory browser state
    in property <[MemoryItem]> memory-results: [];
    in property <bool> is-searching-memories: false;

    // Voice state
    in-out property <bool> voice-active: false;
    in property <int> voice-state: 0;
    in property <string> voice-transcribed: "";
    in property <string> voice-response: "";

    // Whisper Cards (floating notifications)
    in property <[WhisperCardItem]> whisper-cards: [];
    in property <int> whisper-hint-count: 0;

    // Clipboard panel state
    in-out property <bool> clip-panel-open: false;
    in property <[ClipboardEntryData]> clip-panel-entries: [];
    callback clipboard-paste(int);

    // Power menu state
    in-out property <bool> power-menu-open: false;
    callback power-action(string);

    // App grid state
    in-out property <bool> app-grid-open: false;
    in property <[AppGridItem]> grid-apps: [];
    callback grid-launch-app(string);

    // Window switcher state
    in-out property <bool> window-switcher-open: false;
    in property <[WindowItem]> window-list: [];
    callback switch-window(string);

    // Dock items (for running indicators)
    in property <[DockItem]> dock-items: [];

    // Quick Settings state
    in-out property <bool> quick-settings-open: false;
    in-out property <int> brightness-level: 80;
    in-out property <int> volume-level: 50;
    callback toggle-wifi();
    callback brightness-changed(int);
    callback volume-changed(int);

    // Notification toast
    in property <string> notification-text: "";
    in-out property <bool> show-notification: false;

    // Focus mode (Workspace Morph)
    in-out property <bool> focus-mode: false;
    in property <string> focus-remaining: "";
    callback end-focus-mode();

    // Lock screen state
    in property <string> lock-error: "";
    callback try-unlock(string);
    callback lock-screen();

    // Settings state (screen 7)
    in property <string> settings-user-name: "";
    in property <string> settings-companion-name: "Yantrik";
    in property <string> settings-model-name: "";
    in property <int> settings-max-context: 4096;
    in property <int> settings-max-tokens: 512;
    in property <string> settings-tool-permission: "sensitive";
    in property <int> settings-auto-lock-secs: 300;
    in property <string> settings-version: "0.1.0";
    in property <string> settings-ip-address: "";
    in property <string> settings-display-resolution: "";
    in property <string> settings-llm-backend: "candle";
    in property <string> settings-llm-api-url: "";
    in property <string> settings-llm-api-model: "";

    // File browser state (screen 8)
    in property <string> file-browser-path: "~";
    in property <[FileEntry]> file-browser-entries: [];
    in property <bool> file-browser-loading: false;
    callback file-navigate-dir(string);
    callback file-open(string);
    callback file-go-up();

    // Notification Center state (screen 9)
    in property <[NotificationData]> notification-list: [];
    in property <int> notification-unread-count: 0;
    callback notification-clear-all();
    callback notification-mark-all-read();
    callback notification-tapped(string);

    // System Dashboard state (screen 10)
    in property <float> sys-cpu-usage: 0.0;
    in property <float> sys-memory-usage: 0.0;
    in property <string> sys-memory-text: "0 / 0 MB";
    in property <string> sys-uptime-text: "";
    in property <string> sys-wifi-ssid: "";
    in property <int> sys-wifi-signal: 0;
    in property <[ProcessData]> sys-top-processes: [];

    // Onboarding state (0=not onboarding, 1=step:terminal, 2=step:focus, 3=done)
    in-out property <int> onboarding-step: 0;
    callback onboarding-ready();
    callback onboarding-skip();

    // Callbacks to Rust
    callback send-message(string);
    callback mic-pressed();
    callback navigate(int);
    callback search-memories(string);
    callback cancel-voice();
    callback launch-app(string);
    callback lens-query(string);
    callback lens-submit(string);
    callback lens-result-selected(string);
    callback open-lens();
    callback close-lens();
    callback whisper-card-dismissed(string);
    callback whisper-card-action(string);
    callback whisper-hint-clicked();

    Rectangle {
        clip: true;
        width: 100%;
        height: 100%;

        // Boot screen
        if current-screen == 0 : BootScreen {
            width: 100%; height: 100%;
            status-text: root.boot-status;
            memory-count: root.memory-count;
            boot-complete => {
                if root.onboarding-step > 0 {
                    root.current-screen = 2;
                    root.navigate(2);
                } else {
                    root.current-screen = 1;
                    root.navigate(1);
                }
            }
        }

        // Onboarding (first boot only)
        if current-screen == 2 : OnboardingScreen {
            width: 100%; height: 100%;
            ready => {
                root.current-screen = 1;
                root.navigate(1);
                root.onboarding-ready();
            }
            skip => {
                root.current-screen = 1;
                root.navigate(1);
                root.onboarding-skip();
            }
        }

        // Lock screen
        if current-screen == 3 : LockScreen {
            width: 100%; height: 100%;
            clock-text: root.clock-text;
            error-text: root.lock-error;
            try-unlock(pin) => { root.try-unlock(pin); }
        }

        // Desktop (the main experience)
        if current-screen == 1 : DesktopScreen {
            width: 100%; height: 100%;
            // Status bar
            clock-text: root.clock-text;
            companion-status: root.companion-status;
            companion-online: root.companion-online;
            battery-level: root.battery-level;
            battery-charging: root.battery-charging;
            wifi-connected: root.wifi-connected;
            pending-count: root.pending-count;
            // Companion
            is-thinking: root.is-thinking;
            has-urges: root.has-urges;
            is-speaking: root.is-speaking;
            is-listening: root.is-listening;
            greeting-text: root.greeting-text;
            memory-count: root.memory-count;
            // Intent Lens
            lens-open <=> root.lens-open;
            lens-results: root.lens-results;
            lens-chat-mode: root.lens-chat-mode;
            // Chat
            messages: root.messages;
            is-generating: root.is-generating;
            // Urges
            urges: root.urges;
            // Whisper Cards
            whisper-cards: root.whisper-cards;
            whisper-hint-count: root.whisper-hint-count;
            whisper-card-dismissed(id) => { root.whisper-card-dismissed(id); }
            whisper-card-action(id) => { root.whisper-card-action(id); }
            whisper-hint-clicked => { root.whisper-hint-clicked(); }
            // Clipboard panel
            clip-panel-open <=> root.clip-panel-open;
            clip-panel-entries: root.clip-panel-entries;
            clipboard-paste(idx) => { root.clipboard-paste(idx); }
            // Power menu
            power-menu-open <=> root.power-menu-open;
            power-action(action) => { root.power-action(action); }
            // App grid
            app-grid-open <=> root.app-grid-open;
            grid-apps: root.grid-apps;
            grid-launch-app(app-id) => { root.grid-launch-app(app-id); }
            // Window switcher
            window-switcher-open <=> root.window-switcher-open;
            window-list: root.window-list;
            switch-window(title) => { root.switch-window(title); }
            // Dock items
            dock-items: root.dock-items;
            // Quick Settings
            quick-settings-open <=> root.quick-settings-open;
            brightness-level <=> root.brightness-level;
            volume-level <=> root.volume-level;
            toggle-wifi => { root.toggle-wifi(); }
            brightness-changed(val) => { root.brightness-changed(val); }
            volume-changed(val) => { root.volume-changed(val); }
            // Focus mode
            focus-mode <=> root.focus-mode;
            focus-remaining: root.focus-remaining;
            end-focus-mode => { root.end-focus-mode(); }
            // Callbacks
            send-message(text) => { root.send-message(text); }
            mic-pressed => { root.mic-pressed(); }
            launch-app(app-id) => { root.launch-app(app-id); }
            navigate-to(screen) => {
                root.current-screen = screen;
                root.navigate(screen);
            }
            lens-query(text) => { root.lens-query(text); }
            lens-submit(text) => { root.lens-submit(text); }
            lens-result-selected(id) => { root.lens-result-selected(id); }
            open-lens => { root.open-lens(); }
            close-lens => { root.close-lens(); }
        }

        // Bond screen
        if current-screen == 4 : BondScreen {
            width: 100%; height: 100%;
            data: root.bond-data;
            back-pressed => {
                root.current-screen = 1;
                root.navigate(1);
            }
        }

        // Personality screen
        if current-screen == 5 : PersonalityScreen {
            width: 100%; height: 100%;
            formality: root.formality;
            humor-ratio: root.humor-ratio;
            opinion-strength: root.opinion-strength;
            question-ratio: root.question-ratio;
            opinions: root.opinions;
            shared-refs: root.shared-refs;
            back-pressed => {
                root.current-screen = 1;
                root.navigate(1);
            }
        }

        // Memory browser
        if current-screen == 6 : MemoryBrowser {
            width: 100%; height: 100%;
            results: root.memory-results;
            is-searching: root.is-searching-memories;
            total-memories: root.memory-count;
            search(query) => { root.search-memories(query); }
            back-pressed => {
                root.current-screen = 1;
                root.navigate(1);
            }
        }

        // Settings screen
        if current-screen == 7 : SettingsScreen {
            width: 100%; height: 100%;
            user-name: root.settings-user-name;
            companion-name: root.settings-companion-name;
            model-name: root.settings-model-name;
            max-context: root.settings-max-context;
            max-tokens: root.settings-max-tokens;
            tool-permission: root.settings-tool-permission;
            auto-lock-secs: root.settings-auto-lock-secs;
            wifi-connected: root.wifi-connected;
            wifi-ssid: root.sys-wifi-ssid;
            ip-address: root.settings-ip-address;
            display-resolution: root.settings-display-resolution;
            llm-backend: root.settings-llm-backend;
            llm-api-url: root.settings-llm-api-url;
            llm-api-model: root.settings-llm-api-model;
            memory-count: root.memory-count;
            version-text: root.settings-version;
            notification-count: root.notification-unread-count;
            back-pressed => {
                root.current-screen = 1;
                root.navigate(1);
            }
            navigate-to(screen) => {
                root.current-screen = screen;
                root.navigate(screen);
            }
        }

        // File browser
        if current-screen == 8 : FileBrowser {
            width: 100%; height: 100%;
            current-path: root.file-browser-path;
            entries: root.file-browser-entries;
            is-loading: root.file-browser-loading;
            back-pressed => {
                root.current-screen = 1;
                root.navigate(1);
            }
            navigate-dir(name) => { root.file-navigate-dir(name); }
            open-file(name) => { root.file-open(name); }
            go-up => { root.file-go-up(); }
        }

        // Notification Center
        if current-screen == 9 : NotificationCenter {
            width: 100%; height: 100%;
            notifications: root.notification-list;
            unread-count: root.notification-unread-count;
            back-pressed => {
                root.current-screen = 1;
                root.navigate(1);
            }
            clear-all => { root.notification-clear-all(); }
            mark-all-read => { root.notification-mark-all-read(); }
            notification-tapped(id) => { root.notification-tapped(id); }
        }

        // System Dashboard
        if current-screen == 10 : SystemDashboard {
            width: 100%; height: 100%;
            cpu-usage: root.sys-cpu-usage;
            memory-usage: root.sys-memory-usage;
            memory-text: root.sys-memory-text;
            battery-level: root.battery-level;
            battery-charging: root.battery-charging;
            wifi-connected: root.wifi-connected;
            wifi-ssid: root.sys-wifi-ssid;
            wifi-signal: root.sys-wifi-signal;
            uptime-text: root.sys-uptime-text;
            top-processes: root.sys-top-processes;
            back-pressed => {
                root.current-screen = 1;
                root.navigate(1);
            }
        }

        // Voice overlay
        if voice-active : VoiceOverlay {
            width: 100%; height: 100%;
            voice-state: root.voice-state;
            transcribed-text: root.voice-transcribed;
            response-text: root.voice-response;
            cancel-pressed => {
                root.voice-active = false;
                root.cancel-voice();
            }
        }

        // Notification toast (top-right, above the Lens)
        if show-notification : Rectangle {
            x: root.width - 380px;
            y: 32px;
            width: 360px;
            height: notif-text.preferred-height + 20px;
            border-radius: 12px;
            background: Theme.bg-elevated;
            border-width: 1px;
            border-color: Theme.amber-dim;
            opacity: 0.95;
            drop-shadow-blur: 16px;
            drop-shadow-color: Theme.overlay-backdrop;

            TouchArea {
                clicked => { root.show-notification = false; }
            }

            notif-text := Text {
                x: 14px;
                y: 10px;
                width: parent.width - 28px;
                text: root.notification-text;
                color: Theme.text-primary;
                font-size: 13px;
                wrap: word-wrap;
            }

            Timer {
                interval: 5000ms;
                running: true;
                triggered => { root.show-notification = false; }
            }
        }
    }
}
