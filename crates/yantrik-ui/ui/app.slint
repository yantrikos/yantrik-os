                doc-ai-response: root.doc-ai-response;
                doc-ai-submit(prompt) => { root.doc-ai-submit(prompt); }
                doc-ai-apply() => { root.doc-ai-apply(); }
                doc-ai-dismiss() => { root.doc-ai-dismiss(); }
                doc-ai-draft(prompt) => { root.doc-ai-draft(prompt); }
                doc-ai-summarize() => { root.doc-ai-summarize(); }
                doc-ai-improve() => { root.doc-ai-improve(); }
                doc-ai-translate(lang) => { root.doc-ai-translate(lang); }
                doc-ai-insights() => { root.doc-ai-insights(); }
            }
        }

        // Presentation (screen 31)
        if current-screen == 31 : WindowFrame {
            x: root.window-maximized ? 0px : root.window-x;
            y: root.window-maximized ? 0px : root.window-y;
            width: root.window-maximized ? parent.width : root.window-w;
            height: root.window-maximized ? parent.height - 60px : root.window-h;
            is-maximized <=> root.window-maximized;
            win-x <=> root.window-x;
            win-y <=> root.window-y;
            win-w <=> root.window-w;
            win-h <=> root.window-h;
            icon-char: "YP";
            icon-color: Theme.accent;
            title: "yPresent";
            close => { root.current-screen = 1; root.navigate(1); }
            minimize => { root.current-screen = 1; root.navigate(1); }
            animate x, y, width, height { duration: 200ms; easing: ease-out; }

            PresentationScreen {
                width: 100%; height: 100%;
                slides: root.pres-slides;
                current-slide-index <=> root.pres-current-slide-index;
                slide-count: root.pres-slide-count;
                current-layout <=> root.pres-current-layout;
                themes: root.pres-themes;
                is-presenting <=> root.pres-is-presenting;
                current-title <=> root.pres-current-title;
                current-body <=> root.pres-current-body;
                current-notes <=> root.pres-current-notes;
                timer-text: root.pres-timer-text;
                next-title: root.pres-next-title;
                next-body: root.pres-next-body;
                presentation-title: root.pres-presentation-title;
                slide-progress: root.pres-slide-progress;
                file-path: root.pres-file-path;
                is-modified: root.pres-is-modified;
                save-status: root.pres-save-status;
                search-count: root.pres-search-count;
                current-transition: root.pres-current-transition;
                // Existing callbacks
                add-slide => { root.pres-add-slide(); }
                delete-slide => { root.pres-delete-slide(); }
                duplicate-slide => { root.pres-duplicate-slide(); }
                move-slide-up => { root.pres-move-slide-up(); }
                move-slide-down => { root.pres-move-slide-down(); }
                select-slide(idx) => { root.pres-select-slide(idx); }
                set-layout(l) => { root.pres-set-layout(l); }
                set-theme(t) => { root.pres-set-theme(t); }
                toggle-present => { root.pres-toggle-present(); }
                export-pdf => { root.pres-export-pdf(); }
                title-edited(t) => { root.pres-title-edited(t); }
                body-edited(t) => { root.pres-body-edited(t); }
                notes-edited(t) => { root.pres-notes-edited(t); }
                next-slide => { root.pres-next-slide(); }
                prev-slide => { root.pres-prev-slide(); }
                // New callbacks
                save-presentation => { root.pres-save(); }
                load-presentation => { root.pres-load(); }
                toggle-timer => { root.pres-toggle-timer(); }
                reset-timer => { root.pres-reset-timer(); }
                use-template(idx) => { root.pres-use-template(idx); }
                export-markdown => { root.pres-export-markdown(); }
                export-outline => { root.pres-export-outline(); }
                search-slides(q) => { root.pres-search(q); }
                search-next => { root.pres-search-next(); }
                set-transition(t) => { root.pres-set-transition(t); }
                undo => { root.pres-undo(); }
                redo => { root.pres-redo(); }
                generate-notes => { root.pres-generate-notes(); }
                format-bold => { root.pres-format-bold(); }
                format-italic => { root.pres-format-italic(); }
                set-font-size(s) => { root.pres-set-font-size(s); }
                set-text-color(c) => { root.pres-set-text-color(c); }
                insert-object(kind) => { root.pres-insert-object(kind); }
                key-pressed(k) => { root.pres-key-pressed(k); }
                // Template gallery & speaker notes
                pres-template-gallery-open <=> root.pres-template-gallery-open;
                pres-current-speaker-note <=> root.pres-current-speaker-note;
                pres-open-template-gallery() => { root.pres-open-template-gallery(); }
                pres-select-template(idx) => { root.pres-select-template(idx); }
                pres-save-speaker-note(text) => { root.pres-save-speaker-note(text); }
                // AI Assist
                pres-ai-working: root.pres-ai-working;
                pres-ai-status: root.pres-ai-status;
                pres-ai-has-proposal: root.pres-ai-has-proposal;
                pres-ai-proposal: root.pres-ai-proposal;
                pres-ai-apply-title <=> root.pres-ai-apply-title;
                pres-ai-apply-body <=> root.pres-ai-apply-body;
                pres-ai-apply-notes <=> root.pres-ai-apply-notes;
                pres-ai-apply-slide-type <=> root.pres-ai-apply-slide-type;
                pres-ai-instruction <=> root.pres-ai-instruction;
                pres-ai-generate-deck(topic) => { root.pres-ai-generate-deck(topic); }
                pres-ai-structure-text(text) => { root.pres-ai-structure-text(text); }
                pres-ai-generate-all-notes() => { root.pres-ai-generate-all-notes(); }
                pres-ai-improve-slide() => { root.pres-ai-improve-slide(); }
                pres-ai-generate-notes() => { root.pres-ai-generate-notes(); }
                pres-ai-simplify(audience) => { root.pres-ai-simplify(audience); }
                pres-ai-split-slide() => { root.pres-ai-split-slide(); }
                pres-ai-suggest-layout() => { root.pres-ai-suggest-layout(); }
                pres-ai-freeform(prompt) => { root.pres-ai-freeform(prompt); }
                pres-ai-apply() => { root.pres-ai-apply(); }
                pres-ai-dismiss() => { root.pres-ai-dismiss(); }
                pres-ai-preview-slide(idx) => { root.pres-ai-preview-slide(idx); }
                pres-ai-regenerate() => { root.pres-ai-regenerate(); }
            }
        }

        // ── Persistent dock for windowed app screens (auto-hide) ──
        if current-screen >= 4 && current-screen <= 31 : Rectangle {
            width: 100%;
            height: parent.height;
            y: 0;
            background: transparent;

            // Invisible hover-trigger zone at bottom edge
            dock-trigger := TouchArea {
                y: parent.height - 6px;
                width: 100%;
                height: 6px;
            }

            property <bool> dock-revealed: dock-trigger.has-hover || dock-area.has-hover;

            // The actual dock, slides up when revealed
            dock-area := TouchArea {
                y: parent.height - (dock-revealed ? 60px : 4px);
                width: 100%;
                height: 60px;

                animate y { duration: 200ms; easing: ease-out; }

                AppDock {
                    width: 100%;
                    opacity: dock-revealed ? 1.0 : 0.0;
                    animate opacity { duration: 150ms; }
                    items: root.dock-items.length > 0 ? root.dock-items : [
                        { app-id: "terminal",      label: "Terminal", icon-char: ">_", is-running: false },
                        { app-id: "browser",       label: "Browser",  icon-char: "W",  is-running: false },
                        { app-id: "files",         label: "Files",    icon-char: "F",  is-running: false },
                        { app-id: "notes",         label: "Notes",    icon-char: "✎",  is-running: false },
                        { app-id: "editor",        label: "Editor",   icon-char: "≡",  is-running: false },
                        { app-id: "bond",          label: "Bond",     icon-char: "♥",  is-running: false },
                        { app-id: "memory",        label: "Memory",   icon-char: "◈",  is-running: false },
                        { app-id: "notifications", label: "Alerts",   icon-char: "N",  is-running: false },
                        { app-id: "system",        label: "System",   icon-char: "◉",  is-running: false },
                        { app-id: "media",         label: "Media",    icon-char: "♪",  is-running: false },
                        { app-id: "email",         label: "Email",    icon-char: "@",  is-running: false },
                        { app-id: "calendar",      label: "Calendar", icon-char: "▦",  is-running: false },
                        { app-id: "network",       label: "Network",  icon-char: "\u{25CE}",  is-running: false },
                        { app-id: "launchpad",     label: "Apps",     icon-char: "\u{229E}",  is-running: false },
                        { app-id: "spreadsheet",   label: "ySheets",  icon-char: "YS", is-running: false },
                        { app-id: "documents",     label: "yDoc",     icon-char: "YD", is-running: false },
                        { app-id: "presentation",  label: "yPresent", icon-char: "YP", is-running: false },
                        { app-id: "settings",      label: "Settings", icon-char: "\u{2699}",  is-running: false },
                    ];
                    launch-app(app-id) => { root.launch-app(app-id); }
                    anchor-pressed => {
                        root.current-screen = 1;
                        root.navigate(1);
                    }
                }
            }

            // Thin glow hint line when dock is hidden
            Rectangle {
                y: parent.height - 2px;
                width: parent.width * 0.3;
                x: (parent.width - self.width) / 2;
                height: 2px;
                border-radius: 1px;
                background: @linear-gradient(90deg, transparent 0%, Theme.cyan-glow 50%, transparent 100%);
                opacity: dock-revealed ? 0.0 : 0.3;
                animate opacity { duration: 200ms; }
            }
        }

        // Voice overlay
        if voice-active : VoiceOverlay {
            width: 100%; height: 100%;
            voice-state: root.voice-state;
            transcribed-text: root.voice-transcribed;
            response-text: root.voice-response;
            cancel-pressed => {
                root.voice-active = false;
                root.cancel-voice();
            }
        }

        // Toast notification banners (top-right, stacking)
        if toast-queue.length > 0 : ToastBanner {
            width: 100%; height: 100%;
            toasts: root.toast-queue;
            toast-clicked(id) => { root.toast-clicked(id); }
            toast-dismissed(id) => { root.toast-dismissed(id); }
        }

        // Debug: navigate to screen from Rust
        // Set debug-target-screen from Rust, then call debug-navigate()
        // to switch to that screen (useful for automated screenshots).
    }
}
