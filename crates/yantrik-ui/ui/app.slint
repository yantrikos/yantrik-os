                memory-available-text: root.mon-memory-available-text;
                swap-usage: root.mon-swap-usage;
                swap-used-text: root.mon-swap-used-text;
                swap-total-text: root.mon-swap-total-text;
                disks: root.mon-disks;
                network-interfaces: root.mon-network-interfaces;
                processes: root.mon-processes;
                sort-column <=> root.mon-sort-column;
                uptime-text: root.mon-uptime-text;
                sort-by-column(col) => { root.sort-by-column(col); }
                back-pressed => { root.current-screen = 1; root.navigate(1); }
            }
        }

        // Download Manager
        if current-screen == 24 : WindowFrame {
            x: root.window-maximized ? 0px : parent.width * 0.05;
            y: root.window-maximized ? 0px : parent.height * 0.04;
            width: root.window-maximized ? parent.width : parent.width * 0.90;
            height: root.window-maximized ? parent.height - 60px : parent.height * 0.92;
            is-maximized <=> root.window-maximized;
            icon-char: "\u{2B07}";
            icon-color: Theme.holo-blue;
            title: Tr.title-downloads;
            close => { root.current-screen = 1; root.navigate(1); }
            minimize => { root.current-screen = 1; root.navigate(1); }
            animate x, y, width, height { duration: 200ms; easing: ease-out; }

            DownloadManagerScreen {
                width: 100%; height: 100%;
                downloads: root.dl-downloads;
                active-count: root.dl-active-count;
                total-speed: root.dl-total-speed;
                completed-today: root.dl-completed-today;
                error-text: root.dl-error-text;
                active-filter <=> root.dl-active-filter;
                dl-add(url) => { root.dl-add(url); }
                dl-pause(id) => { root.dl-pause(id); }
                dl-resume(id) => { root.dl-resume(id); }
                dl-cancel(id) => { root.dl-cancel(id); }
                dl-retry(id) => { root.dl-retry(id); }
                dl-open-folder(id) => { root.dl-open-folder(id); }
                dl-clear-completed() => { root.dl-clear-completed(); }
                dl-filter(idx) => { root.dl-filter(idx); }
            }
        }

        // Code Snippet Manager
        if current-screen == 25 : WindowFrame {
            x: root.window-maximized ? 0px : parent.width * 0.05;
            y: root.window-maximized ? 0px : parent.height * 0.04;
            width: root.window-maximized ? parent.width : parent.width * 0.90;
            height: root.window-maximized ? parent.height - 60px : parent.height * 0.92;
            is-maximized <=> root.window-maximized;
            icon-char: "<>";
            icon-color: Theme.accent;
            title: Tr.title-snippets;
            close => { root.current-screen = 1; root.navigate(1); }
            minimize => { root.current-screen = 1; root.navigate(1); }
            animate x, y, width, height { duration: 200ms; easing: ease-out; }

            SnippetManagerScreen {
                width: 100%; height: 100%;
                snippets: root.snip-snippets;
                tag-chips: root.snip-tag-chips;
                snippet-count: root.snip-snippet-count;
                detail-id: root.snip-detail-id;
                detail-title <=> root.snip-detail-title;
                detail-language <=> root.snip-detail-language;
                detail-code <=> root.snip-detail-code;
                detail-tags <=> root.snip-detail-tags;
                search-query <=> root.snip-search-query;
                snip-search(q) => { root.snip-search(q); }
                snip-select(id) => { root.snip-select(id); }
                snip-new() => { root.snip-new(); }
                snip-save(id, title, lang, code, tags) => { root.snip-save(id, title, lang, code, tags); }
                snip-delete(id) => { root.snip-delete(id); }
                snip-copy(id) => { root.snip-copy(id); }
                snip-tag-filter(tag) => { root.snip-tag-filter(tag); }
            }
        }

        // Container Manager
        if current-screen == 26 : WindowFrame {
            x: root.window-maximized ? 0px : parent.width * 0.05;
            y: root.window-maximized ? 0px : parent.height * 0.04;
            width: root.window-maximized ? parent.width : parent.width * 0.90;
            height: root.window-maximized ? parent.height - 60px : parent.height * 0.92;
            is-maximized <=> root.window-maximized;
            icon-char: "\u{2338}";
            icon-color: Theme.holo-blue;
            title: Tr.title-containers;
            close => { root.current-screen = 1; root.navigate(1); }
            minimize => { root.current-screen = 1; root.navigate(1); }
            animate x, y, width, height { duration: 200ms; easing: ease-out; }

            ContainerManagerScreen {
                width: 100%; height: 100%;
                active-tab <=> root.ct-active-tab;
                containers: root.ct-containers;
                running-count: root.ct-running-count;
                stopped-count: root.ct-stopped-count;
                total-count: root.ct-total-count;
                images: root.ct-images;
                volumes: root.ct-volumes;
                log-text: root.ct-log-text;
                log-container-name: root.ct-log-container-name;
                show-logs <=> root.ct-show-logs;
                runtime-name: root.ct-runtime-name;
                run-image-input <=> root.ct-run-image-input;
                pull-image-input <=> root.ct-pull-image-input;
                create-volume-input <=> root.ct-create-volume-input;
                ct-tab(idx) => { root.ct-tab(idx); }
                ct-start(id) => { root.ct-start(id); }
                ct-stop(id) => { root.ct-stop(id); }
                ct-restart(id) => { root.ct-restart(id); }
                ct-remove(id) => { root.ct-remove(id); }
                ct-logs(id) => { root.ct-logs(id); }
                ct-run(img) => { root.ct-run(img); }
                ct-pull(img) => { root.ct-pull(img); }
                ct-remove-image(id) => { root.ct-remove-image(id); }
                ct-create-volume(name) => { root.ct-create-volume(name); }
                ct-remove-volume(name) => { root.ct-remove-volume(name); }
                ct-refresh() => { root.ct-refresh(); }
            }
        }

        // Device Dashboard
        if current-screen == 27 : WindowFrame {
            x: root.window-maximized ? 0px : parent.width * 0.05;
            y: root.window-maximized ? 0px : parent.height * 0.04;
            width: root.window-maximized ? parent.width : parent.width * 0.90;
            height: root.window-maximized ? parent.height - 60px : parent.height * 0.92;
            is-maximized <=> root.window-maximized;
            icon-char: "\u{2699}";
            icon-color: Theme.cyan;
            title: Tr.title-devices;
            close => { root.current-screen = 1; root.navigate(1); }
            minimize => { root.current-screen = 1; root.navigate(1); }
            animate x, y, width, height { duration: 200ms; easing: ease-out; }

            DeviceDashboardScreen {
                width: 100%; height: 100%;
                active-tab <=> root.dev-active-tab;
                usb-devices: root.dev-usb-devices;
                usb-selected-index <=> root.dev-usb-selected-index;
                usb-detail-text: root.dev-usb-detail-text;
                pci-devices: root.dev-pci-devices;
                input-devices: root.dev-input-devices;
                storage-devices: root.dev-storage-devices;
                display-devices: root.dev-display-devices;
                gpu-info: root.dev-gpu-info;
                scanning: root.dev-scanning;
                dev-tab(idx) => { root.dev-tab(idx); }
                dev-select-usb(idx) => { root.dev-select-usb(idx); }
                dev-select-pci(idx) => { root.dev-select-pci(idx); }
                dev-refresh() => { root.dev-refresh(); }
            }
        }

        // Permission Dashboard
        if current-screen == 28 : WindowFrame {
            x: root.window-maximized ? 0px : parent.width * 0.05;
            y: root.window-maximized ? 0px : parent.height * 0.04;
            width: root.window-maximized ? parent.width : parent.width * 0.90;
            height: root.window-maximized ? parent.height - 60px : parent.height * 0.92;
            is-maximized <=> root.window-maximized;
            icon-char: "\u{1F512}";
            icon-color: Theme.color-emotional;
            title: Tr.title-permissions;
            close => { root.current-screen = 1; root.navigate(1); }
            minimize => { root.current-screen = 1; root.navigate(1); }
            animate x, y, width, height { duration: 200ms; easing: ease-out; }

            PermissionDashboardScreen {
                width: 100%; height: 100%;
                active-tab <=> root.perm-active-tab;
                perm-users: root.perm-users;
                perm-groups: root.perm-groups;
                perm-selected-user: root.perm-selected-user;
                perm-suid-files: root.perm-suid-files;
                perm-world-writable: root.perm-world-writable;
                perm-scanning: root.perm-scanning;
                perm-tab(idx) => { root.perm-tab(idx); }
                perm-refresh() => { root.perm-refresh(); }
                perm-fix(path) => { root.perm-fix(path); }
                perm-select-user(idx) => { root.perm-select-user(idx); }
            }
        }

        // ── Persistent dock for windowed app screens ──
        if current-screen >= 4 && current-screen <= 28 : AppDock {
            y: parent.height - self.height;
            width: 100%;
            items: root.dock-items.length > 0 ? root.dock-items : [
                { app-id: "terminal",      label: "Terminal", icon-char: ">_", is-running: false },
                { app-id: "browser",       label: "Browser",  icon-char: "W",  is-running: false },
                { app-id: "files",         label: "Files",    icon-char: "F",  is-running: false },
                { app-id: "notes",         label: "Notes",    icon-char: "✎",  is-running: false },
                { app-id: "editor",        label: "Editor",   icon-char: "≡",  is-running: false },
                { app-id: "bond",          label: "Bond",     icon-char: "♥",  is-running: false },
                { app-id: "memory",        label: "Memory",   icon-char: "◈",  is-running: false },
                { app-id: "notifications", label: "Alerts",   icon-char: "N",  is-running: false },
                { app-id: "system",        label: "System",   icon-char: "◉",  is-running: false },
                { app-id: "media",         label: "Media",    icon-char: "♪",  is-running: false },
                { app-id: "email",         label: "Email",    icon-char: "@",  is-running: false },
                { app-id: "calendar",      label: "Calendar", icon-char: "▦",  is-running: false },
                { app-id: "network",       label: "Network",  icon-char: "\u{25CE}",  is-running: false },
                { app-id: "launchpad",     label: "Apps",     icon-char: "\u{229E}",  is-running: false },
                { app-id: "settings",      label: "Settings", icon-char: "\u{2699}",  is-running: false },
            ];
            launch-app(app-id) => { root.launch-app(app-id); }
            anchor-pressed => {
                root.current-screen = 1;
                root.navigate(1);
            }
        }

        // Voice overlay
        if voice-active : VoiceOverlay {
            width: 100%; height: 100%;
            voice-state: root.voice-state;
            transcribed-text: root.voice-transcribed;
            response-text: root.voice-response;
            cancel-pressed => {
                root.voice-active = false;
                root.cancel-voice();
            }
        }

        // Toast notification banners (top-right, stacking)
        if toast-queue.length > 0 : ToastBanner {
            width: 100%; height: 100%;
            toasts: root.toast-queue;
            toast-clicked(id) => { root.toast-clicked(id); }
            toast-dismissed(id) => { root.toast-dismissed(id); }
        }
    }
}
