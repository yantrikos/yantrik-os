// Yantrik OS — AI-native desktop shell.
// Screen states: 0=boot, 1=desktop, 2=onboarding, 3=lock, 4=bond, 5=personality,
//   6=memory, 7=settings, 8=files, 9=notifications, 10=system,
//   11=image_viewer, 12=text_editor, 13=media_player, 14=terminal, 15=notes, 16=about,
//   17=email, 18=calendar, 19=weather, 20=music_player, 21=package_manager, 22=network_manager, 23=system_monitor,
//   24=download_manager, 25=snippet_manager, 26=container_manager, 27=device_dashboard, 28=permission_dashboard,
//   29=spreadsheet, 30=document_editor, 31=presentation.
// The AI IS the shell — Intent Lens is the primary interaction.

import { Theme, ThemeMode, ThemeOverrides, AccentPreset } from "theme.slint";
import { BootScreen } from "boot.slint";
import { OnboardingScreen } from "onboarding.slint";
import { DesktopScreen } from "desktop.slint";
import { BondScreen, BondData } from "bond.slint";
import { PersonalityScreen, OpinionData, SharedRefData } from "personality.slint";
import { LockScreen } from "lock.slint";
import { SettingsScreen, SettingsCategoryItem, AIProviderData, AIModelData, AIStatusData } from "settings.slint";
import { SkillData } from "skill_store.slint";
import { MemoryBrowser, MemoryItem } from "memory_browser.slint";
import { FileBrowser, FileEntry, BreadcrumbSegment, FileDetailData, FileTabData, FileOpItem } from "file_browser.slint";
import { NotificationCenter, NotificationData } from "notification_center.slint";
import { SystemDashboard, ProcessData } from "system_dashboard.slint";
import { VoiceOverlay } from "voice_overlay.slint";
import { ImageViewer } from "image_viewer.slint";
import { TextEditorScreen, EditorTabData } from "text_editor.slint";
import { MediaPlayer } from "media_player.slint";
import { TerminalScreen, TerminalTabData, TerminalSegment } from "terminal.slint";
import { NotesEditor, NoteEntry, NoteVersionEntry, NoteBacklink } from "notes_editor.slint";
import { AboutScreen, ComponentVersionData } from "about.slint";
import { EmailClient, EmailFolderData, EmailListItem, EmailDetailData, EmailThreadMessage, EmailAttachmentData, EmailSignatureData } from "email.slint";
import { CalendarScreen, CalendarDay, CalendarEvent, CalendarTimeEvent, CalendarAttendee, CalendarTemplate } from "calendar.slint";
import { PackageManager, PackageData, PendingAction } from "package_manager.slint";
import { NetworkManager, WifiNetwork, EthernetInterface, BluetoothDevice, VpnConnection, FirewallRule, DiagTestResult, ConnectionEvent, NetAIProviderStatus } from "network_manager.slint";
import { SystemMonitor, CpuCoreData, DiskData, NetworkInterfaceData, MonitorProcessData } from "system_monitor.slint";
import { WeatherDashboard, WeatherCurrent, WeatherHourly, WeatherDaily, WeatherSavedLocation, WeatherAlert } from "weather.slint";
import { MusicPlayerScreen, MusicTrackData, MusicPlaylistData, MusicAlbumData, MusicArtistData, MusicGenreData, MusicScanFolderData } from "music_player.slint";
import { DownloadManagerScreen, DownloadItem } from "download_manager.slint";
import { SnippetManagerScreen, SnippetData, TagChip, CollectionData, LanguageOption } from "snippet_manager.slint";
import { ContainerManagerScreen, ContainerData, ImageData, VolumeData } from "container_manager.slint";
import { DeviceDashboardScreen, UsbDeviceData, PciDeviceData, InputDeviceData, StorageDeviceData, DisplayDeviceData } from "device_dashboard.slint";
import { PermissionDashboardScreen, UserData, GroupData, PermFileData } from "permission_dashboard.slint";
import { SpreadsheetScreen, SpreadsheetCell, SheetTab } from "spreadsheet.slint";
import { DocumentEditorScreen, DocHeadingEntry, DocCommentEntry, DocChangeEntry, DocVersionEntry } from "document_editor.slint";
import { PresentationScreen, SlideData, PresentTheme, AiProposalState } from "presentation.slint";
import { ToastBanner, ToastData } from "components/toast_banner.slint";
import { CommandPalette, CommandItem } from "components/command_palette.slint";
import { ContentBlock, MessageData } from "components/message_bubble.slint";
import { UrgeCardData } from "components/glance_card.slint";
import { LensResult } from "components/intent_lens.slint";
import { WhisperCardItem } from "components/whisper_card.slint";
import { BriefSection } from "components/morning_brief.slint";
import { ClipboardEntryData } from "components/clipboard_panel.slint";
import { AppGridItem } from "components/app_grid.slint";
import { WindowItem } from "components/window_switcher.slint";
import { DockItem, AppDock } from "components/app_dock.slint";
import { WindowFrame } from "components/window_frame.slint";
import { YButton, YIconButton } from "components/y_button.slint";
import { YInput } from "components/y_input.slint";
import { YListItem } from "components/y_list_item.slint";
import { YSidebar, YSidebarItem, YSidebarSection } from "components/y_sidebar.slint";
import { YEmptyState } from "components/y_empty_state.slint";
import { YToolbar } from "components/y_toolbar.slint";
import { YTabs, YTabItem } from "components/y_tabs.slint";
import { YDialog } from "components/y_dialog.slint";
import { YContextMenu, YMenuAction } from "components/y_context_menu.slint";
import { AppShell } from "components/app_shell.slint";
import { Tr } from "translations.slint";

export { Tr, ThemeMode, ThemeOverrides, AccentPreset, ContentBlock, MessageData, UrgeCardData, BondData, OpinionData, SharedRefData, MemoryItem, LensResult, WhisperCardItem, FileEntry, BreadcrumbSegment, FileDetailData, NotificationData, ProcessData, ClipboardEntryData, AppGridItem, WindowItem, DockItem, NoteEntry, ToastData, TerminalTabData, EmailFolderData, EmailListItem, EmailDetailData, EmailAttachmentData, EmailSignatureData, CalendarDay, CalendarEvent, CalendarAttendee, CalendarTemplate, PackageData, PendingAction, WifiNetwork, EthernetInterface, BluetoothDevice, VpnConnection, FirewallRule, CpuCoreData, DiskData, NetworkInterfaceData, MonitorProcessData, WeatherCurrent, WeatherHourly, WeatherDaily, WeatherSavedLocation, WeatherAlert, MusicTrackData, MusicPlaylistData, MusicAlbumData, MusicArtistData, MusicGenreData, MusicScanFolderData, DownloadItem, SnippetData, TagChip, CollectionData, LanguageOption, ContainerData, ImageData, VolumeData, UsbDeviceData, PciDeviceData, InputDeviceData, StorageDeviceData, DisplayDeviceData, UserData, GroupData, PermFileData, ComponentVersionData, BriefSection, SpreadsheetCell, SheetTab, DocHeadingEntry, SlideData, PresentTheme, CommandItem, YSidebarItem, YSidebarSection, YTabItem, YMenuAction }

export component App inherits Window {
    title: "Yantrik OS";
    default-font-size: 14px;
    background: Theme.bg-deep;


    // Screen state: 0=boot, 1=desktop, 2=onboarding, 3=lock, 4=bond, 5=personality,
    //   6=memory, 7=settings, 8=files, 9=notifications, 10=system, 21=package_manager
    in-out property <int> current-screen: 0;

    // Window chrome state (shared across all windowed screens)
    in-out property <bool> window-maximized: true;

    // Window geometry (when not maximized) — drag/resize updates these
    in-out property <length> window-x: 80px;
    in-out property <length> window-y: 40px;
    in-out property <length> window-w: self.width * 0.85;
    in-out property <length> window-h: (self.height - 60px) * 0.90;

    // Boot state
    in property <string> boot-status: "remembering...";

    // Companion state
    in property <int> memory-count: 0;
    in property <bool> is-thinking: false;
    in property <bool> has-urges: false;
    in property <bool> is-speaking: false;
    in property <bool> is-listening: false;
    in property <bool> companion-online: true;  // LLM backend reachable

    // Chat state
    in property <[MessageData]> messages: [];
    in property <bool> is-generating: false;

    // Desktop state
    in property <[UrgeCardData]> urges: [];
    in property <string> clock-text: "00:00";
    in property <string> companion-status: "idle";
    in property <bool> battery-available: false;
    in property <int> battery-level: 100;
    in property <bool> battery-charging: false;
    in property <bool> wifi-connected: false;
    in property <int> pending-count: 0;
    in property <string> greeting-text: "Hello";

    // Intent Lens state
    in-out property <bool> lens-open: false;
    in property <[LensResult]> lens-results: [];
    in property <bool> lens-chat-mode: false;
    in property <[LensResult]> lens-suggestions: [];
    in property <[LensResult]> lens-recents: [];

    // Bond state
    in property <BondData> bond-data: {
        bond-score: 0.0,
        bond-level: "Stranger",
        total-interactions: 0,
        days-together: 0,
        current-streak: 0,
        humor-rate: 0.0,
        vulnerability-events: 0,
        shared-references: 0,
    };

    // Personality state
    in property <float> formality: 0.5;
    in property <float> humor-ratio: 0.0;
    in property <float> opinion-strength: 0.0;
    in property <float> question-ratio: 0.5;
    in property <[OpinionData]> opinions: [];
    in property <[SharedRefData]> shared-refs: [];

    // Memory browser state
    in property <[MemoryItem]> memory-results: [];
    in property <bool> is-searching-memories: false;

    // Voice state
    in-out property <bool> voice-active: false;
    in property <int> voice-state: 0;
    in property <string> voice-transcribed: "";
    in property <string> voice-response: "";

    // Whisper Cards (floating notifications)
    in property <[WhisperCardItem]> whisper-cards: [];
    in property <int> whisper-hint-count: 0;

    // Morning Brief card
    in property <bool> morning-brief-visible: false;
    in property <string> morning-brief-greeting: "Good morning!";
    in property <[BriefSection]> morning-brief-sections: [];
    callback morning-brief-dismissed();
    callback morning-brief-section-action(string);

    // Clipboard panel state
    in-out property <bool> clip-panel-open: false;
    in property <[ClipboardEntryData]> clip-panel-entries: [];
    in-out property <string> clip-search-query: "";
    callback clipboard-paste(int);
    callback clipboard-search(string);

    // Power menu state
    in-out property <bool> power-menu-open: false;
    callback power-action(string);

    // App grid state
    in-out property <bool> app-grid-open: false;
    in property <[AppGridItem]> grid-apps: [];
    callback grid-launch-app(string);
    callback grid-search-apps(string);

    // Window switcher state
    in-out property <bool> window-switcher-open: false;
    in property <[WindowItem]> window-list: [];
    callback switch-window(string);

    // Dock items (for running indicators)
    in property <[DockItem]> dock-items: [];

    // Quick Settings state
    in-out property <bool> quick-settings-open: false;
    in-out property <int> brightness-level: 80;
    in-out property <int> volume-level: 50;
    callback toggle-wifi();
    callback brightness-changed(int);
    callback volume-changed(int);

    // Command Palette state (Ctrl+Shift+P)
    in-out property <bool> command-palette-open: false;
    in property <[CommandItem]> command-palette-filtered: [];
    callback command-palette-search(string);
    callback command-palette-selected(string);
    callback open-command-palette();

    // Cross-App Workflow data transfer
    callback cross-app-action(string, string);  // (action_type, data_json)

    // Pre-fill properties for cross-app data transfer
    in-out property <string> cal-prefill-title: "";
    in-out property <string> cal-prefill-notes: "";
    in-out property <string> notes-prefill-title: "";
    in-out property <string> notes-prefill-content: "";
    in-out property <string> pres-prefill-title: "";
    in-out property <string> pres-prefill-content: "";
    in-out property <string> editor-open-path: "";

    // Notification toast (legacy — kept for backward compatibility)
    in property <string> notification-text: "";
    in-out property <bool> show-notification: false;

    // Toast notification banners (stacking, glassmorphic)
    in property <[ToastData]> toast-queue: [];
    callback toast-clicked(int);
    callback toast-dismissed(int);

    // Ambient Intelligence state
    in property <float> particle-sentiment: 0.0;
    in property <float> particle-cognitive-load: 0.0;
    in property <float> particle-time-of-day: 0.5;

    // Project Consciousness
    in property <string> active-project: "";

    // Do Not Disturb mode
    in-out property <bool> dnd-mode: false;
    callback toggle-dnd-mode();

    // Focus mode (Workspace Morph)
    in-out property <bool> focus-mode: false;
    in property <string> focus-remaining: "";
    callback end-focus-mode();

    // Lock screen state
    in property <string> lock-error: "";
    in property <string> lock-date-text: "";
    in property <string> lock-greeting: "";
    callback try-unlock(string);
    callback lock-screen();

    // Settings state (screen 7)
    in-out property <string> settings-user-name: "";
    in-out property <string> settings-companion-name: "Yantrik";
    callback rename-user(string);
    callback rename-companion(string);
    in property <string> settings-model-name: "";
    in property <int> settings-max-context: 4096;
    in property <int> settings-max-tokens: 512;
    in property <string> settings-tool-permission: "sensitive";
    in property <int> settings-auto-lock-secs: 300;
    in property <string> settings-version: "0.1.0";
    in property <string> settings-ip-address: "";
    in property <string> settings-display-resolution: "";
    in property <string> settings-llm-backend: "candle";
    in property <string> settings-llm-api-url: "";
    in property <string> settings-llm-api-model: "";
    in-out property <bool> settings-dark-mode: true;
    in-out property <bool> settings-incognito-mode: false;
    in-out property <string> settings-accent-color: "cyan";

    // AI Provider management
    in property <AIStatusData> settings-ai-status;
    in property <[AIProviderData]> settings-ai-providers: [];
    in property <[AIModelData]> settings-available-models: [];
    in property <string> settings-provider-test-result: "";
    in property <[SettingsCategoryItem]> settings-categories;
    callback settings-search(string);
    callback add-provider();
    callback save-provider(string, string, string, string, string);
    callback delete-provider(string);
    callback test-provider(string);
    callback test-new-provider(string, string, string);
    callback set-primary-provider(string);
    callback set-fallback-provider(string);
    callback select-model(string);
    callback refresh-models();
    callback toggle-auto-fallback();

    // V60 — Task routing
    in-out property <string> settings-route-fast: "";
    in-out property <string> settings-route-balanced: "";
    in-out property <string> settings-route-powerful: "";
    callback save-task-routing(string, string, string);

    // V60 — Privacy controls
    in-out property <bool> settings-privacy-local-only: false;
    in-out property <bool> settings-privacy-cloud-confirm: true;
    in-out property <string> settings-privacy-preset: "balanced";
    callback set-privacy-preset(string);

    // V62 — Usage / Cost tracking
    in property <string> settings-usage-period: "monthly";
    in property <float> settings-usage-local-percent: 0.0;
    in property <float> settings-usage-cloud-percent: 0.0;
    in property <string> settings-usage-total-cost: "$0.00";
    in property <string> settings-usage-daily-cost: "$0.00";
    in property <string> settings-usage-tokens-today: "0";
    in property <string> settings-usage-tokens-month: "0";
    in property <string> settings-budget-limit: "";
    in property <float> settings-budget-used-percent: 0.0;
    in property <bool> settings-budget-warning: false;
    callback save-budget(string);

    // Connected Services
    in property <string> conn-google-status: "disconnected";
    in property <string> conn-google-detail: "";
    in property <string> conn-spotify-status: "disconnected";
    in property <string> conn-spotify-detail: "";
    in property <string> conn-facebook-status: "disconnected";
    in property <string> conn-facebook-detail: "";
    in property <string> conn-instagram-status: "disconnected";
    in property <string> conn-instagram-detail: "";
    callback connect-service(string);
    callback disconnect-service(string);
    callback sync-service(string);

    // Skills (data-driven via Skill Store)
    in property <[SkillData]> skills;
    in property <[string]> skill-categories: ["All"];
    callback toggle-skill(string);
    callback search-skills(string);
    callback filter-skill-category(string);

    callback toggle-dark-mode();
    callback toggle-incognito-mode();
    callback cycle-accent-color();
    callback cycle-tool-permission();
    callback cycle-auto-lock();
    in-out property <string> wallpaper-path: "";
    in property <image> wallpaper-image;
    callback wallpaper-changed(string);

    // File browser state (screen 8)
    in property <string> file-browser-path: "~";
    in property <[FileEntry]> file-browser-entries: [];
    in property <bool> file-browser-loading: false;
    in property <[BreadcrumbSegment]> file-breadcrumbs: [];
    in property <bool> file-has-clipboard: false;
    in-out property <bool> file-show-hidden: false;
    in-out property <bool> file-grid-view: false;
    callback file-navigate-dir(string);
    callback file-open(string);
    callback file-go-up();
    callback file-navigate-to-path(string);
    callback file-toggle-hidden();
    callback file-delete(string);
    callback file-rename(string, string);
    callback file-copy(string);
    callback file-cut(string);
    callback file-paste();
    callback file-create-folder(string);
    in property <FileDetailData> file-detail-data;
    in property <string> file-free-space-text: "";
    in property <bool> file-can-go-back: false;
    in property <bool> file-can-go-forward: false;
    callback file-selection-changed(string);
    callback file-go-back();
    callback file-go-forward();
    callback file-sort-changed(string, bool);
    callback file-filter-changed(string);
    // File browser AI features
    in property <string> file-ai-summary: "";
    in property <bool> file-is-summarizing: false;
    in property <string> file-dir-type-badge: "";
    callback file-request-summarize();
    callback file-request-ask-ai();
    // File browser enterprise features
    callback file-create-file(string);
    callback file-multi-select-clicked(int, bool, bool);
    callback file-select-all();
    callback file-clear-selection();
    callback file-delete-selected();
    callback file-copy-selected();
    callback file-cut-selected();
    callback file-context-copy-path(string);
    callback file-context-open-terminal();
    callback file-context-compress(string);
    in-out property <int> file-selection-count: 0;
    in property <string> file-selection-size-text: "";
    in-out property <bool> file-detail-panel-visible: false;
    in-out property <int> file-selected-index: -1;
    // File browser V44 — tabs, ops queue, batch rename, quick look, trash
    in property <[FileTabData]> file-tabs: [];
    in property <int> file-active-tab: 0;
    callback file-new-tab();
    callback file-close-tab(int);
    callback file-switch-tab(int);
    in property <[FileOpItem]> file-op-queue: [];
    in-out property <bool> file-op-queue-visible: false;
    in-out property <bool> file-batch-rename-open: false;
    in-out property <string> file-batch-rename-pattern: "";
    in-out property <string> file-batch-rename-replace: "";
    callback file-batch-rename-execute();
    in-out property <bool> file-quick-look-open: false;
    in property <string> file-quick-look-content: "";
    in property <string> file-quick-look-name: "";
    callback file-quick-look(int);
    callback file-close-quick-look();
    in-out property <bool> file-trash-mode: false;
    in property <int> file-trash-count: 0;
    callback file-toggle-trash();
    callback file-empty-trash();
    callback file-restore-from-trash(int);

    // Notification Center state (screen 9)
    in property <[NotificationData]> notification-list: [];
    in property <int> notification-unread-count: 0;
    callback notification-clear-all();
    callback notification-mark-all-read();
    callback notification-tapped(string);
    callback notification-clear-group(string);

    // System Dashboard state (screen 10)
    in property <float> sys-cpu-usage: 0.0;
    in property <float> sys-memory-usage: 0.0;
    in property <string> sys-memory-text: "0 / 0 MB";
    in property <string> sys-uptime-text: "";
    in property <string> sys-wifi-ssid: "";
    in property <int> sys-wifi-signal: 0;
    in property <[ProcessData]> sys-top-processes: [];
    in property <[float]> sys-cpu-history: [];
    in property <[float]> sys-memory-history: [];
    // Memory breakdown
    in property <float> sys-memory-used-percent: 0.0;
    in property <float> sys-memory-cached-percent: 0.0;
    in property <string> sys-memory-used-text: "";
    in property <string> sys-memory-cached-text: "";
    in property <string> sys-memory-total-text: "";
    // Swap
    in property <float> sys-swap-usage: 0.0;
    in property <string> sys-swap-text: "";

    // Image Viewer state (screen 11)
    in property <image> viewer-image;
    in property <string> viewer-file-name: "";
    in property <string> viewer-counter: "";
    in-out property <bool> viewer-fit-contain: true;
    callback viewer-nav-prev();
    callback viewer-nav-next();
    callback viewer-toggle-fit();
    // Image Viewer AI
    in property <bool> viewer-ai-is-working: false;
    in property <string> viewer-ai-response: "";
    in-out property <bool> viewer-ai-panel-open: false;
    callback viewer-ai-describe();
    callback viewer-ai-dismiss();
    // Image Viewer — Rotate / Flip
    in-out property <int> viewer-rotation: 0;
    in-out property <bool> viewer-flip-h: false;
    in-out property <bool> viewer-flip-v: false;
    callback viewer-rotate-left();
    callback viewer-rotate-right();
    callback viewer-flip-horizontal();
    callback viewer-flip-vertical();
    // Image Viewer — EXIF Info Panel
    in-out property <bool> viewer-info-open: false;
    in property <string> viewer-exif-dimensions: "";
    in property <string> viewer-exif-file-size: "";
    in property <string> viewer-exif-format: "";
    in property <string> viewer-exif-camera: "";
    in property <string> viewer-exif-focal-length: "";
    in property <string> viewer-exif-iso: "";
    in property <string> viewer-exif-exposure: "";
    in property <string> viewer-exif-date-taken: "";
    in property <string> viewer-exif-gps: "";
    callback viewer-toggle-info();
    // Image Viewer — Slideshow
    in-out property <bool> viewer-slideshow-active: false;
    in-out property <bool> viewer-slideshow-paused: false;
    in-out property <float> viewer-slideshow-progress: 0.0;
    callback viewer-slideshow-toggle();
    callback viewer-slideshow-stop();
    // Image Viewer — Crop
    in-out property <bool> viewer-crop-mode: false;
    callback viewer-start-crop();
    callback viewer-apply-crop();
    callback viewer-cancel-crop();
    // Image Viewer — Batch operations
    in property <string> viewer-batch-status: "";
    in property <int> viewer-batch-total: 0;
    in property <int> viewer-batch-done: 0;
    in-out property <bool> viewer-batch-panel-open: false;
    callback viewer-batch-rotate-all(int);
    callback viewer-batch-resize(int, int);

    // Text Editor state (screen 12)
    in property <string> editor-file-name: "untitled";
    in-out property <string> editor-file-content: "";
    in property <bool> editor-is-modified: false;
    in property <bool> editor-is-readonly: false;
    // Editor tabs
    in property <[EditorTabData]> editor-tabs: [];
    in property <int> editor-tab-count: 0;
    in property <int> editor-active-tab: 0;
    callback editor-switch-tab(int);
    callback editor-new-tab();
    callback editor-close-tab(int);
    // Editor line/column info
    in property <int> editor-cursor-line: 1;
    in property <int> editor-cursor-col: 1;
    in property <int> editor-total-lines: 1;
    in property <string> editor-encoding: "UTF-8";
    in property <string> editor-line-ending: "LF";
    in property <string> editor-file-type: "Plain Text";
    in property <string> editor-line-numbers-text: "  1";
    // Go-to-line
    in-out property <bool> editor-show-goto-line: false;
    in-out property <string> editor-goto-line-input: "";
    callback editor-goto-line(int);
    // Autosave
    in property <bool> editor-autosave-enabled: true;
    in property <string> editor-last-saved-time: "";
    // Save As
    in-out property <bool> editor-show-save-dialog: false;
    in-out property <string> editor-save-dir: "~/";
    in-out property <string> editor-save-filename: "untitled.txt";
    in property <string> editor-save-error: "";
    callback editor-save();
    callback editor-save-as(string, string);
    callback editor-content-changed(string);
    // Editor AI assist
    in-out property <bool> editor-show-ai-panel: false;
    in-out property <string> editor-ai-prompt: "";
    in property <string> editor-ai-response: "";
    in property <bool> editor-ai-is-working: false;
    callback editor-ai-request(string);
    callback editor-ai-insert();
    callback editor-ai-dismiss();
    // Editor Find & Replace
    in-out property <bool> editor-show-find-bar: false;
    in-out property <string> editor-find-query: "";
    in-out property <string> editor-replace-text: "";
    in property <int> editor-find-match-count: 0;
    in property <int> editor-find-current-match: 0;
    in-out property <bool> editor-show-replace-row: false;
    callback editor-find-next();
    callback editor-find-prev();
    callback editor-replace-current();
    callback editor-replace-all();
