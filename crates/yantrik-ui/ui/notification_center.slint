// Notification Center — persistent notification history.
// Screen 9. All captured D-Bus notifications with urgency, app name, time.

import { Theme } from "theme.slint";

export struct NotificationData {
    id: string,
    app-name: string,
    summary: string,
    body: string,
    urgency: int,  // 0=low, 1=normal, 2=critical
    time-ago: string,
    is-read: bool,
}

export component NotificationCenter inherits Rectangle {
    background: Theme.bg-deep;

    in property <[NotificationData]> notifications: [];
    in property <int> unread-count: 0;

    callback back-pressed();
    callback clear-all();
    callback mark-all-read();
    callback notification-tapped(string);

    VerticalLayout {
        spacing: 0px;

        // Header
        Rectangle {
            height: 56px;
            background: Theme.bg-surface;

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                alignment: start;
                spacing: 12px;

                // Back button
                TouchArea {
                    width: Theme.touch-target;
                    height: Theme.touch-target;
                    clicked => { root.back-pressed(); }
                    Text {
                        text: "←";
                        color: Theme.text-secondary;
                        font-size: 22px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Text {
                    text: "Notifications";
                    color: Theme.text-primary;
                    font-size: Theme.font-title;
                    font-weight: 600;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                // Unread badge
                if root.unread-count > 0 : Rectangle {
                    width: max(22px, unread-text.preferred-width + 12px);
                    height: 22px;
                    y: (parent.height - 22px) / 2;
                    border-radius: 11px;
                    background: Theme.amber-dim;

                    unread-text := Text {
                        text: root.unread-count;
                        color: Theme.bg-deep;
                        font-size: 11px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                // Mark all read
                TouchArea {
                    width: Theme.touch-target;
                    height: Theme.touch-target;
                    clicked => { root.mark-all-read(); }
                    Rectangle {
                        width: 100%; height: 100%;
                        border-radius: 8px;
                        background: parent.has-hover ? Theme.hover-fill : transparent;
                        Text {
                            text: "✓";
                            color: Theme.text-dim;
                            font-size: 18px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                // Clear all
                TouchArea {
                    width: Theme.touch-target;
                    height: Theme.touch-target;
                    clicked => { root.clear-all(); }
                    Rectangle {
                        width: 100%; height: 100%;
                        border-radius: 8px;
                        background: parent.has-hover ? Theme.hover-fill : transparent;
                        Text {
                            text: "✕";
                            color: Theme.text-dim;
                            font-size: 16px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        // Notification list
        Flickable {
            vertical-stretch: 1;

            VerticalLayout {
                padding: 12px;
                spacing: 8px;
                alignment: start;

                // Empty state
                if root.notifications.length == 0 : VerticalLayout {
                    alignment: center;
                    padding-top: 120px;

                    Text {
                        text: "No notifications";
                        color: Theme.text-dim;
                        font-size: 16px;
                        horizontal-alignment: center;
                    }
                    Text {
                        text: "System notifications will appear here";
                        color: Theme.text-dim;
                        font-size: 12px;
                        horizontal-alignment: center;
                        opacity: 0.6;
                    }
                }

                // Notification cards
                for notif in root.notifications : Rectangle {
                    background: notif.is-read ? Theme.bg-card : Theme.bg-elevated;
                    border-radius: Theme.radius-card;
                    border-width: notif.urgency == 2 ? 1px : 0px;
                    border-color: notif.urgency == 2 ? Theme.color-emotional : transparent;
                    height: notif-content.preferred-height;

                    TouchArea {
                        clicked => { root.notification-tapped(notif.id); }
                    }

                    notif-content := VerticalLayout {
                        padding: 12px;
                        spacing: 4px;

                        HorizontalLayout {
                            spacing: 8px;

                            // Urgency dot
                            Rectangle {
                                width: 8px;
                                height: 8px;
                                y: 4px;
                                border-radius: 4px;
                                background: notif.urgency == 2 ? Theme.color-emotional :
                                            notif.urgency == 0 ? Theme.text-dim :
                                            Theme.amber;
                                opacity: notif.is-read ? 0.3 : 1.0;
                            }

                            // App name
                            Text {
                                text: notif.app-name;
                                color: Theme.text-secondary;
                                font-size: 11px;
                                font-weight: 600;
                                letter-spacing: 1px;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }

                            // Time ago
                            Text {
                                text: notif.time-ago;
                                color: Theme.text-dim;
                                font-size: 10px;
                                vertical-alignment: center;
                            }
                        }

                        // Summary
                        Text {
                            text: notif.summary;
                            color: notif.is-read ? Theme.text-secondary : Theme.text-primary;
                            font-size: Theme.font-body;
                            font-weight: notif.is-read ? 400 : 500;
                            wrap: word-wrap;
                        }

                        // Body (only if different from summary)
                        if notif.body != "" && notif.body != notif.summary : Text {
                            text: notif.body;
                            color: Theme.text-dim;
                            font-size: Theme.font-small;
                            wrap: word-wrap;
                        }
                    }
                }

                // Bottom spacer
                Rectangle { height: 20px; }
            }
        }
    }
}
