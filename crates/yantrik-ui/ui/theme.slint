// Firelight Design Tokens — warm amber + electric cyan on deep black.
// A sci-fi neural aesthetic: the companion's mind visualized.

export global Theme {
    // Backgrounds
    out property <color> bg-deep: #050508;
    out property <color> bg-surface: #0c0b10;
    out property <color> bg-card: #12111a;
    out property <color> bg-elevated: #1a1824;
    out property <color> bg-input: #0e0d14;

    // Amber palette (warmth, companion presence)
    out property <color> amber: #d4a574;
    out property <color> amber-light: #e8c496;
    out property <color> amber-dim: #a07a50;
    out property <color> amber-glow: #d4a57440;
    out property <color> amber-glow-strong: #d4a57480;

    // Cyan palette (neural, electric, data)
    out property <color> cyan: #5ac8d4;
    out property <color> cyan-light: #7ee0e8;
    out property <color> cyan-dim: #3a8a94;
    out property <color> cyan-glow: #5ac8d430;

    // Instinct colors
    out property <color> color-pattern: #c48bd4;
    out property <color> color-reminder: #8be86b;
    out property <color> color-emotional: #e86b6b;
    out property <color> color-check-in: #d4a03c;
    out property <color> color-follow-up: #6bb8e8;
    out property <color> color-conflict: #e8a06b;

    // Text
    out property <color> text-primary: #e0e4ec;
    out property <color> text-secondary: #7a8494;
    out property <color> text-dim: #3e4454;

    // Typography
    out property <length> font-body: 15px;
    out property <length> font-small: 12px;
    out property <length> font-title: 17px;
    out property <length> font-logo: 20px;
    out property <length> font-boot: 35px;

    // Touch targets
    out property <length> touch-target: 44px;

    // Border radius
    out property <length> radius-bubble: 18px;
    out property <length> radius-card: 12px;
    out property <length> radius-pill: 16px;
    out property <length> radius-round: 50px;
}
