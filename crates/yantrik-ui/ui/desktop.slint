// Desktop screen — the AI-native desktop experience.
// Clean canvas: particle field + greeting + bottom-center orb.
// Intent Lens overlays when invoked.
// No clutter. The AI is alive, not widgetized.
//
// Layout:
//   ┌─────────────────────────────────────┐
//   │ StatusBar (24px) [●] 14:32    87%  │
//   ├─────────────────────────────────────┤
//   │                                     │
//   │    ░░░ particle field ░░░           │
//   │                                     │
//   │       Good evening, Pranab          │
//   │          12 memories                │
//   │                                     │
//   │              ◉ orb                  │
//   │                                     │
//   │▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁│ ← dock glow trigger
//   └─────────────────────────────────────┘
//
//   Intent Lens: overlays center-screen when Super pressed

import { Theme, ThemeMode } from "theme.slint";
import { ParticleField } from "components/particle_field.slint";
import { Orb } from "components/orb.slint";
import { StatusBar } from "components/status_bar.slint";
import { AppDock, DockItem } from "components/app_dock.slint";
import { IntentLens, LensResult } from "components/intent_lens.slint";
import { MessageData } from "components/message_bubble.slint";
import { UrgeCardData } from "components/glance_card.slint";
import { WhisperCardStack, WhisperCardItem } from "components/whisper_card.slint";
import { QuickSettings } from "components/quick_settings.slint";
import { ClipboardPanel, ClipboardEntryData } from "components/clipboard_panel.slint";
import { PowerMenu } from "components/power_menu.slint";
import { AppGrid, AppGridItem } from "components/app_grid.slint";
import { WindowSwitcher, WindowItem } from "components/window_switcher.slint";

export component DesktopScreen inherits Rectangle {
    // Status bar state
    in property <string> clock-text: "00:00";
    in property <string> companion-status: "idle";
    in property <bool> companion-online: true;
    in property <int> battery-level: 100;
    in property <bool> battery-charging: false;
    in property <bool> wifi-connected: false;
    in property <int> pending-count: 0;

    // Companion state
    in property <bool> is-thinking: false;
    in property <bool> has-urges: false;
    in property <bool> is-speaking: false;
    in property <bool> is-listening: false;
    in property <string> greeting-text: "Hello";
    in property <int> memory-count: 0;

    // Intent Lens state
    in-out property <bool> lens-open: false;
    in property <[LensResult]> lens-results: [];
    in property <bool> lens-chat-mode: false;
    in property <[LensResult]> lens-suggestions: [];
    in property <[LensResult]> lens-recents: [];

    // Chat state (for lens chat mode)
    in property <[MessageData]> messages: [];
    in property <bool> is-generating: false;

    // Urges (for quiet queue)
    in property <[UrgeCardData]> urges: [];

    // Whisper Cards (floating notifications)
    in property <[WhisperCardItem]> whisper-cards: [];
    in property <int> whisper-hint-count: 0;
    callback whisper-card-dismissed(string);
    callback whisper-card-action(string);
    callback whisper-hint-clicked();

    // Quick Settings overlay
    in-out property <bool> quick-settings-open: false;
    in-out property <int> brightness-level: 80;
    in-out property <int> volume-level: 50;
    callback toggle-wifi();
    callback brightness-changed(int);
    callback volume-changed(int);

    // Clipboard panel
    in-out property <bool> clip-panel-open: false;
    in property <[ClipboardEntryData]> clip-panel-entries: [];
    callback clipboard-paste(int);

    // Power menu
    in-out property <bool> power-menu-open: false;
    callback power-action(string);

    // App grid
    in-out property <bool> app-grid-open: false;
    in property <[AppGridItem]> grid-apps: [];
    callback grid-launch-app(string);

    // Window switcher
    in-out property <bool> window-switcher-open: false;
    in property <[WindowItem]> window-list: [];
    callback switch-window(string);

    // Dock items (settable from Rust for running indicators)
    in property <[DockItem]> dock-items: [];

    // Focus mode (Workspace Morph)
    in-out property <bool> focus-mode: false;
    in property <string> focus-remaining: "";
    callback end-focus-mode();

    // Callbacks
    callback send-message(string);
    callback mic-pressed();
    callback launch-app(string);
    callback navigate-to(int);
    callback lens-query(string);
    callback lens-submit(string);
    callback lens-result-selected(string);
    callback open-lens();
    callback close-lens();

    background: Theme.bg-deep;
    clip: true;

    // ── Layer 1: Status bar (always on top, dims in focus mode) ──
    StatusBar {
        x: 0; y: 0;
        width: 100%;
        opacity: root.focus-mode ? 0.5 : 1.0;
        animate opacity { duration: 300ms; }
        clock-text: root.clock-text;
        companion-status: root.companion-status;
        companion-online: root.companion-online;
        battery-level: root.battery-level;
        battery-charging: root.battery-charging;
        wifi-connected: root.wifi-connected;
        pending-count: root.pending-count;
        whisper-hint-count: root.whisper-hint-count;
        anchor-clicked => { root.lens-open = !root.lens-open; root.open-lens(); }
        queue-clicked => { root.lens-open = true; root.open-lens(); }
        whisper-hint-clicked => { root.whisper-hint-clicked(); }
        settings-tapped => { root.quick-settings-open = !root.quick-settings-open; }
        power-pressed => { root.power-menu-open = !root.power-menu-open; }
    }

    // ── Layer 2: Desktop content area ──
    Rectangle {
        y: Theme.status-bar-height;
        width: 100%;
        height: root.height - Theme.status-bar-height;
        clip: true;

        // ── Deep space backdrop (dark mode) ──
        if ThemeMode.dark : Rectangle {
            width: 100%; height: 100%;

            // Animated phase for subtle backdrop movement
            property <float> bg-phase: 0;
            Timer {
                interval: 16ms;
                running: true;
                triggered => {
                    parent.bg-phase = mod(parent.bg-phase + 0.0008, 1.0);
                }
            }

            // Base gradient (deep blue-black abyss)
            Rectangle {
                width: 100%; height: 100%;
                background: @radial-gradient(circle, #0a0a1c 0%, #050510 45%, #020206 100%);
            }
            // Nebula wash — upper right (cool cyan, breathing)
            Rectangle {
                x: parent.width * 0.6;
                y: -parent.height * 0.05;
                width: 600px; height: 500px;
                border-radius: 250px;
                background: @radial-gradient(circle, #5ac8d412 0%, #5ac8d406 40%, transparent 70%);
                opacity: 0.8 + 0.2 * sin(bg-phase * 6.2832 * 1rad);
            }
            // Nebula wash — lower left (warm amber)
            Rectangle {
                x: -50px;
                y: parent.height * 0.5;
                width: 550px; height: 450px;
                border-radius: 225px;
                background: @radial-gradient(circle, #d4a57412 0%, #d4a57406 40%, transparent 70%);
                opacity: 0.7 + 0.2 * sin(bg-phase * 4.712 * 1rad);
            }
            // Nebula wash — center (subtle purple, deeper)
            Rectangle {
                x: parent.width * 0.28;
                y: parent.height * 0.15;
                width: 800px; height: 600px;
                border-radius: 300px;
                background: @radial-gradient(circle, #c48bd40c 0%, #6040a008 30%, transparent 60%);
            }
            // Nebula wash — bottom center (holographic blue for orb area)
            Rectangle {
                x: parent.width * 0.3;
                y: parent.height * 0.6;
                width: 700px; height: 500px;
                border-radius: 250px;
                background: @radial-gradient(circle, #4ab8f008 0%, transparent 55%);
                opacity: 0.6 + 0.3 * sin(bg-phase * 5.341 * 1rad);
            }
            // Horizon glow — subtle light at the bottom edge
            Rectangle {
                y: parent.height - 200px;
                width: 100%;
                height: 200px;
                background: @linear-gradient(180deg,
                    transparent 0%,
                    #5ac8d406 60%,
                    #5ac8d40c 100%
                );
            }
            // Vignette overlay — deeper edges
            Rectangle {
                width: 100%; height: 100%;
                background: @radial-gradient(circle, transparent 20%, #00000030 55%, #00000080 100%);
            }
        }

        // ── Light mode backdrop ──
        if !ThemeMode.dark : Rectangle {
            width: 100%; height: 100%;
            background: @radial-gradient(circle, #f0f0f4 0%, #e4e4ec 50%, #d8d8e0 100%);
        }

        // Particle field (neurons + nebula clouds)
        ParticleField {
            width: 100%;
            height: 100%;
            active: true;
            intensity: root.focus-mode ? 0.15 : 0.7;
            is-thinking: root.is-thinking;
            has-urges: root.has-urges;

            animate intensity { duration: 300ms; }
        }

        // ── Greeting (center of desktop, hidden in focus mode) ──
        if !root.focus-mode : VerticalLayout {
            alignment: center;
            padding-bottom: 80px;  // Push up a bit from dead center

            // Greeting text
            Text {
                text: root.greeting-text;
                color: Theme.text-primary;
                font-size: 32px;
                font-weight: 300;
                letter-spacing: 2px;
                horizontal-alignment: center;
            }

            // Memory count
            Text {
                text: root.memory-count > 0 ?
                    root.memory-count + " memories" : "ready";
                color: Theme.text-dim;
                font-size: 13px;
                letter-spacing: 3px;
                horizontal-alignment: center;
                opacity: 0.6;
            }
        }

        // ── Focus Overlay (Workspace Morph) ──
        if root.focus-mode : VerticalLayout {
            alignment: center;
            spacing: 8px;

            // Large countdown timer
            Text {
                text: root.focus-remaining;
                color: Theme.text-primary;
                font-size: 72px;
                font-weight: 200;
                letter-spacing: 4px;
                horizontal-alignment: center;
                opacity: 0.85;
            }

            // Label
            Text {
                text: "remaining";
                color: Theme.text-dim;
                font-size: 14px;
                letter-spacing: 3px;
                horizontal-alignment: center;
                opacity: 0.5;
            }

            // Spacer
            Rectangle { height: 32px; }

            // End Focus button
            TouchArea {
                width: 120px;
                height: 36px;
                x: (parent.width - 120px) / 2;
                clicked => { root.end-focus-mode(); }

                Rectangle {
                    width: 100%; height: 100%;
                    border-radius: 18px;
                    border-width: 1px;
                    border-color: Theme.text-dim;
                    background: parent.has-hover ? Theme.hover-fill-strong : transparent;

                    Text {
                        text: "End Focus";
                        color: Theme.text-secondary;
                        font-size: 13px;
                        font-weight: 500;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // ── Floating Orb — bottom center (hidden in focus mode) ──
        if !root.focus-mode : TouchArea {
            x: (parent.width - Theme.orb-desktop-size) / 2;
            y: parent.height - Theme.orb-desktop-size - 72px;
            width: Theme.orb-desktop-size;
            height: Theme.orb-desktop-size;
            clicked => {
                root.lens-open = !root.lens-open;
                root.open-lens();
            }

            Orb {
                width: 100%;
                height: 100%;
                size-px: 80;
                is-thinking: root.is-thinking;
                has-urges: root.has-urges;
                is-speaking: root.is-speaking;
                is-listening: root.is-listening;
            }
        }

        // ── Auto-hiding dock (bottom edge) ──
        AppDock {
            y: parent.height - self.height;
            width: 100%;
            items: root.dock-items.length > 0 ? root.dock-items : [
                { app-id: "terminal",      label: "Terminal",      icon-char: ">_", is-running: false },
                { app-id: "browser",       label: "Browser",       icon-char: "W",  is-running: false },
                { app-id: "files",         label: "Files",         icon-char: "F",  is-running: false },
                { app-id: "editor",        label: "Editor",        icon-char: "≡",  is-running: false },
                { app-id: "bond",          label: "Bond",          icon-char: "♥",  is-running: false },
                { app-id: "memory",        label: "Memory",        icon-char: "◈",  is-running: false },
                { app-id: "notifications", label: "Alerts",        icon-char: "N",  is-running: false },
                { app-id: "system",        label: "System",        icon-char: "◉",  is-running: false },
                { app-id: "media",         label: "Media",         icon-char: "♪",  is-running: false },
                { app-id: "settings",      label: "Settings",      icon-char: "⚙",  is-running: false },
            ];
            launch-app(app-id) => { root.launch-app(app-id); }
            anchor-pressed => {
                root.lens-open = !root.lens-open;
                root.open-lens();
            }
        }
    }

    // ── Layer 2.5: Quick Settings overlay (slide down from status bar) ──
    QuickSettings {
        width: 100%;
        height: 100%;
        is-open <=> root.quick-settings-open;
        battery-level: root.battery-level;
        battery-charging: root.battery-charging;
        wifi-connected: root.wifi-connected;
        wifi-ssid: "";
        brightness-level <=> root.brightness-level;
        volume-level <=> root.volume-level;
        toggle-wifi => { root.toggle-wifi(); }
        brightness-changed(val) => { root.brightness-changed(val); }
        volume-changed(val) => { root.volume-changed(val); }
        close => { root.quick-settings-open = false; }
    }

    // ── Layer 2.52: Power menu overlay ──
    PowerMenu {
        width: 100%;
        height: 100%;
        is-open <=> root.power-menu-open;
        power-action(action) => { root.power-action(action); }
        close => { root.power-menu-open = false; }
    }

    // ── Layer 2.53: App grid overlay ──
    AppGrid {
        width: 100%;
        height: 100%;
        is-open <=> root.app-grid-open;
        apps: root.grid-apps;
        launch-app(app-id) => { root.grid-launch-app(app-id); }
        close => { root.app-grid-open = false; }
    }

    // ── Layer 2.54: Window switcher overlay ──
    WindowSwitcher {
        width: 100%;
        height: 100%;
        is-open <=> root.window-switcher-open;
        windows: root.window-list;
        switch-window(title) => { root.switch-window(title); }
        close => { root.window-switcher-open = false; }
    }

    // ── Layer 2.55: Clipboard history panel ──
    ClipboardPanel {
        width: 100%;
        height: 100%;
        is-open <=> root.clip-panel-open;
        entries: root.clip-panel-entries;
        paste-entry(idx) => { root.clipboard-paste(idx); }
        close => { root.clip-panel-open = false; }
    }

    // ── Layer 2.6: Whisper Cards (floating, top-right) ──
    WhisperCardStack {
        x: root.width - 316px;
        y: Theme.status-bar-height + 8px;
        cards: root.whisper-cards;
        card-dismissed(id) => { root.whisper-card-dismissed(id); }
        card-action(id) => { root.whisper-card-action(id); }
    }

    // ── Layer 3: Intent Lens overlay ──
    IntentLens {
        is-open: root.lens-open;
        is-thinking: root.is-thinking;
        results: root.lens-results;
        companion-status: root.companion-status;
        companion-online: root.companion-online;
        chat-mode: root.lens-chat-mode;
        messages: root.messages;
        is-generating: root.is-generating;
        suggestions: root.lens-suggestions;
        recents: root.lens-recents;

        query-changed(text) => { root.lens-query(text); }
        submit-query(text) => { root.lens-submit(text); }
        result-selected(id) => { root.lens-result-selected(id); }
        close-lens => {
            root.lens-open = false;
            root.close-lens();
        }
        send-message(text) => { root.send-message(text); }
        mic-pressed => { root.mic-pressed(); }
    }
}
