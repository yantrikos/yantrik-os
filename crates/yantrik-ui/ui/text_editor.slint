// Text Editor — simple text editing with AI assist and save.
// Screen 12. Opens from file browser or "Editor" dock icon.
// AI panel: summarize, generate, or improve text via Yantrik.

import { Theme } from "theme.slint";

export component TextEditorScreen inherits Rectangle {
    background: Theme.bg-deep;

    in property <string> file-name: "untitled";
    in-out property <string> file-content: "";
    in property <bool> is-modified: false;
    in property <bool> is-readonly: false;

    // Save As dialog state
    in-out property <bool> show-save-dialog: false;
    in-out property <string> save-dir: "~/";
    in-out property <string> save-filename: "untitled.txt";
    in property <string> save-error: "";

    // AI assist state
    in-out property <bool> show-ai-panel: false;
    in-out property <string> ai-prompt: "";
    in property <string> ai-response: "";
    in property <bool> ai-is-working: false;

    // Find & Replace state
    in-out property <bool> show-find-bar: false;
    in-out property <string> find-query: "";
    in-out property <string> replace-text: "";
    in property <int> find-match-count: 0;
    in property <int> find-current-match: 0;
    in-out property <bool> show-replace-row: false;

    callback save-file();
    callback save-file-as(string, string);
    callback content-changed(string);
    callback ai-request(string);       // Send prompt with document context
    callback ai-insert();              // Insert AI response into document
    callback ai-dismiss();             // Close AI panel
    callback find-next();
    callback find-prev();
    callback replace-current();
    callback replace-all();
    callback find-query-changed(string);

    VerticalLayout {
        spacing: 0px;

        // ── Toolbar ──
        Rectangle {
            height: 40px;
            background: Theme.bg-surface;

            HorizontalLayout {
                padding-left: 16px;
                padding-right: 12px;
                alignment: space-between;

                // Left: filename + status
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    horizontal-stretch: 1;

                    Text {
                        text: root.file-name;
                        color: Theme.text-primary;
                        font-size: 14px;
                        font-weight: 500;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    if root.is-modified : Text {
                        text: "\u{25CF}";
                        color: Theme.amber;
                        font-size: 14px;
                        vertical-alignment: center;
                    }

                    if root.is-readonly : Text {
                        text: "[read-only]";
                        color: Theme.text-dim;
                        font-size: Theme.font-small;
                        vertical-alignment: center;
                    }
                }

                // Right: Find + AI button + Save button
                HorizontalLayout {
                    spacing: 6px;
                    alignment: end;

                    // Find button (Ctrl+F)
                    find-btn-ta := TouchArea {
                        width: 56px;
                        height: 32px;
                        clicked => {
                            root.show-find-bar = !root.show-find-bar;
                            if !root.show-find-bar {
                                root.find-query = "";
                                root.replace-text = "";
                                root.show-replace-row = false;
                                root.find-query-changed("");
                            }
                        }

                        Rectangle {
                            width: 56px;
                            height: 32px;
                            border-radius: 8px;
                            background: root.show-find-bar
                                ? Theme.cyan
                                : (find-btn-ta.has-hover ? Theme.hover-fill-strong : Theme.hover-fill);
                            border-width: root.show-find-bar ? 0px : 1px;
                            border-color: Theme.border-subtle;

                            Text {
                                text: "Find";
                                color: root.show-find-bar ? Theme.bg-deep : Theme.text-secondary;
                                font-size: 12px;
                                font-weight: root.show-find-bar ? 600 : 400;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // AI assist button
                    ai-btn-ta := TouchArea {
                        width: 56px;
                        height: 32px;
                        clicked => {
                            root.show-ai-panel = !root.show-ai-panel;
                            root.show-save-dialog = false;
                        }

                        Rectangle {
                            width: 56px;
                            height: 32px;
                            border-radius: 8px;
                            background: root.show-ai-panel
                                ? Theme.amber
                                : (ai-btn-ta.has-hover ? Theme.hover-fill-strong : Theme.hover-fill);
                            border-width: root.show-ai-panel ? 0px : 1px;
                            border-color: Theme.border-subtle;

                            Text {
                                text: "AI";
                                color: root.show-ai-panel ? Theme.bg-deep : Theme.amber;
                                font-size: 12px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Save button
                    if !root.is-readonly : save-btn-ta := TouchArea {
                        width: 72px;
                        height: 32px;
                        clicked => { root.save-file(); }

                        Rectangle {
                            width: 72px;
                            height: 32px;
                            border-radius: 8px;
                            background: root.is-modified
                                ? Theme.cyan
                                : (save-btn-ta.has-hover ? Theme.hover-fill-strong : Theme.hover-fill);
                            border-width: root.is-modified ? 0px : 1px;
                            border-color: Theme.border-subtle;

                            Text {
                                text: "Save";
                                color: root.is-modified ? Theme.bg-deep : Theme.text-secondary;
                                font-size: 13px;
                                font-weight: root.is-modified ? 600 : 400;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }

        Rectangle { height: 1px; background: Theme.separator; }

        // ── Find & Replace bar ──
        if root.show-find-bar : Rectangle {
            height: find-bar-layout.preferred-height;
            background: @linear-gradient(135deg, #12111ae0 0%, #0c0b10c0 100%);
            border-width: 1px;
            border-color: Theme.cyan-dim;

            find-bar-layout := VerticalLayout {
                padding: 8px;
                padding-left: 12px;
                padding-right: 12px;
                spacing: 6px;

                // Row 1: Search input + match count + prev/next + close
                HorizontalLayout {
                    spacing: 6px;

                    // Search icon
                    Text {
                        text: "\u{26B2}";
                        color: Theme.cyan;
                        font-size: 14px;
                        vertical-alignment: center;
                        width: 18px;
                    }

                    // Search input
                    Rectangle {
                        horizontal-stretch: 1;
                        height: 30px;
                        border-radius: 8px;
                        background: #0a091080;
                        border-width: 1px;
                        border-color: root.find-query != "" && root.find-match-count > 0
                            ? Theme.cyan-dim
                            : (root.find-query != "" ? Theme.color-emotional : Theme.border-subtle);

                        find-input := TextInput {
                            x: 10px;
                            y: (parent.height - self.preferred-height) / 2;
                            width: parent.width - 20px;
                            color: Theme.text-primary;
                            font-size: 13px;
                            text <=> root.find-query;
                            input-type: text;
                            single-line: true;
                            accepted => { root.find-next(); }
                            edited => { root.find-query-changed(self.text); }
                        }
                    }

                    // Match count badge
                    if root.find-query != "" : Rectangle {
                        width: match-count-text.preferred-width + 16px;
                        height: 24px;
                        border-radius: 12px;
                        background: root.find-match-count > 0 ? Theme.tint-cyan : #ff444430;

                        match-count-text := Text {
                            text: root.find-match-count > 0
                                ? "\{root.find-current-match} of \{root.find-match-count}"
                                : "0";
                            color: root.find-match-count > 0 ? Theme.cyan : Theme.color-emotional;
                            font-size: 11px;
                            font-weight: 500;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    // Prev match
                    find-prev-ta := TouchArea {
                        width: 28px;
                        height: 28px;
                        clicked => { root.find-prev(); }

                        Rectangle {
                            width: 28px;
                            height: 28px;
                            border-radius: 6px;
                            background: find-prev-ta.has-hover ? Theme.hover-fill-strong : transparent;

                            Text {
                                text: "\u{25B2}";
                                color: Theme.text-secondary;
                                font-size: 10px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Next match
                    find-next-ta := TouchArea {
                        width: 28px;
                        height: 28px;
                        clicked => { root.find-next(); }

                        Rectangle {
                            width: 28px;
                            height: 28px;
                            border-radius: 6px;
                            background: find-next-ta.has-hover ? Theme.hover-fill-strong : transparent;

                            Text {
                                text: "\u{25BC}";
                                color: Theme.text-secondary;
                                font-size: 10px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Toggle replace row
                    find-expand-ta := TouchArea {
                        width: 28px;
                        height: 28px;
                        clicked => { root.show-replace-row = !root.show-replace-row; }

                        Rectangle {
                            width: 28px;
                            height: 28px;
                            border-radius: 6px;
                            background: find-expand-ta.has-hover ? Theme.hover-fill-strong
                                : (root.show-replace-row ? Theme.hover-fill : transparent);

                            Text {
                                text: root.show-replace-row ? "\u{25BD}" : "\u{25B7}";
                                color: root.show-replace-row ? Theme.cyan : Theme.text-dim;
                                font-size: 10px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Close find bar
                    find-close-ta := TouchArea {
                        width: 24px;
                        height: 24px;
                        clicked => {
                            root.show-find-bar = false;
                            root.find-query = "";
                            root.replace-text = "";
                            root.show-replace-row = false;
                            root.find-query-changed("");
                        }

                        Rectangle {
                            width: 24px;
                            height: 24px;
                            border-radius: 6px;
                            background: find-close-ta.has-hover ? Theme.hover-fill-strong : transparent;

                            Text {
                                text: "\u{00D7}";
                                color: Theme.text-dim;
                                font-size: 16px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                // Row 2: Replace input + Replace + Replace All (expandable)
                if root.show-replace-row && !root.is-readonly : HorizontalLayout {
                    spacing: 6px;

                    // Spacer to align with search input (icon width + spacing)
                    Rectangle { width: 18px; }

                    // Replace input
                    Rectangle {
                        horizontal-stretch: 1;
                        height: 30px;
                        border-radius: 8px;
                        background: #0a091080;
                        border-width: 1px;
                        border-color: Theme.border-subtle;

                        replace-input := TextInput {
                            x: 10px;
                            y: (parent.height - self.preferred-height) / 2;
                            width: parent.width - 20px;
                            color: Theme.text-primary;
                            font-size: 13px;
                            text <=> root.replace-text;
                            input-type: text;
                            single-line: true;
                            accepted => { root.replace-current(); }
                        }
                    }

                    // Replace button
                    replace-btn-ta := TouchArea {
                        width: 68px;
                        height: 28px;
                        clicked => { root.replace-current(); }

                        Rectangle {
                            width: 68px;
                            height: 28px;
                            border-radius: 8px;
                            background: replace-btn-ta.has-hover ? Theme.cyan : Theme.hover-fill-strong;
                            border-width: replace-btn-ta.has-hover ? 0px : 1px;
                            border-color: Theme.cyan-dim;

                            Text {
                                text: "Replace";
                                color: replace-btn-ta.has-hover ? Theme.bg-deep : Theme.cyan;
                                font-size: 11px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Replace All button
                    replace-all-ta := TouchArea {
                        width: 80px;
                        height: 28px;
                        clicked => { root.replace-all(); }

                        Rectangle {
                            width: 80px;
                            height: 28px;
                            border-radius: 8px;
                            background: replace-all-ta.has-hover ? Theme.cyan : Theme.hover-fill-strong;
                            border-width: replace-all-ta.has-hover ? 0px : 1px;
                            border-color: Theme.cyan-dim;

                            Text {
                                text: "Replace All";
                                color: replace-all-ta.has-hover ? Theme.bg-deep : Theme.cyan;
                                font-size: 11px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }

        if root.show-find-bar : Rectangle { height: 1px; background: Theme.separator; }

        // ── AI assist panel ──
        if root.show-ai-panel : Rectangle {
            max-height: 250px;
            background: @linear-gradient(135deg, #12111ae0 0%, #0c0b10c0 100%);
            border-width: 1px;
            border-color: Theme.amber-dim;

            ai-panel-layout := VerticalLayout {
                padding: 12px;
                spacing: 8px;

                // Header: label + quick actions + close
                HorizontalLayout {
                    spacing: 6px;

                    Text {
                        text: "\u{25C9} AI Assist";
                        color: Theme.amber;
                        font-size: 12px;
                        font-weight: 600;
                        vertical-alignment: center;
                    }

                    Rectangle { horizontal-stretch: 1; }

                    // Quick action: Summarize
                    sum-ta := TouchArea {
                        width: 76px;
                        height: 24px;
                        clicked => { root.ai-request("summarize"); }

                        Rectangle {
                            width: 76px;
                            height: 24px;
                            border-radius: 12px;
                            background: sum-ta.has-hover ? Theme.hover-fill-strong : Theme.hover-fill;
                            border-width: 1px;
                            border-color: Theme.border-subtle;

                            Text {
                                text: "Summarize";
                                color: Theme.text-secondary;
                                font-size: 11px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Quick action: Improve
                    imp-ta := TouchArea {
                        width: 66px;
                        height: 24px;
                        clicked => { root.ai-request("improve"); }

                        Rectangle {
                            width: 66px;
                            height: 24px;
                            border-radius: 12px;
                            background: imp-ta.has-hover ? Theme.hover-fill-strong : Theme.hover-fill;
                            border-width: 1px;
                            border-color: Theme.border-subtle;

                            Text {
                                text: "Improve";
                                color: Theme.text-secondary;
                                font-size: 11px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Close
                    ai-close-ta := TouchArea {
                        width: 24px;
                        height: 24px;
                        clicked => { root.ai-dismiss(); }
                        Rectangle {
                            width: 24px;
                            height: 24px;
                            border-radius: 6px;
                            background: ai-close-ta.has-hover ? Theme.hover-fill-strong : transparent;
                            Text {
                                text: "\u{00D7}";
                                color: Theme.text-dim;
                                font-size: 16px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                // Prompt input row
                HorizontalLayout {
                    spacing: 6px;

                    Rectangle {
                        horizontal-stretch: 1;
                        height: 32px;
                        border-radius: 8px;
                        background: #0a091080;
                        border-width: 1px;
                        border-color: Theme.border-subtle;

                        ai-input := TextInput {
                            x: 12px;
                            y: (parent.height - self.preferred-height) / 2;
                            width: parent.width - 24px;
                            color: Theme.text-primary;
                            font-size: 13px;
                            text <=> root.ai-prompt;
                            input-type: text;
                            accepted => {
                                if root.ai-prompt != "" {
                                    root.ai-request(root.ai-prompt);
                                }
                            }
                        }
                    }

                    // Send button
                    send-ta := TouchArea {
                        width: 56px;
                        height: 32px;
                        clicked => {
                            if root.ai-prompt != "" {
                                root.ai-request(root.ai-prompt);
                            }
                        }

                        Rectangle {
                            width: 56px;
                            height: 32px;
                            border-radius: 8px;
                            background: root.ai-is-working
                                ? Theme.hover-fill
                                : (send-ta.has-hover ? Theme.amber : Theme.hover-fill-strong);
                            border-width: send-ta.has-hover ? 0px : 1px;
                            border-color: Theme.amber-dim;

                            Text {
                                text: root.ai-is-working ? "..." : "Ask";
                                color: send-ta.has-hover && !root.ai-is-working ? Theme.bg-deep : Theme.amber;
                                font-size: 12px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                // AI response area (scrollable)
                if root.ai-response != "" : Rectangle {
                    min-height: 40px;
                    max-height: 140px;
                    border-radius: 8px;
                    background: #0a091060;

                    Flickable {
                        width: parent.width;
                        height: parent.height;
                        viewport-height: ai-resp-text.preferred-height + 16px;

                        ai-resp-text := Text {
                            x: 12px;
                            y: 8px;
                            width: parent.width - 24px;
                            text: root.ai-response;
                            color: Theme.text-secondary;
                            font-size: 13px;
                            wrap: word-wrap;
                        }
                    }
                }

                // Insert button (when response is available and not working)
                if root.ai-response != "" && !root.ai-is-working : HorizontalLayout {
                    alignment: end;
                    spacing: 6px;

                    ins-ta := TouchArea {
                        width: 110px;
                        height: 28px;
                        clicked => { root.ai-insert(); }

                        Rectangle {
                            width: 110px;
                            height: 28px;
                            border-radius: 8px;
                            background: ins-ta.has-hover ? Theme.cyan : Theme.hover-fill-strong;
                            border-width: ins-ta.has-hover ? 0px : 1px;
                            border-color: Theme.cyan-dim;

                            Text {
                                text: "Insert into doc";
                                color: ins-ta.has-hover ? Theme.bg-deep : Theme.cyan;
                                font-size: 11px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }

        if root.show-ai-panel : Rectangle { height: 1px; background: Theme.separator; }

        // ── Save As dialog ──
        if root.show-save-dialog : Rectangle {
            height: save-dialog-layout.preferred-height;
            background: @linear-gradient(135deg, #12111ae0 0%, #0c0b10c0 100%);
            border-width: 1px;
            border-color: Theme.cyan-dim;

            save-dialog-layout := VerticalLayout {
                padding: 16px;
                spacing: 12px;

                HorizontalLayout {
                    spacing: 8px;
                    Text {
                        text: "Save As";
                        color: Theme.cyan;
                        font-size: 14px;
                        font-weight: 600;
                        horizontal-stretch: 1;
                        vertical-alignment: center;
                    }
                    close-ta := TouchArea {
                        width: 24px;
                        height: 24px;
                        clicked => { root.show-save-dialog = false; }
                        Rectangle {
                            width: 24px;
                            height: 24px;
                            border-radius: 6px;
                            background: close-ta.has-hover ? Theme.hover-fill-strong : transparent;
                            Text {
                                text: "\u{00D7}";
                                color: Theme.text-dim;
                                font-size: 16px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                VerticalLayout {
                    spacing: 4px;
                    Text { text: "Directory"; color: Theme.text-dim; font-size: 11px; }
                    Rectangle {
                        height: 34px;
                        border-radius: 8px;
                        background: #0a091080;
                        border-width: 1px;
                        border-color: Theme.border-subtle;
                        dir-input := TextInput {
                            x: 12px;
                            y: (parent.height - self.preferred-height) / 2;
                            width: parent.width - 24px;
                            color: Theme.text-primary;
                            font-size: 13px;
                            text <=> root.save-dir;
                            accepted => { root.save-file-as(root.save-dir, root.save-filename); }
                        }
                    }
                }

                VerticalLayout {
                    spacing: 4px;
                    Text { text: "Filename"; color: Theme.text-dim; font-size: 11px; }
                    Rectangle {
                        height: 34px;
                        border-radius: 8px;
                        background: #0a091080;
                        border-width: 1px;
                        border-color: Theme.border-subtle;
                        name-input := TextInput {
                            x: 12px;
                            y: (parent.height - self.preferred-height) / 2;
                            width: parent.width - 24px;
                            color: Theme.text-primary;
                            font-size: 13px;
                            text <=> root.save-filename;
                            accepted => { root.save-file-as(root.save-dir, root.save-filename); }
                        }
                    }
                }

                if root.save-error != "" : Text {
                    text: root.save-error;
                    color: Theme.color-emotional;
                    font-size: 12px;
                }

                HorizontalLayout {
                    spacing: 8px;
                    alignment: end;
                    cancel-ta := TouchArea {
                        width: 72px; height: 32px;
                        clicked => { root.show-save-dialog = false; }
                        Rectangle {
                            width: 72px; height: 32px; border-radius: 8px;
                            background: cancel-ta.has-hover ? Theme.hover-fill-strong : Theme.hover-fill;
                            border-width: 1px; border-color: Theme.border-subtle;
                            Text { text: "Cancel"; color: Theme.text-secondary; font-size: 13px; horizontal-alignment: center; vertical-alignment: center; }
                        }
                    }
                    confirm-ta := TouchArea {
                        width: 72px; height: 32px;
                        clicked => { root.save-file-as(root.save-dir, root.save-filename); }
                        Rectangle {
                            width: 72px; height: 32px; border-radius: 8px;
                            background: Theme.cyan;
                            Text { text: "Save"; color: Theme.bg-deep; font-size: 13px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
                        }
                    }
                }
            }
        }

        if root.show-save-dialog : Rectangle { height: 1px; background: Theme.separator; }

        // ── Editor area ──
        Rectangle {
            background: Theme.bg-deep;
            vertical-stretch: 1;

            Flickable {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: parent.height;
                viewport-height: editor-input.preferred-height + 32px;

                editor-input := TextInput {
                    x: 16px;
                    y: 12px;
                    width: parent.width - 32px;
                    color: Theme.text-primary;
                    font-size: 14px;
                    text <=> root.file-content;
                    read-only: root.is-readonly;
                    single-line: false;
                    wrap: word-wrap;
                    selection-foreground-color: Theme.bg-deep;
                    selection-background-color: Theme.cyan;
                    edited => { root.content-changed(self.text); }
                }
            }
        }
    }
}
