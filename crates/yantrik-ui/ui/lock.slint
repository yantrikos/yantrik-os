// Lock Screen — atmospheric lock with premium typography, clock, date, password.
// Shown on idle timeout or manual lock (Super+L). Validates password to unlock.

import { Theme } from "theme.slint";

export component LockScreen inherits Rectangle {
    background: Theme.bg-deep;

    in property <string> clock-text: "00:00";
    in property <string> date-text: "";
    in property <string> greeting-text: "";
    in property <string> error-text: "";

    // Internal state
    property <bool> show-password: false;
    property <float> bg-phase: 0;

    callback try-unlock(string);

    // Animated background phase
    Timer {
        interval: 16ms;
        running: true;
        triggered => {
            bg-phase = mod(bg-phase + 0.0006, 1.0);
        }
    }

    // ── Animated gradient background ──
    Rectangle {
        width: 100%;
        height: 100%;
        background: Theme.bg-deep;

        // Top gradient
        Rectangle {
            width: 100%;
            height: 45%;
            y: 0;
            background: @linear-gradient(180deg, Theme.bg-deep 0%, Theme.bg-deep.transparentize(100%) 100%);
        }

        // Bottom gradient
        Rectangle {
            width: 100%;
            height: 45%;
            y: parent.height - self.height;
            background: @linear-gradient(0deg, Theme.bg-deep 0%, Theme.bg-deep.transparentize(100%) 100%);
        }

        // Animated amber glow (breathing)
        Rectangle {
            width: 500px;
            height: 500px;
            x: (parent.width - self.width) / 2;
            y: parent.height * 0.08;
            border-radius: 250px;
            background: @radial-gradient(circle, Theme.amber.transparentize(94%) 0%, Theme.amber.transparentize(100%) 70%);
            opacity: 0.7 + 0.3 * sin(bg-phase * 6.2832 * 1rad);
        }

        // Animated cyan glow
        Rectangle {
            width: 350px;
            height: 350px;
            x: (parent.width - self.width) / 2 + 80px;
            y: parent.height * 0.60;
            border-radius: 175px;
            background: @radial-gradient(circle, Theme.cyan.transparentize(95%) 0%, Theme.cyan.transparentize(100%) 70%);
            opacity: 0.6 + 0.3 * sin(bg-phase * 4.712 * 1rad);
        }
    }

    // ── Center content ──
    VerticalLayout {
        alignment: center;
        spacing: 0;
        padding-left: 40px;
        padding-right: 40px;

        // Push content slightly above center
        Rectangle { height: 20px; }

        // Clock — large, thin, elegant
        Text {
            text: root.clock-text;
            color: Theme.text-primary;
            font-size: 96px;
            font-weight: 200;
            horizontal-alignment: center;
            letter-spacing: 6px;
        }

        // Date — refined typography
        if root.date-text != "" : Text {
            text: root.date-text;
            color: Theme.text-secondary;
            font-size: Theme.fs-title-2;
            font-weight: Theme.fw-body;
            horizontal-alignment: center;
            letter-spacing: 1px;
        }

        Rectangle { height: Theme.sp-6; }

        // Orb (breathing glow)
        HorizontalLayout {
            alignment: center;
            Rectangle {
                width: 64px;
                height: 64px;

                Rectangle {
                    width: 48px;
                    height: 48px;
                    border-radius: 24px;
                    background: Theme.amber-glow;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    opacity: 0.8 + 0.2 * sin(bg-phase * 6.2832 * 1rad);

                    Rectangle {
                        width: 24px;
                        height: 24px;
                        border-radius: 12px;
                        background: Theme.amber-dim;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                    }
                }
            }
        }

        Rectangle { height: Theme.sp-2; }

        // Greeting from companion
        if root.greeting-text != "" : Text {
            text: root.greeting-text;
            color: Theme.text-secondary;
            font-size: Theme.fs-body;
            font-weight: Theme.fw-body;
            horizontal-alignment: center;
            font-italic: true;
            opacity: 0.8;
        }

        Rectangle { height: Theme.sp-6; }

        // "Enter password" label
        Text {
            text: "Enter password to unlock";
            color: Theme.text-dim;
            font-size: Theme.fs-caption;
            horizontal-alignment: center;
            letter-spacing: 0.5px;
        }

        Rectangle { height: Theme.sp-2; }

        // Password input — glass pill
        HorizontalLayout {
            alignment: center;

            Rectangle {
                width: 320px;
                height: 48px;
                border-radius: Theme.r-xl;
                background: Theme.bg-input;
                border-width: 1px;
                border-color: root.error-text != "" ? Theme.color-danger
                            : pin-input.has-focus ? Theme.accent-dim
                            : Theme.text-dim;
                clip: true;

                animate border-color { duration: Theme.dur-normal; easing: ease-out; }

                // Focus glow
                drop-shadow-blur: pin-input.has-focus ? 12px : 0;
                drop-shadow-color: root.error-text != "" ? Theme.color-danger-dim : Theme.accent-glow;
                animate drop-shadow-blur { duration: Theme.dur-normal; }

                pin-input := TextInput {
                    x: Theme.sp-4;
                    y: 0;
                    width: parent.width - 60px;
                    height: parent.height;
                    color: Theme.text-primary;
                    font-size: Theme.fs-title-2;
                    horizontal-alignment: left;
                    input-type: root.show-password ? InputType.text : InputType.password;

                    accepted => {
                        root.try-unlock(self.text);
                        self.text = "";
                    }
                }

                // Show/hide toggle
                Rectangle {
                    x: parent.width - 44px;
                    y: (parent.height - self.height) / 2;
                    width: 36px;
                    height: 36px;
                    border-radius: 18px;
                    background: toggle-touch.has-hover ? Theme.hover-fill : transparent;
                    animate background { duration: Theme.dur-fast; }

                    Text {
                        text: root.show-password ? "◉" : "○";
                        color: Theme.text-dim;
                        font-size: Theme.fs-headline;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        width: 100%;
                        height: 100%;
                    }

                    toggle-touch := TouchArea {
                        clicked => { root.show-password = !root.show-password; }
                    }
                }
            }
        }

        // Error text
        if root.error-text != "" : Text {
            text: root.error-text;
            color: Theme.color-danger;
            font-size: Theme.fs-caption;
            horizontal-alignment: center;
            animate opacity { duration: Theme.dur-normal; easing: ease-out; }
        }

        Rectangle { height: Theme.sp-2; }

        // Hint
        Text {
            text: "Press Enter to unlock";
            color: Theme.text-dim;
            font-size: Theme.fs-caption;
            horizontal-alignment: center;
            opacity: 0.5;
        }

        Rectangle { height: 40px; }
    }

    // Focus the PIN input when shown
    FocusScope {
        key-pressed(event) => {
            pin-input.focus();
            accept
        }
    }
}
