// Lock Screen — Enhanced atmospheric lock with clock, date, greeting, password toggle.
// Shown on idle timeout or manual lock. Validates PIN to unlock.

import { Theme } from "theme.slint";

export component LockScreen inherits Rectangle {
    background: Theme.bg-deep;

    in property <string> clock-text: "00:00";
    in property <string> date-text: "";
    in property <string> greeting-text: "";
    in property <string> error-text: "";

    // Internal state
    property <bool> show-password: false;

    callback try-unlock(string);

    // ── Animated gradient background ──
    // Dark atmospheric layers with subtle color
    Rectangle {
        width: 100%;
        height: 100%;
        background: Theme.bg-deep;

        // Top gradient overlay (dark to transparent)
        Rectangle {
            width: 100%;
            height: 40%;
            y: 0;
            background: @linear-gradient(180deg, #08060e 0%, #08060e00 100%);
        }

        // Bottom gradient overlay (transparent to dark)
        Rectangle {
            width: 100%;
            height: 40%;
            y: parent.height - self.height;
            background: @linear-gradient(0deg, #0a0810 0%, #0a081000 100%);
        }

        // Subtle amber accent glow (top-center, atmospheric)
        Rectangle {
            width: 400px;
            height: 400px;
            x: (parent.width - self.width) / 2;
            y: parent.height * 0.10;
            border-radius: 200px;
            background: @radial-gradient(circle, #d4a57410 0%, #d4a57400 70%);
        }

        // Subtle cyan accent glow (bottom, atmospheric)
        Rectangle {
            width: 300px;
            height: 300px;
            x: (parent.width - self.width) / 2 + 100px;
            y: parent.height * 0.65;
            border-radius: 150px;
            background: @radial-gradient(circle, #56ccf208 0%, #56ccf200 70%);
        }
    }

    // ── Center content ──
    VerticalLayout {
        alignment: center;
        spacing: 8px;
        padding-left: 40px;
        padding-right: 40px;

        // Spacer to push content slightly above center
        Rectangle { height: 20px; }

        // Clock (large, prominent)
        Text {
            text: root.clock-text;
            color: Theme.text-primary;
            font-size: 96px;
            font-weight: 200;
            horizontal-alignment: center;
            letter-spacing: 4px;
        }

        // Date
        if root.date-text != "" : Text {
            text: root.date-text;
            color: Theme.text-secondary;
            font-size: 18px;
            font-weight: 400;
            horizontal-alignment: center;
        }

        // Spacer
        Rectangle { height: 12px; }

        // Orb (dimmed, smaller)
        HorizontalLayout {
            alignment: center;
            Rectangle {
                width: 72px;
                height: 72px;

                Rectangle {
                    width: 56px;
                    height: 56px;
                    border-radius: 28px;
                    background: Theme.amber-glow;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;

                    // Inner glow
                    Rectangle {
                        width: 28px;
                        height: 28px;
                        border-radius: 14px;
                        background: Theme.amber-dim;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                    }
                }
            }
        }

        // Spacer
        Rectangle { height: 4px; }

        // Greeting from companion
        if root.greeting-text != "" : Text {
            text: root.greeting-text;
            color: Theme.text-secondary;
            font-size: Theme.font-body;
            font-weight: 400;
            horizontal-alignment: center;
            font-italic: true;
        }

        // Spacer
        Rectangle { height: 16px; }

        // "Enter password" label
        Text {
            text: "Enter password to unlock";
            color: Theme.text-dim;
            font-size: Theme.font-small;
            horizontal-alignment: center;
        }

        // Spacer
        Rectangle { height: 4px; }

        // Password input container with show/hide toggle
        HorizontalLayout {
            alignment: center;

            Rectangle {
                width: 300px;
                height: 48px;
                border-radius: Theme.radius-card;
                background: Theme.bg-input;
                border-width: 1px;
                border-color: root.error-text != "" ? Theme.color-emotional : Theme.text-dim;

                animate border-color { duration: 300ms; easing: ease-out; }

                // Password text input
                pin-input := TextInput {
                    x: 16px;
                    y: 0;
                    width: parent.width - 60px;
                    height: parent.height;
                    color: Theme.text-primary;
                    font-size: 18px;
                    horizontal-alignment: left;
                    input-type: root.show-password ? InputType.text : InputType.password;

                    accepted => {
                        root.try-unlock(self.text);
                        self.text = "";
                    }
                }

                // Show/hide toggle button
                Rectangle {
                    x: parent.width - 44px;
                    y: (parent.height - self.height) / 2;
                    width: 36px;
                    height: 36px;
                    border-radius: 18px;
                    background: toggle-touch.has-hover ? Theme.hover-fill : transparent;

                    animate background { duration: 150ms; }

                    Text {
                        text: root.show-password ? "\u{25C9}" : "\u{25CE}";
                        color: Theme.text-dim;
                        font-size: 16px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        width: 100%;
                        height: 100%;
                    }

                    toggle-touch := TouchArea {
                        clicked => {
                            root.show-password = !root.show-password;
                        }
                    }
                }
            }
        }

        // Error text
        if root.error-text != "" : Text {
            text: root.error-text;
            color: Theme.color-emotional;
            font-size: Theme.font-small;
            horizontal-alignment: center;

            animate opacity { duration: 300ms; easing: ease-out; }
        }

        // Hint
        Text {
            text: "Press Enter to unlock";
            color: Theme.text-dim;
            font-size: 11px;
            horizontal-alignment: center;
        }

        // Bottom spacer
        Rectangle { height: 40px; }
    }

    // Focus the PIN input when shown
    FocusScope {
        key-pressed(event) => {
            pin-input.focus();
            accept
        }
    }
}
