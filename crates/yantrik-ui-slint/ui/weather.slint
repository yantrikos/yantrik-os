// Weather Dashboard — screen 19.
// Current conditions, hourly forecast, 5-day forecast, weather details.
// Saved locations, unit toggle, severe weather alerts, last updated, AQI.

import { Theme } from "theme.slint";
import { YButton, YIconButton } from "components/y_button.slint";
import { YInput } from "components/y_input.slint";
import { YEmptyState } from "components/y_empty_state.slint";

// ── Data structs ──

export struct WeatherCurrent {
    temperature: string,
    feels-like: string,
    condition: string,
    icon: string,
    location: string,
    humidity: string,
    wind-speed: string,
    wind-direction: string,
    uv-index: string,
    visibility: string,
    pressure: string,
    cloud-cover: string,
    dew-point: string,
    sunrise: string,
    sunset: string,
    is-loading: bool,
    error-text: string,
}

export struct WeatherHourly {
    time: string,
    icon: string,
    temp: string,
    is-current: bool,
}

export struct WeatherDaily {
    day-name: string,
    icon: string,
    high: string,
    low: string,
    precip-chance: string,
    high-value: float,
    low-value: float,
    temp-range-min: float,
    temp-range-max: float,
}

export struct WeatherSavedLocation {
    name: string,
    lat: float,
    lon: float,
    is-active: bool,
}

export struct WeatherAlert {
    title: string,
    description: string,
    severity: int,   // 0=info, 1=moderate, 2=severe
    icon: string,
}

export component WeatherDashboard inherits Rectangle {
    background: Theme.bg-deep;

    in property <WeatherCurrent> current: {
        temperature: "--",
        feels-like: "--",
        condition: "Loading...",
        icon: "...",
        location: "...",
        humidity: "--",
        wind-speed: "--",
        wind-direction: "--",
        uv-index: "--",
        visibility: "--",
        pressure: "--",
        cloud-cover: "--",
        dew-point: "--",
        sunrise: "--",
        sunset: "--",
        is-loading: true,
        error-text: "",
    };
    in property <[WeatherHourly]> hourly: [];
    in property <[WeatherDaily]> daily: [];

    callback back-pressed();
    callback refresh-pressed();

    // AI Assist
    in property <bool> ai-is-working: false;
    in property <string> ai-response: "";
    in-out property <bool> ai-panel-open: false;
    callback ai-explain-pressed();
    callback ai-dismiss();

    // Saved locations
    in property <[WeatherSavedLocation]> weather-saved-locations: [];
    in-out property <bool> weather-location-panel-open: false;
    in-out property <string> weather-add-location-text: "";
    callback weather-select-location(int);
    callback weather-add-location(string);
    callback weather-remove-location(int);

    // Units toggle (false = Celsius, true = Fahrenheit)
    in-out property <bool> weather-use-fahrenheit: false;
    callback weather-toggle-units();

    // Severe weather alerts
    in property <[WeatherAlert]> weather-alerts: [];

    // Severe weather alert banner
    in property <bool> weather-severe-alert-active: false;
    in property <string> weather-severe-alert-text: "";
    in property <string> weather-severe-alert-level: "";  // "watch", "warning", "emergency"

    // Last updated
    in property <string> weather-last-updated: "";

    // AQI (Air Quality Index)
    in property <string> weather-aqi-value: "--";
    in property <string> weather-aqi-label: "N/A";
    in property <int> weather-aqi-level: 0;  // 0=good, 1=moderate, 2=unhealthy

    VerticalLayout {
        width: 100%;
        height: 100%;

        // ── Header bar ──
        Rectangle {
            height: Theme.sp-9;
            background: Theme.bg-surface;

            // Bottom divider
            Rectangle {
                y: parent.height - 1px;
                width: 100%;
                height: 1px;
                background: Theme.separator;
            }

            HorizontalLayout {
                padding-left: Theme.sp-3;
                padding-right: Theme.sp-4;
                spacing: Theme.sp-3;

                // Back button
                YIconButton {
                    icon: "\u{2190}";
                    variant: 2;
                    clicked => { root.back-pressed(); }
                }

                // Title
                Text {
                    text: "Weather";
                    color: Theme.text-primary;
                    font-size: Theme.fs-title-2;
                    font-weight: Theme.fw-title-2;
                    vertical-alignment: center;
                }

                // Location selector button
                TouchArea {
                    width: loc-btn-row.preferred-width + 16px;
                    height: 32px;
                    clicked => {
                        root.weather-location-panel-open = !root.weather-location-panel-open;
                    }
                    Rectangle {
                        height: 32px;
                        border-radius: Theme.r-pill;
                        background: root.weather-location-panel-open ? Theme.tint-accent : (parent.has-hover ? Theme.hover-fill-strong : Theme.bg-card);
                        border-width: 1px;
                        border-color: root.weather-location-panel-open ? Theme.accent-dim : Theme.border-subtle;
                        loc-btn-row := HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: 4px;
                            alignment: center;
                            Text {
                                text: "\u{1F4CD}";
                                font-size: 12px;
                                vertical-alignment: center;
                            }
                            Text {
                                text: root.current.location;
                                color: Theme.text-secondary;
                                font-size: 12px;
                                font-weight: 500;
                                vertical-alignment: center;
                            }
                            Text {
                                text: "\u{25BC}";
                                font-size: 8px;
                                color: Theme.text-dim;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                // Last updated timestamp
                if root.weather-last-updated != "" : Text {
                    text: root.weather-last-updated;
                    color: Theme.text-dim;
                    font-size: 10px;
                    vertical-alignment: center;
                }

                Rectangle { horizontal-stretch: 1; }

                // Units toggle (°C / °F)
                TouchArea {
                    width: 52px;
                    height: 28px;
                    clicked => {
                        root.weather-use-fahrenheit = !root.weather-use-fahrenheit;
                        root.weather-toggle-units();
                    }
                    Rectangle {
                        width: 52px;
                        height: 28px;
                        border-radius: 14px;
                        background: Theme.bg-card;
                        border-width: 1px;
                        border-color: Theme.border-subtle;

                        // Sliding indicator
                        Rectangle {
                            width: 24px;
                            height: 24px;
                            x: root.weather-use-fahrenheit ? 26px : 2px;
                            y: 2px;
                            border-radius: 12px;
                            background: Theme.accent;
                            animate x { duration: 150ms; easing: ease-out; }
                        }

                        // °C label
                        Text {
                            text: "\u{00B0}C";
                            x: 6px;
                            color: root.weather-use-fahrenheit ? Theme.text-dim : Theme.text-on-accent;
                            font-size: 10px;
                            font-weight: 600;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                            width: 20px;
                        }

                        // °F label
                        Text {
                            text: "\u{00B0}F";
                            x: 28px;
                            color: root.weather-use-fahrenheit ? Theme.text-on-accent : Theme.text-dim;
                            font-size: 10px;
                            font-weight: 600;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                            width: 20px;
                        }
                    }
                }

                // AI Insights button
                TouchArea {
                    width: ai-wx-btn.preferred-width + 16px;
                    height: 32px;
                    clicked => {
                        if root.ai-panel-open {
                            root.ai-dismiss();
                            root.ai-panel-open = false;
                        } else {
                            root.ai-explain-pressed();
                            root.ai-panel-open = true;
                        }
                    }
                    ai-wx-btn := Rectangle {
                        height: 32px;
                        border-radius: Theme.r-pill;
                        background: root.ai-is-working ? Theme.accent
                            : (parent.has-hover ? Theme.hover-fill-strong : Theme.bg-card);
                        border-width: 1px;
                        border-color: Theme.border-subtle;
                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: 4px;
                            alignment: center;
                            Text {
                                text: root.ai-is-working ? "\u{2B50}" : "\u{2728}";
                                font-size: 12px;
                                vertical-alignment: center;
                            }
                            Text {
                                text: root.ai-is-working ? "Analyzing..." : "AI Insights";
                                color: root.ai-is-working ? Theme.text-on-accent : Theme.text-secondary;
                                font-size: 11px;
                                font-weight: 500;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                // Refresh button
                Rectangle {
                    width: 36px;
                    height: 36px;
                    y: (parent.height - 36px) / 2;
                    border-radius: 18px;
                    background: ta-refresh.has-hover ? Theme.hover-fill-strong : transparent;

                    ta-refresh := TouchArea {
                        clicked => { root.refresh-pressed(); }
                    }

                    Text {
                        text: "\u{21BB}";
                        color: Theme.accent;
                        font-size: 18px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // ── Location Selector Panel ──
        if root.weather-location-panel-open : Rectangle {
            max-height: 240px;
            background: Theme.bg-surface;
            border-width: 1px;
            border-color: Theme.border-subtle;

            Flickable {
                viewport-height: loc-panel-col.preferred-height;

                loc-panel-col := VerticalLayout {
                    padding: 12px;
                    spacing: 6px;

                    // Add location row
                    HorizontalLayout {
                        spacing: 8px;
                        height: 36px;

                        Rectangle {
                            horizontal-stretch: 1;
                            height: 36px;
                            border-radius: 8px;
                            background: Theme.bg-card;
                            border-width: 1px;
                            border-color: Theme.border-subtle;
                            clip: true;

                            loc-input := TextInput {
                                text <=> root.weather-add-location-text;
                                font-size: 12px;
                                color: Theme.text-primary;
                                width: parent.width - 16px;
                                x: 8px;
                                vertical-alignment: center;
                                accepted => {
                                    if root.weather-add-location-text != "" {
                                        root.weather-add-location(root.weather-add-location-text);
                                        root.weather-add-location-text = "";
                                    }
                                }
                            }

                            // Placeholder
                            if root.weather-add-location-text == "" : Text {
                                text: "Add city...";
                                color: Theme.text-dim;
                                font-size: 12px;
                                x: 8px;
                                vertical-alignment: center;
                            }
                        }

                        TouchArea {
                            width: 36px;
                            height: 36px;
                            clicked => {
                                if root.weather-add-location-text != "" {
                                    root.weather-add-location(root.weather-add-location-text);
                                    root.weather-add-location-text = "";
                                }
                            }
                            add-loc-btn := Rectangle {
                                width: 36px;
                                height: 36px;
                                border-radius: 8px;
                                background: parent.has-hover ? Theme.accent : Theme.bg-card;
                                border-width: 1px;
                                border-color: Theme.border-subtle;
                                Text {
                                    text: "+";
                                    color: add-loc-btn.background == Theme.accent ? Theme.text-on-accent : Theme.accent;
                                    font-size: 16px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    // Saved locations list
                    for loc[idx] in root.weather-saved-locations : Rectangle {
                        height: 40px;
                        border-radius: 8px;
                        background: loc.is-active ? Theme.tint-accent : (ta-loc.has-hover ? Theme.hover-fill : transparent);
                        border-width: loc.is-active ? 1px : 0px;
                        border-color: loc.is-active ? Theme.accent-dim : transparent;

                        ta-loc := TouchArea {
                            clicked => {
                                root.weather-select-location(idx);
                                root.weather-location-panel-open = false;
                            }
                        }

                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 8px;
                            spacing: 8px;

                            Text {
                                text: "\u{1F4CD}";
                                font-size: 14px;
                                vertical-alignment: center;
                            }
                            Text {
                                text: loc.name;
                                color: loc.is-active ? Theme.accent : Theme.text-primary;
                                font-size: 13px;
                                font-weight: loc.is-active ? 600 : 400;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }

                            if loc.is-active : Text {
                                text: "\u{2713}";
                                color: Theme.accent;
                                font-size: 14px;
                                font-weight: 700;
                                vertical-alignment: center;
                            }

                            // Remove button
                            TouchArea {
                                width: 28px;
                                height: 28px;
                                clicked => { root.weather-remove-location(idx); }
                                Rectangle {
                                    width: 28px;
                                    height: 28px;
                                    border-radius: 14px;
                                    background: parent.has-hover ? Theme.hover-fill-strong : transparent;
                                    Text {
                                        text: "\u{2715}";
                                        color: Theme.text-dim;
                                        font-size: 10px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        // ── Severe Weather Alerts ──
        for alert[ai] in root.weather-alerts : Rectangle {
            height: 44px;
            background: alert.severity >= 2 ? Theme.color-emotional.transparentize(85%)
                       : alert.severity == 1 ? Theme.amber.transparentize(85%)
                       : Theme.accent.transparentize(85%);
            border-width: 1px;
            border-color: alert.severity >= 2 ? Theme.color-emotional.transparentize(50%)
                         : alert.severity == 1 ? Theme.amber.transparentize(50%)
                         : Theme.accent.transparentize(50%);

            HorizontalLayout {
                padding-left: 16px;
                padding-right: 16px;
                spacing: 10px;

                Text {
                    text: alert.icon;
                    font-size: 18px;
                    vertical-alignment: center;
                }

                Text {
                    text: alert.title;
                    color: alert.severity >= 2 ? Theme.color-emotional
                          : alert.severity == 1 ? Theme.amber
                          : Theme.accent;
                    font-size: 12px;
                    font-weight: 700;
                    vertical-alignment: center;
                }

                Text {
                    text: alert.description;
                    color: alert.severity >= 2 ? Theme.color-emotional.transparentize(20%)
                          : alert.severity == 1 ? Theme.amber-light
                          : Theme.text-secondary;
                    font-size: 12px;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                    overflow: elide;
                }

                // Severity badge
                Rectangle {
                    width: sev-text.preferred-width + 12px;
                    height: 20px;
                    y: (parent.height - 20px) / 2;
                    border-radius: 10px;
                    background: alert.severity >= 2 ? Theme.color-emotional.transparentize(60%)
                               : alert.severity == 1 ? Theme.amber.transparentize(60%)
                               : Theme.accent.transparentize(60%);
                    sev-text := Text {
                        text: alert.severity >= 2 ? "SEVERE"
                             : alert.severity == 1 ? "MODERATE"
                             : "INFO";
                        color: alert.severity >= 2 ? Theme.color-emotional
                              : alert.severity == 1 ? Theme.amber
                              : Theme.accent;
                        font-size: 9px;
                        font-weight: 700;
                        letter-spacing: 1px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // ── AI Response Panel ──
        if root.ai-panel-open && root.ai-response != "" : Rectangle {
            max-height: 160px;
            background: Theme.bg-overlay-panel;
            border-width: 1px;
            border-color: Theme.accent.transparentize(70%);

            Flickable {
                viewport-height: ai-wx-resp.preferred-height + 16px;

                ai-wx-resp := VerticalLayout {
                    padding: Theme.sp-3;
                    spacing: Theme.sp-2;

                    HorizontalLayout {
                        spacing: 6px;
                        Text {
                            text: "\u{2728}";
                            font-size: 12px;
                            vertical-alignment: center;
                        }
                        Text {
                            text: "AI Insights";
                            color: Theme.accent;
                            font-size: 12px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                        Rectangle { horizontal-stretch: 1; }
                        YIconButton {
                            icon: "\u{2715}";
                            variant: 2;
                            clicked => {
                                root.ai-panel-open = false;
                                root.ai-dismiss();
                            }
                        }
                    }

                    Text {
                        text: root.ai-response;
                        color: Theme.text-primary;
                        font-size: 12px;
                        wrap: word-wrap;
                    }
                }
            }
        }

        // ── Scrollable content ──
        Flickable {
            viewport-height: content-col.preferred-height + 40px;

            content-col := VerticalLayout {
                padding: Theme.sp-5;
                spacing: Theme.sp-4;

                // ══════ ERROR BANNER ══════
                if root.current.error-text != "" : Rectangle {
                    background: Theme.color-danger-dim;
                    border-radius: Theme.r-lg;
                    border-width: 1px;
                    border-color: Theme.color-danger.with-alpha(0.25);
                    height: 48px;

                    Text {
                        text: root.current.error-text;
                        color: Theme.color-danger;
                        font-size: Theme.fs-body;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                // ══════ SEVERE WEATHER ALERT BANNER ══════
                if root.weather-severe-alert-active : Rectangle {
                    background: root.weather-severe-alert-level == "watch" ? Theme.color-warning-dim
                        : root.weather-severe-alert-level == "warning" ? Theme.color-danger-dim
                        : root.weather-severe-alert-level == "emergency" ? Theme.color-danger.with-alpha(0.19)
                        : Theme.color-warning-dim;
                    border-radius: Theme.r-lg;
                    border-width: 1px;
                    border-color: root.weather-severe-alert-level == "watch" ? Theme.color-warning.with-alpha(0.37)
                        : Theme.color-danger.with-alpha(0.37);
                    height: severe-alert-row.preferred-height + 16px;

                    severe-alert-row := HorizontalLayout {
                        padding: 12px;
                        spacing: 10px;
                        alignment: center;

                        Text {
                            text: root.weather-severe-alert-level == "watch" ? "\u{26A0}\u{FE0F}"
                                : "\u{1F6A8}";
                            font-size: 20px;
                            vertical-alignment: center;
                        }

                        VerticalLayout {
                            spacing: 2px;
                            horizontal-stretch: 1;

                            Text {
                                text: root.weather-severe-alert-level == "watch" ? "Weather Watch"
                                    : root.weather-severe-alert-level == "warning" ? "Weather Warning"
                                    : "Weather Emergency";
                                font-size: Theme.fs-body;
                                font-weight: 700;
                                color: root.weather-severe-alert-level == "watch" ? Theme.color-warning
                                    : Theme.color-danger;
                            }

                            Text {
                                text: root.weather-severe-alert-text;
                                font-size: Theme.fs-caption;
                                color: root.weather-severe-alert-level == "watch" ? Theme.color-warning
                                    : Theme.color-danger;
                                wrap: word-wrap;
                            }
                        }
                    }
                }

                // ══════ HERO SECTION — Current Conditions ══════
                Rectangle {
                    background: Theme.bg-card;
                    border-radius: Theme.r-lg;
                    border-width: 1px;
                    border-color: Theme.border-subtle;
                    height: hero-col.preferred-height;

                    // Subtle accent glow at top
                    Rectangle {
                        height: 2px;
                        width: parent.width;
                        y: 0;
                        background: Theme.accent-glow;
                        border-radius: 1px;
                    }

                    hero-col := VerticalLayout {
                        padding: Theme.sp-6;
                        spacing: Theme.sp-4;

                        // Loading indicator
                        if root.current.is-loading : Text {
                            text: "Fetching weather data...";
                            color: Theme.text-dim;
                            font-size: Theme.fs-body;
                            horizontal-alignment: center;
                        }

                        // Main temperature row
                        HorizontalLayout {
                            alignment: center;
                            spacing: 16px;

                            // Weather icon (large)
                            Text {
                                text: root.current.icon;
                                font-size: 56px;
                                vertical-alignment: center;
                            }

                            // Temperature + condition
                            VerticalLayout {
                                spacing: 4px;
                                alignment: center;

                                Text {
                                    text: root.current.temperature;
                                    color: Theme.text-primary;
                                    font-size: 52px;
                                    font-weight: 300;
                                }

                                Text {
                                    text: root.current.condition;
                                    color: Theme.text-secondary;
                                    font-size: Theme.fs-headline;
                                }

                                Text {
                                    text: "Feels like " + root.current.feels-like;
                                    color: Theme.text-dim;
                                    font-size: Theme.fs-caption;
                                }
                            }
                        }

                        // Divider
                        Rectangle { height: 1px; background: Theme.separator; }

                        // Quick stats row
                        HorizontalLayout {
                            spacing: 0px;

                            // Humidity
                            VerticalLayout {
                                horizontal-stretch: 1;
                                alignment: center;

                                Text {
                                    text: "\u{1F4A7}";
                                    font-size: 18px;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: root.current.humidity;
                                    color: Theme.text-primary;
                                    font-size: Theme.fs-body;
                                    font-weight: 600;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: "Humidity";
                                    color: Theme.text-dim;
                                    font-size: 10px;
                                    horizontal-alignment: center;
                                }
                            }

                            // Wind
                            VerticalLayout {
                                horizontal-stretch: 1;
                                alignment: center;

                                Text {
                                    text: "\u{1F4A8}";
                                    font-size: 18px;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: root.current.wind-speed;
                                    color: Theme.text-primary;
                                    font-size: Theme.fs-body;
                                    font-weight: 600;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: "Wind " + root.current.wind-direction;
                                    color: Theme.text-dim;
                                    font-size: 10px;
                                    horizontal-alignment: center;
                                }
                            }

                            // UV Index
                            VerticalLayout {
                                horizontal-stretch: 1;
                                alignment: center;

                                Text {
                                    text: "\u{2600}";
                                    font-size: 18px;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: root.current.uv-index;
                                    color: Theme.text-primary;
                                    font-size: Theme.fs-body;
                                    font-weight: 600;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: "UV Index";
                                    color: Theme.text-dim;
                                    font-size: 10px;
                                    horizontal-alignment: center;
                                }
                            }

                            // Visibility
                            VerticalLayout {
                                horizontal-stretch: 1;
                                alignment: center;

                                Text {
                                    text: "\u{1F441}";
                                    font-size: 18px;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: root.current.visibility;
                                    color: Theme.text-primary;
                                    font-size: Theme.fs-body;
                                    font-weight: 600;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: "Visibility";
                                    color: Theme.text-dim;
                                    font-size: 10px;
                                    horizontal-alignment: center;
                                }
                            }
                        }
                    }
                }

                // ══════ HOURLY FORECAST ══════
                // Section header
                HorizontalLayout {
                    spacing: 8px;
                    Rectangle {
                        width: 3px; height: 14px;
                        border-radius: 1.5px;
                        background: Theme.accent;
                        drop-shadow-blur: 4px;
                        drop-shadow-color: Theme.accent-glow;
                    }
                    Text {
                        text: "HOURLY FORECAST";
                        color: Theme.text-dim;
                        font-size: 11px;
                        letter-spacing: 2px;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    background: Theme.bg-card;
                    border-radius: Theme.r-lg;
                    border-width: 1px;
                    border-color: Theme.border-subtle;
                    height: 110px;
                    clip: true;

                    Flickable {
                        width: parent.width - Theme.sp-4;
                        x: Theme.sp-2;
                        height: parent.height;
                        viewport-width: hourly.length * 70px + Theme.sp-4;

                        HorizontalLayout {
                            padding: Theme.sp-2;
                            spacing: Theme.sp-1;

                            for hour[i] in root.hourly : Rectangle {
                                width: 62px;
                                border-radius: Theme.r-md;
                                background: hour.is-current ? Theme.tint-accent : transparent;
                                border-width: hour.is-current ? 1px : 0px;
                                border-color: hour.is-current ? Theme.accent-dim : transparent;

                                VerticalLayout {
                                    padding: 8px;
                                    spacing: 4px;
                                    alignment: center;

                                    Text {
                                        text: hour.time;
                                        color: hour.is-current ? Theme.accent : Theme.text-secondary;
                                        font-size: 11px;
                                        font-weight: hour.is-current ? 700 : 400;
                                        horizontal-alignment: center;
                                    }

                                    Text {
                                        text: hour.icon;
                                        font-size: 22px;
                                        horizontal-alignment: center;
                                    }

                                    Text {
                                        text: hour.temp;
                                        color: Theme.text-primary;
                                        font-size: 13px;
                                        font-weight: 600;
                                        horizontal-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }

                // ══════ 5-DAY FORECAST ══════
                // Section header
                HorizontalLayout {
                    spacing: 8px;
                    Rectangle {
                        width: 3px; height: 14px;
                        border-radius: 1.5px;
                        background: Theme.amber;
                        drop-shadow-blur: 4px;
                        drop-shadow-color: Theme.amber-glow;
                    }
                    Text {
                        text: "5-DAY FORECAST";
                        color: Theme.text-dim;
                        font-size: 11px;
                        letter-spacing: 2px;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    background: Theme.bg-card;
                    border-radius: Theme.r-lg;
                    border-width: 1px;
                    border-color: Theme.border-subtle;
                    height: daily-col.preferred-height;

                    daily-col := VerticalLayout {
                        padding: 8px;
                        spacing: 0px;

                        for day[i] in root.daily : Rectangle {
                            height: 56px;

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;
                                spacing: 12px;

                                // Day name
                                Text {
                                    text: day.day-name;
                                    color: Theme.text-primary;
                                    font-size: Theme.fs-body;
                                    vertical-alignment: center;
                                    width: 80px;
                                }

                                // Icon
                                Text {
                                    text: day.icon;
                                    font-size: 22px;
                                    vertical-alignment: center;
                                    width: 32px;
                                    horizontal-alignment: center;
                                }

                                // Precipitation chance
                                Text {
                                    text: day.precip-chance;
                                    color: Theme.holo-blue;
                                    font-size: Theme.fs-caption;
                                    vertical-alignment: center;
                                    width: 42px;
                                    horizontal-alignment: right;
                                }

                                // Temperature range bar
                                Rectangle {
                                    horizontal-stretch: 1;
                                    height: 6px;
                                    y: (parent.height - 6px) / 2;
                                    border-radius: 3px;
                                    background: Theme.bg-surface;

                                    // Color-coded range indicator
                                    Rectangle {
                                        x: parent.width * clamp(day.temp-range-min, 0, 1);
                                        width: parent.width * clamp(day.temp-range-max - day.temp-range-min, 0.05, 1);
                                        height: 6px;
                                        border-radius: 3px;
                                        background: Theme.accent;
                                    }
                                }

                                // Low temp
                                Text {
                                    text: day.low;
                                    color: Theme.text-dim;
                                    font-size: 13px;
                                    vertical-alignment: center;
                                    width: 38px;
                                    horizontal-alignment: right;
                                }

                                // High temp
                                Text {
                                    text: day.high;
                                    color: Theme.text-primary;
                                    font-size: 13px;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                    width: 38px;
                                    horizontal-alignment: right;
                                }
                            }

                            // Separator
                            Rectangle {
                                height: 1px;
                                x: 16px;
                                width: parent.width - 32px;
                                y: parent.height - 1px;
                                background: Theme.separator;
                            }
                        }
                    }
                }

                // ══════ WEATHER DETAILS GRID ══════
                // Section header
                HorizontalLayout {
                    spacing: 8px;
                    Rectangle {
                        width: 3px; height: 14px;
                        border-radius: 1.5px;
                        background: Theme.accent;
                        drop-shadow-blur: 4px;
                        drop-shadow-color: Theme.accent-glow;
                    }
                    Text {
                        text: "DETAILS";
                        color: Theme.text-dim;
                        font-size: 11px;
                        letter-spacing: 2px;
                        vertical-alignment: center;
                    }
                }

                // Details grid (2 columns)
                HorizontalLayout {
                    spacing: 12px;

                    // Left column
                    VerticalLayout {
                        horizontal-stretch: 1;
                        spacing: 12px;

                        // Sunrise
                        Rectangle {
                            background: Theme.bg-card;
                            border-radius: Theme.r-lg;
                            border-width: 1px;
                            border-color: Theme.border-subtle;
                            height: 72px;

                            VerticalLayout {
                                padding: 12px;
                                spacing: 4px;

                                HorizontalLayout {
                                    spacing: 6px;
                                    Text {
                                        text: "\u{1F305}";
                                        font-size: 16px;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: "Sunrise";
                                        color: Theme.text-dim;
                                        font-size: Theme.fs-caption;
                                        vertical-alignment: center;
                                    }
                                }
                                Text {
                                    text: root.current.sunrise;
                                    color: Theme.text-primary;
                                    font-size: 18px;
                                    font-weight: 600;
                                }
                            }
                        }

                        // Pressure
                        Rectangle {
                            background: Theme.bg-card;
                            border-radius: Theme.r-lg;
                            border-width: 1px;
                            border-color: Theme.border-subtle;
                            height: 72px;

                            VerticalLayout {
                                padding: 12px;
                                spacing: 4px;

                                HorizontalLayout {
                                    spacing: 6px;
                                    Text {
                                        text: "\u{1F4CA}";
                                        font-size: 16px;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: "Pressure";
                                        color: Theme.text-dim;
                                        font-size: Theme.fs-caption;
                                        vertical-alignment: center;
                                    }
                                }
                                Text {
                                    text: root.current.pressure;
                                    color: Theme.text-primary;
                                    font-size: 18px;
                                    font-weight: 600;
                                }
                            }
                        }

                        // Cloud Cover
                        Rectangle {
                            background: Theme.bg-card;
                            border-radius: Theme.r-lg;
                            border-width: 1px;
                            border-color: Theme.border-subtle;
                            height: 72px;

                            VerticalLayout {
                                padding: 12px;
                                spacing: 4px;

                                HorizontalLayout {
                                    spacing: 6px;
                                    Text {
                                        text: "\u{2601}";
                                        font-size: 16px;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: "Cloud Cover";
                                        color: Theme.text-dim;
                                        font-size: Theme.fs-caption;
                                        vertical-alignment: center;
                                    }
                                }
                                Text {
                                    text: root.current.cloud-cover;
                                    color: Theme.text-primary;
                                    font-size: 18px;
                                    font-weight: 600;
                                }
                            }
                        }

                        // AQI Card
                        Rectangle {
                            background: Theme.bg-card;
                            border-radius: Theme.r-lg;
                            border-width: 1px;
                            border-color: Theme.border-subtle;
                            height: 72px;

                            VerticalLayout {
                                padding: 12px;
                                spacing: 4px;

                                HorizontalLayout {
                                    spacing: 6px;
                                    Text {
                                        text: "\u{1F32C}";
                                        font-size: 16px;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: "Air Quality";
                                        color: Theme.text-dim;
                                        font-size: Theme.fs-caption;
                                        vertical-alignment: center;
                                    }
                                    Rectangle { horizontal-stretch: 1; }
                                    // AQI level badge
                                    Rectangle {
                                        width: aqi-badge-text.preferred-width + 10px;
                                        height: 18px;
                                        border-radius: 9px;
                                        background: root.weather-aqi-level == 0 ? Theme.color-success-dim
                                                   : root.weather-aqi-level == 1 ? Theme.amber.transparentize(70%)
                                                   : Theme.color-emotional.transparentize(70%);
                                        aqi-badge-text := Text {
                                            text: root.weather-aqi-label;
                                            color: root.weather-aqi-level == 0 ? Theme.color-success
                                                  : root.weather-aqi-level == 1 ? Theme.amber
                                                  : Theme.color-emotional;
                                            font-size: 9px;
                                            font-weight: 700;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                                Text {
                                    text: root.weather-aqi-value;
                                    color: root.weather-aqi-level == 0 ? Theme.color-success
                                          : root.weather-aqi-level == 1 ? Theme.amber
                                          : Theme.color-emotional;
                                    font-size: 18px;
                                    font-weight: 600;
                                }
                            }
                        }
                    }

                    // Right column
                    VerticalLayout {
                        horizontal-stretch: 1;
                        spacing: 12px;

                        // Sunset
                        Rectangle {
                            background: Theme.bg-card;
                            border-radius: Theme.r-lg;
                            border-width: 1px;
                            border-color: Theme.border-subtle;
                            height: 72px;

                            VerticalLayout {
                                padding: 12px;
                                spacing: 4px;

                                HorizontalLayout {
                                    spacing: 6px;
                                    Text {
                                        text: "\u{1F307}";
                                        font-size: 16px;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: "Sunset";
                                        color: Theme.text-dim;
                                        font-size: Theme.fs-caption;
                                        vertical-alignment: center;
                                    }
                                }
                                Text {
                                    text: root.current.sunset;
                                    color: Theme.text-primary;
                                    font-size: 18px;
                                    font-weight: 600;
                                }
                            }
                        }

                        // Dew Point
                        Rectangle {
                            background: Theme.bg-card;
                            border-radius: Theme.r-lg;
                            border-width: 1px;
                            border-color: Theme.border-subtle;
                            height: 72px;

                            VerticalLayout {
                                padding: 12px;
                                spacing: 4px;

                                HorizontalLayout {
                                    spacing: 6px;
                                    Text {
                                        text: "\u{1F4A7}";
                                        font-size: 16px;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: "Dew Point";
                                        color: Theme.text-dim;
                                        font-size: Theme.fs-caption;
                                        vertical-alignment: center;
                                    }
                                }
                                Text {
                                    text: root.current.dew-point;
                                    color: Theme.text-primary;
                                    font-size: 18px;
                                    font-weight: 600;
                                }
                            }
                        }

                        // Precipitation
                        Rectangle {
                            background: Theme.bg-card;
                            border-radius: Theme.r-lg;
                            border-width: 1px;
                            border-color: Theme.border-subtle;
                            height: 72px;

                            VerticalLayout {
                                padding: 12px;
                                spacing: 4px;

                                HorizontalLayout {
                                    spacing: 6px;
                                    Text {
                                        text: "\u{1F327}";
                                        font-size: 16px;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: "Precip.";
                                        color: Theme.text-dim;
                                        font-size: Theme.fs-caption;
                                        vertical-alignment: center;
                                    }
                                }
                                Text {
                                    text: root.current.dew-point != "--" ? "See daily" : "--";
                                    color: Theme.text-primary;
                                    font-size: 18px;
                                    font-weight: 600;
                                }
                            }
                        }

                        // Wind Direction detail
                        Rectangle {
                            background: Theme.bg-card;
                            border-radius: Theme.r-lg;
                            border-width: 1px;
                            border-color: Theme.border-subtle;
                            height: 72px;

                            VerticalLayout {
                                padding: 12px;
                                spacing: 4px;

                                HorizontalLayout {
                                    spacing: 6px;
                                    Text {
                                        text: "\u{1F9ED}";
                                        font-size: 16px;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: "Wind Dir.";
                                        color: Theme.text-dim;
                                        font-size: Theme.fs-caption;
                                        vertical-alignment: center;
                                    }
                                }
                                Text {
                                    text: root.current.wind-direction;
                                    color: Theme.text-primary;
                                    font-size: 18px;
                                    font-weight: 600;
                                }
                            }
                        }
                    }
                }

                // Bottom spacer
                Rectangle { height: 40px; }
            }
        }
    }
}
