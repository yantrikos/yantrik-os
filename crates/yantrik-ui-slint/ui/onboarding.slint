// Onboarding — "Hey. I'm Yantrik."
// First-boot experience with interest discovery + profile setup + AI provider setup.
// Phases: orb kindle → greeting → name input → interest chips →
//         location + notification pref → AI hardware scan → AI mode select →
//         AI provider setup → AI test → instruction → ready.

import { Theme } from "theme.slint";
import { Orb } from "components/orb.slint";
import { ParticleField } from "components/particle_field.slint";

// ── Interest chip (toggleable) ────────────────────────────────────

component InterestChip inherits Rectangle {
    in-out property <bool> selected: false;
    in property <string> label;
    callback toggled(bool);

    width: chip-text.preferred-width + 28px;
    height: 34px;
    border-radius: 17px;
    border-width: 1px;
    border-color: selected ? Theme.cyan : Theme.border-default;
    background: selected ? Theme.cyan-glow : Theme.hover-fill;
    animate background { duration: Theme.dur-normal; }
    animate border-color { duration: Theme.dur-normal; }

    chip-text := Text {
        text: label;
        color: selected ? Theme.cyan-light : Theme.text-secondary;
        font-size: Theme.font-label;
        font-weight: selected ? 600 : 400;
        horizontal-alignment: center;
        vertical-alignment: center;
        animate color { duration: Theme.dur-normal; }
    }

    TouchArea {
        clicked => {
            root.selected = !root.selected;
            root.toggled(root.selected);
        }
    }
}

// ── Pill button ───────────────────────────────────────────────────

component PillButton inherits Rectangle {
    in property <string> label;
    in property <bool> enabled: true;
    callback clicked();

    width: 160px;
    height: 42px;
    border-radius: 21px;
    background: enabled ? Theme.cyan-glow : Theme.hover-fill;
    border-width: 1px;
    border-color: enabled ? Theme.cyan : Theme.border-subtle;
    opacity: enabled ? 1.0 : 0.4;
    animate opacity { duration: Theme.dur-normal; }

    Text {
        text: label;
        color: enabled ? Theme.cyan : Theme.text-dim;
        font-size: Theme.fs-body;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }
}

// ── Text field ────────────────────────────────────────────────────

component OnboardField inherits Rectangle {
    in property <string> placeholder;
    in-out property <string> value;
    in property <color> text-color: Theme.text-primary;
    in property <bool> is-password: false;
    in property <string> label: "";

    width: 340px;
    height: self.label != "" ? 68px : 44px;

    VerticalLayout {
        spacing: 4px;

        // Label above field
        if root.label != "" : Text {
            text: root.label;
            color: Theme.text-secondary;
            font-size: Theme.fs-caption;
            letter-spacing: 0.5px;
        }

        Rectangle {
            height: 44px;
            border-radius: Theme.r-xl;
            background: Theme.bg-input;
            border-width: 1px;
            border-color: field-input.has-focus ? Theme.cyan : Theme.border-default;
            clip: true;
            animate border-color { duration: Theme.dur-normal; }
            drop-shadow-blur: field-input.has-focus ? 6px : 0;
            drop-shadow-color: Theme.cyan.transparentize(80%);
            animate drop-shadow-blur { duration: Theme.dur-normal; }

            TouchArea {
                clicked => { field-input.focus(); }
            }

            // Placeholder text
            if root.value == "" && !field-input.has-focus : Text {
                x: 16px;
                width: parent.width - 32px;
                height: parent.height;
                text: root.placeholder;
                color: Theme.text-dim;
                font-size: Theme.fs-body;
                vertical-alignment: center;
                opacity: 0.5;
            }

            field-input := TextInput {
                x: 16px;
                y: 0;
                width: parent.width - 32px;
                height: parent.height;
                text <=> root.value;
                color: root.text-color;
                font-size: Theme.fs-body;
                vertical-alignment: center;
                input-type: root.is-password ? InputType.password : InputType.text;
                selection-background-color: Theme.cyan.transparentize(60%);
            }
        }
    }
}

// ── Notification pref option ──────────────────────────────────────

component NotifOption inherits Rectangle {
    in property <string> label;
    in property <string> desc;
    in property <bool> active: false;
    callback selected();

    height: 52px;
    border-radius: Theme.r-md;
    border-width: 1px;
    border-color: active ? Theme.cyan : Theme.border-default;
    background: active ? Theme.cyan-glow : Theme.border-subtle;
    animate background { duration: Theme.dur-normal; }
    animate border-color { duration: Theme.dur-normal; }

    HorizontalLayout {
        padding-left: Theme.sp-4;
        padding-right: Theme.sp-4;
        alignment: start;
        spacing: Theme.sp-3;

        // Radio dot
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 16px;
                height: 16px;
                border-radius: 8px;
                border-width: 1.5px;
                border-color: active ? Theme.cyan : Theme.border-strong;
                Rectangle {
                    x: 4px;
                    y: 4px;
                    width: 8px;
                    height: 8px;
                    border-radius: 4px;
                    background: active ? Theme.cyan : transparent;
                    animate background { duration: Theme.dur-normal; }
                }
            }
        }

        VerticalLayout {
            alignment: center;
            spacing: 2px;
            Text {
                text: label;
                color: active ? Theme.text-primary : Theme.text-secondary;
                font-size: Theme.font-label;
                font-weight: 500;
            }
            Text {
                text: desc;
                color: Theme.text-dim;
                font-size: Theme.fs-micro;
            }
        }
    }

    TouchArea { clicked => { root.selected(); } }
}

// ── Main onboarding screen ───────────────────────────────────────

export component OnboardingScreen inherits Rectangle {
    callback ready();   // User completed onboarding
    callback skip();    // User wants to skip onboarding
    callback set-names(string, string);  // (user_name, companion_name)
    callback set-profile(/* interests */ string, /* home_loc */ string,
                         /* notif_pref */ string);
    callback install-to-disk(/* username */ string, /* password */ string,
                             /* full_name */ string, /* hostname */ string,
                             /* companion_name */ string, /* target_disk */ string);
    callback install-reboot();

    // AI setup callbacks
    callback ai-mode-selected(string);       // "local", "cloud", "later"
    callback ai-provider-selected(string);   // provider type: "ollama", "openai", "anthropic", "google", "deepseek", "openrouter"
    callback ai-api-key-submitted(string, string);  // (provider_type, api_key)
    callback ai-test-connection();
    callback ai-skip-setup();

    /// True when booted from ISO with installer mode (shows username/password/disk fields)
    in property <bool> installer-mode: false;

    // AI setup input properties (set from wire)
    in property <bool> ai-hw-cpu-ok: false;
    in property <bool> ai-hw-ram-ok: false;
    in property <bool> ai-hw-gpu-ok: false;
    in property <bool> ai-hw-disk-ok: false;
    in property <bool> ai-hw-network-ok: false;
    in property <bool> ai-hw-runtime-ok: false;
    in property <string> ai-hw-cpu-label: "";
    in property <string> ai-hw-ram-label: "";
    in property <string> ai-hw-gpu-label: "";
    in property <string> ai-hw-disk-label: "";
    // Disk info for installer — populated by backend
    in property <string> disk-1-name: "";   // e.g. "sda"
    in property <string> disk-1-size: "";   // e.g. "80G"
    in property <string> disk-1-model: "";  // e.g. "VBOX HARDDISK"
    in property <string> disk-2-name: "";
    in property <string> disk-2-size: "";
    in property <string> disk-2-model: "";
    in property <string> disk-3-name: "";
    in property <string> disk-3-size: "";
    in property <string> disk-3-model: "";
    in-out property <string> selected-disk: "";  // e.g. "sda"
    property <string> erase-mode: "full";  // "full" = erase entire disk
    in property <string> ai-hw-recommend: "local";  // "local" or "cloud"
    in property <string> ai-test-status: "";         // "", "testing", "success", "error: ..."
    in property <string> ai-test-model: "";
    in property <int> ai-test-latency-ms: 0;
    in property <string> ai-test-privacy: "local";

    in-out property <string> companion-name: "Yantrik";

    background: Theme.bg-deep;
    clip: true;

    // Phase tracking:
    // 0=dim, 1=orb kindles, 2=greeting, 3=name-input,
    // 4=interests, 5=location+notif, 6=hw-scan, 7=ai-mode-select,
    // 8=ai-provider-setup, 9=ai-test, 10=instruction/install-summary,
    // 11=install-progress (installer only), 12=install-complete (installer only)
    property <int> phase: 0;
    property <float> timer-elapsed: 0;
    property <string> input-user-name: "";
    property <string> input-companion-name: "";
    property <string> input-home-location: "";
    // Installer fields (only shown when installer-mode is true)
    property <string> input-username: "";
    property <string> input-password: "";
    property <string> input-password-confirm: "";
    property <string> input-hostname: "yantrik";
    property <string> install-error: "";
    property <bool> installing: false;
    in-out property <int> install-progress: 0;
    in-out property <string> install-status: "";

    // Interest state — 14 categories, tracked as booleans
    property <bool> int-technology: false;
    property <bool> int-finance: false;
    property <bool> int-sports: false;
    property <bool> int-music: false;
    property <bool> int-politics: false;
    property <bool> int-health: false;
    property <bool> int-food: false;
    property <bool> int-science: false;
    property <bool> int-gaming: false;
    property <bool> int-travel: false;
    property <bool> int-fashion: false;
    property <bool> int-business: false;
    property <bool> int-entertainment: false;
    property <bool> int-auto: false;

    property <int> interest-count:
        (int-technology ? 1 : 0) + (int-finance ? 1 : 0) +
        (int-sports ? 1 : 0) + (int-music ? 1 : 0) +
        (int-politics ? 1 : 0) + (int-health ? 1 : 0) +
        (int-food ? 1 : 0) + (int-science ? 1 : 0) +
        (int-gaming ? 1 : 0) + (int-travel ? 1 : 0) +
        (int-fashion ? 1 : 0) + (int-business ? 1 : 0) +
        (int-entertainment ? 1 : 0) + (int-auto ? 1 : 0);

    // Notification preference: "morning_brief" | "realtime" | "minimal"
    property <string> notif-pref: "morning_brief";

    // AI setup state
    property <string> ai-mode: "";               // "local", "cloud", "later"
    property <string> ai-selected-provider: "";   // "ollama", "openai", "anthropic", "google", "deepseek", "openrouter"
    property <string> ai-api-key-input: "";
    property <float> hw-scan-progress: 0;
    property <int> hw-scan-step: 0;

    Timer {
        interval: 16ms;
        running: phase < 3 || phase == 6 || phase == 11;
        triggered => {
            timer-elapsed += 0.016;
            if timer-elapsed > 0.5 && phase == 0 { phase = 1; }
            if timer-elapsed > 2.0 && phase == 1 { phase = 2; }
            if timer-elapsed > 4.0 && phase == 2 { phase = 3; }
            // Hardware scan animation — advance steps every 400ms
            if phase == 6 {
                hw-scan-progress = min(1.0, hw-scan-progress + 0.008);
                if hw-scan-progress > 0.15 && hw-scan-step < 1 { hw-scan-step = 1; }
                if hw-scan-progress > 0.30 && hw-scan-step < 2 { hw-scan-step = 2; }
                if hw-scan-progress > 0.45 && hw-scan-step < 3 { hw-scan-step = 3; }
                if hw-scan-progress > 0.60 && hw-scan-step < 4 { hw-scan-step = 4; }
                if hw-scan-progress > 0.75 && hw-scan-step < 5 { hw-scan-step = 5; }
                if hw-scan-progress > 0.90 && hw-scan-step < 6 { hw-scan-step = 6; }
            }
            // Auto-advance to install complete when progress reaches 100
            if phase == 11 && root.install-progress >= 100 {
                phase = 12;
            }
        }
    }

    // ── Backdrop ──────────────────────────────────────────────────

    ParticleField {
        width: 100%; height: 100%;
        active: true;
        intensity: phase >= 1 ? 0.4 : 0.1;
        animate intensity { duration: 2000ms; }
    }

    Rectangle {
        width: 100%; height: 100%;
        background: @radial-gradient(circle, Theme.bg-deep.transparentize(100%) 0%, Theme.bg-deep.transparentize(60%) 50%, Theme.bg-deep.transparentize(30%) 100%);
    }

    // ── Scrollable content ────────────────────────────────────────

    Flickable {
        width: 100%; height: 100%;
        viewport-height: self.height;

        VerticalLayout {
            alignment: center;
            spacing: Theme.sp-5;
            padding-left: Theme.sp-8;
            padding-right: Theme.sp-8;
            padding-top: Theme.sp-8;
            padding-bottom: 60px;

            // ── Orb (kindles at phase 1) ──────────────────────────

            HorizontalLayout {
                alignment: center;
                Orb {
                    width: phase >= 4 ? 60px : 120px;
                    height: phase >= 4 ? 60px : 120px;
                    size-px: phase >= 4 ? 60 : 120;
                    opacity: phase >= 1 ? 1.0 : 0;
                    animate opacity { duration: 2000ms; easing: ease-out; }
                    animate width { duration: 600ms; easing: ease-out; }
                    animate height { duration: 600ms; easing: ease-out; }
                }
            }

            // ── Greeting (phase 2+) ──────────────────────────────

            Text {
                text: phase < 4 ? "Hey. I'm " + root.companion-name + "."
                    : phase == 4 ? "What are you into?"
                    : phase == 5 ? "Almost there."
                    : phase == 6 ? "Scanning your hardware..."
                    : phase == 7 ? "How should I think?"
                    : phase == 8 ? "Set up your AI provider."
                    : phase == 9 ? "Testing your AI..."
                    : phase == 10 && root.installer-mode ? "Ready to install."
                    : phase == 11 ? "Installing..."
                    : phase == 12 ? "Installation complete!"
                    : "You're all set.";
                color: Theme.cyan;
                font-size: phase < 4 ? 28px : 22px;
                font-weight: 300;
                letter-spacing: 2px;
                horizontal-alignment: center;
                opacity: phase >= 2 ? 1.0 : 0;
                animate opacity { duration: 1500ms; easing: ease-out; }
                animate font-size { duration: 400ms; }
            }

            // ── Phase 3: Account Setup ──────────────────────────────

            if phase == 3: VerticalLayout {
                spacing: Theme.sp-2;
                padding-left: 40px;
                padding-right: 40px;
                opacity: 1.0;
                animate opacity { duration: 800ms; easing: ease-out; }

                // Two-column layout for installer mode
                if root.installer-mode: HorizontalLayout {
                    alignment: center;
                    spacing: 40px;

                    // Left column: Personal
                    VerticalLayout {
                        spacing: 6px;
                        width: 340px;

                        Text {
                            text: "Your Identity";
                            color: Theme.cyan;
                            font-size: Theme.fs-body;
                            font-weight: 600;
                            letter-spacing: 1px;
                        }

                        Rectangle { height: 4px; }

                        OnboardField {
                            label: "Full Name";
                            value <=> root.input-user-name;
                            placeholder: "e.g. John Doe";
                        }

                        OnboardField {
                            label: "Username (login)";
                            value <=> root.input-username;
                            placeholder: "e.g. john";
                        }

                        OnboardField {
                            label: "Password";
                            value <=> root.input-password;
                            placeholder: "Choose a strong password";
                            is-password: true;
                        }

                        OnboardField {
                            label: "Confirm Password";
                            value <=> root.input-password-confirm;
                            placeholder: "Re-enter password";
                            is-password: true;
                        }
                    }

                    // Right column: System
                    VerticalLayout {
                        spacing: 6px;
                        width: 340px;

                        Text {
                            text: "System";
                            color: Theme.cyan;
                            font-size: Theme.fs-body;
                            font-weight: 600;
                            letter-spacing: 1px;
                        }

                        Rectangle { height: 4px; }

                        OnboardField {
                            label: "Computer Name";
                            value <=> root.input-hostname;
                            placeholder: "e.g. my-desktop";
                        }

                        Rectangle { height: 10px; }

                        Text {
                            text: "Your AI Companion";
                            color: Theme.cyan;
                            font-size: Theme.fs-body;
                            font-weight: 600;
                            letter-spacing: 1px;
                        }

                        Rectangle { height: 4px; }

                        OnboardField {
                            label: "Companion Name";
                            value <=> root.input-companion-name;
                            placeholder: "e.g. Yantrik";
                            text-color: Theme.amber;
                        }

                        Rectangle { height: 10px; }

                        // Subtle info text
                        Text {
                            text: "Your companion is an AI assistant that\nlives on your desktop and helps you\nwith daily tasks.";
                            color: Theme.text-dim;
                            font-size: Theme.fs-caption;
                            opacity: 0.6;
                            wrap: word-wrap;
                        }
                    }
                }

                // Single column for non-installer mode
                if !root.installer-mode: VerticalLayout {
                    spacing: Theme.sp-3;

                    Text {
                        text: "What should I call you?";
                        color: Theme.text-secondary;
                        font-size: Theme.fs-body;
                        horizontal-alignment: center;
                        letter-spacing: 1px;
                    }

                    HorizontalLayout {
                        alignment: center;
                        OnboardField {
                            value <=> root.input-user-name;
                            placeholder: "Your name";
                        }
                    }

                    Text {
                        text: "And what would you like to call me?";
                        color: Theme.text-secondary;
                        font-size: Theme.fs-body;
                        horizontal-alignment: center;
                        letter-spacing: 1px;
                    }

                    HorizontalLayout {
                        alignment: center;
                        OnboardField {
                            value <=> root.input-companion-name;
                            text-color: Theme.amber;
                            placeholder: "Companion name";
                        }
                    }
                }

                // Error display
                if root.install-error != "": Text {
                    text: root.install-error;
                    color: Theme.amber;
                    font-size: Theme.fs-caption;
                    horizontal-alignment: center;
                }

                Rectangle { height: Theme.sp-2; }

                HorizontalLayout {
                    alignment: center;
                    PillButton {
                        label: "Next \u{2192}";
                        clicked => {
                            if root.installer-mode {
                                if root.input-username == "" {
                                    root.install-error = "Username is required";
                                } else if root.input-password == "" {
                                    root.install-error = "Password is required";
                                } else if root.input-password != root.input-password-confirm {
                                    root.install-error = "Passwords don't match";
                                } else {
                                    root.install-error = "";
                                    root.set-names(root.input-user-name, root.input-companion-name);
                                    root.phase = 4;
                                }
                            } else {
                                root.set-names(root.input-user-name, root.input-companion-name);
                                root.phase = 4;
                            }
                        }
                    }
                }
            }

            // ── Phase 4: Interest selection ──────────────────────

            if phase == 4: VerticalLayout {
                spacing: Theme.sp-4;
                animate opacity { duration: 600ms; easing: ease-out; }

                Text {
                    text: "Pick 3–10 topics you care about.";
                    color: Theme.text-secondary;
                    font-size: Theme.font-label;
                    horizontal-alignment: center;
                    letter-spacing: 0.5px;
                }

                Text {
                    text: interest-count + " selected";
                    color: interest-count >= 3 ? Theme.cyan : Theme.text-dim;
                    font-size: Theme.fs-caption;
                    horizontal-alignment: center;
                }

                // Row 1
                HorizontalLayout {
                    alignment: center;
                    spacing: Theme.sp-2;
                    InterestChip { label: "Technology"; selected <=> root.int-technology; }
                    InterestChip { label: "Finance"; selected <=> root.int-finance; }
                    InterestChip { label: "Science"; selected <=> root.int-science; }
                    InterestChip { label: "Business"; selected <=> root.int-business; }
                }
                // Row 2
                HorizontalLayout {
                    alignment: center;
                    spacing: Theme.sp-2;
                    InterestChip { label: "Sports"; selected <=> root.int-sports; }
                    InterestChip { label: "Music"; selected <=> root.int-music; }
                    InterestChip { label: "Gaming"; selected <=> root.int-gaming; }
                    InterestChip { label: "Entertainment"; selected <=> root.int-entertainment; }
                }
                // Row 3
                HorizontalLayout {
                    alignment: center;
                    spacing: Theme.sp-2;
                    InterestChip { label: "Health & Fitness"; selected <=> root.int-health; }
                    InterestChip { label: "Food & Cooking"; selected <=> root.int-food; }
                    InterestChip { label: "Travel"; selected <=> root.int-travel; }
                }
                // Row 4
                HorizontalLayout {
                    alignment: center;
                    spacing: Theme.sp-2;
                    InterestChip { label: "Politics"; selected <=> root.int-politics; }
                    InterestChip { label: "Fashion"; selected <=> root.int-fashion; }
                    InterestChip { label: "Cars & Auto"; selected <=> root.int-auto; }
                }

                HorizontalLayout {
                    alignment: center;
                    padding-top: Theme.sp-2;
                    PillButton {
                        label: "Next →";
                        enabled: interest-count >= 3;
                        clicked => { root.phase = 5; }
                    }
                }
            }

            // ── Phase 5: Location + notification pref ────────────

            if phase == 5: VerticalLayout {
                spacing: Theme.sp-5;
                animate opacity { duration: 600ms; easing: ease-out; }

                // Location
                VerticalLayout {
                    spacing: Theme.sp-3;
                    Text {
                        text: "Where are you based?";
                        color: Theme.text-secondary;
                        font-size: Theme.fs-body;
                        horizontal-alignment: center;
                        letter-spacing: 1px;
                    }
                    Text {
                        text: "City or region — for weather, events, and local context.";
                        color: Theme.text-dim;
                        font-size: Theme.fs-micro;
                        horizontal-alignment: center;
                    }
                    HorizontalLayout {
                        alignment: center;
                        OnboardField {
                            value <=> root.input-home-location;
                            placeholder: "e.g. Bangalore, New York";
                        }
                    }
                }

                // Notification preference
                VerticalLayout {
                    spacing: Theme.sp-3;
                    Text {
                        text: "How should I reach out?";
                        color: Theme.text-secondary;
                        font-size: Theme.fs-body;
                        horizontal-alignment: center;
                        letter-spacing: 1px;
                    }

                    HorizontalLayout {
                        alignment: center;
                        VerticalLayout {
                            width: 320px;
                            spacing: Theme.sp-2;

                            NotifOption {
                                label: "Morning Brief";
                                desc: "Daily summary of your day + notable updates";
                                active: root.notif-pref == "morning_brief";
                                selected => { root.notif-pref = "morning_brief"; }
                            }

                            NotifOption {
                                label: "Real-time";
                                desc: "Nudges as things happen (events, weather, news)";
                                active: root.notif-pref == "realtime";
                                selected => { root.notif-pref = "realtime"; }
                            }

                            NotifOption {
                                label: "Minimal";
                                desc: "Only urgent items — I'll stay quiet otherwise";
                                active: root.notif-pref == "minimal";
                                selected => { root.notif-pref = "minimal"; }
                            }
                        }
                    }
                }

                HorizontalLayout {
                    alignment: center;
                    padding-top: Theme.sp-1;
                    PillButton {
                        label: "Next →";
                        clicked => {
                            // Build interest string: comma-separated selected interests
                            root.set-profile(
                                root.build-interests(),
                                root.input-home-location,
                                root.notif-pref,
                            );
                            root.hw-scan-progress = 0;
                            root.hw-scan-step = 0;
                            root.phase = 6;
                        }
                    }
                }
            }

            // ── Phase 6: Hardware Scan ─────────────────────────

            if phase == 6: VerticalLayout {
                spacing: Theme.sp-4;
                animate opacity { duration: 600ms; easing: ease-out; }

                // Progress bar
                HorizontalLayout {
                    alignment: center;
                    Rectangle {
                        width: 300px;
                        height: 4px;
                        border-radius: 2px;
                        background: Theme.hover-fill-strong;
                        Rectangle {
                            width: parent.width * root.hw-scan-progress;
                            height: 4px;
                            border-radius: 2px;
                            background: Theme.cyan;
                            drop-shadow-blur: 6px;
                            drop-shadow-color: Theme.cyan-glow;
                            animate width { duration: Theme.dur-normal; }
                        }
                    }
                }

                // Checklist items
                HorizontalLayout {
                    alignment: center;
                    VerticalLayout {
                        width: 280px;
                        spacing: Theme.sp-2;

                        // CPU
                        HorizontalLayout {
                            spacing: Theme.sp-3;
                            Text {
                                text: root.hw-scan-step >= 1 ? "\u{2713}" : "\u{25CB}";
                                color: root.hw-scan-step >= 1 ? Theme.color-success : Theme.text-dim;
                                font-size: Theme.fs-body;
                                width: 20px;
                                vertical-alignment: center;
                            }
                            Text {
                                text: "CPU";
                                color: root.hw-scan-step >= 1 ? Theme.text-primary : Theme.text-dim;
                                font-size: Theme.fs-body;
                                horizontal-stretch: 1;
                                vertical-alignment: center;
                            }
                            Text {
                                text: root.ai-hw-cpu-label;
                                color: Theme.text-dim;
                                font-size: Theme.fs-caption;
                                vertical-alignment: center;
                                opacity: root.hw-scan-step >= 1 ? 1.0 : 0;
                            }
                        }

                        // RAM
                        HorizontalLayout {
                            spacing: Theme.sp-3;
                            Text {
                                text: root.hw-scan-step >= 2 ? "\u{2713}" : "\u{25CB}";
                                color: root.hw-scan-step >= 2 ? Theme.color-success : Theme.text-dim;
                                font-size: Theme.fs-body;
                                width: 20px;
                                vertical-alignment: center;
                            }
                            Text {
                                text: "RAM";
                                color: root.hw-scan-step >= 2 ? Theme.text-primary : Theme.text-dim;
                                font-size: Theme.fs-body;
                                horizontal-stretch: 1;
                                vertical-alignment: center;
                            }
                            Text {
                                text: root.ai-hw-ram-label;
                                color: Theme.text-dim;
                                font-size: Theme.fs-caption;
                                vertical-alignment: center;
                                opacity: root.hw-scan-step >= 2 ? 1.0 : 0;
                            }
                        }

                        // GPU
                        HorizontalLayout {
                            spacing: Theme.sp-3;
                            Text {
                                text: root.hw-scan-step >= 3 ? "\u{2713}" : "\u{25CB}";
                                color: root.hw-scan-step >= 3 ? (root.ai-hw-gpu-ok ? Theme.color-success : Theme.amber) : Theme.text-dim;
                                font-size: Theme.fs-body;
                                width: 20px;
                                vertical-alignment: center;
                            }
                            Text {
                                text: "GPU";
                                color: root.hw-scan-step >= 3 ? Theme.text-primary : Theme.text-dim;
                                font-size: Theme.fs-body;
                                horizontal-stretch: 1;
                                vertical-alignment: center;
                            }
                            Text {
                                text: root.ai-hw-gpu-label;
                                color: Theme.text-dim;
                                font-size: Theme.fs-caption;
                                vertical-alignment: center;
                                opacity: root.hw-scan-step >= 3 ? 1.0 : 0;
                            }
                        }

                        // Disk
                        HorizontalLayout {
                            spacing: Theme.sp-3;
                            Text {
                                text: root.hw-scan-step >= 4 ? "\u{2713}" : "\u{25CB}";
                                color: root.hw-scan-step >= 4 ? Theme.color-success : Theme.text-dim;
                                font-size: Theme.fs-body;
                                width: 20px;
                                vertical-alignment: center;
                            }
                            Text {
                                text: "Disk";
                                color: root.hw-scan-step >= 4 ? Theme.text-primary : Theme.text-dim;
                                font-size: Theme.fs-body;
                                horizontal-stretch: 1;
                                vertical-alignment: center;
                            }
                            Text {
                                text: root.ai-hw-disk-label;
                                color: Theme.text-dim;
                                font-size: Theme.fs-caption;
                                vertical-alignment: center;
                                opacity: root.hw-scan-step >= 4 ? 1.0 : 0;
                            }
                        }

                        // Network
                        HorizontalLayout {
                            spacing: Theme.sp-3;
                            Text {
                                text: root.hw-scan-step >= 5 ? "\u{2713}" : "\u{25CB}";
                                color: root.hw-scan-step >= 5 ? Theme.color-success : Theme.text-dim;
                                font-size: Theme.fs-body;
                                width: 20px;
                                vertical-alignment: center;
                            }
                            Text {
                                text: "Network";
                                color: root.hw-scan-step >= 5 ? Theme.text-primary : Theme.text-dim;
                                font-size: Theme.fs-body;
                                horizontal-stretch: 1;
                                vertical-alignment: center;
                            }
                        }

                        // Local Runtimes
                        HorizontalLayout {
                            spacing: Theme.sp-3;
                            Text {
                                text: root.hw-scan-step >= 6 ? "\u{2713}" : "\u{25CB}";
                                color: root.hw-scan-step >= 6 ? (root.ai-hw-runtime-ok ? Theme.color-success : Theme.text-dim) : Theme.text-dim;
                                font-size: Theme.fs-body;
                                width: 20px;
                                vertical-alignment: center;
                            }
                            Text {
                                text: "Local Runtimes";
                                color: root.hw-scan-step >= 6 ? Theme.text-primary : Theme.text-dim;
                                font-size: Theme.fs-body;
                                horizontal-stretch: 1;
                                vertical-alignment: center;
                            }
                            Text {
                                text: root.ai-hw-runtime-ok ? "Ollama detected" : "Not found";
                                color: root.ai-hw-runtime-ok ? Theme.color-success : Theme.text-dim;
                                font-size: Theme.fs-caption;
                                vertical-alignment: center;
                                opacity: root.hw-scan-step >= 6 ? 1.0 : 0;
                            }
                        }
                    }
                }

                // Summary card (appears after scan complete)
                if root.hw-scan-step >= 6 : HorizontalLayout {
                    alignment: center;
                    padding-top: Theme.sp-3;
                    Rectangle {
                        width: 300px;
                        height: summary-col.preferred-height;
                        border-radius: Theme.r-lg;
                        background: Theme.hover-fill;
                        border-width: 1px;
                        border-color: Theme.cyan-glow;

                        summary-col := VerticalLayout {
                            padding: Theme.sp-4;
                            spacing: Theme.sp-2;
                            Text {
                                text: root.ai-hw-gpu-ok ? "GPU available — local inference recommended"
                                    : "No GPU — cloud provider recommended";
                                color: Theme.cyan;
                                font-size: Theme.fs-body;
                                font-weight: 500;
                                horizontal-alignment: center;
                            }
                        }
                    }
                }

                // Next button (appears after scan)
                if root.hw-scan-step >= 6 : HorizontalLayout {
                    alignment: center;
                    padding-top: Theme.sp-2;
                    PillButton {
                        label: "Next →";
                        clicked => { root.phase = 7; }
                    }
                }
            }

            // ── Phase 7: AI Mode Selection (3 cards) ────────────

            if phase == 7: VerticalLayout {
                spacing: Theme.sp-5;
                animate opacity { duration: 600ms; easing: ease-out; }

                Text {
                    text: "Choose how your AI companion operates.";
                    color: Theme.text-secondary;
                    font-size: Theme.fs-body;
                    horizontal-alignment: center;
                }

                // Three mode cards
                HorizontalLayout {
                    alignment: center;
                    spacing: Theme.sp-4;

                    // Local First card
                    TouchArea {
                        width: 170px;
                        height: 180px;
                        clicked => {
                            root.ai-mode = "local";
                            root.ai-mode-selected("local");
                            root.phase = 8;
                        }
                        Rectangle {
                            border-radius: Theme.r-lg;
                            background: root.ai-mode == "local" ? Theme.cyan-glow : Theme.hover-fill;
                            border-width: 1px;
                            border-color: root.ai-hw-recommend == "local" ? Theme.cyan : Theme.border-strong;
                            animate background { duration: Theme.dur-normal; }

                            VerticalLayout {
                                padding: Theme.sp-4;
                                spacing: Theme.sp-3;
                                alignment: center;

                                // Recommend badge
                                if root.ai-hw-recommend == "local" : HorizontalLayout {
                                    alignment: center;
                                    Rectangle {
                                        width: rec-local-txt.preferred-width + 16px;
                                        height: 20px;
                                        border-radius: 10px;
                                        background: Theme.tint-cyan;
                                        border-width: 1px;
                                        border-color: Theme.cyan-dim;
                                        rec-local-txt := Text {
                                            text: "Recommended";
                                            color: Theme.cyan;
                                            font-size: 9px;
                                            font-weight: 600;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }

                                Text {
                                    text: "\u{1F512}";
                                    font-size: 28px;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: "Local First";
                                    color: Theme.text-primary;
                                    font-size: Theme.fs-headline;
                                    font-weight: 600;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: "Private. Runs on your hardware. Needs GPU.";
                                    color: Theme.text-dim;
                                    font-size: Theme.fs-caption;
                                    horizontal-alignment: center;
                                    wrap: word-wrap;
                                }
                            }
                        }
                    }

                    // Cloud Powered card
                    TouchArea {
                        width: 170px;
                        height: 180px;
                        clicked => {
                            root.ai-mode = "cloud";
                            root.ai-mode-selected("cloud");
                            root.phase = 8;
                        }
                        Rectangle {
                            border-radius: Theme.r-lg;
                            background: root.ai-mode == "cloud" ? Theme.cyan-glow : Theme.hover-fill;
                            border-width: 1px;
                            border-color: root.ai-hw-recommend == "cloud" ? Theme.cyan : Theme.border-strong;
                            animate background { duration: Theme.dur-normal; }

                            VerticalLayout {
                                padding: Theme.sp-4;
                                spacing: Theme.sp-3;
                                alignment: center;

                                if root.ai-hw-recommend == "cloud" : HorizontalLayout {
                                    alignment: center;
                                    Rectangle {
                                        width: rec-cloud-txt.preferred-width + 16px;
                                        height: 20px;
                                        border-radius: 10px;
                                        background: Theme.tint-cyan;
                                        border-width: 1px;
                                        border-color: Theme.cyan-dim;
                                        rec-cloud-txt := Text {
                                            text: "Recommended";
                                            color: Theme.cyan;
                                            font-size: 9px;
                                            font-weight: 600;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }

                                Text {
                                    text: "\u{26A1}";
                                    font-size: 28px;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: "Cloud Powered";
                                    color: Theme.text-primary;
                                    font-size: Theme.fs-headline;
                                    font-weight: 600;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: "Fast. Powerful models. Needs API key.";
                                    color: Theme.text-dim;
                                    font-size: Theme.fs-caption;
                                    horizontal-alignment: center;
                                    wrap: word-wrap;
                                }
                            }
                        }
                    }

                    // Configure Later card
                    TouchArea {
                        width: 170px;
                        height: 180px;
                        clicked => {
                            root.ai-mode = "later";
                            root.ai-mode-selected("later");
                            root.phase = 10;  // Skip to instruction
                        }
                        Rectangle {
                            border-radius: Theme.r-lg;
                            background: Theme.hover-fill;
                            border-width: 1px;
                            border-color: Theme.border-strong;
                            animate background { duration: Theme.dur-normal; }

                            VerticalLayout {
                                padding: Theme.sp-4;
                                spacing: Theme.sp-3;
                                alignment: center;

                                Text {
                                    text: "\u{23F3}";
                                    font-size: 28px;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: "Configure Later";
                                    color: Theme.text-primary;
                                    font-size: Theme.fs-headline;
                                    font-weight: 600;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: "Use bundled fallback model. Set up anytime in Settings.";
                                    color: Theme.text-dim;
                                    font-size: Theme.fs-caption;
                                    horizontal-alignment: center;
                                    wrap: word-wrap;
                                }
                            }
                        }
                    }
                }
            }

            // ── Phase 8: Provider Setup ──────────────────────────

            if phase == 8: VerticalLayout {
                spacing: Theme.sp-4;
                animate opacity { duration: 600ms; easing: ease-out; }

                // Local path: Ollama detection
                if root.ai-mode == "local" : VerticalLayout {
                    spacing: Theme.sp-4;

                    HorizontalLayout {
                        alignment: center;
                        Rectangle {
                            width: 320px;
                            height: ollama-col.preferred-height;
                            border-radius: Theme.r-lg;
                            background: Theme.hover-fill;
                            border-width: 1px;
                            border-color: root.ai-hw-runtime-ok ? Theme.color-success.transparentize(75%) : Theme.amber-dim;

                            ollama-col := VerticalLayout {
                                padding: Theme.sp-5;
                                spacing: Theme.sp-3;

                                HorizontalLayout {
                                    spacing: Theme.sp-2;
                                    Text {
                                        text: root.ai-hw-runtime-ok ? "\u{2713}" : "\u{2717}";
                                        color: root.ai-hw-runtime-ok ? Theme.color-success : Theme.amber;
                                        font-size: Theme.fs-headline;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: root.ai-hw-runtime-ok ? "Ollama detected" : "Ollama not found";
                                        color: Theme.text-primary;
                                        font-size: Theme.fs-headline;
                                        font-weight: 600;
                                        vertical-alignment: center;
                                    }
                                }

                                if !root.ai-hw-runtime-ok : Text {
                                    text: "Install Ollama from ollama.com, then come back here or configure in Settings later.";
                                    color: Theme.text-dim;
                                    font-size: Theme.fs-caption;
                                    wrap: word-wrap;
                                }

                                if root.ai-hw-runtime-ok : Text {
                                    text: "Connected to local Ollama instance. Models will be auto-detected.";
                                    color: Theme.text-dim;
                                    font-size: Theme.fs-caption;
                                    wrap: word-wrap;
                                }
                            }
                        }
                    }

                    HorizontalLayout {
                        alignment: center;
                        spacing: Theme.sp-3;

                        PillButton {
                            label: root.ai-hw-runtime-ok ? "Test Connection →" : "Skip for now →";
                            clicked => {
                                if root.ai-hw-runtime-ok {
                                    root.ai-selected-provider = "ollama";
                                    root.ai-provider-selected("ollama");
                                    root.ai-test-connection();
                                    root.phase = 9;
                                } else {
                                    root.phase = 10;
                                }
                            }
                        }
                    }
                }

                // Cloud path: Provider cards
                if root.ai-mode == "cloud" : VerticalLayout {
                    spacing: Theme.sp-4;

                    Text {
                        text: "Select a provider and enter your API key.";
                        color: Theme.text-secondary;
                        font-size: Theme.fs-body;
                        horizontal-alignment: center;
                    }

                    // Provider selection grid
                    HorizontalLayout {
                        alignment: center;
                        spacing: Theme.sp-2;

                        for prov-item in [
                            { label: "OpenAI", value: "openai" },
                            { label: "Anthropic", value: "anthropic" },
                            { label: "Google", value: "google" },
                            { label: "DeepSeek", value: "deepseek" },
                            { label: "OpenRouter", value: "openrouter" }
                        ] : TouchArea {
                            width: 100px;
                            height: 56px;
                            clicked => {
                                root.ai-selected-provider = prov-item.value;
                            }
                            Rectangle {
                                border-radius: Theme.r-md;
                                background: root.ai-selected-provider == prov-item.value ? Theme.cyan-glow : Theme.hover-fill;
                                border-width: 1px;
                                border-color: root.ai-selected-provider == prov-item.value ? Theme.cyan : Theme.border-strong;
                                animate background { duration: Theme.dur-fast; }
                                animate border-color { duration: Theme.dur-fast; }

                                Text {
                                    text: prov-item.label;
                                    color: root.ai-selected-provider == prov-item.value ? Theme.cyan : Theme.text-secondary;
                                    font-size: Theme.fs-body;
                                    font-weight: root.ai-selected-provider == prov-item.value ? 600 : 400;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    // API Key input
                    if root.ai-selected-provider != "" : VerticalLayout {
                        spacing: Theme.sp-3;

                        HorizontalLayout {
                            alignment: center;
                            VerticalLayout {
                                width: 320px;
                                spacing: Theme.sp-1;

                                Text {
                                    text: "API Key";
                                    color: Theme.text-secondary;
                                    font-size: Theme.fs-caption;
                                }

                                Rectangle {
                                    height: 36px;
                                    border-radius: Theme.r-md;
                                    background: Theme.border-default;
                                    border-width: 1px;
                                    border-color: Theme.border-strong;
                                    clip: true;

                                    onboard-key-input := TextInput {
                                        x: Theme.sp-3;
                                        width: parent.width - Theme.sp-6;
                                        height: 100%;
                                        color: Theme.text-primary;
                                        font-size: Theme.fs-body;
                                        input-type: password;
                                        vertical-alignment: center;
                                        accepted => {
                                            root.ai-api-key-input = self.text;
                                        }
                                        edited => {
                                            root.ai-api-key-input = self.text;
                                        }
                                    }

                                    if onboard-key-input.text == "" : Text {
                                        x: Theme.sp-3;
                                        text: "sk-... or your API key";
                                        color: Theme.text-dim;
                                        font-size: Theme.fs-body;
                                        vertical-alignment: center;
                                        opacity: 0.5;
                                    }
                                }
                            }
                        }

                        HorizontalLayout {
                            alignment: center;
                            spacing: Theme.sp-3;

                            PillButton {
                                label: "Validate & Test →";
                                enabled: root.ai-api-key-input != "";
                                clicked => {
                                    root.ai-provider-selected(root.ai-selected-provider);
                                    root.ai-api-key-submitted(root.ai-selected-provider, root.ai-api-key-input);
                                    root.ai-test-connection();
                                    root.phase = 9;
                                }
                            }
                        }
                    }
                }
            }

            // ── Phase 9: Test + Confirmation ─────────────────────

            if phase == 9: VerticalLayout {
                spacing: Theme.sp-5;
                animate opacity { duration: 600ms; easing: ease-out; }

                HorizontalLayout {
                    alignment: center;
                    VerticalLayout {
                        width: 340px;
                        spacing: Theme.sp-4;

                        // Test status card
                        Rectangle {
                            height: test-card-col.preferred-height;
                            border-radius: Theme.r-lg;
                            background: root.ai-test-status == "success" ? Theme.color-success.transparentize(94%)
                                      : root.ai-test-status == "testing" ? Theme.hover-fill
                                      : Theme.color-danger.transparentize(94%);
                            border-width: 1px;
                            border-color: root.ai-test-status == "success" ? Theme.color-success.transparentize(81%)
                                        : root.ai-test-status == "testing" ? Theme.border-strong
                                        : Theme.color-danger.transparentize(81%);

                            test-card-col := VerticalLayout {
                                padding: Theme.sp-5;
                                spacing: Theme.sp-3;

                                // Status indicator
                                HorizontalLayout {
                                    alignment: center;
                                    spacing: Theme.sp-2;

                                    Text {
                                        text: root.ai-test-status == "success" ? "\u{2713}"
                                            : root.ai-test-status == "testing" ? "\u{25CB}"
                                            : "\u{2717}";
                                        color: root.ai-test-status == "success" ? Theme.color-success
                                             : root.ai-test-status == "testing" ? Theme.amber
                                             : Theme.color-emotional;
                                        font-size: 24px;
                                    }

                                    Text {
                                        text: root.ai-test-status == "success" ? "Your AI is ready!"
                                            : root.ai-test-status == "testing" ? "Sending test prompt..."
                                            : "Connection failed";
                                        color: root.ai-test-status == "success" ? Theme.color-success
                                             : root.ai-test-status == "testing" ? Theme.amber
                                             : Theme.color-emotional;
                                        font-size: Theme.fs-headline;
                                        font-weight: 600;
                                    }
                                }

                                // Metrics (shown on success)
                                if root.ai-test-status == "success" : VerticalLayout {
                                    spacing: Theme.sp-2;
                                    Rectangle { height: 1px; background: Theme.separator; }

                                    HorizontalLayout {
                                        Text {
                                            text: "Model";
                                            color: Theme.text-dim;
                                            font-size: Theme.fs-caption;
                                            horizontal-stretch: 1;
                                        }
                                        Text {
                                            text: root.ai-test-model;
                                            color: Theme.accent;
                                            font-size: Theme.fs-caption;
                                            font-weight: 500;
                                        }
                                    }
                                    HorizontalLayout {
                                        Text {
                                            text: "Latency";
                                            color: Theme.text-dim;
                                            font-size: Theme.fs-caption;
                                            horizontal-stretch: 1;
                                        }
                                        Text {
                                            text: root.ai-test-latency-ms + "ms";
                                            color: root.ai-test-latency-ms < 300 ? Theme.color-success : Theme.amber;
                                            font-size: Theme.fs-caption;
                                            font-weight: 500;
                                        }
                                    }
                                    HorizontalLayout {
                                        Text {
                                            text: "Privacy";
                                            color: Theme.text-dim;
                                            font-size: Theme.fs-caption;
                                            horizontal-stretch: 1;
                                        }
                                        Text {
                                            text: root.ai-test-privacy == "local" ? "\u{1F512} Local only" : "\u{2601} Cloud";
                                            color: root.ai-test-privacy == "local" ? Theme.color-success : Theme.holo-blue;
                                            font-size: Theme.fs-caption;
                                            font-weight: 500;
                                        }
                                    }
                                }

                                // Error message + fallback button
                                if root.ai-test-status != "" && root.ai-test-status != "success" && root.ai-test-status != "testing" : VerticalLayout {
                                    spacing: Theme.sp-2;
                                    Text {
                                        text: root.ai-test-status;
                                        color: Theme.text-dim;
                                        font-size: Theme.fs-caption;
                                        wrap: word-wrap;
                                    }
                                }
                            }
                        }

                        // Action buttons
                        HorizontalLayout {
                            alignment: center;
                            spacing: Theme.sp-3;

                            if root.ai-test-status == "success" : PillButton {
                                label: "Continue →";
                                clicked => { root.phase = 10; }
                            }

                            if root.ai-test-status != "" && root.ai-test-status != "success" && root.ai-test-status != "testing" : PillButton {
                                label: "Use offline fallback →";
                                clicked => {
                                    root.ai-mode = "later";
                                    root.ai-skip-setup();
                                    root.phase = 10;
                                }
                            }

                            if root.ai-test-status != "" && root.ai-test-status != "success" && root.ai-test-status != "testing" : PillButton {
                                label: "← Retry";
                                clicked => { root.phase = 8; }
                            }
                        }
                    }
                }
            }

            // ── Phase 10: Instruction (non-installer) / Install summary (installer) ──

            if phase == 10 && !root.installer-mode: VerticalLayout {
                spacing: Theme.sp-3;
                animate opacity { duration: 1200ms; easing: ease-out; }

                Text {
                    text: "Press Super to talk to me about anything.";
                    color: Theme.text-dim;
                    font-size: Theme.fs-body;
                    letter-spacing: 1px;
                    horizontal-alignment: center;
                    opacity: 0.7;
                }

                Text {
                    text: "or tap the orb";
                    color: Theme.text-dim;
                    font-size: Theme.fs-micro;
                    letter-spacing: 2px;
                    horizontal-alignment: center;
                    opacity: 0.4;
                }
            }

            if phase == 10 && root.installer-mode: VerticalLayout {
                spacing: Theme.sp-3;
                padding-left: 40px;
                padding-right: 40px;
                animate opacity { duration: 800ms; easing: ease-out; }

                HorizontalLayout {
                    alignment: center;
                    spacing: 40px;

                    // Left: Disk Selection
                    VerticalLayout {
                        spacing: 8px;
                        width: 360px;

                        Text {
                            text: "Select Installation Disk";
                            color: Theme.cyan;
                            font-size: Theme.fs-body;
                            font-weight: 600;
                            letter-spacing: 1px;
                        }

                        Text {
                            text: "Choose where to install Yantrik OS";
                            color: Theme.text-dim;
                            font-size: Theme.fs-caption;
                        }

                        Rectangle { height: 4px; }

                        // Disk list
                        if root.disk-1-name == "" && root.disk-2-name == "" : Text {
                            text: "Scanning for disks...";
                            color: Theme.text-dim;
                            font-size: Theme.fs-body;
                            horizontal-alignment: center;
                        }

                        // Disk 1
                        if root.disk-1-name != "": Rectangle {
                            property <bool> is-selected: root.selected-disk == root.disk-1-name;
                            width: 360px;
                            height: 64px;
                            border-radius: Theme.r-lg;
                            background: is-selected ? Theme.cyan-glow : Theme.hover-fill;
                            border-width: is-selected ? 2px : 1px;
                            border-color: is-selected ? Theme.cyan : Theme.border-default;
                            animate background, border-color { duration: Theme.dur-normal; }

                            TouchArea { clicked => { root.selected-disk = root.disk-1-name; } }

                            HorizontalLayout {
                                padding: 12px;
                                spacing: 12px;

                                VerticalLayout {
                                    alignment: center;
                                    Rectangle {
                                        width: 18px; height: 18px; border-radius: 9px;
                                        border-width: 2px;
                                        border-color: is-selected ? Theme.cyan : Theme.border-strong;
                                        Rectangle {
                                            x: 4px; y: 4px; width: 10px; height: 10px;
                                            border-radius: 5px;
                                            background: is-selected ? Theme.cyan : transparent;
                                        }
                                    }
                                }

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 2px;
                                    Text {
                                        text: "/dev/" + root.disk-1-name + "  (" + root.disk-1-size + ")";
                                        color: Theme.text-primary;
                                        font-size: Theme.fs-body;
                                        font-weight: 500;
                                    }
                                    Text {
                                        text: root.disk-1-model;
                                        color: Theme.text-dim;
                                        font-size: Theme.fs-caption;
                                    }
                                }
                            }
                        }

                        // Disk 2
                        if root.disk-2-name != "": Rectangle {
                            property <bool> is-selected: root.selected-disk == root.disk-2-name;
                            width: 360px;
                            height: 64px;
                            border-radius: Theme.r-lg;
                            background: is-selected ? Theme.cyan-glow : Theme.hover-fill;
                            border-width: is-selected ? 2px : 1px;
                            border-color: is-selected ? Theme.cyan : Theme.border-default;
                            animate background, border-color { duration: Theme.dur-normal; }

                            TouchArea { clicked => { root.selected-disk = root.disk-2-name; } }

                            HorizontalLayout {
                                padding: 12px;
                                spacing: 12px;

                                VerticalLayout {
                                    alignment: center;
                                    Rectangle {
                                        width: 18px; height: 18px; border-radius: 9px;
                                        border-width: 2px;
                                        border-color: is-selected ? Theme.cyan : Theme.border-strong;
                                        Rectangle {
                                            x: 4px; y: 4px; width: 10px; height: 10px;
                                            border-radius: 5px;
                                            background: is-selected ? Theme.cyan : transparent;
                                        }
                                    }
                                }

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 2px;
                                    Text {
                                        text: "/dev/" + root.disk-2-name + "  (" + root.disk-2-size + ")";
                                        color: Theme.text-primary;
                                        font-size: Theme.fs-body;
                                        font-weight: 500;
                                    }
                                    Text {
                                        text: root.disk-2-model;
                                        color: Theme.text-dim;
                                        font-size: Theme.fs-caption;
                                    }
                                }
                            }
                        }

                        // Disk 3
                        if root.disk-3-name != "": Rectangle {
                            property <bool> is-selected: root.selected-disk == root.disk-3-name;
                            width: 360px;
                            height: 64px;
                            border-radius: Theme.r-lg;
                            background: is-selected ? Theme.cyan-glow : Theme.hover-fill;
                            border-width: is-selected ? 2px : 1px;
                            border-color: is-selected ? Theme.cyan : Theme.border-default;
                            animate background, border-color { duration: Theme.dur-normal; }

                            TouchArea { clicked => { root.selected-disk = root.disk-3-name; } }

                            HorizontalLayout {
                                padding: 12px;
                                spacing: 12px;

                                VerticalLayout {
                                    alignment: center;
                                    Rectangle {
                                        width: 18px; height: 18px; border-radius: 9px;
                                        border-width: 2px;
                                        border-color: is-selected ? Theme.cyan : Theme.border-strong;
                                        Rectangle {
                                            x: 4px; y: 4px; width: 10px; height: 10px;
                                            border-radius: 5px;
                                            background: is-selected ? Theme.cyan : transparent;
                                        }
                                    }
                                }

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 2px;
                                    Text {
                                        text: "/dev/" + root.disk-3-name + "  (" + root.disk-3-size + ")";
                                        color: Theme.text-primary;
                                        font-size: Theme.fs-body;
                                        font-weight: 500;
                                    }
                                    Text {
                                        text: root.disk-3-model;
                                        color: Theme.text-dim;
                                        font-size: Theme.fs-caption;
                                    }
                                }
                            }
                        }

                        Rectangle { height: 8px; }

                        // Erase mode
                        Text {
                            text: "Installation Type";
                            color: Theme.cyan;
                            font-size: Theme.fs-body;
                            font-weight: 600;
                            letter-spacing: 1px;
                        }

                        // Erase entire disk option
                        Rectangle {
                            width: 360px;
                            height: 52px;
                            border-radius: Theme.r-lg;
                            background: root.erase-mode == "full" ? Theme.cyan-glow : Theme.hover-fill;
                            border-width: root.erase-mode == "full" ? 2px : 1px;
                            border-color: root.erase-mode == "full" ? Theme.cyan : Theme.border-default;

                            TouchArea {
                                clicked => { root.erase-mode = "full"; }
                            }

                            HorizontalLayout {
                                padding: 12px;
                                spacing: 12px;

                                VerticalLayout {
                                    alignment: center;
                                    Rectangle {
                                        width: 18px; height: 18px;
                                        border-radius: 9px;
                                        border-width: 2px;
                                        border-color: root.erase-mode == "full" ? Theme.cyan : Theme.border-strong;
                                        Rectangle {
                                            x: 4px; y: 4px;
                                            width: 10px; height: 10px;
                                            border-radius: 5px;
                                            background: root.erase-mode == "full" ? Theme.cyan : transparent;
                                        }
                                    }
                                }

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 2px;
                                    Text {
                                        text: "Erase disk and install Yantrik OS";
                                        color: Theme.text-primary;
                                        font-size: Theme.fs-body;
                                        font-weight: 500;
                                    }
                                    Text {
                                        text: "All data on the selected disk will be erased";
                                        color: Theme.text-dim;
                                        font-size: Theme.fs-micro;
                                    }
                                }
                            }
                        }
                    }

                    // Right: Summary
                    VerticalLayout {
                        spacing: 8px;
                        width: 300px;

                        Text {
                            text: "Installation Summary";
                            color: Theme.cyan;
                            font-size: Theme.fs-body;
                            font-weight: 600;
                            letter-spacing: 1px;
                        }

                        Rectangle { height: 4px; }

                        Rectangle {
                            width: 300px;
                            border-radius: Theme.r-lg;
                            background: Theme.hover-fill;
                            border-width: 1px;
                            border-color: Theme.border-default;
                            height: install-summary-col.preferred-height;

                            install-summary-col := VerticalLayout {
                                padding: 16px;
                                spacing: 10px;

                                HorizontalLayout {
                                    Text { text: "User"; color: Theme.text-dim; font-size: Theme.fs-caption; horizontal-stretch: 1; }
                                    Text { text: root.input-user-name != "" ? root.input-user-name : root.input-username; color: Theme.text-primary; font-size: Theme.fs-caption; font-weight: 500; }
                                }

                                HorizontalLayout {
                                    Text { text: "Login"; color: Theme.text-dim; font-size: Theme.fs-caption; horizontal-stretch: 1; }
                                    Text { text: root.input-username; color: Theme.text-primary; font-size: Theme.fs-caption; font-weight: 500; }
                                }

                                HorizontalLayout {
                                    Text { text: "Host"; color: Theme.text-dim; font-size: Theme.fs-caption; horizontal-stretch: 1; }
                                    Text { text: root.input-hostname; color: Theme.text-primary; font-size: Theme.fs-caption; font-weight: 500; }
                                }

                                HorizontalLayout {
                                    Text { text: "Disk"; color: Theme.text-dim; font-size: Theme.fs-caption; horizontal-stretch: 1; }
                                    Text {
                                        text: root.selected-disk != "" ? "/dev/" + root.selected-disk : "Auto-detect";
                                        color: Theme.text-primary; font-size: Theme.fs-caption; font-weight: 500;
                                    }
                                }

                                HorizontalLayout {
                                    Text { text: "Companion"; color: Theme.text-dim; font-size: Theme.fs-caption; horizontal-stretch: 1; }
                                    Text {
                                        text: root.input-companion-name != "" ? root.input-companion-name : root.companion-name;
                                        color: Theme.amber; font-size: Theme.fs-caption; font-weight: 500;
                                    }
                                }

                                Rectangle { height: 1px; background: Theme.separator; }

                                Text {
                                    text: "\u{26A0} This will erase the selected disk.\nAll existing data will be permanently lost.";
                                    color: Theme.amber;
                                    font-size: Theme.fs-micro;
                                    horizontal-alignment: center;
                                    wrap: word-wrap;
                                }
                            }
                        }
                    }
                }

                if root.install-error != "": Text {
                    text: root.install-error;
                    color: Theme.amber;
                    font-size: Theme.fs-caption;
                    horizontal-alignment: center;
                }

                Rectangle { height: Theme.sp-2; }

                HorizontalLayout {
                    alignment: center;
                    spacing: Theme.sp-3;

                    PillButton {
                        label: "\u{2190} Back";
                        clicked => { root.phase = 9; }
                    }

                    PillButton {
                        label: "Install Now";
                        width: 180px;
                        clicked => {
                            root.install-error = "";
                            root.installing = true;
                            // Don't reset install-progress here — would break parent binding
                            root.install-to-disk(
                                root.input-username, root.input-password,
                                root.input-user-name, root.input-hostname,
                                root.input-companion-name != "" ? root.input-companion-name : root.companion-name,
                                root.selected-disk
                            );
                            root.phase = 11;
                        }
                    }
                }
            }

            // ── Phase 11: Installation progress (installer only) ─────

            if phase == 11: VerticalLayout {
                spacing: Theme.sp-4;
                animate opacity { duration: 600ms; easing: ease-out; }

                // Progress bar
                HorizontalLayout {
                    alignment: center;
                    Rectangle {
                        width: 340px;
                        height: 6px;
                        border-radius: 3px;
                        background: Theme.hover-fill-strong;

                        Rectangle {
                            width: parent.width * root.install-progress / 100;
                            height: parent.height;
                            border-radius: 3px;
                            background: Theme.cyan;
                            drop-shadow-blur: 6px;
                            drop-shadow-color: Theme.cyan-glow;
                            animate width { duration: 300ms; }
                        }
                    }
                }

                // Percentage
                Text {
                    text: root.install-progress + "%";
                    color: Theme.cyan;
                    font-size: Theme.fs-headline;
                    font-weight: 600;
                    horizontal-alignment: center;
                }

                // Status text
                Text {
                    text: root.install-status;
                    color: Theme.text-secondary;
                    font-size: Theme.fs-body;
                    horizontal-alignment: center;
                }

                // Step checklist
                HorizontalLayout {
                    alignment: center;
                    VerticalLayout {
                        width: 280px;
                        spacing: Theme.sp-2;

                        HorizontalLayout {
                            spacing: Theme.sp-3;
                            Text {
                                text: root.install-progress >= 10 ? "\u{2713}" : "\u{25CB}";
                                color: root.install-progress >= 10 ? Theme.color-success : Theme.text-dim;
                                font-size: Theme.fs-body;
                                width: 20px;
                            }
                            Text {
                                text: "Partitioning disk";
                                color: root.install-progress >= 10 ? Theme.text-primary : Theme.text-dim;
                                font-size: Theme.fs-body;
                            }
                        }

                        HorizontalLayout {
                            spacing: Theme.sp-3;
                            Text {
                                text: root.install-progress >= 25 ? "\u{2713}" : "\u{25CB}";
                                color: root.install-progress >= 25 ? Theme.color-success : Theme.text-dim;
                                font-size: Theme.fs-body;
                                width: 20px;
                            }
                            Text {
                                text: "Formatting";
                                color: root.install-progress >= 25 ? Theme.text-primary : Theme.text-dim;
                                font-size: Theme.fs-body;
                            }
                        }

                        HorizontalLayout {
                            spacing: Theme.sp-3;
                            Text {
                                text: root.install-progress >= 60 ? "\u{2713}" : "\u{25CB}";
                                color: root.install-progress >= 60 ? Theme.color-success : Theme.text-dim;
                                font-size: Theme.fs-body;
                                width: 20px;
                            }
                            Text {
                                text: "Copying files";
                                color: root.install-progress >= 60 ? Theme.text-primary : Theme.text-dim;
                                font-size: Theme.fs-body;
                            }
                        }

                        HorizontalLayout {
                            spacing: Theme.sp-3;
                            Text {
                                text: root.install-progress >= 80 ? "\u{2713}" : "\u{25CB}";
                                color: root.install-progress >= 80 ? Theme.color-success : Theme.text-dim;
                                font-size: Theme.fs-body;
                                width: 20px;
                            }
                            Text {
                                text: "Installing bootloader";
                                color: root.install-progress >= 80 ? Theme.text-primary : Theme.text-dim;
                                font-size: Theme.fs-body;
                            }
                        }

                        HorizontalLayout {
                            spacing: Theme.sp-3;
                            Text {
                                text: root.install-progress >= 95 ? "\u{2713}" : "\u{25CB}";
                                color: root.install-progress >= 95 ? Theme.color-success : Theme.text-dim;
                                font-size: Theme.fs-body;
                                width: 20px;
                            }
                            Text {
                                text: "Configuring system";
                                color: root.install-progress >= 95 ? Theme.text-primary : Theme.text-dim;
                                font-size: Theme.fs-body;
                            }
                        }

                        HorizontalLayout {
                            spacing: Theme.sp-3;
                            Text {
                                text: root.install-progress >= 100 ? "\u{2713}" : "\u{25CB}";
                                color: root.install-progress >= 100 ? Theme.color-success : Theme.text-dim;
                                font-size: Theme.fs-body;
                                width: 20px;
                            }
                            Text {
                                text: "Complete";
                                color: root.install-progress >= 100 ? Theme.color-success : Theme.text-dim;
                                font-size: Theme.fs-body;
                                font-weight: root.install-progress >= 100 ? 600 : 400;
                            }
                        }
                    }
                }
            }

            // ── Phase 12: Installation complete (installer only) ─────

            if phase == 12: VerticalLayout {
                spacing: Theme.sp-5;
                animate opacity { duration: 800ms; easing: ease-out; }

                Text {
                    text: "Yantrik OS has been installed successfully.";
                    color: Theme.text-secondary;
                    font-size: Theme.fs-body;
                    horizontal-alignment: center;
                    letter-spacing: 1px;
                }

                HorizontalLayout {
                    alignment: center;
                    Rectangle {
                        width: 340px;
                        height: reboot-col.preferred-height;
                        border-radius: Theme.r-lg;
                        background: Theme.hover-fill;
                        border-width: 1px;
                        border-color: Theme.color-success.transparentize(75%);

                        reboot-col := VerticalLayout {
                            padding: Theme.sp-5;
                            spacing: Theme.sp-3;
                            alignment: center;

                            Text {
                                text: "\u{2713}";
                                color: Theme.color-success;
                                font-size: 48px;
                                horizontal-alignment: center;
                            }

                            Text {
                                text: "Remove the installation media and reboot to start using Yantrik OS.";
                                color: Theme.text-secondary;
                                font-size: Theme.fs-body;
                                horizontal-alignment: center;
                                wrap: word-wrap;
                            }
                        }
                    }
                }

                HorizontalLayout {
                    alignment: center;
                    PillButton {
                        label: "Reboot";
                        width: 180px;
                        clicked => {
                            root.install-reboot();
                        }
                    }
                }
            }
        }
    }

    // Ready orb tap area (only in non-installer mode after instruction shown)
    if phase == 10 && !root.installer-mode: TouchArea {
        width: 100%;
        height: 100%;
        clicked => { root.ready(); }
    }

    // Skip link — bottom right
    TouchArea {
        x: root.width - 80px;
        y: root.height - 40px;
        width: 60px;
        height: 24px;
        clicked => { root.skip(); }

        Text {
            text: "Skip";
            color: Theme.text-dim;
            font-size: Theme.fs-micro;
            horizontal-alignment: right;
            vertical-alignment: center;
            opacity: phase >= 3 && phase < 10 && !root.installing ? 0.4 : 0;
            animate opacity { duration: Theme.dur-slow; }
        }
    }

    // ── Helper: build comma-separated interest string ─────────────

    pure function build-interests() -> string {
        // Slint doesn't have string concat loops, so we build manually
        // Each interest name matches the PWG Interest node convention
        (int-technology ? "technology," : "") +
        (int-finance ? "finance," : "") +
        (int-sports ? "sports," : "") +
        (int-music ? "music," : "") +
        (int-politics ? "politics," : "") +
        (int-health ? "health," : "") +
        (int-food ? "food," : "") +
        (int-science ? "science," : "") +
        (int-gaming ? "gaming," : "") +
        (int-travel ? "travel," : "") +
        (int-fashion ? "fashion," : "") +
        (int-business ? "business," : "") +
        (int-entertainment ? "entertainment," : "") +
        (int-auto ? "automotive," : "")
    }
}
