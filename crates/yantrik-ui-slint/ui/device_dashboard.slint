// Device Dashboard — hardware device overview. Screen 27.

import { Theme } from "theme.slint";

// ── Data structs ──

export struct UsbDeviceData {
    bus: string,
    device-id: string,
    vendor-product: string,
    description: string,
    is-selected: bool,
}

export struct PciDeviceData {
    slot: string,
    class-name: string,
    vendor: string,
    device-name: string,
    class-color: color,
}

export struct InputDeviceData {
    name: string,
    handler: string,
    device-type: string,
    phys: string,
}

export struct StorageDeviceData {
    name: string,
    size-text: string,
    device-type: string,
    mountpoint: string,
    filesystem: string,
    usage-percent: float,
    smart-status: string,
}

export struct DisplayDeviceData {
    name: string,
    resolution: string,
    connector: string,
    status: string,
}

// ── Tab button component ──

component DevTabButton inherits TouchArea {
    in property <string> label;
    in property <bool> active;
    in property <string> icon;
    height: 44px;

    Rectangle {
        background: active ? Theme.bg-elevated : (parent.has-hover ? Theme.hover-fill : transparent);

        HorizontalLayout {
            spacing: Theme.sp-2;
            padding-left: Theme.sp-4;
            padding-right: Theme.sp-4;
            alignment: center;

            Text {
                text: icon;
                color: active ? Theme.accent : Theme.text-secondary;
                font-size: Theme.fs-title-2;
                vertical-alignment: center;
            }
            Text {
                text: label;
                color: active ? Theme.accent : Theme.text-secondary;
                font-size: Theme.fs-body;
                font-weight: active ? 600 : 400;
                vertical-alignment: center;
            }
        }

        // Bottom accent line
        if active : Rectangle {
            y: parent.height - 2px;
            width: 100%;
            height: 2px;
            background: Theme.accent;
        }
    }
}

// ── Refresh button ──

component RefreshButton inherits TouchArea {
    height: 36px;
    width: 100px;

    Rectangle {
        border-radius: Theme.r-lg;
        background: parent.has-hover ? Theme.hover-fill-strong : Theme.bg-elevated;
        border-width: 1px;
        border-color: Theme.border-subtle;

        HorizontalLayout {
            padding-left: Theme.sp-3;
            padding-right: Theme.sp-3;
            alignment: center;
            spacing: Theme.r-sm;

            Text {
                text: "\u{21BB}";
                color: Theme.accent;
                font-size: Theme.fs-title-2;
                vertical-alignment: center;
            }
            Text {
                text: "Refresh";
                color: Theme.text-primary;
                font-size: Theme.fs-caption;
                font-weight: 600;
                vertical-alignment: center;
            }
        }
    }
}

// ── Export button ──

component ExportButton inherits TouchArea {
    height: 36px;
    width: 100px;

    Rectangle {
        border-radius: Theme.r-lg;
        background: parent.has-hover ? Theme.hover-fill-strong : Theme.bg-elevated;
        border-width: 1px;
        border-color: Theme.border-subtle;

        HorizontalLayout {
            padding-left: Theme.sp-3;
            padding-right: Theme.sp-3;
            alignment: center;
            spacing: Theme.r-sm;

            Text {
                text: "\u{1F4E5}";
                font-size: Theme.fs-body;
                vertical-alignment: center;
            }
            Text {
                text: "Export";
                color: Theme.text-primary;
                font-size: Theme.fs-caption;
                font-weight: 600;
                vertical-alignment: center;
            }
        }
    }
}

// ── Device type badge ──

component TypeBadge inherits Rectangle {
    in property <string> label;
    in property <color> badge-color: Theme.accent;
    height: 22px;
    width: badge-text.preferred-width + Theme.sp-4;
    border-radius: Theme.sp-1;
    background: badge-color.with-alpha(0.15);

    badge-text := Text {
        text: label;
        color: badge-color;
        font-size: Theme.fs-micro;
        font-weight: 600;
        vertical-alignment: center;
        horizontal-alignment: center;
    }
}

// ── SMART status badge ──

component SmartBadge inherits Rectangle {
    in property <string> status;
    height: 22px;
    width: smart-text.preferred-width + Theme.sp-4;
    border-radius: Theme.sp-1;
    background: status == "Healthy" ? Theme.color-success.with-alpha(0.15)
              : status == "Warning" ? Theme.color-warning.with-alpha(0.15)
              : status == "Critical" ? Theme.color-danger.with-alpha(0.15)
              : Theme.text-dim.with-alpha(0.10);

    smart-text := Text {
        text: status != "" ? status : "N/A";
        color: status == "Healthy" ? Theme.color-success
             : status == "Warning" ? Theme.color-warning
             : status == "Critical" ? Theme.color-danger
             : Theme.text-dim;
        font-size: Theme.fs-micro;
        font-weight: 600;
        vertical-alignment: center;
        horizontal-alignment: center;
    }
}

// ── Usage bar ──

component UsageBar inherits Rectangle {
    in property <float> percent;
    in property <color> bar-color: Theme.accent;
    height: 6px;
    border-radius: 3px;
    background: Theme.bg-deep;

    Rectangle {
        x: 0;
        y: 0;
        width: parent.width * clamp(percent / 100.0, 0.0, 1.0);
        height: parent.height;
        border-radius: 3px;
        background: percent > 90 ? Theme.color-emotional : percent > 70 ? Theme.color-conflict : bar-color;
    }
}

// ── USB device row ──

component UsbDeviceRow inherits TouchArea {
    in property <UsbDeviceData> data;
    height: 52px;

    Rectangle {
        background: data.is-selected ? Theme.bg-selected
                  : parent.has-hover ? Theme.hover-fill
                  : transparent;
        border-radius: Theme.r-sm;

        HorizontalLayout {
            spacing: Theme.sp-3;
            padding-left: Theme.sp-4;
            padding-right: Theme.sp-4;

            // Bus badge
            Rectangle {
                width: 52px;
                height: 24px;
                border-radius: Theme.sp-1;
                background: Theme.holo-blue.with-alpha(0.12);

                Text {
                    text: data.bus;
                    color: Theme.holo-blue;
                    font-size: Theme.fs-micro;
                    font-weight: 600;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                }
            }

            // Vendor:Product ID
            Text {
                text: data.vendor-product;
                color: Theme.accent;
                font-size: Theme.fs-caption;
                font-family: "monospace";
                vertical-alignment: center;
                width: 100px;
            }

            // Description
            Text {
                text: data.description;
                color: Theme.text-primary;
                font-size: Theme.fs-body;
                vertical-alignment: center;
                overflow: elide;
                horizontal-stretch: 1;
            }

            // Device ID
            Text {
                text: data.device-id;
                color: Theme.text-dim;
                font-size: Theme.fs-caption;
                vertical-alignment: center;
                width: 60px;
                horizontal-alignment: right;
            }
        }
    }
}

// ── PCI device row ──

component PciDeviceRow inherits TouchArea {
    in property <PciDeviceData> data;
    in property <bool> is-selected: false;
    height: 52px;

    Rectangle {
        background: is-selected ? Theme.bg-selected
                  : parent.has-hover ? Theme.hover-fill
                  : transparent;
        border-radius: Theme.r-sm;

        HorizontalLayout {
            spacing: Theme.sp-3;
            padding-left: Theme.sp-4;
            padding-right: Theme.sp-4;

            // Slot
            Text {
                text: data.slot;
                color: Theme.text-dim;
                font-size: Theme.fs-caption;
                font-family: "monospace";
                vertical-alignment: center;
                width: 80px;
            }

            // Class badge
            TypeBadge {
                label: data.class-name;
                badge-color: data.class-color;
            }

            // Device name
            Text {
                text: data.device-name;
                color: Theme.text-primary;
                font-size: Theme.fs-body;
                vertical-alignment: center;
                overflow: elide;
                horizontal-stretch: 1;
            }

            // Vendor
            Text {
                text: data.vendor;
                color: Theme.text-secondary;
                font-size: Theme.fs-caption;
                vertical-alignment: center;
                width: 120px;
                horizontal-alignment: right;
                overflow: elide;
            }
        }
    }
}

// ── Input device row ──

component InputDeviceRow inherits Rectangle {
    in property <InputDeviceData> data;
    height: 56px;
    background: transparent;
    border-radius: Theme.r-sm;

    HorizontalLayout {
        spacing: Theme.sp-3;
        padding-left: Theme.sp-4;
        padding-right: Theme.sp-4;

        // Device type icon
        Rectangle {
            width: 36px;
            height: 36px;
            border-radius: Theme.r-md;
            background: data.device-type == "keyboard" ? Theme.holo-blue.with-alpha(0.12)
                      : data.device-type == "mouse" ? Theme.accent.with-alpha(0.12)
                      : data.device-type == "touchpad" ? Theme.color-pattern.with-alpha(0.12)
                      : Theme.text-dim.with-alpha(0.12);

            Text {
                text: data.device-type == "keyboard" ? "\u{2328}"
                    : data.device-type == "mouse" ? "\u{1F5B1}"
                    : data.device-type == "touchpad" ? "\u{261F}"
                    : "\u{2699}";
                font-size: Theme.fs-title-1;
                color: data.device-type == "keyboard" ? Theme.holo-blue
                     : data.device-type == "mouse" ? Theme.accent
                     : data.device-type == "touchpad" ? Theme.color-pattern
                     : Theme.text-dim;
                vertical-alignment: center;
                horizontal-alignment: center;
            }
        }

        // Name + handler
        VerticalLayout {
            spacing: 2px;
            horizontal-stretch: 1;

            Text {
                text: data.name;
                color: Theme.text-primary;
                font-size: Theme.fs-body;
                vertical-alignment: center;
                overflow: elide;
            }
            Text {
                text: data.handler;
                color: Theme.text-secondary;
                font-size: Theme.fs-caption;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        // Type badge
        TypeBadge {
            label: data.device-type;
            badge-color: data.device-type == "keyboard" ? Theme.holo-blue
                       : data.device-type == "mouse" ? Theme.accent
                       : data.device-type == "touchpad" ? Theme.color-pattern
                       : Theme.text-dim;
        }

        // Phys
        Text {
            text: data.phys;
            color: Theme.text-dim;
            font-size: Theme.fs-caption;
            font-family: "monospace";
            vertical-alignment: center;
            width: 140px;
            horizontal-alignment: right;
            overflow: elide;
        }
    }
}

// ── Storage device row ──

component StorageDeviceRow inherits Rectangle {
    in property <StorageDeviceData> data;
    height: 62px;
    background: transparent;
    border-radius: Theme.r-sm;

    HorizontalLayout {
        spacing: Theme.sp-3;
        padding-left: Theme.sp-4;
        padding-right: Theme.sp-4;

        // Device icon
        Rectangle {
            width: 36px;
            height: 36px;
            border-radius: Theme.r-md;
            background: data.device-type == "disk" ? Theme.accent.with-alpha(0.12)
                      : data.device-type == "part" ? Theme.holo-blue.with-alpha(0.12)
                      : data.device-type == "lvm" ? Theme.color-pattern.with-alpha(0.12)
                      : Theme.text-dim.with-alpha(0.12);

            Text {
                text: data.device-type == "disk" ? "\u{1F4BD}"
                    : data.device-type == "rom" ? "\u{1F4BF}"
                    : "\u{1F4C1}";
                font-size: Theme.fs-title-1;
                color: Theme.text-primary;
                vertical-alignment: center;
                horizontal-alignment: center;
            }
        }

        // Name + mountpoint
        VerticalLayout {
            spacing: 2px;
            horizontal-stretch: 1;

            HorizontalLayout {
                spacing: Theme.sp-2;
                Text {
                    text: data.name;
                    color: Theme.text-primary;
                    font-size: Theme.fs-body;
                    font-weight: 600;
                    vertical-alignment: center;
                }
                TypeBadge {
                    label: data.device-type;
                    badge-color: data.device-type == "disk" ? Theme.accent
                               : data.device-type == "part" ? Theme.holo-blue
                               : data.device-type == "lvm" ? Theme.color-pattern
                               : Theme.text-dim;
                }
            }

            HorizontalLayout {
                spacing: Theme.sp-3;
                Text {
                    text: data.mountpoint != "" ? data.mountpoint : "(not mounted)";
                    color: data.mountpoint != "" ? Theme.text-secondary : Theme.text-dim;
                    font-size: Theme.fs-caption;
                    vertical-alignment: center;
                }
                Text {
                    text: data.filesystem;
                    color: Theme.text-dim;
                    font-size: Theme.fs-caption;
                    vertical-alignment: center;
                }
            }
        }

        // SMART status badge
        if data.smart-status != "" : SmartBadge {
            status: data.smart-status;
        }

        // Size
        Text {
            text: data.size-text;
            color: Theme.text-primary;
            font-size: Theme.fs-body;
            font-weight: 600;
            vertical-alignment: center;
            width: 80px;
            horizontal-alignment: right;
        }

        // Usage bar
        VerticalLayout {
            width: 100px;
            spacing: 2px;

            UsageBar {
                percent: data.usage-percent;
                bar-color: Theme.accent;
            }
            Text {
                text: data.usage-percent > 0 ? "\{round(data.usage-percent)}%" : "";
                color: data.usage-percent > 90 ? Theme.color-emotional
                     : data.usage-percent > 70 ? Theme.color-conflict
                     : Theme.text-secondary;
                font-size: Theme.fs-micro;
                horizontal-alignment: right;
                vertical-alignment: center;
            }
        }
    }
}

// ── Display device row ──

component DisplayDeviceRow inherits Rectangle {
    in property <DisplayDeviceData> data;
    height: 56px;
    background: transparent;
    border-radius: Theme.r-sm;

    HorizontalLayout {
        spacing: Theme.sp-3;
        padding-left: Theme.sp-4;
        padding-right: Theme.sp-4;

        // Status indicator
        Rectangle {
            width: 10px;
            height: 10px;
            border-radius: 5px;
            background: data.status == "connected" ? Theme.color-success : Theme.text-dim;
        }

        // Connector
        Text {
            text: data.connector;
            color: Theme.accent;
            font-size: Theme.fs-body;
            font-weight: 600;
            vertical-alignment: center;
            width: 100px;
        }

        // Name
        Text {
            text: data.name;
            color: Theme.text-primary;
            font-size: Theme.fs-body;
            vertical-alignment: center;
            horizontal-stretch: 1;
            overflow: elide;
        }

        // Resolution
        Text {
            text: data.resolution;
            color: data.resolution != "" ? Theme.holo-blue : Theme.text-dim;
            font-size: Theme.fs-body;
            font-family: "monospace";
            vertical-alignment: center;
            width: 140px;
            horizontal-alignment: right;
        }

        // Status badge
        TypeBadge {
            label: data.status;
            badge-color: data.status == "connected" ? Theme.color-success : Theme.text-dim;
        }
    }
}

// ── Section header ──

component SectionHeader inherits Rectangle {
    in property <string> title;
    in property <int> count: 0;
    height: 36px;
    background: transparent;

    HorizontalLayout {
        padding-left: Theme.sp-4;
        padding-right: Theme.sp-4;
        spacing: Theme.sp-2;

        Text {
            text: title;
            color: Theme.text-secondary;
            font-size: Theme.fs-caption;
            font-weight: 700;
            vertical-alignment: center;
            letter-spacing: 0.8px;
        }
        if count > 0 : Rectangle {
            width: 28px;
            height: 20px;
            border-radius: 10px;
            background: Theme.accent.with-alpha(0.15);

            Text {
                text: count;
                color: Theme.accent;
                font-size: Theme.fs-micro;
                font-weight: 600;
                vertical-alignment: center;
                horizontal-alignment: center;
            }
        }
        Rectangle { horizontal-stretch: 1; }
    }
}

// ── Empty state ──

component EmptyState inherits Rectangle {
    in property <string> message: "No devices found";
    height: 120px;
    background: transparent;

    Text {
        text: message;
        color: Theme.text-dim;
        font-size: Theme.fs-body;
        vertical-alignment: center;
        horizontal-alignment: center;
    }
}

// ── Device detail panel (right-side) ──

component DeviceDetailPanel inherits Rectangle {
    in property <string> detail-info;
    width: 320px;
    background: Theme.bg-card;
    border-width: 1px;
    border-color: Theme.border-subtle;

    callback close-detail();

    if detail-info == "" : VerticalLayout {
        alignment: center;
        Text {
            text: "Select a device to view details";
            color: Theme.text-dim;
            font-size: Theme.fs-body;
            horizontal-alignment: center;
        }
    }

    if detail-info != "" : VerticalLayout {
        padding: Theme.sp-4;
        spacing: 10px;

        HorizontalLayout {
            spacing: Theme.sp-2;
            Text {
                text: "Device Details";
                color: Theme.accent;
                font-size: Theme.fs-body;
                font-weight: 700;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }
            TouchArea {
                width: Theme.sp-6;
                height: Theme.sp-6;
                clicked => { root.close-detail(); }
                Rectangle {
                    width: Theme.sp-6; height: Theme.sp-6;
                    border-radius: Theme.r-lg;
                    background: parent.has-hover ? Theme.hover-fill : transparent;
                    Text {
                        text: "\u{2715}";
                        font-size: Theme.fs-micro;
                        color: Theme.text-dim;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        Rectangle {
            height: 1px;
            background: Theme.border-subtle;
        }

        Flickable {
            vertical-stretch: 1;
            viewport-height: detail-content.preferred-height;

            detail-content := Text {
                text: detail-info;
                color: Theme.text-secondary;
                font-size: Theme.fs-caption;
                font-family: "monospace";
                wrap: word-wrap;
                vertical-alignment: top;
            }
        }
    }
}

// ── Search bar component ──

component SearchBar inherits Rectangle {
    in-out property <string> search-text;
    callback search-changed(string);
    height: 40px;
    background: Theme.bg-elevated;
    border-radius: Theme.r-lg;
    border-width: 1px;
    border-color: Theme.border-subtle;
    clip: true;

    HorizontalLayout {
        padding-left: Theme.sp-3;
        padding-right: Theme.sp-3;
        spacing: Theme.sp-2;

        Text {
            text: "\u{1F50D}";
            font-size: Theme.fs-body;
            color: Theme.text-dim;
            vertical-alignment: center;
            width: 20px;
        }

        search-input := TextInput {
            text <=> root.search-text;
            font-size: Theme.fs-body;
            color: Theme.text-primary;
            vertical-alignment: center;
            horizontal-stretch: 1;
            edited => { root.search-changed(self.text); }
        }

        // Clear button
        if search-text != "" : TouchArea {
            width: Theme.sp-6;
            height: Theme.sp-6;
            clicked => {
                root.search-text = "";
                root.search-changed("");
            }
            Rectangle {
                width: Theme.sp-6; height: Theme.sp-6;
                border-radius: Theme.r-lg;
                background: parent.has-hover ? Theme.hover-fill : transparent;
                Text {
                    text: "\u{2715}";
                    font-size: Theme.fs-micro;
                    color: Theme.text-dim;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }
}

// ── Summary count chip ──

component CountChip inherits Rectangle {
    in property <int> count;
    in property <string> label;
    in property <color> chip-color: Theme.text-secondary;
    height: 26px;
    width: chip-layout.preferred-width + 20px;
    border-radius: 13px;
    background: chip-color.with-alpha(0.10);

    chip-layout := HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: Theme.sp-1;
        alignment: center;

        Text {
            text: count;
            color: chip-color;
            font-size: Theme.fs-caption;
            font-weight: 700;
            vertical-alignment: center;
        }
        Text {
            text: label;
            color: chip-color;
            font-size: Theme.fs-micro;
            font-weight: 500;
            vertical-alignment: center;
        }
    }
}

// ── Main component ──

export component DeviceDashboardScreen inherits Rectangle {
    background: Theme.bg-deep;

    // Active tab: 0=USB, 1=PCI, 2=Input, 3=Storage, 4=Display
    in-out property <int> active-tab: 0;

    // USB
    in property <[UsbDeviceData]> usb-devices: [];
    in-out property <int> usb-selected-index: -1;
    in property <string> usb-detail-text: "";

    // PCI
    in property <[PciDeviceData]> pci-devices: [];
    in-out property <int> pci-selected-index: -1;

    // Input
    in property <[InputDeviceData]> input-devices: [];

    // Storage
    in property <[StorageDeviceData]> storage-devices: [];

    // Display
    in property <[DisplayDeviceData]> display-devices: [];
    in property <string> gpu-info: "";

    // Scanning state
    in property <bool> scanning: false;

    // Device detail panel
    in property <string> selected-device-info: "";

    // Search
    in-out property <string> dev-search-text: "";

    // Export status
    in property <string> dev-export-status: "";

    // Summary counts (pre-computed from backend after search filter)
    in property <string> dev-summary: "";

    // Hotplug notifications
    in property <string> dev-hotplug-notification: "";
    in property <int> dev-hotplug-count: 0;
    in-out property <bool> dev-hotplug-banner-visible: false;

    // Callbacks
    callback dev-tab(int);
    callback dev-select-usb(int);
    callback dev-select-pci(int);
    callback dev-refresh();
    callback dev-export();
    callback dev-search(string);
    callback dev-close-detail();
    callback dev-dismiss-hotplug();

    // AI Assist
    in property <bool> ai-is-working: false;
    in property <string> ai-response: "";
    in-out property <bool> ai-panel-open: false;
    callback ai-explain-pressed();
    callback ai-dismiss();

    VerticalLayout {
        spacing: 0px;

        // ── Tab bar ──
        Rectangle {
            height: 48px;
            background: Theme.bg-card;
            border-width: 0px;

            HorizontalLayout {
                spacing: 0px;

                DevTabButton {
                    label: "USB";
                    icon: "\u{1F50C}";
                    active: active-tab == 0;
                    width: 120px;
                    clicked => { root.active-tab = 0; root.dev-tab(0); }
                }
                DevTabButton {
                    label: "PCI";
                    icon: "\u{1F4E6}";
                    active: active-tab == 1;
                    width: 120px;
                    clicked => { root.active-tab = 1; root.dev-tab(1); }
                }
                DevTabButton {
                    label: "Input";
                    icon: "\u{2328}";
                    active: active-tab == 2;
                    width: 120px;
                    clicked => { root.active-tab = 2; root.dev-tab(2); }
                }
                DevTabButton {
                    label: "Storage";
                    icon: "\u{1F4BD}";
                    active: active-tab == 3;
                    width: 120px;
                    clicked => { root.active-tab = 3; root.dev-tab(3); }
                }
                DevTabButton {
                    label: "Display";
                    icon: "\u{1F5B5}";
                    active: active-tab == 4;
                    width: 120px;
                    clicked => { root.active-tab = 4; root.dev-tab(4); }
                }

                // Spacer
                Rectangle { horizontal-stretch: 1; }

                // AI Explain button
                TouchArea {
                    width: ai-dev-btn.preferred-width + 16px;
                    height: 32px;
                    clicked => {
                        if root.ai-panel-open {
                            root.ai-dismiss();
                            root.ai-panel-open = false;
                        } else {
                            root.ai-explain-pressed();
                            root.ai-panel-open = true;
                        }
                    }
                    ai-dev-btn := Rectangle {
                        height: 32px;
                        border-radius: Theme.r-pill;
                        background: root.ai-is-working ? Theme.accent
                            : (parent.has-hover ? Theme.hover-fill-strong : Theme.bg-elevated);
                        border-width: 1px;
                        border-color: Theme.border-subtle;
                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: Theme.sp-1;
                            alignment: center;
                            Text {
                                text: root.ai-is-working ? "\u{2B50}" : "\u{2728}";
                                font-size: Theme.fs-caption;
                                vertical-alignment: center;
                            }
                            Text {
                                text: root.ai-is-working ? "Analyzing..." : "AI Explain";
                                color: root.ai-is-working ? Theme.text-on-accent : Theme.text-secondary;
                                font-size: Theme.fs-micro;
                                font-weight: 500;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                // Export button
                ExportButton {
                    clicked => { root.dev-export(); }
                }

                // Refresh button
                RefreshButton {
                    clicked => { root.dev-refresh(); }
                }

                // Scanning indicator
                if scanning : Text {
                    text: "Scanning...";
                    color: Theme.accent;
                    font-size: Theme.fs-caption;
                    vertical-alignment: center;
                }

                Rectangle { width: Theme.sp-4; }
            }
        }

        // Separator
        Rectangle {
            height: 1px;
            background: Theme.border-subtle;
        }

        // ── Hotplug notification banner ──
        if root.dev-hotplug-banner-visible : Rectangle {
            height: 44px;
            background: Theme.holo-blue.with-alpha(0.12);
            border-width: 0px;

            HorizontalLayout {
                padding-left: Theme.sp-4;
                padding-right: Theme.sp-2;
                spacing: 10px;

                Text {
                    text: "\u{1F50C}";
                    font-size: Theme.fs-title-2;
                    vertical-alignment: center;
                }

                Text {
                    text: root.dev-hotplug-notification;
                    font-size: Theme.fs-body;
                    font-weight: 500;
                    color: Theme.holo-blue;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                TouchArea {
                    width: 28px;
                    height: 28px;
                    clicked => {
                        root.dev-hotplug-banner-visible = false;
                        root.dev-dismiss-hotplug();
                    }
                    Rectangle {
                        width: 28px; height: 28px;
                        border-radius: 14px;
                        background: parent.has-hover ? Theme.hover-fill-strong : transparent;

                        Text {
                            text: "\u{2715}";
                            font-size: Theme.fs-micro;
                            color: Theme.text-dim;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        // ── Search bar ──
        Rectangle {
            height: 52px;
            background: Theme.bg-card;

            HorizontalLayout {
                padding-left: Theme.sp-4;
                padding-right: Theme.sp-4;
                padding-top: Theme.r-sm;
                padding-bottom: Theme.r-sm;
                spacing: Theme.sp-3;

                SearchBar {
                    horizontal-stretch: 1;
                    search-text <=> root.dev-search-text;
                    search-changed(text) => { root.dev-search(text); }
                }

                // Export status message
                if root.dev-export-status != "" : Rectangle {
                    width: export-status-text.preferred-width + 20px;
                    height: 32px;
                    border-radius: Theme.r-sm;
                    background: Theme.color-success.with-alpha(0.15);

                    export-status-text := Text {
                        text: root.dev-export-status;
                        color: Theme.color-success;
                        font-size: Theme.fs-caption;
                        font-weight: 500;
                        vertical-alignment: center;
                        horizontal-alignment: center;
                    }
                }
            }
        }

        // Separator
        Rectangle {
            height: 1px;
            background: Theme.border-subtle;
        }

        // ── AI Response Panel ──
        if root.ai-panel-open && root.ai-response != "" : Rectangle {
            max-height: 160px;
            background: Theme.bg-elevated;
            border-width: 1px;
            border-color: Theme.accent.transparentize(70%);

            Flickable {
                viewport-height: ai-dev-resp.preferred-height + Theme.sp-4;

                ai-dev-resp := VerticalLayout {
                    padding: Theme.sp-3;
                    spacing: Theme.sp-2;

                    HorizontalLayout {
                        spacing: Theme.r-sm;
                        Text {
                            text: "\u{2728}";
                            font-size: Theme.fs-caption;
                            vertical-alignment: center;
                        }
                        Text {
                            text: "AI Analysis";
                            color: Theme.accent;
                            font-size: Theme.fs-caption;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                        Rectangle { horizontal-stretch: 1; }
                        TouchArea {
                            width: Theme.sp-6;
                            height: Theme.sp-6;
                            clicked => {
                                root.ai-panel-open = false;
                                root.ai-dismiss();
                            }
                            Rectangle {
                                width: Theme.sp-6; height: Theme.sp-6;
                                border-radius: Theme.r-lg;
                                background: parent.has-hover ? Theme.hover-fill : transparent;
                                Text {
                                    text: "\u{2715}";
                                    font-size: Theme.fs-micro;
                                    color: Theme.text-dim;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    Text {
                        text: root.ai-response;
                        color: Theme.text-primary;
                        font-size: Theme.fs-caption;
                        wrap: word-wrap;
                    }
                }
            }
        }

        // ── Content area (device list + optional detail panel) ──
        HorizontalLayout {
            vertical-stretch: 1;

            // Left: device lists
            Rectangle {
                horizontal-stretch: 1;
                background: Theme.bg-deep;

                // ── USB tab ──
                if active-tab == 0 : VerticalLayout {
                    spacing: 0px;

                    SectionHeader {
                        title: "USB DEVICES";
                        count: usb-devices.length;
                    }

                    if usb-devices.length == 0 : EmptyState {
                        message: scanning ? "Scanning USB bus..." : "No USB devices found";
                    }

                    // USB device list
                    Flickable {
                        vertical-stretch: 1;

                        VerticalLayout {
                            spacing: 2px;
                            padding: Theme.sp-2;

                            for device[idx] in usb-devices : UsbDeviceRow {
                                data: device;
                                clicked => {
                                    root.usb-selected-index = idx;
                                    root.pci-selected-index = -1;
                                    root.dev-select-usb(idx);
                                }
                            }
                        }
                    }
                }

                // ── PCI tab ──
                if active-tab == 1 : VerticalLayout {
                    spacing: 0px;

                    SectionHeader {
                        title: "PCI DEVICES";
                        count: pci-devices.length;
                    }

                    if pci-devices.length == 0 : EmptyState {
                        message: scanning ? "Scanning PCI bus..." : "No PCI devices found";
                    }

                    Flickable {
                        vertical-stretch: 1;

                        VerticalLayout {
                            spacing: 2px;
                            padding: Theme.sp-2;

                            for device[idx] in pci-devices : PciDeviceRow {
                                data: device;
                                is-selected: idx == root.pci-selected-index;
                                clicked => {
                                    root.pci-selected-index = idx;
                                    root.usb-selected-index = -1;
                                    root.dev-select-pci(idx);
                                }
                            }
                        }
                    }
                }

                // ── Input tab ──
                if active-tab == 2 : VerticalLayout {
                    spacing: 0px;

                    SectionHeader {
                        title: "INPUT DEVICES";
                        count: input-devices.length;
                    }

                    if input-devices.length == 0 : EmptyState {
                        message: scanning ? "Scanning input devices..." : "No input devices found";
                    }

                    Flickable {
                        vertical-stretch: 1;

                        VerticalLayout {
                            spacing: 2px;
                            padding: Theme.sp-2;

                            for device in input-devices : InputDeviceRow {
                                data: device;
                            }
                        }
                    }
                }

                // ── Storage tab ──
                if active-tab == 3 : VerticalLayout {
                    spacing: 0px;

                    SectionHeader {
                        title: "BLOCK DEVICES";
                        count: storage-devices.length;
                    }

                    if storage-devices.length == 0 : EmptyState {
                        message: scanning ? "Scanning block devices..." : "No storage devices found";
                    }

                    Flickable {
                        vertical-stretch: 1;

                        VerticalLayout {
                            spacing: 2px;
                            padding: Theme.sp-2;

                            for device in storage-devices : StorageDeviceRow {
                                data: device;
                            }
                        }
                    }
                }

                // ── Display tab ──
                if active-tab == 4 : VerticalLayout {
                    spacing: 0px;

                    // GPU info card
                    if gpu-info != "" : Rectangle {
                        height: 64px;
                        background: Theme.bg-card;
                        border-radius: Theme.r-lg;
                        border-width: 1px;
                        border-color: Theme.border-subtle;

                        HorizontalLayout {
                            padding-left: Theme.sp-4;
                            padding-right: Theme.sp-4;
                            spacing: Theme.sp-3;

                            Rectangle {
                                width: 36px;
                                height: 36px;
                                border-radius: Theme.r-md;
                                background: Theme.color-success.with-alpha(0.12);

                                Text {
                                    text: "GPU";
                                    color: Theme.color-success;
                                    font-size: Theme.fs-micro;
                                    font-weight: 700;
                                    vertical-alignment: center;
                                    horizontal-alignment: center;
                                }
                            }

                            Text {
                                text: gpu-info;
                                color: Theme.text-primary;
                                font-size: Theme.fs-body;
                                vertical-alignment: center;
                                overflow: elide;
                                horizontal-stretch: 1;
                            }
                        }
                    }

                    SectionHeader {
                        title: "DISPLAY OUTPUTS";
                        count: display-devices.length;
                    }

                    if display-devices.length == 0 : EmptyState {
                        message: scanning ? "Scanning display outputs..." : "No display outputs found";
                    }

                    Flickable {
                        vertical-stretch: 1;

                        VerticalLayout {
                            spacing: 2px;
                            padding: Theme.sp-2;

                            for device in display-devices : DisplayDeviceRow {
                                data: device;
                            }
                        }
                    }
                }
            }

            // Right: detail panel (shown when a USB or PCI device is selected)
            if root.selected-device-info != "" : Rectangle {
                width: 1px;
                background: Theme.border-subtle;
            }

            if root.selected-device-info != "" : DeviceDetailPanel {
                detail-info: root.selected-device-info;
                close-detail => {
                    root.usb-selected-index = -1;
                    root.pci-selected-index = -1;
                    root.dev-close-detail();
                }
            }
        }

        // ── Summary bar ──
        Rectangle {
            height: 36px;
            background: Theme.bg-card;
            border-width: 1px;
            border-color: Theme.border-subtle;

            HorizontalLayout {
                padding-left: Theme.sp-4;
                padding-right: Theme.sp-4;
                spacing: 10px;
                alignment: start;

                CountChip {
                    count: usb-devices.length;
                    label: "USB";
                    chip-color: Theme.holo-blue;
                }
                CountChip {
                    count: pci-devices.length;
                    label: "PCI";
                    chip-color: Theme.accent;
                }
                CountChip {
                    count: input-devices.length;
                    label: "Input";
                    chip-color: Theme.color-pattern;
                }
                CountChip {
                    count: storage-devices.length;
                    label: "Storage";
                    chip-color: Theme.color-warning;
                }
                CountChip {
                    count: display-devices.length;
                    label: "Display";
                    chip-color: Theme.color-success;
                }

                Rectangle { horizontal-stretch: 1; }

                // Total
                Text {
                    text: dev-summary;
                    color: Theme.text-dim;
                    font-size: Theme.fs-caption;
                    vertical-alignment: center;
                }
            }
        }
    }
}
