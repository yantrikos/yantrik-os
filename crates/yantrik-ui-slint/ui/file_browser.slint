// File browser — full-featured file navigation with sidebar, status bar.
// Screen 8. Sidebar (Places/Devices) + breadcrumb + list + details panel.
// Wrapped in WindowFrame by app.slint — no internal header needed.
// Firelight treatment: glassmorphism, holographic glows, gradient accents.
// Enterprise features: multi-select, context menu, detail panel toggle,
// create file/folder, status bar with selection info.

import { Theme } from "theme.slint";
import { ListView, LineEdit } from "std-widgets.slint";

export struct FileEntry {
    name: string,
    is-dir: bool,
    size-text: string,
    modified-text: string,
    icon-char: string,
    selected: bool,
}

export struct BreadcrumbSegment {
    label: string,
    full-path: string,
}

export struct FileDetailData {
    name: string,
    file-type: string,
    size-text: string,
    modified-text: string,
    path-text: string,
    permissions: string,
    preview-text: string,
    is-text-file: bool,
    icon-char: string,
}

export struct FileTabData {
    path: string,
    label: string,
    is-active: bool,
}

export struct FileOpItem {
    operation: string,  // "Copying", "Moving", "Deleting"
    filename: string,
    progress: float,    // 0.0-1.0
    status: string,     // "in_progress", "done", "error"
}

export component FileBrowser inherits Rectangle {
    background: transparent;

    in property <string> current-path: "~";
    in property <[FileEntry]> entries: [];
    in property <bool> is-loading: false;
    in property <[BreadcrumbSegment]> breadcrumbs: [];
    in property <bool> has-clipboard: false;
    in-out property <bool> show-hidden: false;
    in-out property <bool> grid-view: false;
    in-out property <int> selected-index: -1;
    in property <FileDetailData> file-details;
    in property <string> free-space-text: "";
    in property <bool> can-go-back: false;
    in property <bool> can-go-forward: false;

    // AI features
    in property <string> ai-summary: "";
    in property <bool> is-summarizing: false;
    in property <string> dir-type-badge: "";
    callback request-summarize();
    callback request-ask-ai();

    // Multi-select
    in-out property <int> selection-count: 0;
    in property <string> selection-size-text: "";
    callback multi-select-clicked(int, bool, bool);  // index, ctrl-held, shift-held
    callback select-all();
    callback clear-selection();
    callback delete-selected();
    callback copy-selected();
    callback cut-selected();

    // Detail panel toggle
    in-out property <bool> detail-panel-visible: false;

    // Context menu
    property <bool> show-context-menu: false;
    property <int> context-menu-x: 0;
    property <int> context-menu-y: 0;
    property <int> context-menu-index: -1;
    callback context-copy-path(string);
    callback context-open-terminal();
    callback context-compress(string);

    // Create new file
    callback create-file(string);

    // Dialog state
    property <bool> show-rename-dialog: false;
    property <string> rename-old-name: "";
    property <string> rename-new-name: "";
    property <bool> show-delete-dialog: false;
    property <string> delete-target-name: "";
    property <bool> show-new-folder-dialog: false;
    property <string> new-folder-name: "";
    property <bool> show-new-file-dialog: false;
    property <string> new-file-name: "";
    property <bool> show-summary-dialog: false;

    callback navigate-dir(string);
    callback open-file(string);
    callback go-up();
    callback go-back();
    callback go-forward();
    callback navigate-to-path(string);
    callback toggle-hidden();
    callback file-delete(string);
    callback file-rename(string, string);
    callback file-copy(string);
    callback file-cut(string);
    callback file-paste();
    callback create-folder(string);
    callback file-selection-changed(string);
    callback file-sort-changed(string, bool);
    callback file-filter-changed(string);

    // Tab management
    in property <[FileTabData]> file-tabs: [];
    in property <int> file-active-tab: 0;
    callback file-new-tab();
    callback file-close-tab(int);
    callback file-switch-tab(int);

    // File operations queue
    in property <[FileOpItem]> file-op-queue: [];
    in-out property <bool> file-op-queue-visible: false;

    // Batch rename
    in-out property <bool> file-batch-rename-open: false;
    in-out property <string> file-batch-rename-pattern: "";
    in-out property <string> file-batch-rename-replace: "";
    callback file-batch-rename-execute();

    // Quick Look
    in-out property <bool> file-quick-look-open: false;
    in property <string> file-quick-look-content: "";
    in property <string> file-quick-look-name: "";
    callback file-quick-look(int);
    callback file-close-quick-look();

    // Trash
    in-out property <bool> file-trash-mode: false;
    in property <int> file-trash-count: 0;
    callback file-toggle-trash();
    callback file-empty-trash();
    callback file-restore-from-trash(int);

    // Sort state
    property <string> sort-field: "name";
    property <bool> sort-ascending: true;

    // Search state
    property <bool> search-active: false;
    property <string> search-text: "";

    // Address bar state
    property <bool> address-editing: false;

    // Helper: sort order display text
    pure function sort-order-text() -> string {
        if root.sort-field == "name" && root.sort-ascending { return "Name A-Z"; }
        if root.sort-field == "name" && !root.sort-ascending { return "Name Z-A"; }
        if root.sort-field == "size" && root.sort-ascending { return "Size (small first)"; }
        if root.sort-field == "size" && !root.sort-ascending { return "Size (large first)"; }
        if root.sort-field == "modified" && root.sort-ascending { return "Oldest first"; }
        if root.sort-field == "modified" && !root.sort-ascending { return "Newest first"; }
        return "Name A-Z";
    }

    VerticalLayout {
        spacing: 0px;

        // ── Tab bar — horizontal row of open tabs ──
        if root.file-tabs.length > 0 : Rectangle {
            height: 34px;
            background: Theme.bg-surface;

            // Bottom edge
            Rectangle {
                y: parent.height - 1px;
                width: 100%;
                height: 1px;
                background: Theme.separator;
            }

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 4px;
                alignment: start;

                for tab[idx] in root.file-tabs : TouchArea {
                    width: tab-pill.preferred-width + 32px;
                    height: 28px;
                    clicked => { root.file-switch-tab(idx); }

                    tab-pill := Rectangle {
                        border-radius: Theme.r-md;
                        background: tab.is-active
                            ? Theme.accent-dim
                            : (parent.has-hover ? Theme.hover-fill : transparent);
                        border-width: tab.is-active ? 1px : 0;
                        border-color: Theme.cyan-dim;
                        animate background, border-width { duration: Theme.dur-fast; }

                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 4px;
                            spacing: 6px;
                            alignment: center;

                            Text {
                                text: tab.label;
                                color: tab.is-active ? Theme.cyan : Theme.text-secondary;
                                font-size: Theme.fs-micro;
                                font-weight: tab.is-active ? 600 : 400;
                                vertical-alignment: center;
                                overflow: elide;
                                max-width: 120px;
                                animate color { duration: Theme.dur-fast; }
                            }

                            // Close button
                            tab-close := TouchArea {
                                width: 16px; height: 16px;
                                clicked => { root.file-close-tab(idx); }
                                Rectangle {
                                    border-radius: 4px;
                                    background: tab-close.has-hover ? Theme.color-danger-dim : transparent;
                                    animate background { duration: Theme.dur-fast; }
                                    Text {
                                        text: "\u{2715}";
                                        color: tab-close.has-hover ? Theme.color-danger : Theme.text-dim;
                                        font-size: 9px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }

                // "+" button to add a new tab
                new-tab-btn := TouchArea {
                    width: 28px; height: 28px;
                    clicked => { root.file-new-tab(); }
                    Rectangle {
                        border-radius: Theme.r-md;
                        background: new-tab-btn.has-hover
                            ? Theme.hover-fill
                            : transparent;
                        animate background { duration: Theme.dur-fast; }
                        Text {
                            text: "+";
                            color: new-tab-btn.has-hover ? Theme.cyan : Theme.text-dim;
                            font-size: Theme.fs-headline;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            animate color { duration: Theme.dur-fast; }
                        }
                    }
                }

                Rectangle { horizontal-stretch: 1; }
            }
        }

        // ── Navigation bar — glass gradient with back/forward/up/home + breadcrumbs ──
        Rectangle {
            height: 40px;
            background: Theme.bg-surface;

            // Bottom holographic edge
            Rectangle {
                y: parent.height - 1px;
                width: 100%;
                height: 1px;
                background: Theme.separator;
            }

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 2px;

                // Back button
                back-btn := TouchArea {
                    width: 28px; height: 32px;
                    clicked => { root.selected-index = -1; root.clear-selection(); root.go-back(); }
                    Rectangle {
                        border-radius: Theme.r-sm;
                        background: back-btn.has-hover && root.can-go-back
                            ? Theme.hover-fill
                            : transparent;
                        animate background { duration: Theme.dur-fast; }
                        Text {
                            text: "\u{25c1}";
                            color: root.can-go-back ? (back-btn.has-hover ? Theme.cyan : Theme.text-secondary) : Theme.text-dim;
                            font-size: Theme.fs-body;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            animate color { duration: Theme.dur-fast; }
                        }
                    }
                }

                // Forward button
                fwd-btn := TouchArea {
                    width: 28px; height: 32px;
                    clicked => { root.selected-index = -1; root.clear-selection(); root.go-forward(); }
                    Rectangle {
                        border-radius: Theme.r-sm;
                        background: fwd-btn.has-hover && root.can-go-forward
                            ? Theme.hover-fill
                            : transparent;
                        animate background { duration: Theme.dur-fast; }
                        Text {
                            text: "\u{25b7}";
                            color: root.can-go-forward ? (fwd-btn.has-hover ? Theme.cyan : Theme.text-secondary) : Theme.text-dim;
                            font-size: Theme.fs-body;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            animate color { duration: Theme.dur-fast; }
                        }
                    }
                }

                // Up button
                up-btn := TouchArea {
                    width: 28px; height: 32px;
                    clicked => { root.selected-index = -1; root.clear-selection(); root.go-up(); }
                    Rectangle {
                        border-radius: Theme.r-sm;
                        background: up-btn.has-hover
                            ? Theme.hover-fill
                            : transparent;
                        animate background { duration: Theme.dur-fast; }
                        Text {
                            text: "\u{2191}";
                            color: up-btn.has-hover ? Theme.cyan : Theme.text-secondary;
                            font-size: Theme.fs-headline;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            animate color { duration: Theme.dur-fast; }
                        }
                    }
                }

                // Home button
                home-btn := TouchArea {
                    width: 28px; height: 32px;
                    clicked => { root.selected-index = -1; root.clear-selection(); root.navigate-to-path("~"); }
                    Rectangle {
                        border-radius: Theme.r-sm;
                        background: home-btn.has-hover
                            ? Theme.hover-fill
                            : transparent;
                        animate background { duration: Theme.dur-fast; }
                        Text {
                            text: "\u{2302}";
                            color: home-btn.has-hover ? Theme.cyan : Theme.text-secondary;
                            font-size: Theme.fs-headline;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            animate color { duration: Theme.dur-fast; }
                        }
                    }
                }

                // Separator
                Rectangle {
                    width: 1px; height: 24px;
                    background: Theme.border-subtle;
                }

                // Breadcrumb / editable address bar toggle
                if !root.address-editing : HorizontalLayout {
                    horizontal-stretch: 1;
                    spacing: 0px;

                    // Double-click area to enter address editing
                    addr-click := TouchArea {
                        horizontal-stretch: 1;
                        double-clicked => { root.address-editing = true; }

                        HorizontalLayout {
                            spacing: 0px;

                            for seg[idx] in root.breadcrumbs : HorizontalLayout {
                                spacing: 4px;

                                if idx > 0 : Text {
                                    text: "/";
                                    color: Theme.text-dim;
                                    font-size: Theme.font-small;
                                    vertical-alignment: center;
                                }

                                TouchArea {
                                    height: 28px;
                                    width: seg-text.preferred-width + 12px;
                                    clicked => { root.selected-index = -1; root.clear-selection(); root.navigate-to-path(seg.full-path); }

                                    Rectangle {
                                        border-radius: 4px;
                                        background: parent.has-hover
                                            ? Theme.hover-fill
                                            : transparent;
                                        animate background { duration: Theme.dur-fast; }

                                        seg-text := Text {
                                            text: seg.label;
                                            color: idx == root.breadcrumbs.length - 1 ? Theme.cyan : Theme.cyan-dim;
                                            font-size: Theme.font-small;
                                            font-weight: idx == root.breadcrumbs.length - 1 ? 600 : 400;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }

                            Rectangle { horizontal-stretch: 1; }
                        }
                    }
                }

                // Editable address bar (shown when address-editing is true)
                if root.address-editing : HorizontalLayout {
                    horizontal-stretch: 1;
                    spacing: 4px;

                    addr-input := LineEdit {
                        horizontal-stretch: 1;
                        text: root.current-path;
                        accepted(t) => {
                            root.address-editing = false;
                            root.selected-index = -1;
                            root.clear-selection();
                            root.navigate-to-path(t);
                        }
                    }

                    // Cancel button
                    addr-cancel := TouchArea {
                        width: 28px; height: 28px;
                        clicked => { root.address-editing = false; }
                        Rectangle {
                            border-radius: Theme.r-sm;
                            background: addr-cancel.has-hover ? Theme.color-danger-dim : transparent;
                            animate background { duration: Theme.dur-fast; }
                            Text { text: "\u{2715}"; color: addr-cancel.has-hover ? Theme.color-danger : Theme.text-dim; font-size: Theme.fs-caption; horizontal-alignment: center; vertical-alignment: center; }
                        }
                    }
                }

                // Spacer (only when not in address editing mode and breadcrumbs don't stretch)
                if root.address-editing : Rectangle { }

                // Toolbar buttons
                HorizontalLayout {
                    spacing: 2px;
                    alignment: end;

                    // Search toggle / inline filter
                    if !root.search-active : search-btn := TouchArea {
                        width: 28px; height: 32px;
                        clicked => { root.search-active = true; root.search-text = ""; }
                        Rectangle {
                            border-radius: Theme.r-sm;
                            background: search-btn.has-hover
                                ? Theme.hover-fill : transparent;
                            animate background { duration: Theme.dur-fast; }
                            Text { text: "\u{2315}"; color: search-btn.has-hover ? Theme.cyan : Theme.text-dim; font-size: Theme.fs-body; horizontal-alignment: center; vertical-alignment: center; }
                        }
                    }

                    if root.search-active : HorizontalLayout {
                        spacing: 2px;

                        filter-input := LineEdit {
                            width: 160px;
                            placeholder-text: "Filter...";
                            text: root.search-text;
                            edited(t) => { root.search-text = t; root.file-filter-changed(t); }
                            accepted(t) => { /* keep filter active */ }
                        }

                        filter-close := TouchArea {
                            width: 24px; height: 28px;
                            clicked => { root.search-active = false; root.search-text = ""; root.file-filter-changed(""); }
                            Rectangle {
                                border-radius: Theme.r-sm;
                                background: filter-close.has-hover ? Theme.color-danger-dim : transparent;
                                animate background { duration: Theme.dur-fast; }
                                Text { text: "\u{2715}"; color: filter-close.has-hover ? Theme.color-danger : Theme.text-dim; font-size: Theme.fs-micro; horizontal-alignment: center; vertical-alignment: center; }
                            }
                        }
                    }

                    // Address bar toggle
                    addr-btn := TouchArea {
                        width: 28px; height: 32px;
                        clicked => { root.address-editing = !root.address-editing; }
                        Rectangle {
                            border-radius: Theme.r-sm;
                            background: addr-btn.has-hover
                                ? Theme.hover-fill : transparent;
                            animate background { duration: Theme.dur-fast; }
                            Text {
                                text: "/";
                                color: root.address-editing ? Theme.cyan : (addr-btn.has-hover ? Theme.cyan : Theme.text-dim);
                                font-size: Theme.fs-body; font-weight: 700;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                animate color { duration: Theme.dur-fast; }
                            }
                        }
                    }

                    // New file
                    newfile-btn := TouchArea {
                        width: 28px; height: 32px;
                        clicked => { root.new-file-name = ""; root.show-new-file-dialog = true; }
                        Rectangle {
                            border-radius: Theme.r-sm;
                            background: newfile-btn.has-hover
                                ? Theme.color-success-dim : transparent;
                            animate background { duration: Theme.dur-fast; }
                            Text {
                                text: "\u{2610}";
                                color: newfile-btn.has-hover ? Theme.color-success : Theme.text-dim;
                                font-size: Theme.fs-body;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                animate color { duration: Theme.dur-fast; }
                            }
                        }
                    }

                    // New folder
                    newfolder-btn := TouchArea {
                        width: 28px; height: 32px;
                        clicked => { root.new-folder-name = ""; root.show-new-folder-dialog = true; }
                        Rectangle {
                            border-radius: Theme.r-sm;
                            background: newfolder-btn.has-hover
                                ? Theme.hover-fill : transparent;
                            animate background { duration: Theme.dur-fast; }
                            Text {
                                text: "+";
                                color: newfolder-btn.has-hover ? Theme.cyan : Theme.cyan-dim;
                                font-size: Theme.fs-headline;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                animate color { duration: Theme.dur-fast; }
                            }
                        }
                    }

                    // Paste
                    if root.has-clipboard : TouchArea {
                        width: 28px; height: 32px;
                        clicked => { root.file-paste(); }
                        Rectangle {
                            border-radius: Theme.r-sm;
                            background: parent.has-hover
                                ? Theme.hover-fill : transparent;
                            animate background { duration: Theme.dur-fast; }
                            Text { text: "\u{1f4cb}"; font-size: Theme.fs-caption; horizontal-alignment: center; vertical-alignment: center; }
                        }
                    }

                    // Toggle hidden
                    hidden-btn := TouchArea {
                        width: 28px; height: 32px;
                        clicked => { root.selected-index = -1; root.clear-selection(); root.toggle-hidden(); }
                        Rectangle {
                            border-radius: Theme.r-sm;
                            background: hidden-btn.has-hover
                                ? Theme.hover-fill : transparent;
                            animate background { duration: Theme.dur-fast; }
                            Text {
                                text: root.show-hidden ? "\u{25c9}" : "\u{25ce}";
                                color: root.show-hidden ? Theme.cyan : Theme.text-dim;
                                font-size: Theme.fs-body;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Detail panel toggle
                    detail-toggle-btn := TouchArea {
                        width: 28px; height: 32px;
                        clicked => { root.detail-panel-visible = !root.detail-panel-visible; }
                        Rectangle {
                            border-radius: Theme.r-sm;
                            background: detail-toggle-btn.has-hover
                                ? Theme.hover-fill : transparent;
                            animate background { duration: Theme.dur-fast; }
                            Text {
                                text: "\u{2261}";
                                color: root.detail-panel-visible ? Theme.cyan : (detail-toggle-btn.has-hover ? Theme.cyan : Theme.text-dim);
                                font-size: Theme.fs-headline;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                animate color { duration: Theme.dur-fast; }
                            }
                        }
                    }

                    // Grid/List view toggle
                    view-toggle-btn := TouchArea {
                        width: 28px; height: 32px;
                        clicked => { root.grid-view = !root.grid-view; root.selected-index = -1; root.clear-selection(); }
                        Rectangle {
                            border-radius: Theme.r-sm;
                            background: view-toggle-btn.has-hover
                                ? Theme.hover-fill : transparent;
                            animate background { duration: Theme.dur-fast; }
                            Text {
                                text: root.grid-view ? "\u{2261}" : "\u{229e}";
                                color: view-toggle-btn.has-hover ? Theme.cyan : Theme.text-dim;
                                font-size: Theme.fs-body;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                animate color { duration: Theme.dur-fast; }
                            }
                        }
                    }

                    // Trash toggle
                    trash-toggle-btn := TouchArea {
                        width: 32px; height: 32px;
                        clicked => { root.file-toggle-trash(); }
                        Rectangle {
                            border-radius: Theme.r-sm;
                            background: root.file-trash-mode
                                ? Theme.color-danger-dim
                                : (trash-toggle-btn.has-hover ? Theme.hover-fill : transparent);
                            animate background { duration: Theme.dur-fast; }
                            Text {
                                text: "\u{2672}";
                                color: root.file-trash-mode ? Theme.color-danger : (trash-toggle-btn.has-hover ? Theme.cyan : Theme.text-dim);
                                font-size: Theme.fs-body;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                animate color { duration: Theme.dur-fast; }
                            }

                            // Badge showing trash count
                            if root.file-trash-count > 0 && !root.file-trash-mode : Rectangle {
                                x: parent.width - 12px;
                                y: 0;
                                width: 14px;
                                height: 14px;
                                border-radius: 7px;
                                background: Theme.color-danger;
                                Text {
                                    text: root.file-trash-count < 100 ? root.file-trash-count : "99+";
                                    color: Theme.text-on-accent;
                                    font-size: 8px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    // Batch rename (visible when multi-select active)
                    if root.selection-count > 1 : batch-rename-btn := TouchArea {
                        width: 28px; height: 32px;
                        clicked => { root.file-batch-rename-open = true; root.file-batch-rename-pattern = ""; root.file-batch-rename-replace = ""; }
                        Rectangle {
                            border-radius: Theme.r-sm;
                            background: batch-rename-btn.has-hover
                                ? Theme.hover-fill : transparent;
                            animate background { duration: Theme.dur-fast; }
                            Text {
                                text: "R";
                                color: batch-rename-btn.has-hover ? Theme.amber : Theme.text-dim;
                                font-size: Theme.fs-caption;
                                font-weight: 700;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                animate color { duration: Theme.dur-fast; }
                            }
                        }
                    }
                }
            }
        }

        // ── Multi-select action bar ──
        if root.selection-count > 1 : Rectangle {
            height: 36px;
            background: Theme.bg-surface;

            Rectangle {
                y: parent.height - 1px; width: 100%; height: 1px;
                background: Theme.separator;
            }

            HorizontalLayout {
                padding-left: 12px; padding-right: 12px; spacing: 8px;

                // Selection badge
                Rectangle {
                    width: sel-badge-text.preferred-width + 16px;
                    height: 24px;
                    border-radius: Theme.r-lg;
                    background: Theme.accent-dim;
                    border-width: 1px; border-color: Theme.cyan-dim;

                    sel-badge-text := Text {
                        text: root.selection-count + " selected";
                        color: Theme.cyan;
                        font-size: Theme.fs-micro; font-weight: 600;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle { horizontal-stretch: 1; }

                // Copy selected
                ms-copy-btn := TouchArea {
                    width: 56px; height: 28px;
                    clicked => { root.copy-selected(); }
                    Rectangle {
                        border-radius: Theme.r-sm;
                        background: ms-copy-btn.has-hover ? Theme.hover-fill : transparent;
                        animate background { duration: Theme.dur-fast; }
                        Text { text: "Copy"; color: ms-copy-btn.has-hover ? Theme.text-primary : Theme.text-secondary; font-size: Theme.fs-caption; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }

                // Cut selected
                ms-cut-btn := TouchArea {
                    width: 48px; height: 28px;
                    clicked => { root.cut-selected(); }
                    Rectangle {
                        border-radius: Theme.r-sm;
                        background: ms-cut-btn.has-hover ? Theme.hover-fill : transparent;
                        animate background { duration: Theme.dur-fast; }
                        Text { text: "Cut"; color: ms-cut-btn.has-hover ? Theme.text-primary : Theme.text-secondary; font-size: Theme.fs-caption; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }

                // Delete selected
                ms-del-btn := TouchArea {
                    width: 60px; height: 28px;
                    clicked => { root.delete-target-name = root.selection-count + " items"; root.show-delete-dialog = true; }
                    Rectangle {
                        border-radius: Theme.r-sm;
                        background: ms-del-btn.has-hover ? Theme.color-danger-dim : transparent;
                        animate background { duration: Theme.dur-fast; }
                        Text { text: "Delete"; color: ms-del-btn.has-hover ? Theme.color-danger : Theme.color-danger; font-size: Theme.fs-caption; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }

                // Clear selection
                ms-clear-btn := TouchArea {
                    width: 24px; height: 28px;
                    clicked => { root.clear-selection(); root.selected-index = -1; }
                    Rectangle {
                        border-radius: Theme.r-sm;
                        background: ms-clear-btn.has-hover ? Theme.color-danger-dim : transparent;
                        animate background { duration: Theme.dur-fast; }
                        Text { text: "\u{2715}"; color: ms-clear-btn.has-hover ? Theme.color-danger : Theme.text-dim; font-size: Theme.fs-micro; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }
            }
        }

        // ── Trash mode action bar ──
        if root.file-trash-mode : Rectangle {
            height: 36px;
            background: Theme.bg-surface;

            Rectangle {
                y: parent.height - 1px; width: 100%; height: 1px;
                background: Theme.separator;
            }

            HorizontalLayout {
                padding-left: 12px; padding-right: 12px; spacing: 8px;

                // Trash badge
                Rectangle {
                    width: trash-badge-txt.preferred-width + 16px;
                    height: 24px;
                    border-radius: Theme.r-lg;
                    background: Theme.color-danger-dim;
                    border-width: 1px; border-color: Theme.color-danger-dim;

                    trash-badge-txt := Text {
                        text: "\u{2672} Trash (" + root.file-trash-count + ")";
                        color: Theme.color-danger;
                        font-size: Theme.fs-micro; font-weight: 600;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle { horizontal-stretch: 1; }

                // Restore selected
                if root.selected-index >= 0 : trash-restore-btn := TouchArea {
                    width: 72px; height: 28px;
                    clicked => { root.file-restore-from-trash(root.selected-index); }
                    Rectangle {
                        border-radius: Theme.r-sm;
                        background: trash-restore-btn.has-hover ? Theme.color-success-dim : transparent;
                        animate background { duration: Theme.dur-fast; }
                        Text { text: "Restore"; color: trash-restore-btn.has-hover ? Theme.color-success : Theme.color-success; font-size: Theme.fs-caption; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }

                // Empty trash
                trash-empty-btn := TouchArea {
                    width: 88px; height: 28px;
                    clicked => { root.file-empty-trash(); }
                    Rectangle {
                        border-radius: Theme.r-sm;
                        background: trash-empty-btn.has-hover ? Theme.color-danger-dim : transparent;
                        animate background { duration: Theme.dur-fast; }
                        Text { text: "Empty Trash"; color: trash-empty-btn.has-hover ? Theme.color-danger : Theme.color-danger; font-size: Theme.fs-caption; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }

                // Exit trash view
                trash-exit-btn := TouchArea {
                    width: 24px; height: 28px;
                    clicked => { root.file-toggle-trash(); }
                    Rectangle {
                        border-radius: Theme.r-sm;
                        background: trash-exit-btn.has-hover ? Theme.color-danger-dim : transparent;
                        animate background { duration: Theme.dur-fast; }
                        Text { text: "\u{2715}"; color: trash-exit-btn.has-hover ? Theme.color-danger : Theme.text-dim; font-size: Theme.fs-micro; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }
            }
        }

        // ── Main body: sidebar + file list + optional detail panel ──
        HorizontalLayout {
            vertical-stretch: 1;
            spacing: 0px;

            // ── Left sidebar — Places & Devices ──
            Rectangle {
                width: 160px;
                background: Theme.bg-deep;

                // Right border
                Rectangle {
                    x: parent.width - 1px;
                    width: 1px;
                    height: 100%;
                    background: Theme.border-default;
                }

                Flickable {
                    width: parent.width - 1px;
                    height: parent.height;
                    viewport-height: sidebar-col.preferred-height;

                    sidebar-col := VerticalLayout {
                        padding: 8px;
                        padding-top: 12px;
                        spacing: 2px;

                        // ── Places section ──
                        Text {
                            text: "Places";
                            color: Theme.text-dim;
                            font-size: Theme.fs-micro;
                            font-weight: 600;
                            letter-spacing: 1.5px;
                        }

                        Rectangle { height: 4px; }

                        // Home
                        sb-home := TouchArea {
                            height: 30px;
                            clicked => { root.selected-index = -1; root.clear-selection(); root.navigate-to-path("~"); }
                            Rectangle {
                                border-radius: Theme.r-sm;
                                background: sb-home.has-hover
                                    ? Theme.hover-fill
                                    : (root.current-path == "~" || root.current-path == "/home/yantrik"
                                        ? Theme.hover-fill
                                        : transparent);
                                animate background { duration: Theme.dur-fast; }
                                HorizontalLayout {
                                    padding-left: 8px;
                                    spacing: 8px;
                                    Rectangle {
                                        width: 20px; height: 20px; border-radius: 5px;
                                        background: #3a9ac8;
                                        border-width: 1px; border-color: #3a9ac840;
                                        Text { text: "\u{2302}"; color: Theme.text-on-accent; font-size: Theme.fs-micro; horizontal-alignment: center; vertical-alignment: center; }
                                    }
                                    Text { text: "Home"; color: sb-home.has-hover ? Theme.cyan : Theme.text-secondary; font-size: Theme.fs-caption; vertical-alignment: center; animate color { duration: Theme.dur-fast; } }
                                }
                            }
                        }

                        // Documents
                        sb-docs := TouchArea {
                            height: 30px;
                            clicked => { root.selected-index = -1; root.clear-selection(); root.navigate-to-path("~/Documents"); }
                            Rectangle {
                                border-radius: Theme.r-sm;
                                background: sb-docs.has-hover
                                    ? Theme.hover-fill : transparent;
                                animate background { duration: Theme.dur-fast; }
                                HorizontalLayout {
                                    padding-left: 8px;
                                    spacing: 8px;
                                    Rectangle {
                                        width: 20px; height: 20px; border-radius: 5px;
                                        background: #5a7abd;
                                        border-width: 1px; border-color: #5a7abd40;
                                        Text { text: "\u{2261}"; color: Theme.text-on-accent; font-size: Theme.fs-micro; horizontal-alignment: center; vertical-alignment: center; }
                                    }
                                    Text { text: "Documents"; color: sb-docs.has-hover ? Theme.cyan : Theme.text-secondary; font-size: Theme.fs-caption; vertical-alignment: center; animate color { duration: Theme.dur-fast; } }
                                }
                            }
                        }

                        // Downloads
                        sb-dl := TouchArea {
                            height: 30px;
                            clicked => { root.selected-index = -1; root.clear-selection(); root.navigate-to-path("~/Downloads"); }
                            Rectangle {
                                border-radius: Theme.r-sm;
                                background: sb-dl.has-hover
                                    ? Theme.hover-fill : transparent;
                                animate background { duration: Theme.dur-fast; }
                                HorizontalLayout {
                                    padding-left: 8px;
                                    spacing: 8px;
                                    Rectangle {
                                        width: 20px; height: 20px; border-radius: 5px;
                                        background: Theme.color-success;
                                        border-width: 1px; border-color: #3aad6a40;
                                        Text { text: "\u{2193}"; color: Theme.text-on-accent; font-size: Theme.fs-micro; horizontal-alignment: center; vertical-alignment: center; }
                                    }
                                    Text { text: "Downloads"; color: sb-dl.has-hover ? Theme.cyan : Theme.text-secondary; font-size: Theme.fs-caption; vertical-alignment: center; animate color { duration: Theme.dur-fast; } }
                                }
                            }
                        }

                        // Pictures
                        sb-pics := TouchArea {
                            height: 30px;
                            clicked => { root.selected-index = -1; root.clear-selection(); root.navigate-to-path("~/Pictures"); }
                            Rectangle {
                                border-radius: Theme.r-sm;
                                background: sb-pics.has-hover
                                    ? Theme.hover-fill : transparent;
                                animate background { duration: Theme.dur-fast; }
                                HorizontalLayout {
                                    padding-left: 8px;
                                    spacing: 8px;
                                    Rectangle {
                                        width: 20px; height: 20px; border-radius: 5px;
                                        background: #9a4a9a;
                                        border-width: 1px; border-color: #9a4a9a40;
                                        Text { text: "\u{25a3}"; color: Theme.text-on-accent; font-size: Theme.fs-micro; horizontal-alignment: center; vertical-alignment: center; }
                                    }
                                    Text { text: "Pictures"; color: sb-pics.has-hover ? Theme.cyan : Theme.text-secondary; font-size: Theme.fs-caption; vertical-alignment: center; animate color { duration: Theme.dur-fast; } }
                                }
                            }
                        }

                        // Music
                        sb-music := TouchArea {
                            height: 30px;
                            clicked => { root.selected-index = -1; root.clear-selection(); root.navigate-to-path("~/Music"); }
                            Rectangle {
                                border-radius: Theme.r-sm;
                                background: sb-music.has-hover
                                    ? Theme.hover-fill : transparent;
                                animate background { duration: Theme.dur-fast; }
                                HorizontalLayout {
                                    padding-left: 8px;
                                    spacing: 8px;
                                    Rectangle {
                                        width: 20px; height: 20px; border-radius: 5px;
                                        background: #c89a3a;
                                        border-width: 1px; border-color: #c89a3a40;
                                        Text { text: "\u{266a}"; color: Theme.text-on-accent; font-size: Theme.fs-micro; horizontal-alignment: center; vertical-alignment: center; }
                                    }
                                    Text { text: "Music"; color: sb-music.has-hover ? Theme.cyan : Theme.text-secondary; font-size: Theme.fs-caption; vertical-alignment: center; animate color { duration: Theme.dur-fast; } }
                                }
                            }
                        }

                        Rectangle { height: 12px; }

                        // ── Devices section ──
                        Text {
                            text: "Devices";
                            color: Theme.text-dim;
                            font-size: Theme.fs-micro;
                            font-weight: 600;
                            letter-spacing: 1.5px;
                        }

                        Rectangle { height: 4px; }

                        // File System
                        sb-root := TouchArea {
                            height: 30px;
                            clicked => { root.selected-index = -1; root.clear-selection(); root.navigate-to-path("/"); }
                            Rectangle {
                                border-radius: Theme.r-sm;
                                background: sb-root.has-hover
                                    ? Theme.hover-fill : transparent;
                                animate background { duration: Theme.dur-fast; }
                                HorizontalLayout {
                                    padding-left: 8px;
                                    spacing: 8px;
                                    Rectangle {
                                        width: 20px; height: 20px; border-radius: 5px;
                                        background: #6a6a7a;
                                        border-width: 1px; border-color: #6a6a7a40;
                                        Text { text: "\u{25c9}"; color: Theme.text-on-accent; font-size: Theme.fs-micro; horizontal-alignment: center; vertical-alignment: center; }
                                    }
                                    Text { text: "File System"; color: sb-root.has-hover ? Theme.cyan : Theme.text-secondary; font-size: Theme.fs-caption; vertical-alignment: center; animate color { duration: Theme.dur-fast; } }
                                }
                            }
                        }

                        // /tmp
                        sb-tmp := TouchArea {
                            height: 30px;
                            clicked => { root.selected-index = -1; root.clear-selection(); root.navigate-to-path("/tmp"); }
                            Rectangle {
                                border-radius: Theme.r-sm;
                                background: sb-tmp.has-hover
                                    ? Theme.hover-fill : transparent;
                                animate background { duration: Theme.dur-fast; }
                                HorizontalLayout {
                                    padding-left: 8px;
                                    spacing: 8px;
                                    Rectangle {
                                        width: 20px; height: 20px; border-radius: 5px;
                                        background: #bd5a4a;
                                        border-width: 1px; border-color: #bd5a4a40;
                                        Text { text: "T"; color: Theme.text-on-accent; font-size: Theme.fs-micro; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                                    }
                                    Text { text: "Temp"; color: sb-tmp.has-hover ? Theme.cyan : Theme.text-secondary; font-size: Theme.fs-caption; vertical-alignment: center; animate color { duration: Theme.dur-fast; } }
                                }
                            }
                        }
                    }
                }
            }

            // ── Center: file list area ──
            VerticalLayout {
                horizontal-stretch: 1;
                spacing: 0px;

                // ── Column headers (list view only) ──
                if !root.grid-view : Rectangle {
                    height: 28px;
                    background: Theme.bg-surface;

                    // Bottom edge
                    Rectangle {
                        y: parent.height - 1px; width: 100%; height: 1px;
                        background: Theme.separator;
                    }

                    HorizontalLayout {
                        padding-left: 50px; // align with file names (icon badge 28px + 12px pad + 10px gap)
                        padding-right: 8px;
                        spacing: 10px;

                        // Name header
                        name-hdr := TouchArea {
                            horizontal-stretch: 1; height: 28px;
                            clicked => {
                                if root.sort-field == "name" { root.sort-ascending = !root.sort-ascending; }
                                else { root.sort-field = "name"; root.sort-ascending = true; }
                                root.file-sort-changed(root.sort-field, root.sort-ascending);
                            }
                            HorizontalLayout {
                                spacing: 4px;
                                Text {
                                    text: "Name";
                                    color: root.sort-field == "name" ? Theme.cyan : (name-hdr.has-hover ? Theme.text-secondary : Theme.text-dim);
                                    font-size: Theme.fs-micro; font-weight: 600;
                                    vertical-alignment: center;
                                    animate color { duration: Theme.dur-fast; }
                                }
                                if root.sort-field == "name" : Text {
                                    text: root.sort-ascending ? "\u{25b2}" : "\u{25bc}";
                                    color: Theme.cyan-dim; font-size: 9px; vertical-alignment: center;
                                }
                            }
                        }

                        // Size header
                        size-hdr := TouchArea {
                            width: 80px; height: 28px;
                            clicked => {
                                if root.sort-field == "size" { root.sort-ascending = !root.sort-ascending; }
                                else { root.sort-field = "size"; root.sort-ascending = false; }
                                root.file-sort-changed(root.sort-field, root.sort-ascending);
                            }
                            HorizontalLayout {
                                spacing: 4px;
                                Text {
                                    text: "Size";
                                    color: root.sort-field == "size" ? Theme.cyan : (size-hdr.has-hover ? Theme.text-secondary : Theme.text-dim);
                                    font-size: Theme.fs-micro; font-weight: 600;
                                    vertical-alignment: center;
                                    animate color { duration: Theme.dur-fast; }
                                }
                                if root.sort-field == "size" : Text {
                                    text: root.sort-ascending ? "\u{25b2}" : "\u{25bc}";
                                    color: Theme.cyan-dim; font-size: 9px; vertical-alignment: center;
                                }
                            }
                        }

                        // Modified header
                        mod-hdr := TouchArea {
                            width: 80px; height: 28px;
                            clicked => {
                                if root.sort-field == "modified" { root.sort-ascending = !root.sort-ascending; }
                                else { root.sort-field = "modified"; root.sort-ascending = true; }
                                root.file-sort-changed(root.sort-field, root.sort-ascending);
                            }
                            HorizontalLayout {
                                spacing: 4px;
                                Text {
                                    text: "Modified";
                                    color: root.sort-field == "modified" ? Theme.cyan : (mod-hdr.has-hover ? Theme.text-secondary : Theme.text-dim);
                                    font-size: Theme.fs-micro; font-weight: 600;
                                    vertical-alignment: center;
                                    animate color { duration: Theme.dur-fast; }
                                }
                                if root.sort-field == "modified" : Text {
                                    text: root.sort-ascending ? "\u{25b2}" : "\u{25bc}";
                                    color: Theme.cyan-dim; font-size: 9px; vertical-alignment: center;
                                }
                            }
                        }
                    }
                }

                // ── Grid view ──
                if root.grid-view : Flickable {
                    vertical-stretch: 1;
                    viewport-height: ((root.entries.length + 3) / 4) * 100px;

                    for entry[idx] in root.entries : grid-card := Rectangle {
                        property <int> col-idx: idx - (idx / 4) * 4;
                        property <int> row-idx: idx / 4;
                        x: self.col-idx * (parent.width / 4);
                        y: self.row-idx * 100px;
                        width: parent.width / 4;
                        height: 100px;

                        property <color> grid-badge-color:
                            entry.is-dir ? #3a9ac8 :
                            entry.icon-char == "\u{25c7}" ? #3aad6a :
                            entry.icon-char == "\u{2261}" ? #5a7abd :
                            entry.icon-char == "\u{25a3}" ? #9a4a9a :
                            entry.icon-char == "\u{266a}" ? #c89a3a :
                            entry.icon-char == "\u{25b6}" ? #c84a5a :
                            entry.icon-char == "\u{25a4}" ? #7a8a6a :
                            entry.icon-char == "\u{25a7}" ? #bd5a4a :
                            entry.icon-char == "\u{2699}" ? #4a7abd :
                            entry.icon-char == "\u{00b7}" ? #6a6a7a :
                            #5a5a7a;

                        grid-card-touch := TouchArea {
                            clicked => {
                                if entry.is-dir {
                                    root.selected-index = -1;
                                    root.clear-selection();
                                    root.navigate-dir(entry.name);
                                } else {
                                    root.multi-select-clicked(idx, false, false);
                                    root.file-selection-changed(entry.name);
                                }
                            }
                            double-clicked => {
                                if !entry.is-dir {
                                    root.open-file(entry.name);
                                }
                            }
                        }

                        // Card background
                        Rectangle {
                            border-radius: 10px;
                            x: 4px;
                            y: 4px;
                            width: parent.width - 8px;
                            height: parent.height - 8px;
                            background: entry.selected
                                ? Theme.accent-dim
                                : (grid-card-touch.has-hover
                                    ? Theme.hover-fill
                                    : transparent);
                            border-width: entry.selected ? 1px : (grid-card-touch.has-hover ? 1px : 0);
                            border-color: entry.selected ? Theme.cyan-dim : Theme.border-subtle;
                            animate background, border-width, border-color { duration: Theme.dur-fast; }

                            VerticalLayout {
                                alignment: center;
                                spacing: 6px;
                                padding: 8px;

                                // Icon badge
                                Rectangle {
                                    property <color> badge-color: grid-card.grid-badge-color;
                                    width: 36px;
                                    height: 36px;
                                    border-radius: 10px;
                                    background: badge-color;
                                    border-width: 1px;
                                    border-color: badge-color;
                                    drop-shadow-blur: grid-card-touch.has-hover ? 12px : 4px;
                                    drop-shadow-color: badge-color;
                                    animate drop-shadow-blur { duration: Theme.dur-fast; }

                                    Text {
                                        text: entry.icon-char;
                                        color: Theme.text-on-accent;
                                        font-size: Theme.fs-headline;
                                        font-weight: 700;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                // File name
                                Text {
                                    text: entry.name;
                                    color: entry.is-dir ? Theme.cyan-light : Theme.text-primary;
                                    font-size: Theme.fs-micro;
                                    font-weight: entry.is-dir ? 600 : 400;
                                    horizontal-alignment: center;
                                    overflow: elide;
                                    wrap: word-wrap;
                                }
                            }
                        }
                    }
                }

                // ── File list (list view) ──
                if !root.grid-view : ListView {
                    vertical-stretch: 1;

                    for entry[idx] in entries : Rectangle {
                        height: 44px;
                        background: entry.selected
                            ? Theme.accent-dim
                            : (file-touch.has-hover
                                ? Theme.hover-fill
                                : transparent);
                        animate background { duration: Theme.dur-fast; }

                        // Left edge glow on selected
                        if entry.selected : Rectangle {
                            x: 0; width: 3px; height: parent.height;
                            background: Theme.cyan;
                            drop-shadow-blur: 8px;
                            drop-shadow-color: Theme.cyan-glow;
                        }

                        file-touch := TouchArea {
                            clicked => {
                                if entry.is-dir {
                                    root.selected-index = -1;
                                    root.clear-selection();
                                    root.navigate-dir(entry.name);
                                } else {
                                    root.multi-select-clicked(idx, false, false);
                                    root.file-selection-changed(entry.name);
                                }
                            }
                            double-clicked => {
                                if !entry.is-dir {
                                    root.open-file(entry.name);
                                }
                            }
                        }

                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 8px;
                            spacing: 10px;

                            // Vivid icon badge
                            Rectangle {
                                property <color> badge-color:
                                    entry.is-dir ? #3a9ac8 :
                                    entry.icon-char == "\u{25c7}" ? #3aad6a :
                                    entry.icon-char == "\u{2261}" ? #5a7abd :
                                    entry.icon-char == "\u{25a3}" ? #9a4a9a :
                                    entry.icon-char == "\u{266a}" ? #c89a3a :
                                    entry.icon-char == "\u{25b6}" ? #c84a5a :
                                    entry.icon-char == "\u{25a4}" ? #7a8a6a :
                                    entry.icon-char == "\u{25a7}" ? #bd5a4a :
                                    entry.icon-char == "\u{2699}" ? #4a7abd :
                                    entry.icon-char == "\u{00b7}" ? #6a6a7a :
                                    #5a5a7a;
                                width: 28px;
                                height: 28px;
                                border-radius: 7px;
                                background: badge-color;
                                border-width: 1px;
                                border-color: badge-color;
                                drop-shadow-blur: file-touch.has-hover ? 10px : 3px;
                                drop-shadow-color: badge-color;
                                animate drop-shadow-blur { duration: Theme.dur-fast; }

                                Text {
                                    text: entry.icon-char;
                                    color: Theme.text-on-accent;
                                    font-size: Theme.fs-caption;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            // Name
                            Text {
                                text: entry.name;
                                color: entry.is-dir ? Theme.cyan-light : Theme.text-primary;
                                font-size: Theme.font-body;
                                font-weight: entry.is-dir ? 600 : 400;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                                overflow: elide;
                            }

                            // Size
                            if !entry.is-dir : Text {
                                text: entry.size-text;
                                color: Theme.text-dim;
                                font-size: Theme.font-small;
                                vertical-alignment: center;
                            }

                            // Modified
                            Text {
                                text: entry.modified-text;
                                color: Theme.text-dim;
                                font-size: Theme.font-small;
                                vertical-alignment: center;
                            }

                            // Context menu trigger button (more actions)
                            ctx-btn := TouchArea {
                                width: 24px; height: 28px;
                                clicked => {
                                    root.context-menu-index = idx;
                                    root.show-context-menu = true;
                                    // Position near bottom-right of row
                                    root.context-menu-x = 0;
                                    root.context-menu-y = 0;
                                }
                                Rectangle {
                                    border-radius: 4px;
                                    background: ctx-btn.has-hover ? Theme.border-subtle : transparent;
                                    animate background { duration: Theme.dur-fast; }
                                    Text {
                                        text: "\u{22ee}";
                                        color: ctx-btn.has-hover ? Theme.text-primary : Theme.text-dim;
                                        font-size: Theme.fs-body;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }

                        // Row separator
                        Rectangle {
                            y: parent.height - 1px;
                            height: 1px;
                            background: Theme.separator;
                        }
                    }
                }

                // ── Single-select action bar ──
                if root.selected-index >= 0 && root.selected-index < root.entries.length && root.selection-count <= 1 : Rectangle {
                    height: 48px;
                    background: Theme.bg-surface;
                    // Top holographic edge
                    Rectangle {
                        y: 0; width: 100%; height: 1px;
                        background: Theme.separator;
                    }

                    HorizontalLayout {
                        padding-left: 16px; padding-right: 16px; spacing: 8px; alignment: center;

                        open-btn := TouchArea {
                            width: 56px; height: 36px;
                            clicked => { root.open-file(root.entries[root.selected-index].name); root.selected-index = -1; root.clear-selection(); }
                            Rectangle {
                                border-radius: Theme.r-md;
                                background: open-btn.has-hover ? Theme.hover-fill : transparent;
                                border-width: open-btn.has-hover ? 1px : 0; border-color: Theme.cyan-dim;
                                animate background, border-width { duration: Theme.dur-fast; }
                                Text { text: "Open"; color: open-btn.has-hover ? Theme.cyan : Theme.cyan-dim; font-size: Theme.fs-caption; horizontal-alignment: center; vertical-alignment: center; animate color { duration: Theme.dur-fast; } }
                            }
                        }

                        // Quick Look button
                        if !root.entries[root.selected-index].is-dir : ql-btn := TouchArea {
                            width: 72px; height: 36px;
                            clicked => { root.file-quick-look(root.selected-index); }
                            Rectangle {
                                border-radius: Theme.r-md;
                                background: ql-btn.has-hover ? Theme.hover-fill : transparent;
                                border-width: ql-btn.has-hover ? 1px : 0; border-color: Theme.amber-dim;
                                animate background, border-width { duration: Theme.dur-fast; }
                                Text { text: "Preview"; color: ql-btn.has-hover ? Theme.amber : Theme.amber-dim; font-size: Theme.fs-caption; horizontal-alignment: center; vertical-alignment: center; animate color { duration: Theme.dur-fast; } }
                            }
                        }

                        copy-btn := TouchArea {
                            width: 56px; height: 36px;
                            clicked => { root.file-copy(root.entries[root.selected-index].name); root.selected-index = -1; root.clear-selection(); }
                            Rectangle {
                                border-radius: Theme.r-md;
                                background: copy-btn.has-hover ? Theme.hover-fill : transparent;
                                animate background { duration: Theme.dur-fast; }
                                Text { text: "Copy"; color: copy-btn.has-hover ? Theme.text-primary : Theme.text-secondary; font-size: Theme.fs-caption; horizontal-alignment: center; vertical-alignment: center; animate color { duration: Theme.dur-fast; } }
                            }
                        }

                        cut-btn := TouchArea {
                            width: 56px; height: 36px;
                            clicked => { root.file-cut(root.entries[root.selected-index].name); root.selected-index = -1; root.clear-selection(); }
                            Rectangle {
                                border-radius: Theme.r-md;
                                background: cut-btn.has-hover ? Theme.hover-fill : transparent;
                                animate background { duration: Theme.dur-fast; }
                                Text { text: "Cut"; color: cut-btn.has-hover ? Theme.text-primary : Theme.text-secondary; font-size: Theme.fs-caption; horizontal-alignment: center; vertical-alignment: center; animate color { duration: Theme.dur-fast; } }
                            }
                        }

                        rename-btn := TouchArea {
                            width: 64px; height: 36px;
                            clicked => { root.rename-old-name = root.entries[root.selected-index].name; root.rename-new-name = root.entries[root.selected-index].name; root.show-rename-dialog = true; }
                            Rectangle {
                                border-radius: Theme.r-md;
                                background: rename-btn.has-hover ? Theme.hover-fill : transparent;
                                animate background { duration: Theme.dur-fast; }
                                Text { text: "Rename"; color: rename-btn.has-hover ? Theme.text-primary : Theme.text-secondary; font-size: Theme.fs-caption; horizontal-alignment: center; vertical-alignment: center; animate color { duration: Theme.dur-fast; } }
                            }
                        }

                        del-btn := TouchArea {
                            width: 64px; height: 36px;
                            clicked => { root.delete-target-name = root.entries[root.selected-index].name; root.show-delete-dialog = true; }
                            Rectangle {
                                border-radius: Theme.r-md;
                                background: del-btn.has-hover ? Theme.color-danger-dim : transparent;
                                border-width: del-btn.has-hover ? 1px : 0; border-color: Theme.color-danger-dim;
                                animate background, border-width { duration: Theme.dur-fast; }
                                Text { text: "Delete"; color: del-btn.has-hover ? Theme.color-danger : Theme.color-danger; font-size: Theme.fs-caption; horizontal-alignment: center; vertical-alignment: center; animate color { duration: Theme.dur-fast; } }
                            }
                        }
                    }
                }

                // ── Empty state ──
                if entries.length == 0 && !is-loading : VerticalLayout {
                    vertical-stretch: 1;
                    alignment: center;
                    padding: 40px;
                    Rectangle {
                        width: 48px; height: 48px; x: (parent.width - 48px) / 2;
                        border-radius: 24px; border-width: 1px; border-color: Theme.cyan-dim;
                        background: Theme.accent-dim;
                        drop-shadow-blur: 8px; drop-shadow-color: Theme.cyan-glow;
                        Text { text: "\u{2205}"; color: Theme.cyan-dim; font-size: Theme.fs-display; horizontal-alignment: center; vertical-alignment: center; }
                    }
                    Rectangle { height: 12px; }
                    Text { text: "Empty directory"; color: Theme.text-dim; font-size: Theme.font-body; horizontal-alignment: center; }
                }

                // Loading
                if is-loading : VerticalLayout {
                    vertical-stretch: 1;
                    alignment: center;
                    Text { text: "Loading..."; color: Theme.text-dim; font-size: Theme.font-body; horizontal-alignment: center; }
                }
            }

            // ── Right detail panel (toggleable) ──
            if root.detail-panel-visible && root.selected-index >= 0 && root.file-details.name != "" : Rectangle {
                width: 260px;

                background: Theme.bg-card;

                // Left holographic border
                Rectangle {
                    x: 0; y: 0; width: 2px; height: parent.height;
                    background: Theme.border-strong;
                    opacity: 0.6;
                }

                // Close button
                detail-close := TouchArea {
                    x: parent.width - 36px; y: 4px; width: 28px; height: 28px;
                    clicked => { root.detail-panel-visible = false; }
                    Rectangle {
                        border-radius: Theme.r-sm;
                        background: detail-close.has-hover ? Theme.color-danger-dim : transparent;
                        animate background { duration: Theme.dur-fast; }
                        Text { text: "\u{2715}"; color: detail-close.has-hover ? Theme.color-danger : Theme.text-dim; font-size: Theme.fs-body; horizontal-alignment: center; vertical-alignment: center; animate color { duration: Theme.dur-fast; } }
                    }
                }

                Flickable {
                    x: 2px; y: 0; width: parent.width - 2px; height: parent.height;
                    viewport-height: detail-col.preferred-height;

                    detail-col := VerticalLayout {
                        padding: 16px; padding-top: 12px; spacing: 14px;

                        // Large icon badge
                        HorizontalLayout {
                            spacing: 12px;
                            Rectangle {
                                property <color> detail-badge-color:
                                    root.file-details.icon-char == "\u{25c7}" ? #3aad6a :
                                    root.file-details.icon-char == "\u{2261}" ? #5a7abd :
                                    root.file-details.icon-char == "\u{25a3}" ? #9a4a9a :
                                    root.file-details.icon-char == "\u{266a}" ? #c89a3a :
                                    root.file-details.icon-char == "\u{25b6}" ? #c84a5a :
                                    root.file-details.icon-char == "\u{25a4}" ? #7a8a6a :
                                    root.file-details.icon-char == "\u{25a7}" ? #bd5a4a :
                                    root.file-details.icon-char == "\u{2699}" ? #4a7abd :
                                    root.file-details.icon-char == "\u{00b7}" ? #6a6a7a :
                                    #5a5a7a;
                                width: 48px; height: 48px; border-radius: Theme.r-lg;
                                background: detail-badge-color;
                                border-width: 1px; border-color: detail-badge-color;
                                drop-shadow-blur: 16px; drop-shadow-color: detail-badge-color;
                                Text { text: root.file-details.icon-char; color: Theme.text-on-accent; font-size: Theme.fs-display; horizontal-alignment: center; vertical-alignment: center; }
                            }
                            VerticalLayout {
                                alignment: center; horizontal-stretch: 1;
                                Text { text: root.file-details.name; color: Theme.text-primary; font-size: Theme.fs-body; font-weight: 600; wrap: word-wrap; }
                                Text { text: root.file-details.file-type; color: Theme.text-dim; font-size: Theme.fs-caption; }
                            }
                        }

                        // Separator
                        Rectangle { height: 1px; background: Theme.separator; opacity: 0.5; }

                        // Info rows
                        VerticalLayout {
                            spacing: 10px;
                            if root.file-details.size-text != "" : HorizontalLayout { spacing: 8px; Text { text: "Size"; color: Theme.text-dim; font-size: Theme.fs-caption; width: 72px; vertical-alignment: center; } Text { text: root.file-details.size-text; color: Theme.text-secondary; font-size: Theme.fs-caption; vertical-alignment: center; } }
                            if root.file-details.modified-text != "" : HorizontalLayout { spacing: 8px; Text { text: "Modified"; color: Theme.text-dim; font-size: Theme.fs-caption; width: 72px; } Text { text: root.file-details.modified-text; color: Theme.text-secondary; font-size: Theme.fs-caption; wrap: word-wrap; horizontal-stretch: 1; } }
                            HorizontalLayout { spacing: 8px; Text { text: "Path"; color: Theme.text-dim; font-size: Theme.fs-caption; width: 72px; } Text { text: root.file-details.path-text; color: Theme.text-secondary; font-size: Theme.fs-caption; wrap: char-wrap; horizontal-stretch: 1; } }
                            if root.file-details.permissions != "" : HorizontalLayout { spacing: 8px; Text { text: "Perms"; color: Theme.text-dim; font-size: Theme.fs-caption; width: 72px; vertical-alignment: center; } Text { text: root.file-details.permissions; color: Theme.text-secondary; font-size: Theme.fs-caption; vertical-alignment: center; } }
                        }

                        // Preview
                        if root.file-details.is-text-file : VerticalLayout {
                            spacing: 8px;
                            Rectangle { height: 1px; background: Theme.separator; opacity: 0.5; }
                            Text { text: "Preview"; color: Theme.cyan-dim; font-size: Theme.fs-caption; font-weight: 600; letter-spacing: 2px; }
                            Rectangle {
                                clip: true; border-radius: Theme.r-sm; height: 180px;
                                background: Theme.bg-deep;
                                border-width: 1px; border-color: Theme.border-subtle;
                                Rectangle { x: 8px; y: 0; width: parent.width - 16px; height: 1px; background: Theme.separator; }
                                Text { x: 8px; y: 8px; width: parent.width - 16px; text: root.file-details.preview-text; color: Theme.text-dim; font-size: Theme.fs-micro; wrap: word-wrap; }
                            }
                        }

                        // ── AI Actions ──
                        Rectangle { height: 1px; background: Theme.separator; opacity: 0.5; }

                        HorizontalLayout {
                            spacing: 8px;
                            padding-top: 2px;

                            // Summarize button
                            if root.file-details.is-text-file : summarize-btn := TouchArea {
                                horizontal-stretch: 1;
                                height: 32px;
                                clicked => { root.show-summary-dialog = true; root.request-summarize(); }
                                Rectangle {
                                    border-radius: Theme.r-md;
                                    background: summarize-btn.has-hover
                                        ? Theme.hover-fill
                                        : transparent;
                                    border-width: 1px;
                                    border-color: summarize-btn.has-hover ? Theme.amber-dim : Theme.border-subtle;
                                    animate background, border-color { duration: Theme.dur-fast; }
                                    HorizontalLayout {
                                        spacing: 6px;
                                        alignment: center;
                                        Text { text: "\u{2726}"; color: Theme.amber; font-size: Theme.fs-caption; vertical-alignment: center; }
                                        Text { text: "Summarize"; color: summarize-btn.has-hover ? Theme.amber : Theme.amber-dim; font-size: Theme.fs-caption; vertical-alignment: center; animate color { duration: Theme.dur-fast; } }
                                    }
                                }
                            }

                            // Ask AI button
                            ask-ai-btn := TouchArea {
                                horizontal-stretch: 1;
                                height: 32px;
                                clicked => { root.request-ask-ai(); }
                                Rectangle {
                                    border-radius: Theme.r-md;
                                    background: ask-ai-btn.has-hover
                                        ? Theme.hover-fill
                                        : transparent;
                                    border-width: 1px;
                                    border-color: ask-ai-btn.has-hover ? Theme.cyan-dim : Theme.border-subtle;
                                    animate background, border-color { duration: Theme.dur-fast; }
                                    HorizontalLayout {
                                        spacing: 6px;
                                        alignment: center;
                                        Text { text: "\u{25c8}"; color: Theme.cyan; font-size: Theme.fs-caption; vertical-alignment: center; }
                                        Text { text: "Ask AI"; color: ask-ai-btn.has-hover ? Theme.cyan : Theme.cyan-dim; font-size: Theme.fs-caption; vertical-alignment: center; animate color { duration: Theme.dur-fast; } }
                                    }
                                }
                            }
                        }

                        // Quick actions
                        Rectangle { height: 1px; background: Theme.separator; opacity: 0.5; }

                        VerticalLayout {
                            spacing: 4px;

                            // Copy path button
                            cp-path-btn := TouchArea {
                                height: 28px;
                                clicked => { root.context-copy-path(root.file-details.path-text); }
                                Rectangle {
                                    border-radius: Theme.r-sm;
                                    background: cp-path-btn.has-hover ? Theme.hover-fill : transparent;
                                    animate background { duration: Theme.dur-fast; }
                                    HorizontalLayout {
                                        padding-left: 8px; spacing: 8px;
                                        Text { text: "\u{2398}"; color: Theme.text-dim; font-size: Theme.fs-caption; vertical-alignment: center; }
                                        Text { text: "Copy Path"; color: cp-path-btn.has-hover ? Theme.text-primary : Theme.text-secondary; font-size: Theme.fs-caption; vertical-alignment: center; }
                                    }
                                }
                            }

                            // Open terminal here
                            term-btn := TouchArea {
                                height: 28px;
                                clicked => { root.context-open-terminal(); }
                                Rectangle {
                                    border-radius: Theme.r-sm;
                                    background: term-btn.has-hover ? Theme.hover-fill : transparent;
                                    animate background { duration: Theme.dur-fast; }
                                    HorizontalLayout {
                                        padding-left: 8px; spacing: 8px;
                                        Text { text: ">_"; color: Theme.text-dim; font-size: Theme.fs-micro; font-weight: 700; vertical-alignment: center; }
                                        Text { text: "Open Terminal Here"; color: term-btn.has-hover ? Theme.text-primary : Theme.text-secondary; font-size: Theme.fs-caption; vertical-alignment: center; }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        // ── File operations queue drawer ──
        if root.file-op-queue.length > 0 : Rectangle {
            height: root.file-op-queue-visible ? min(root.file-op-queue.length * 32px + 36px, 160px) : 28px;
            background: Theme.bg-surface;
            clip: true;
            animate height { duration: Theme.dur-normal; easing: ease-out; }

            // Top edge
            Rectangle {
                y: 0; width: 100%; height: 1px;
                background: Theme.separator;
            }

            VerticalLayout {
                spacing: 0px;

                // Toggle header
                ops-toggle := TouchArea {
                    height: 28px;
                    clicked => { root.file-op-queue-visible = !root.file-op-queue-visible; }
                    HorizontalLayout {
                        padding-left: 12px; padding-right: 12px; spacing: 8px;

                        Text {
                            text: root.file-op-queue-visible ? "\u{25bc}" : "\u{25b6}";
                            color: Theme.text-dim;
                            font-size: 10px;
                            vertical-alignment: center;
                        }

                        Text {
                            text: root.file-op-queue.length + " operation(s)";
                            color: Theme.cyan-dim;
                            font-size: Theme.fs-micro;
                            font-weight: 600;
                            vertical-alignment: center;
                        }

                        Rectangle { horizontal-stretch: 1; }
                    }
                }

                // Operation items
                if root.file-op-queue-visible : Flickable {
                    vertical-stretch: 1;
                    viewport-height: root.file-op-queue.length * 32px;

                    for op[idx] in root.file-op-queue : Rectangle {
                        height: 32px;
                        y: idx * 32px;

                        HorizontalLayout {
                            padding-left: 16px; padding-right: 16px; spacing: 8px;

                            Text {
                                text: op.operation;
                                color: op.status == "error" ? Theme.color-danger : (op.status == "done" ? Theme.color-success : Theme.text-secondary);
                                font-size: Theme.fs-micro;
                                width: 56px;
                                vertical-alignment: center;
                            }

                            Text {
                                text: op.filename;
                                color: Theme.text-primary;
                                font-size: Theme.fs-micro;
                                horizontal-stretch: 1;
                                vertical-alignment: center;
                                overflow: elide;
                            }

                            // Progress bar
                            Rectangle {
                                width: 80px; height: 6px;
                                border-radius: 3px;
                                background: Theme.hover-fill;

                                Rectangle {
                                    width: parent.width * op.progress;
                                    height: 100%;
                                    border-radius: 3px;
                                    background: op.status == "error" ? Theme.color-danger : (op.status == "done" ? Theme.color-success : Theme.cyan);
                                    animate width { duration: Theme.dur-fast; }
                                }
                            }

                            Text {
                                text: op.status == "done" ? "\u{2713}" : (op.status == "error" ? "\u{2715}" : "");
                                color: op.status == "done" ? Theme.color-success : Theme.color-danger;
                                font-size: Theme.fs-caption;
                                width: 16px;
                                vertical-alignment: center;
                                horizontal-alignment: center;
                            }
                        }
                    }
                }
            }
        }

        // ── Status bar — file count + selection info + sort order + free space ──
        Rectangle {
            height: 26px;
            background: Theme.bg-surface;

            // Top edge
            Rectangle {
                y: 0; width: 100%; height: 1px;
                background: Theme.separator;
            }

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                spacing: 16px;

                // Item count
                Text {
                    text: root.entries.length == 1 ? "1 item" : root.entries.length + " items";
                    color: Theme.text-dim;
                    font-size: Theme.fs-micro;
                    vertical-alignment: center;
                }

                // Selection count
                if root.selection-count > 0 : Text {
                    text: "\u{2502}";
                    color: Theme.text-dim;
                    font-size: Theme.fs-micro;
                    vertical-alignment: center;
                }

                if root.selection-count > 0 : Text {
                    text: root.selection-count + " selected";
                    color: Theme.cyan-dim;
                    font-size: Theme.fs-micro;
                    font-weight: 600;
                    vertical-alignment: center;
                }

                // Selection size
                if root.selection-size-text != "" : Text {
                    text: "(" + root.selection-size-text + ")";
                    color: Theme.text-dim;
                    font-size: Theme.fs-micro;
                    vertical-alignment: center;
                }

                // Sort order
                Text {
                    text: "\u{2502}";
                    color: Theme.text-dim;
                    font-size: Theme.fs-micro;
                    vertical-alignment: center;
                }

                Text {
                    text: root.sort-order-text();
                    color: Theme.text-dim;
                    font-size: Theme.fs-micro;
                    vertical-alignment: center;
                }

                if root.dir-type-badge != "" : Text {
                    text: "\u{2502}";
                    color: Theme.text-dim;
                    font-size: Theme.fs-micro;
                    vertical-alignment: center;
                }

                if root.dir-type-badge != "" : Text {
                    text: root.dir-type-badge;
                    color: Theme.amber-dim;
                    font-size: Theme.fs-micro;
                    font-weight: 600;
                    vertical-alignment: center;
                }

                if root.free-space-text != "" : Text {
                    text: "\u{2502}";
                    color: Theme.text-dim;
                    font-size: Theme.fs-micro;
                    vertical-alignment: center;
                }

                if root.free-space-text != "" : Text {
                    text: "Free: " + root.free-space-text;
                    color: Theme.text-dim;
                    font-size: Theme.fs-micro;
                    vertical-alignment: center;
                }

                Rectangle { horizontal-stretch: 1; }

                Text {
                    text: root.current-path;
                    color: Theme.text-dim;
                    font-size: Theme.fs-micro;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
        }
    }

    // ═══ Context menu overlay ═══
    if root.show-context-menu && root.context-menu-index >= 0 && root.context-menu-index < root.entries.length : Rectangle {
        width: 100%; height: 100%; background: Theme.overlay-backdrop;
        // Click outside to dismiss
        TouchArea {
            clicked => { root.show-context-menu = false; }
        }

        // Menu card — centered for simplicity
        Rectangle {
            x: (parent.width - 200px) / 2;
            y: (parent.height - 380px) / 2;
            width: 200px;
            height: 380px;
            border-radius: Theme.r-lg;
            background: Theme.bg-elevated;
            border-width: 1px; border-color: Theme.border-subtle;
            drop-shadow-blur: 24px; drop-shadow-color: Theme.overlay-shadow;
            clip: true;

            // Block clicks from passing through
            TouchArea {}

            VerticalLayout {
                padding: 6px; spacing: 0px;

                // Header
                Rectangle {
                    height: 32px;
                    HorizontalLayout {
                        padding-left: 12px;
                        Text {
                            text: root.entries[root.context-menu-index].name;
                            color: Theme.text-primary;
                            font-size: Theme.fs-caption; font-weight: 600;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                    }
                }
                Rectangle { height: 1px; background: Theme.border-subtle; }

                // Open
                ctx-open := TouchArea {
                    height: 32px;
                    clicked => {
                        if root.entries[root.context-menu-index].is-dir {
                            root.navigate-dir(root.entries[root.context-menu-index].name);
                        } else {
                            root.open-file(root.entries[root.context-menu-index].name);
                        }
                        root.show-context-menu = false;
                    }
                    Rectangle {
                        border-radius: Theme.r-sm;
                        background: ctx-open.has-hover ? Theme.hover-fill : transparent;
                        HorizontalLayout { padding-left: 12px; spacing: 10px; Text { text: "Open"; color: ctx-open.has-hover ? Theme.cyan : Theme.text-secondary; font-size: Theme.fs-caption; vertical-alignment: center; } }
                    }
                }

                Rectangle { height: 1px; background: Theme.border-subtle; }

                // Copy
                ctx-copy := TouchArea {
                    height: 32px;
                    clicked => { root.file-copy(root.entries[root.context-menu-index].name); root.show-context-menu = false; }
                    Rectangle {
                        border-radius: Theme.r-sm;
                        background: ctx-copy.has-hover ? Theme.hover-fill : transparent;
                        HorizontalLayout { padding-left: 12px; spacing: 10px; Text { text: "Copy"; color: ctx-copy.has-hover ? Theme.text-primary : Theme.text-secondary; font-size: Theme.fs-caption; vertical-alignment: center; } }
                    }
                }

                // Cut
                ctx-cut := TouchArea {
                    height: 32px;
                    clicked => { root.file-cut(root.entries[root.context-menu-index].name); root.show-context-menu = false; }
                    Rectangle {
                        border-radius: Theme.r-sm;
                        background: ctx-cut.has-hover ? Theme.hover-fill : transparent;
                        HorizontalLayout { padding-left: 12px; spacing: 10px; Text { text: "Cut"; color: ctx-cut.has-hover ? Theme.text-primary : Theme.text-secondary; font-size: Theme.fs-caption; vertical-alignment: center; } }
                    }
                }

                // Paste (if clipboard)
                if root.has-clipboard : ctx-paste := TouchArea {
                    height: 32px;
                    clicked => { root.file-paste(); root.show-context-menu = false; }
                    Rectangle {
                        border-radius: Theme.r-sm;
                        background: ctx-paste.has-hover ? Theme.hover-fill : transparent;
                        HorizontalLayout { padding-left: 12px; spacing: 10px; Text { text: "Paste"; color: ctx-paste.has-hover ? Theme.text-primary : Theme.text-secondary; font-size: Theme.fs-caption; vertical-alignment: center; } }
                    }
                }

                Rectangle { height: 1px; background: Theme.border-subtle; }

                // Rename
                ctx-rename := TouchArea {
                    height: 32px;
                    clicked => {
                        root.rename-old-name = root.entries[root.context-menu-index].name;
                        root.rename-new-name = root.entries[root.context-menu-index].name;
                        root.show-rename-dialog = true;
                        root.show-context-menu = false;
                    }
                    Rectangle {
                        border-radius: Theme.r-sm;
                        background: ctx-rename.has-hover ? Theme.hover-fill : transparent;
                        HorizontalLayout { padding-left: 12px; spacing: 10px; Text { text: "Rename"; color: ctx-rename.has-hover ? Theme.text-primary : Theme.text-secondary; font-size: Theme.fs-caption; vertical-alignment: center; } }
                    }
                }

                // Delete
                ctx-del := TouchArea {
                    height: 32px;
                    clicked => {
                        root.delete-target-name = root.entries[root.context-menu-index].name;
                        root.show-delete-dialog = true;
                        root.show-context-menu = false;
                    }
                    Rectangle {
                        border-radius: Theme.r-sm;
                        background: ctx-del.has-hover ? Theme.color-danger-dim : transparent;
                        HorizontalLayout { padding-left: 12px; spacing: 10px; Text { text: "Delete"; color: ctx-del.has-hover ? Theme.color-danger : Theme.color-danger; font-size: Theme.fs-caption; vertical-alignment: center; } }
                    }
                }

                Rectangle { height: 1px; background: Theme.border-subtle; }

                // Compress
                ctx-compress := TouchArea {
                    height: 32px;
                    clicked => { root.context-compress(root.entries[root.context-menu-index].name); root.show-context-menu = false; }
                    Rectangle {
                        border-radius: Theme.r-sm;
                        background: ctx-compress.has-hover ? Theme.hover-fill : transparent;
                        HorizontalLayout { padding-left: 12px; spacing: 10px; Text { text: "Compress"; color: ctx-compress.has-hover ? Theme.text-primary : Theme.text-secondary; font-size: Theme.fs-caption; vertical-alignment: center; } }
                    }
                }

                // Copy Path
                ctx-cp-path := TouchArea {
                    height: 32px;
                    clicked => { root.context-copy-path(root.entries[root.context-menu-index].name); root.show-context-menu = false; }
                    Rectangle {
                        border-radius: Theme.r-sm;
                        background: ctx-cp-path.has-hover ? Theme.hover-fill : transparent;
                        HorizontalLayout { padding-left: 12px; spacing: 10px; Text { text: "Copy Path"; color: ctx-cp-path.has-hover ? Theme.text-primary : Theme.text-secondary; font-size: Theme.fs-caption; vertical-alignment: center; } }
                    }
                }

                // Open Terminal Here
                ctx-term := TouchArea {
                    height: 32px;
                    clicked => { root.context-open-terminal(); root.show-context-menu = false; }
                    Rectangle {
                        border-radius: Theme.r-sm;
                        background: ctx-term.has-hover ? Theme.hover-fill : transparent;
                        HorizontalLayout { padding-left: 12px; spacing: 10px; Text { text: "Open Terminal Here"; color: ctx-term.has-hover ? Theme.text-primary : Theme.text-secondary; font-size: Theme.fs-caption; vertical-alignment: center; } }
                    }
                }
            }
        }
    }

    // ═══ Rename dialog ═══
    if root.show-rename-dialog : Rectangle {
        width: 100%; height: 100%; background: Theme.overlay-backdrop;
        TouchArea { clicked => { root.show-rename-dialog = false; root.selected-index = -1; root.clear-selection(); } }
        Rectangle {
            x: (parent.width - 340px) / 2; y: (parent.height - 180px) / 2; width: 340px; height: 180px;
            border-radius: 16px;
            background: Theme.bg-elevated;
            border-width: 1px; border-color: Theme.border-subtle;
            drop-shadow-blur: 24px; drop-shadow-color: Theme.overlay-shadow;
            Rectangle { x: 16px; y: 1px; width: parent.width - 32px; height: 1px; border-radius: 0.5px; background: Theme.separator; }
            TouchArea {}
            VerticalLayout {
                padding: 20px; spacing: 16px;
                Text { text: "Rename"; color: Theme.text-primary; font-size: Theme.font-title; font-weight: 600; }
                rename-input := LineEdit { text: root.rename-new-name; edited(t) => { root.rename-new-name = t; } accepted(t) => { root.file-rename(root.rename-old-name, t); root.show-rename-dialog = false; root.selected-index = -1; root.clear-selection(); } }
                HorizontalLayout {
                    spacing: 12px; alignment: end;
                    TouchArea { width: 80px; height: 36px; clicked => { root.show-rename-dialog = false; root.selected-index = -1; root.clear-selection(); } Rectangle { border-radius: Theme.r-md; background: parent.has-hover ? Theme.hover-fill : transparent; animate background { duration: Theme.dur-fast; } Text { text: "Cancel"; color: Theme.text-dim; font-size: Theme.fs-body; horizontal-alignment: center; vertical-alignment: center; } } }
                    TouchArea { width: 80px; height: 36px; clicked => { root.file-rename(root.rename-old-name, root.rename-new-name); root.show-rename-dialog = false; root.selected-index = -1; root.clear-selection(); } Rectangle { border-radius: Theme.r-md; background: parent.has-hover ? Theme.hover-fill : Theme.bg-elevated; animate background { duration: Theme.dur-fast; } Text { text: "Rename"; color: Theme.cyan; font-size: Theme.fs-body; horizontal-alignment: center; vertical-alignment: center; } } }
                }
            }
        }
    }

    // ═══ Delete dialog ═══
    if root.show-delete-dialog : Rectangle {
        width: 100%; height: 100%; background: Theme.overlay-backdrop;
        TouchArea { clicked => { root.show-delete-dialog = false; root.selected-index = -1; root.clear-selection(); } }
        Rectangle {
            x: (parent.width - 340px) / 2; y: (parent.height - 160px) / 2; width: 340px; height: 160px;
            border-radius: 16px;
            background: Theme.bg-elevated;
            border-width: 1px; border-color: Theme.border-subtle;
            drop-shadow-blur: 24px; drop-shadow-color: Theme.overlay-shadow;
            Rectangle { x: 16px; y: 1px; width: parent.width - 32px; height: 1px; border-radius: 0.5px; background: Theme.separator; }
            TouchArea {}
            VerticalLayout {
                padding: 20px; spacing: 16px;
                Text { text: "Delete \"" + root.delete-target-name + "\"?"; color: Theme.text-primary; font-size: Theme.font-body; wrap: word-wrap; }
                Text { text: "This cannot be undone."; color: Theme.text-dim; font-size: Theme.font-small; }
                HorizontalLayout {
                    spacing: 12px; alignment: end;
                    TouchArea { width: 80px; height: 36px; clicked => { root.show-delete-dialog = false; root.selected-index = -1; root.clear-selection(); } Rectangle { border-radius: Theme.r-md; background: parent.has-hover ? Theme.hover-fill : transparent; animate background { duration: Theme.dur-fast; } Text { text: "Cancel"; color: Theme.text-dim; font-size: Theme.fs-body; horizontal-alignment: center; vertical-alignment: center; } } }
                    TouchArea { width: 80px; height: 36px; clicked => {
                        if root.selection-count > 1 {
                            root.delete-selected();
                        } else {
                            root.file-delete(root.delete-target-name);
                        }
                        root.show-delete-dialog = false; root.selected-index = -1; root.clear-selection();
                    } Rectangle { border-radius: Theme.r-md; background: parent.has-hover ? Theme.color-danger-dim : Theme.color-danger; drop-shadow-blur: parent.has-hover ? 8px : 0; drop-shadow-color: Theme.color-danger-dim; animate background, drop-shadow-blur { duration: Theme.dur-fast; } Text { text: "Delete"; color: Theme.text-on-accent; font-size: Theme.fs-body; horizontal-alignment: center; vertical-alignment: center; } } }
                }
            }
        }
    }

    // ═══ New folder dialog ═══
    if root.show-new-folder-dialog : Rectangle {
        width: 100%; height: 100%; background: Theme.overlay-backdrop;
        TouchArea { clicked => { root.show-new-folder-dialog = false; } }
        Rectangle {
            x: (parent.width - 340px) / 2; y: (parent.height - 180px) / 2; width: 340px; height: 180px;
            border-radius: 16px;
            background: Theme.bg-elevated;
            border-width: 1px; border-color: Theme.border-subtle;
            drop-shadow-blur: 24px; drop-shadow-color: Theme.overlay-shadow;
            Rectangle { x: 16px; y: 1px; width: parent.width - 32px; height: 1px; border-radius: 0.5px; background: Theme.separator; }
            TouchArea {}
            VerticalLayout {
                padding: 20px; spacing: 16px;
                Text { text: "New Folder"; color: Theme.text-primary; font-size: Theme.font-title; font-weight: 600; }
                folder-input := LineEdit { text: root.new-folder-name; placeholder-text: "Folder name"; edited(t) => { root.new-folder-name = t; } accepted(t) => { root.create-folder(t); root.show-new-folder-dialog = false; } }
                HorizontalLayout {
                    spacing: 12px; alignment: end;
                    TouchArea { width: 80px; height: 36px; clicked => { root.show-new-folder-dialog = false; } Rectangle { border-radius: Theme.r-md; background: parent.has-hover ? Theme.hover-fill : transparent; animate background { duration: Theme.dur-fast; } Text { text: "Cancel"; color: Theme.text-dim; font-size: Theme.fs-body; horizontal-alignment: center; vertical-alignment: center; } } }
                    TouchArea { width: 80px; height: 36px; clicked => { root.create-folder(root.new-folder-name); root.show-new-folder-dialog = false; } Rectangle { border-radius: Theme.r-md; background: parent.has-hover ? Theme.hover-fill : Theme.bg-elevated; animate background { duration: Theme.dur-fast; } Text { text: "Create"; color: Theme.cyan; font-size: Theme.fs-body; horizontal-alignment: center; vertical-alignment: center; } } }
                }
            }
        }
    }

    // ═══ New file dialog ═══
    if root.show-new-file-dialog : Rectangle {
        width: 100%; height: 100%; background: Theme.overlay-backdrop;
        TouchArea { clicked => { root.show-new-file-dialog = false; } }
        Rectangle {
            x: (parent.width - 340px) / 2; y: (parent.height - 180px) / 2; width: 340px; height: 180px;
            border-radius: 16px;
            background: Theme.bg-elevated;
            border-width: 1px; border-color: Theme.border-subtle;
            drop-shadow-blur: 24px; drop-shadow-color: Theme.overlay-shadow;
            Rectangle { x: 16px; y: 1px; width: parent.width - 32px; height: 1px; border-radius: 0.5px; background: Theme.separator; }
            TouchArea {}
            VerticalLayout {
                padding: 20px; spacing: 16px;
                Text { text: "New File"; color: Theme.text-primary; font-size: Theme.font-title; font-weight: 600; }
                file-input := LineEdit { text: root.new-file-name; placeholder-text: "File name"; edited(t) => { root.new-file-name = t; } accepted(t) => { root.create-file(t); root.show-new-file-dialog = false; } }
                HorizontalLayout {
                    spacing: 12px; alignment: end;
                    TouchArea { width: 80px; height: 36px; clicked => { root.show-new-file-dialog = false; } Rectangle { border-radius: Theme.r-md; background: parent.has-hover ? Theme.hover-fill : transparent; animate background { duration: Theme.dur-fast; } Text { text: "Cancel"; color: Theme.text-dim; font-size: Theme.fs-body; horizontal-alignment: center; vertical-alignment: center; } } }
                    TouchArea { width: 80px; height: 36px; clicked => { root.create-file(root.new-file-name); root.show-new-file-dialog = false; } Rectangle { border-radius: Theme.r-md; background: parent.has-hover ? Theme.color-success-dim : Theme.bg-elevated; animate background { duration: Theme.dur-fast; } Text { text: "Create"; color: Theme.color-success; font-size: Theme.fs-body; horizontal-alignment: center; vertical-alignment: center; } } }
                }
            }
        }
    }

    // ═══ AI Summary dialog ═══
    if root.show-summary-dialog : Rectangle {
        width: 100%; height: 100%; background: Theme.overlay-backdrop;
        TouchArea { clicked => { root.show-summary-dialog = false; } }
        Rectangle {
            x: (parent.width - 420px) / 2; y: (parent.height - 300px) / 2; width: 420px; height: 300px;
            border-radius: 16px;
            background: Theme.bg-elevated;
            border-width: 1px; border-color: root.is-summarizing ? Theme.amber : Theme.amber-dim;
            drop-shadow-blur: 32px; drop-shadow-color: Theme.amber-glow;
            animate border-color { duration: Theme.dur-slow; }

            // Top holographic edge
            Rectangle {
                y: 0; width: parent.width; height: 1px; border-radius: 16px;
                background: Theme.separator;
            }

            VerticalLayout {
                padding: 20px; spacing: 12px;

                // Header
                HorizontalLayout {
                    spacing: 10px;
                    Text {
                        text: "\u{2726}";
                        color: Theme.amber;
                        font-size: Theme.fs-headline;
                        vertical-alignment: center;
                    }
                    VerticalLayout {
                        horizontal-stretch: 1;
                        Text {
                            text: "AI Summary";
                            color: Theme.text-primary;
                            font-size: Theme.fs-headline;
                            font-weight: 600;
                        }
                        Text {
                            text: root.file-details.name;
                            color: Theme.text-dim;
                            font-size: Theme.fs-caption;
                        }
                    }
                    // Close button
                    summary-close := TouchArea {
                        width: 28px; height: 28px;
                        clicked => { root.show-summary-dialog = false; }
                        Rectangle {
                            border-radius: Theme.r-sm;
                            background: summary-close.has-hover ? Theme.color-danger-dim : transparent;
                            animate background { duration: Theme.dur-fast; }
                            Text { text: "\u{2715}"; color: summary-close.has-hover ? Theme.color-danger : Theme.text-dim; font-size: Theme.fs-body; horizontal-alignment: center; vertical-alignment: center; }
                        }
                    }
                }

                // Separator
                Rectangle { height: 1px; background: Theme.separator; opacity: 0.4; }

                // Summary content area
                Rectangle {
                    vertical-stretch: 1;
                    clip: true;
                    border-radius: Theme.r-md;
                    background: Theme.bg-deep;
                    border-width: 1px; border-color: Theme.border-subtle;

                    Flickable {
                        x: 0; y: 0; width: parent.width; height: parent.height;
                        viewport-height: summary-text.preferred-height + 24px;

                        summary-text := Text {
                            x: 14px;
                            y: 12px;
                            width: parent.width - 28px;
                            text: root.is-summarizing && root.ai-summary == "" ? "Thinking..." : root.ai-summary;
                            color: root.is-summarizing && root.ai-summary == "" ? Theme.text-dim : Theme.text-secondary;
                            font-size: Theme.fs-caption;
                            font-italic: root.is-summarizing && root.ai-summary == "";
                            wrap: word-wrap;
                            horizontal-alignment: left;
                        }
                    }

                    // Pulsing glow while summarizing
                    if root.is-summarizing : Rectangle {
                        x: 0; y: 0; width: parent.width; height: parent.height;
                        border-radius: Theme.r-md;
                        border-width: 1px;
                        border-color: Theme.amber;
                        opacity: 0.4;
                        animate opacity { duration: Theme.dur-slow; }
                    }
                }

                // Status
                if root.is-summarizing : Text {
                    text: "\u{27f3} Generating summary...";
                    color: Theme.amber-dim;
                    font-size: Theme.fs-micro;
                    horizontal-alignment: center;
                }
            }
        }
    }

    // ═══ Batch rename dialog ═══
    if root.file-batch-rename-open : Rectangle {
        width: 100%; height: 100%; background: Theme.overlay-backdrop;
        TouchArea { clicked => { root.file-batch-rename-open = false; } }
        Rectangle {
            x: (parent.width - 400px) / 2; y: (parent.height - 260px) / 2; width: 400px; height: 260px;
            border-radius: 16px;
            background: Theme.bg-elevated;
            border-width: 1px; border-color: Theme.amber-dim;
            drop-shadow-blur: 24px; drop-shadow-color: Theme.amber-glow;

            // Top edge
            Rectangle {
                y: 0; width: parent.width; height: 1px; border-radius: 16px;
                background: Theme.separator;
            }

            TouchArea {}

            VerticalLayout {
                padding: 20px; spacing: 14px;

                // Header
                HorizontalLayout {
                    spacing: 10px;
                    Text { text: "R"; color: Theme.amber; font-size: Theme.fs-headline; font-weight: 700; vertical-alignment: center; }
                    Text { text: "Batch Rename"; color: Theme.text-primary; font-size: Theme.fs-headline; font-weight: 600; vertical-alignment: center; horizontal-stretch: 1; }
                    batch-close := TouchArea {
                        width: 28px; height: 28px;
                        clicked => { root.file-batch-rename-open = false; }
                        Rectangle {
                            border-radius: Theme.r-sm;
                            background: batch-close.has-hover ? Theme.color-danger-dim : transparent;
                            animate background { duration: Theme.dur-fast; }
                            Text { text: "\u{2715}"; color: batch-close.has-hover ? Theme.color-danger : Theme.text-dim; font-size: Theme.fs-body; horizontal-alignment: center; vertical-alignment: center; }
                        }
                    }
                }

                // Pattern input
                VerticalLayout {
                    spacing: 4px;
                    Text { text: "Find pattern"; color: Theme.text-dim; font-size: Theme.fs-micro; font-weight: 600; letter-spacing: 1px; }
                    batch-pattern-input := LineEdit {
                        text: root.file-batch-rename-pattern;
                        placeholder-text: "e.g. .txt";
                        edited(t) => { root.file-batch-rename-pattern = t; }
                    }
                }

                // Replace input
                VerticalLayout {
                    spacing: 4px;
                    Text { text: "Replace with"; color: Theme.text-dim; font-size: Theme.fs-micro; font-weight: 600; letter-spacing: 1px; }
                    batch-replace-input := LineEdit {
                        text: root.file-batch-rename-replace;
                        placeholder-text: "e.g. .md";
                        edited(t) => { root.file-batch-rename-replace = t; }
                    }
                }

                // Preview hint
                Text {
                    text: root.selection-count + " file(s) will be renamed";
                    color: Theme.text-dim;
                    font-size: Theme.fs-micro;
                    font-italic: true;
                }

                // Buttons
                HorizontalLayout {
                    spacing: 12px; alignment: end;
                    TouchArea { width: 80px; height: 36px; clicked => { root.file-batch-rename-open = false; } Rectangle { border-radius: Theme.r-md; background: parent.has-hover ? Theme.hover-fill : transparent; animate background { duration: Theme.dur-fast; } Text { text: "Cancel"; color: Theme.text-dim; font-size: Theme.fs-body; horizontal-alignment: center; vertical-alignment: center; } } }
                    TouchArea { width: 88px; height: 36px; clicked => { root.file-batch-rename-execute(); root.file-batch-rename-open = false; } Rectangle { border-radius: Theme.r-md; background: parent.has-hover ? Theme.hover-fill : Theme.bg-elevated; animate background { duration: Theme.dur-fast; } Text { text: "Rename All"; color: Theme.amber; font-size: Theme.fs-body; horizontal-alignment: center; vertical-alignment: center; } } }
                }
            }
        }
    }

    // ═══ Quick Look overlay ═══
    if root.file-quick-look-open : Rectangle {
        width: 100%; height: 100%; background: Theme.overlay-backdrop;
        TouchArea { clicked => { root.file-quick-look-open = false; root.file-close-quick-look(); } }
        Rectangle {
            x: (parent.width - 520px) / 2; y: (parent.height - 420px) / 2; width: 520px; height: 420px;
            border-radius: 16px;
            background: Theme.bg-elevated;
            border-width: 1px; border-color: Theme.cyan-dim;
            drop-shadow-blur: 32px; drop-shadow-color: Theme.cyan-glow;

            // Top holographic edge
            Rectangle {
                y: 0; width: parent.width; height: 1px; border-radius: 16px;
                background: Theme.separator;
            }

            TouchArea {}

            VerticalLayout {
                padding: 20px; spacing: 12px;

                // Header
                HorizontalLayout {
                    spacing: 10px;
                    Text { text: "\u{25a3}"; color: Theme.cyan; font-size: Theme.fs-headline; vertical-alignment: center; }
                    VerticalLayout {
                        horizontal-stretch: 1;
                        Text { text: "Quick Look"; color: Theme.text-primary; font-size: Theme.fs-headline; font-weight: 600; }
                        Text { text: root.file-quick-look-name; color: Theme.text-dim; font-size: Theme.fs-caption; overflow: elide; }
                    }
                    ql-close := TouchArea {
                        width: 28px; height: 28px;
                        clicked => { root.file-quick-look-open = false; root.file-close-quick-look(); }
                        Rectangle {
                            border-radius: Theme.r-sm;
                            background: ql-close.has-hover ? Theme.color-danger-dim : transparent;
                            animate background { duration: Theme.dur-fast; }
                            Text { text: "\u{2715}"; color: ql-close.has-hover ? Theme.color-danger : Theme.text-dim; font-size: Theme.fs-body; horizontal-alignment: center; vertical-alignment: center; }
                        }
                    }
                }

                // Separator
                Rectangle { height: 1px; background: Theme.separator; opacity: 0.5; }

                // Content area
                Rectangle {
                    vertical-stretch: 1;
                    clip: true;
                    border-radius: Theme.r-md;
                    background: Theme.bg-deep;
                    border-width: 1px; border-color: Theme.border-subtle;

                    Flickable {
                        x: 0; y: 0; width: parent.width; height: parent.height;
                        viewport-height: ql-content-text.preferred-height + 24px;

                        ql-content-text := Text {
                            x: 14px;
                            y: 12px;
                            width: parent.width - 28px;
                            text: root.file-quick-look-content != "" ? root.file-quick-look-content : "No preview available";
                            color: root.file-quick-look-content != "" ? Theme.text-secondary : Theme.text-dim;
                            font-size: Theme.fs-caption;
                            font-italic: root.file-quick-look-content == "";
                            wrap: word-wrap;
                            horizontal-alignment: left;
                        }
                    }
                }
            }
        }
    }
}
