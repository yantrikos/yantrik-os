// Command Palette — Ctrl+Shift+P overlay for quick command access.
// Glassmorphic centered panel with fuzzy search, categorized results, keyboard navigation.

import { Theme } from "theme.slint";

export struct CommandItem {
    label: string,
    category: string,
    shortcut: string,
    icon-char: string,
    action-id: string,
}

export component CommandPalette inherits Rectangle {
    in-out property <bool> is-open: false;
    in property <[CommandItem]> commands: [];
    in property <[CommandItem]> filtered-commands: [];
    in property <string> search-text: "";
    in-out property <int> selected-index: 0;

    callback search-changed(string);
    callback command-selected(string);
    callback close();

    width: 100%;
    height: 100%;

    // Backdrop with fade
    if root.is-open : TouchArea {
        width: 100%;
        height: 100%;
        clicked => { root.is-open = false; root.close(); }

        Rectangle {
            width: 100%;
            height: 100%;
            background: Theme.overlay-backdrop;
            opacity: 1.0;
            animate opacity { duration: Theme.dur-normal; }
        }
    }

    // Panel — glassmorphic, centered with slide+fade entrance
    if root.is-open : Rectangle {
        x: (parent.width - 580px) / 2;
        y: 72px;
        width: 580px;
        height: min(palette-layout.preferred-height + Theme.sp-4, parent.height - 160px);
        border-radius: Theme.r-xl;
        clip: true;

        // Glass background
        background: @linear-gradient(180deg,
            Theme.bg-deep.transparentize(9%) 0%,
            Theme.bg-deep.transparentize(12%) 50%,
            Theme.bg-deep.transparentize(15%) 100%
        );
        border-width: 1px;
        border-color: Theme.hover-fill-strong;

        // Top glass rim
        Rectangle {
            x: Theme.sp-6; y: 0;
            width: parent.width - Theme.sp-9;
            height: 1px;
            background: @linear-gradient(90deg, transparent 0%, Theme.border-strong 50%, transparent 100%);
        }

        // Accent glow
        drop-shadow-blur: 40px;
        drop-shadow-color: Theme.accent-glow;
        drop-shadow-offset-y: 8px;

        palette-layout := VerticalLayout {
            padding: 0px;
            spacing: 0px;

            // Search input area
            Rectangle {
                height: Theme.lens-input-height;
                background: Theme.border-subtle;
                clip: true;

                HorizontalLayout {
                    padding-left: Theme.sp-4;
                    padding-right: Theme.sp-4;
                    spacing: Theme.sp-2;
                    alignment: center;

                    // Prompt icon
                    Text {
                        text: ">";
                        color: Theme.accent;
                        font-size: Theme.fs-headline;
                        font-weight: 700;
                        vertical-alignment: center;
                        width: 18px;
                    }

                    search-input := TextInput {
                        text: root.search-text;
                        font-size: Theme.fs-headline;
                        color: Theme.text-primary;
                        horizontal-alignment: left;
                        vertical-alignment: center;
                        input-type: text;
                        edited => {
                            root.selected-index = 0;
                            root.search-changed(self.text);
                        }
                        accepted => {
                            if root.filtered-commands.length > 0 {
                                root.command-selected(
                                    root.filtered-commands[min(root.selected-index, root.filtered-commands.length - 1)].action-id
                                );
                            }
                        }
                    }

                    // Escape hint
                    Rectangle {
                        width: 32px;
                        height: 20px;
                        y: (parent.height - 20px) / 2;
                        border-radius: Theme.r-sm;
                        background: Theme.bg-elevated;
                        border-width: 1px;
                        border-color: Theme.border-subtle;

                        Text {
                            text: "Esc";
                            color: Theme.text-dim;
                            font-size: 10px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                // Bottom separator
                Rectangle {
                    y: parent.height - 1px;
                    width: 100%;
                    height: 1px;
                    background: Theme.separator;
                }
            }

            // Results list with keyboard selection
            Flickable {
                viewport-height: results-col.preferred-height;
                height: min(results-col.preferred-height, 400px);

                results-col := VerticalLayout {
                    padding: Theme.sp-1;
                    spacing: 1px;

                    for item[idx] in root.filtered-commands : TouchArea {
                        property <bool> is-selected: idx == root.selected-index;
                        height: 40px;
                        clicked => { root.command-selected(item.action-id); }

                        Rectangle {
                            width: 100%;
                            height: 100%;
                            border-radius: Theme.r-md;
                            background: is-selected ? Theme.tint-accent
                                      : parent.has-hover ? Theme.hover-fill
                                      : transparent;
                            border-width: is-selected ? 1px : 0;
                            border-color: is-selected ? Theme.accent-glow : transparent;
                            animate background { duration: Theme.dur-fast; }

                            HorizontalLayout {
                                padding-left: Theme.sp-3;
                                padding-right: Theme.sp-3;
                                spacing: Theme.sp-2;
                                alignment: stretch;

                                // Icon
                                Rectangle {
                                    width: 28px;
                                    Text {
                                        text: item.icon-char;
                                        color: is-selected ? Theme.accent : Theme.accent-dim;
                                        font-size: Theme.fs-body;
                                        font-weight: 600;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                // Label
                                Text {
                                    text: item.label;
                                    color: is-selected ? Theme.text-primary : Theme.text-secondary;
                                    font-size: Theme.fs-body;
                                    font-weight: is-selected ? Theme.fw-body-strong : Theme.fw-body;
                                    vertical-alignment: center;
                                    overflow: elide;
                                    horizontal-stretch: 1;
                                }

                                // Category badge
                                Rectangle {
                                    width: cat-text.preferred-width + Theme.sp-3;
                                    height: 20px;
                                    border-radius: Theme.r-sm;
                                    background: Theme.hover-fill;

                                    cat-text := Text {
                                        text: item.category;
                                        color: Theme.text-dim;
                                        font-size: Theme.fs-caption;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                // Shortcut
                                if item.shortcut != "" : Rectangle {
                                    width: shortcut-text.preferred-width + Theme.sp-3;
                                    height: 20px;
                                    border-radius: Theme.r-sm;
                                    background: Theme.bg-elevated;
                                    border-width: 1px;
                                    border-color: Theme.border-subtle;

                                    shortcut-text := Text {
                                        text: item.shortcut;
                                        color: Theme.text-dim;
                                        font-size: 10px;
                                        font-weight: Theme.fw-body-strong;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }

                    // Empty state
                    if root.filtered-commands.length == 0 : VerticalLayout {
                        height: 80px;
                        alignment: center;
                        spacing: Theme.sp-1;

                        Text {
                            text: "No matching commands";
                            color: Theme.text-secondary;
                            font-size: Theme.fs-body;
                            horizontal-alignment: center;
                        }
                        Text {
                            text: "Try a different search term";
                            color: Theme.text-dim;
                            font-size: Theme.fs-caption;
                            horizontal-alignment: center;
                        }
                    }
                }
            }

            // Footer hint
            Rectangle {
                height: 32px;
                background: Theme.border-subtle;

                // Top separator
                Rectangle {
                    y: 0; width: 100%; height: 1px;
                    background: Theme.separator;
                }

                HorizontalLayout {
                    padding-left: Theme.sp-4;
                    padding-right: Theme.sp-4;
                    alignment: center;
                    spacing: Theme.sp-4;

                    Text {
                        text: "↑↓ Navigate";
                        color: Theme.text-dim;
                        font-size: Theme.fs-caption;
                        vertical-alignment: center;
                        opacity: 0.7;
                    }
                    Text {
                        text: "↵ Select";
                        color: Theme.text-dim;
                        font-size: Theme.fs-caption;
                        vertical-alignment: center;
                        opacity: 0.7;
                    }
                    Text {
                        text: "Esc Close";
                        color: Theme.text-dim;
                        font-size: Theme.fs-caption;
                        vertical-alignment: center;
                        opacity: 0.7;
                    }
                }
            }
        }
    }
}
