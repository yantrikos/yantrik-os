// App Grid — full-screen app launcher overlay.
// Shows all installed apps in a scrollable grid with search.
// Triggered by Super+A or dock gesture.

import { Theme } from "theme.slint";

export struct AppGridItem {
    app-id: string,
    name: string,
    icon-char: string,
}

export component AppGrid inherits Rectangle {
    in-out property <bool> is-open: false;
    in property <[AppGridItem]> apps: [];

    callback launch-app(string);
    callback close();
    callback search-changed(string);

    width: 100%;
    height: 100%;

    property <int> columns: 4;
    property <length> cell-size: 140px;
    property <length> grid-width: root.columns * root.cell-size + (root.columns - 1) * 16px + 48px;

    // Backdrop (click to close)
    if root.is-open : TouchArea {
        width: 100%;
        height: 100%;
        clicked => { root.is-open = false; root.close(); }

        Rectangle {
            width: 100%;
            height: 100%;
            background: Theme.overlay-backdrop;
        }
    }

    // Centered panel
    if root.is-open : Rectangle {
        x: (parent.width - root.grid-width) / 2;
        y: (parent.height - panel-height) / 2;
        property <int> rows: (root.apps.length + root.columns - 1) / root.columns;
        property <length> panel-height: min(self.rows * (root.cell-size + 12px) + 190px, parent.height - 80px);
        width: root.grid-width;
        height: panel-height;
        background: Theme.bg-elevated;
        border-radius: 16px;
        border-width: 1px;
        border-color: Theme.border-subtle;
        drop-shadow-blur: 32px;
        drop-shadow-color: Theme.overlay-shadow;
        clip: true;

        // Block click-through
        TouchArea { width: 100%; height: 100%; }

        VerticalLayout {
            padding: 20px;
            spacing: 12px;

            // Header with recent apps row
            Text {
                text: "Applications";
                color: Theme.text-primary;
                font-size: Theme.fs-title-1;
                font-weight: Theme.fw-title-1;
                horizontal-alignment: center;
            }

            // Search bar — search-first layout
            Rectangle {
                height: Theme.h-prominent;
                background: Theme.bg-deep;
                border-radius: Theme.r-lg;
                border-width: 1px;
                border-color: search-input.has-focus ? Theme.accent : Theme.border-subtle;
                clip: true;

                animate border-color { duration: Theme.dur-fast; }

                HorizontalLayout {
                    padding-left: Theme.sp-4;
                    padding-right: Theme.sp-4;
                    spacing: Theme.sp-2;

                    // Search icon
                    Text {
                        text: "⌕";
                        color: search-input.has-focus ? Theme.accent : Theme.text-dim;
                        font-size: Theme.fs-headline;
                        vertical-alignment: center;
                        animate color { duration: Theme.dur-fast; }
                    }

                    search-input := TextInput {
                        vertical-alignment: center;
                        font-size: Theme.fs-body;
                        color: Theme.text-primary;
                        horizontal-stretch: 1;

                        edited => {
                            root.search-changed(self.text);
                        }
                    }

                    // Result count badge
                    Rectangle {
                        width: count-text.preferred-width + Theme.sp-3;
                        height: 20px;
                        y: (parent.height - 20px) / 2;
                        border-radius: Theme.r-pill;
                        background: Theme.bg-elevated;

                        count-text := Text {
                            text: root.apps.length + " apps";
                            color: Theme.text-dim;
                            font-size: Theme.fs-caption;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }

            Rectangle { height: 1px; background: Theme.separator; }

            // Empty state
            if root.apps.length == 0 : VerticalLayout {
                vertical-stretch: 1;
                alignment: center;
                spacing: Theme.sp-2;

                Text {
                    text: "📦";
                    font-size: 40px;
                    horizontal-alignment: center;
                }
                Text {
                    text: "No apps found";
                    color: Theme.text-secondary;
                    font-size: Theme.fs-headline;
                    font-weight: Theme.fw-headline;
                    horizontal-alignment: center;
                }
                Text {
                    text: "Try a different search term";
                    color: Theme.text-dim;
                    font-size: Theme.fs-caption;
                    horizontal-alignment: center;
                }
            }

            // Scrollable app grid
            if root.apps.length > 0 : Flickable {
                vertical-stretch: 1;
                viewport-height: ((root.apps.length + root.columns - 1) / root.columns) * (root.cell-size + Theme.sp-3);

                for app[idx] in root.apps : TouchArea {
                    x: Math.mod(idx, root.columns) * (root.cell-size + Theme.sp-4) + Theme.sp-1;
                    y: Math.floor(idx / root.columns) * (root.cell-size + Theme.sp-3);
                    width: root.cell-size;
                    height: root.cell-size;

                    clicked => {
                        root.launch-app(app.app-id);
                        root.is-open = false;
                        root.close();
                    }

                    cell := Rectangle {
                        width: 100%;
                        height: 100%;
                        border-radius: Theme.r-lg;
                        background: parent.has-hover ? Theme.hover-fill : transparent;
                        property <bool> hovered: parent.has-hover;
                        animate background { duration: Theme.dur-fast; }

                        VerticalLayout {
                            alignment: center;
                            spacing: Theme.sp-2;
                            padding: Theme.sp-3;

                            // Icon badge — consistent canvas size
                            HorizontalLayout {
                                alignment: center;
                                Rectangle {
                                    width: 56px;
                                    height: 56px;
                                    border-radius: Theme.r-lg;
                                    background: Theme.bg-card;
                                    border-width: 1px;
                                    border-color: cell.hovered ? Theme.accent-dim : Theme.border-subtle;
                                    drop-shadow-blur: cell.hovered ? 8px : 0;
                                    drop-shadow-color: Theme.accent-glow;

                                    animate border-color { duration: Theme.dur-fast; }
                                    animate drop-shadow-blur { duration: Theme.dur-normal; }

                                    Text {
                                        text: app.icon-char;
                                        color: cell.hovered ? Theme.accent : Theme.text-secondary;
                                        font-size: 22px;
                                        font-weight: 700;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        animate color { duration: Theme.dur-fast; }
                                    }
                                }
                            }

                            // App name — consistent label
                            Text {
                                text: app.name;
                                color: Theme.text-primary;
                                font-size: Theme.fs-caption;
                                font-weight: Theme.fw-body-strong;
                                horizontal-alignment: center;
                                overflow: elide;
                            }
                        }
                    }
                }
            }
        }
    }
}
