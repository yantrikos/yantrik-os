// Notification Center — persistent notification history.
// Screen 9. Grouped by app-name with collapsible sections, unread dots, per-group clear.
// V52 polish: premium cards, hover states, better empty state, theme tokens.

import { Theme } from "theme.slint";

export struct NotificationData {
    id: string,
    app-name: string,
    summary: string,
    body: string,
    urgency: int,  // 0=low, 1=normal, 2=critical
    time-ago: string,
    is-read: bool,
    // Grouping fields
    is-group-header: bool,
    group-name: string,
    group-icon: string,
    group-count: int,
}

export component NotificationCenter inherits Rectangle {
    background: Theme.bg-deep;

    in property <[NotificationData]> notifications: [];
    in property <int> unread-count: 0;

    callback back-pressed();
    callback clear-all();
    callback mark-all-read();
    callback notification-tapped(string);
    callback clear-group(string);

    VerticalLayout {
        spacing: 0px;

        // ── Header toolbar ──
        Rectangle {
            height: 52px;
            background: Theme.bg-surface;

            Rectangle {
                y: parent.height - 1px;
                width: 100%; height: 1px;
                background: Theme.separator;
            }

            HorizontalLayout {
                padding-left: Theme.sp-3;
                padding-right: Theme.sp-3;
                alignment: start;
                spacing: Theme.sp-2;

                // Back
                TouchArea {
                    width: Theme.h-prominent;
                    height: Theme.h-prominent;
                    y: (parent.height - Theme.h-prominent) / 2;
                    clicked => { root.back-pressed(); }
                    Rectangle {
                        width: 100%; height: 100%;
                        border-radius: Theme.r-md;
                        background: parent.has-hover ? Theme.hover-fill : transparent;
                        animate background { duration: Theme.dur-fast; }
                        Text { text: "←"; color: Theme.text-secondary; font-size: Theme.fs-title-2; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }

                Text {
                    text: "Notifications";
                    color: Theme.text-primary;
                    font-size: Theme.fs-title-2;
                    font-weight: Theme.fw-title-2;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                if root.unread-count > 0 : Rectangle {
                    width: max(22px, unread-text.preferred-width + Theme.sp-3);
                    height: 22px;
                    y: (parent.height - 22px) / 2;
                    border-radius: Theme.r-pill;
                    background: Theme.accent;
                    unread-text := Text { text: root.unread-count; color: Theme.text-on-accent; font-size: Theme.fs-caption; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                }

                // Mark all read
                TouchArea {
                    width: Theme.h-prominent; height: Theme.h-prominent;
                    y: (parent.height - Theme.h-prominent) / 2;
                    clicked => { root.mark-all-read(); }
                    Rectangle {
                        width: 100%; height: 100%;
                        border-radius: Theme.r-md;
                        background: parent.has-hover ? Theme.hover-fill : transparent;
                        animate background { duration: Theme.dur-fast; }
                        Text { text: "✓"; color: Theme.text-dim; font-size: Theme.fs-title-2; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }

                // Clear all
                TouchArea {
                    width: Theme.h-prominent; height: Theme.h-prominent;
                    y: (parent.height - Theme.h-prominent) / 2;
                    clicked => { root.clear-all(); }
                    Rectangle {
                        width: 100%; height: 100%;
                        border-radius: Theme.r-md;
                        background: parent.has-hover ? Theme.hover-fill : transparent;
                        animate background { duration: Theme.dur-fast; }
                        Text { text: "✕"; color: Theme.text-dim; font-size: Theme.fs-headline; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }
            }
        }

        // ── Notification list ──
        Flickable {
            vertical-stretch: 1;

            VerticalLayout {
                padding: Theme.sp-4;
                spacing: Theme.sp-1;
                alignment: start;

                // Empty state
                if root.notifications.length == 0 : VerticalLayout {
                    alignment: center;
                    padding-top: 120px;
                    spacing: Theme.sp-2;

                    Text { text: "🔔"; font-size: 48px; horizontal-alignment: center; }
                    Text { text: "All caught up"; color: Theme.text-secondary; font-size: Theme.fs-title-2; font-weight: Theme.fw-title-2; horizontal-alignment: center; }
                    Text { text: "System notifications will appear here"; color: Theme.text-dim; font-size: Theme.fs-caption; horizontal-alignment: center; }
                }

                for notif[idx] in root.notifications : VerticalLayout {
                    spacing: 0px;

                    // Group header
                    if notif.is-group-header : Rectangle {
                        height: group-header-layout.preferred-height;

                        group-header-layout := VerticalLayout {
                            spacing: 0px;

                            HorizontalLayout {
                                padding-top: idx > 0 ? Theme.sp-4 : Theme.sp-1;
                                padding-bottom: Theme.sp-2;
                                padding-left: Theme.sp-1;
                                padding-right: Theme.sp-1;
                                spacing: Theme.sp-2;

                                Rectangle {
                                    width: 28px; height: 28px;
                                    border-radius: Theme.r-md;
                                    background: Theme.tint-accent;
                                    Text { width: parent.width; height: parent.height; text: notif.group-icon; color: Theme.accent; font-size: Theme.fs-body; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                                }

                                Text { text: notif.group-name; color: Theme.text-primary; font-size: Theme.fs-body; font-weight: Theme.fw-headline; vertical-alignment: center; horizontal-stretch: 1; }

                                Rectangle {
                                    width: max(20px, gct.preferred-width + Theme.sp-2);
                                    height: 20px; border-radius: Theme.r-pill; background: Theme.bg-elevated;
                                    gct := Text { text: notif.group-count; color: Theme.text-dim; font-size: 10px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
                                }

                                TouchArea {
                                    width: 28px; height: 28px;
                                    clicked => { root.clear-group(notif.group-name); }
                                    Rectangle {
                                        width: 100%; height: 100%;
                                        border-radius: Theme.r-md;
                                        background: parent.has-hover ? Theme.hover-fill : transparent;
                                        animate background { duration: Theme.dur-fast; }
                                        Text { text: "✕"; color: Theme.text-dim; font-size: Theme.fs-caption; horizontal-alignment: center; vertical-alignment: center; }
                                    }
                                }
                            }

                            Rectangle { height: 1px; background: Theme.separator; }
                        }
                    }

                    // Notification card
                    if !notif.is-group-header : Rectangle {
                        property <bool> hovered: cta.has-hover;
                        background: hovered ? Theme.hover-fill : notif.is-read ? Theme.bg-card : Theme.bg-elevated;
                        border-radius: Theme.r-lg;
                        border-width: notif.urgency == 2 ? 1px : 0px;
                        border-color: notif.urgency == 2 ? Theme.color-danger-dim : transparent;
                        height: nc.preferred-height;
                        animate background { duration: Theme.dur-fast; }

                        cta := TouchArea { clicked => { root.notification-tapped(notif.id); } }

                        nc := VerticalLayout {
                            padding: Theme.sp-3;
                            spacing: Theme.sp-1;

                            HorizontalLayout {
                                spacing: Theme.sp-2;

                                Rectangle {
                                    width: 8px; height: 8px; y: 5px;
                                    border-radius: 4px;
                                    background: !notif.is-read ? (notif.urgency == 2 ? Theme.color-danger : notif.urgency == 0 ? Theme.text-dim : Theme.accent) : transparent;
                                }

                                Text {
                                    text: notif.summary;
                                    color: notif.is-read ? Theme.text-secondary : Theme.text-primary;
                                    font-size: Theme.fs-body;
                                    font-weight: notif.is-read ? Theme.fw-body : Theme.fw-body-strong;
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }

                                Text { text: notif.time-ago; color: Theme.text-dim; font-size: Theme.fs-caption; vertical-alignment: center; }
                            }

                            if notif.body != "" && notif.body != notif.summary : Text {
                                text: notif.body;
                                color: Theme.text-dim;
                                font-size: Theme.fs-caption;
                                wrap: word-wrap;
                            }
                        }
                    }
                }

                Rectangle { height: Theme.sp-5; }
            }
        }
    }
}
