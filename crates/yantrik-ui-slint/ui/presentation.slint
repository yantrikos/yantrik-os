// Presentation App (yPresent) — screen 31
// Full-featured slide deck editor with layouts, themes, speaker notes,
// presenter mode with timer, text formatting, file save/load, templates,
// slide search, keyboard navigation, export.
// Wrapped in WindowFrame by app.slint.

import { Theme } from "theme.slint";
import { ListView, ScrollView, LineEdit } from "std-widgets.slint";
import { YButton, YIconButton } from "components/y_button.slint";
import { YEmptyState } from "components/y_empty_state.slint";
import { RibbonToolButton, RibbonToolButtonWide, RibbonSeparator, RibbonTabButton,
         RibbonQuickAction, RibbonGroupLabel, RibbonDropdown,
         RibbonAccentButton } from "components/app_ribbon.slint";

export struct SlideData {
    title: string,
    body: string,
    notes: string,
    layout: int,
    slide-number: int,
}

export struct PresentTheme {
    name: string,
    bg-color: brush,
    text-color: brush,
    accent-color: brush,
    is-active: bool,
}

export struct AiSlideProposal {
    title: string,
    body: string,
    notes: string,
    slide-type: string,
    has-title: bool,
    has-body: bool,
    has-notes: bool,
    has-slide-type: bool,
}

export struct AiProposalState {
    action-name: string,
    is-deck-proposal: bool,
    slide-count: int,
    current-preview-index: int,
    original-title: string,
    original-body: string,
    original-notes: string,
    proposed-title: string,
    proposed-body: string,
    proposed-notes: string,
    proposed-slide-type: string,
    title-changed: bool,
    body-changed: bool,
    notes-changed: bool,
    slide-type-changed: bool,
}

export component PresentationScreen inherits Rectangle {
    background: transparent;

    // Slide data
    in property <[SlideData]> slides: [];
    in-out property <int> current-slide-index: 0;
    in property <int> slide-count: 1;
    in-out property <int> current-layout: 0;
    in property <[PresentTheme]> themes: [];
    in-out property <bool> is-presenting: false;
    in-out property <string> current-title: "Title Slide";
    in-out property <string> current-body: "Click to add subtitle";
    in-out property <string> current-notes: "";

    // New properties
    in property <string> timer-text: "00:00";
    in property <string> next-title: "";
    in property <string> next-body: "";
    in property <string> presentation-title: "";
    in property <string> slide-progress: "Slide 1 of 1";
    in property <string> file-path: "";
    in property <bool> is-modified: false;
    in property <string> save-status: "";
    in property <int> search-count: 0;
    in-out property <string> search-query: "";
    in-out property <bool> show-search: false;
    in property <int> current-transition: 0;

    // Template picker
    in-out property <bool> show-templates: false;

    // Template gallery
    in-out property <bool> pres-template-gallery-open: false;
    in property <[string]> pres-template-names: ["Minimal", "Corporate", "Creative", "Academic", "Pitch Deck"];

    // Speaker notes toggle
    in-out property <bool> pres-show-speaker-notes: false;
    in-out property <string> pres-current-speaker-note: "";

    // Layout names for display
    property <[string]> layout-names: ["Title Slide", "Title + Content", "Two Column", "Section Header", "Blank", "Image + Text"];

    // Callbacks — existing
    callback add-slide();
    callback delete-slide();
    callback duplicate-slide();
    callback move-slide-up();
    callback move-slide-down();
    callback select-slide(int);
    callback set-layout(int);
    callback set-theme(int);
    callback toggle-present();
    callback export-pdf();
    callback title-edited(string);
    callback body-edited(string);
    callback notes-edited(string);
    callback next-slide();
    callback prev-slide();

    // Callbacks — new
    callback save-presentation();
    callback load-presentation();
    callback toggle-timer();
    callback reset-timer();
    callback key-pressed(string);
    callback use-template(int);
    callback export-markdown();
    callback export-outline();
    callback search-slides(string);
    callback search-next();
    callback set-transition(int);
    callback undo();
    callback redo();
    callback generate-notes();
    callback format-bold();
    callback format-italic();
    callback set-font-size(int);
    callback set-text-color(int);
    callback insert-object(string);

    // AI Assist — Proposal-based architecture
    in-out property <bool> show-ai-panel: false;
    in property <bool> pres-ai-working: false;
    in property <string> pres-ai-status: "";
    in property <bool> pres-ai-has-proposal: false;
    in property <AiProposalState> pres-ai-proposal;
    in-out property <bool> pres-ai-apply-title: true;
    in-out property <bool> pres-ai-apply-body: true;
    in-out property <bool> pres-ai-apply-notes: true;
    in-out property <bool> pres-ai-apply-slide-type: true;
    in-out property <string> pres-ai-instruction: "";

    // AI action callbacks
    callback pres-ai-generate-deck(string);
    callback pres-ai-structure-text(string);
    callback pres-ai-generate-all-notes();
    callback pres-ai-improve-slide();
    callback pres-ai-generate-notes();
    callback pres-ai-simplify(string);
    callback pres-ai-split-slide();
    callback pres-ai-suggest-layout();
    callback pres-ai-freeform(string);
    // Proposal navigation & apply
    callback pres-ai-apply();
    callback pres-ai-dismiss();
    callback pres-ai-preview-slide(int);
    callback pres-ai-regenerate();

    // Template gallery + speaker notes callbacks
    callback pres-open-template-gallery();
    callback pres-select-template(int);
    callback pres-save-speaker-note(string);

    // ══════════════════════════════════════════
    // Presenter mode: full-screen slide view
    // ══════════════════════════════════════════
    Rectangle {
        visible: root.is-presenting;
        width: 100%;
        height: 100%;
        background: themes.length > 0 ? themes[0].bg-color : Theme.bg-card;

        property <brush> slide-bg: themes.length > 0 ? themes[0].bg-color : Theme.bg-card;
        property <brush> slide-text: themes.length > 0 ? themes[0].text-color : Theme.text-primary;
        property <brush> slide-accent: themes.length > 0 ? themes[0].accent-color : Theme.accent;

        // Main slide area (top 70%)
        Rectangle {
            width: 100%;
            height: parent.height * 0.70;

            // 16:9 slide centered
            Rectangle {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                width: min(parent.width - 40px, (parent.height - 20px) * 16 / 9);
                height: self.width * 9 / 16;
                background: slide-bg;
                border-radius: 4px;
                border-width: 1px;
                border-color: Theme.border-subtle;

                // Title
                Text {
                    x: 40px;
                    y: current-layout == 0 || current-layout == 3 ? parent.height * 0.35 : 30px;
                    width: parent.width - 80px;
                    text: current-title;
                    color: slide-text;
                    font-size: current-layout == 0 || current-layout == 3 ? 36px : 28px;
                    font-weight: 700;
                    horizontal-alignment: current-layout == 0 || current-layout == 3 ? center : left;
                    overflow: elide;
                }

                // Body
                Text {
                    x: 40px;
                    y: current-layout == 0 || current-layout == 3 ? parent.height * 0.55 : 80px;
                    width: current-layout == 2 ? parent.width / 2 - 60px : parent.width - 80px;
                    height: parent.height - (current-layout == 0 || current-layout == 3 ? parent.height * 0.55 : 80px) - 20px;
                    text: current-body;
                    color: slide-text;
                    font-size: current-layout == 0 ? 18px : 16px;
                    horizontal-alignment: current-layout == 0 || current-layout == 3 ? center : left;
                    vertical-alignment: top;
                    wrap: word-wrap;
                    overflow: elide;
                }
            }

            // Left/right click navigation
            TouchArea {
                width: parent.width / 2;
                height: parent.height;
                clicked => { root.prev-slide(); }
            }
            TouchArea {
                x: parent.width / 2;
                width: parent.width / 2;
                height: parent.height;
                clicked => { root.next-slide(); }
            }
        }

        // Presenter bottom panel (30% — notes + next slide + controls)
        Rectangle {
            y: parent.height * 0.70;
            width: 100%;
            height: parent.height * 0.30;
            background: Theme.bg-surface;

            // Top border
            Rectangle { height: 1px; background: Theme.border-subtle; }

            HorizontalLayout {
                padding: 12px;
                spacing: 12px;

                // Speaker notes
                Rectangle {
                    background: Theme.bg-card;
                    border-radius: 6px;

                    VerticalLayout {
                        padding: 10px;
                        spacing: 4px;

                        Text {
                            text: "Speaker Notes";
                            color: Theme.text-secondary;
                            font-size: 10px;
                            font-weight: 700;
                            letter-spacing: 0.5px;
                        }

                        ScrollView {
                            Text {
                                text: root.current-notes != "" ? root.current-notes : "(No notes for this slide)";
                                color: root.current-notes != "" ? Theme.text-primary : Theme.text-dim;
                                font-size: 14px;
                                wrap: word-wrap;
                            }
                        }
                    }
                }

                // Next slide preview + controls
                Rectangle {
                    width: 280px;

                    VerticalLayout {
                        spacing: 8px;

                        Text {
                            text: "Next Slide";
                            color: Theme.text-dim;
                            font-size: 10px;
                            font-weight: 700;
                            letter-spacing: 0.5px;
                        }

                        // Mini next slide preview
                        Rectangle {
                            height: 80px;
                            background: slide-bg;
                            border-radius: 4px;
                            border-width: 1px;
                            border-color: Theme.border-subtle;

                            VerticalLayout {
                                padding: 8px;
                                spacing: 2px;

                                Text {
                                    text: root.next-title;
                                    color: slide-text;
                                    font-size: 10px;
                                    font-weight: 600;
                                    overflow: elide;
                                }

                                Text {
                                    text: root.next-body;
                                    color: slide-text;
                                    font-size: 8px;
                                    overflow: elide;
                                    wrap: word-wrap;
                                    opacity: 0.7;
                                }
                            }
                        }

                        // Timer
                        Rectangle {
                            height: 36px;
                            background: Theme.bg-card;
                            border-radius: 6px;

                            HorizontalLayout {
                                padding-left: 12px;
                                padding-right: 12px;
                                spacing: 8px;

                                Text {
                                    text: root.timer-text;
                                    color: Theme.text-primary;
                                    font-size: 20px;
                                    font-weight: 700;
                                    vertical-alignment: center;
                                }

                                Rectangle {}

                                // Play/Pause timer
                                Rectangle {
                                    width: 28px;
                                    height: 28px;
                                    border-radius: 4px;
                                    background: timer-ta.has-hover ? Theme.hover-fill : transparent;

                                    timer-ta := TouchArea { clicked => { root.toggle-timer(); } }
                                    Text { text: "▶"; color: Theme.text-secondary; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; }
                                }

                                // Reset timer
                                Rectangle {
                                    width: 28px;
                                    height: 28px;
                                    border-radius: 4px;
                                    background: reset-ta.has-hover ? Theme.hover-fill : transparent;

                                    reset-ta := TouchArea { clicked => { root.reset-timer(); } }
                                    Text { text: "↺"; color: Theme.text-secondary; font-size: 14px; horizontal-alignment: center; vertical-alignment: center; }
                                }
                            }
                        }

                        // Slide counter
                        Text {
                            text: root.slide-progress;
                            color: Theme.text-secondary;
                            font-size: 13px;
                            font-weight: 600;
                            horizontal-alignment: center;
                        }
                    }
                }
            }
        }

        // Exit button (top-right)
        Rectangle {
            x: parent.width - 120px;
            y: 10px;
            width: 100px;
            height: 36px;
            background: Theme.overlay-backdrop;
            border-radius: Theme.r-sm;

            Text {
                text: "Exit (Esc)";
                color: Theme.text-primary;
                font-size: 13px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            TouchArea { clicked => { root.toggle-present(); } }
        }
    }

    // ══════════════════════════════════════════
    // Normal edit mode
    // ══════════════════════════════════════════
    Rectangle {
        visible: !root.is-presenting;
        width: 100%;
        height: 100%;

        // Ribbon tab state: 0=Slides, 1=Design, 2=Insert, 3=Export
        property <int> ribbon-tab: 0;

        VerticalLayout {
            // ═══ Row 1: Tab strip + Quick Actions (36px) ═══
            Rectangle {
                height: 36px;
                background: Theme.bg-surface;

                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    spacing: 0px;

                    // Quick actions
                    RibbonQuickAction { label: "💾"; tooltip-text: "Save"; clicked => { root.save-presentation(); } }
                    RibbonQuickAction { label: "↶"; tooltip-text: "Undo"; clicked => { root.undo(); } }
                    RibbonQuickAction { label: "↷"; tooltip-text: "Redo"; clicked => { root.redo(); } }

                    Rectangle { width: 12px; }

                    // Tab strip
                    RibbonTabButton { label: "Slides"; is-active: ribbon-tab == 0; clicked => { ribbon-tab = 0; } }
                    RibbonTabButton { label: "Design"; is-active: ribbon-tab == 1; clicked => { ribbon-tab = 1; } }
                    RibbonTabButton { label: "Insert"; is-active: ribbon-tab == 2; clicked => { ribbon-tab = 2; } }
                    RibbonTabButton { label: "Export"; is-active: ribbon-tab == 3; clicked => { ribbon-tab = 3; } }

                    // Spacer
                    Rectangle {}

                    // Far-right: Search + AI + Present
                    RibbonQuickAction {
                        label: "🔍";
                        tooltip-text: "Search";
                        clicked => { root.show-search = !root.show-search; }
                    }
                    RibbonToolButton {
                        label: "AI";
                        is-active: root.show-ai-panel;
                        tooltip-text: "AI Assist";
                        clicked => { root.show-ai-panel = !root.show-ai-panel; }
                    }

                    Rectangle { width: 8px; }

                    RibbonAccentButton {
                        label: "Present";
                        icon: "▶";
                        accent-color: Theme.accent;
                        clicked => { root.toggle-present(); }
                    }
                }

                Rectangle { y: parent.height - 1px; height: 1px; background: Theme.separator; }
            }

            // ═══ Row 2: Grouped command band (44px) ═══
            Rectangle {
                height: 44px;
                background: Theme.bg-card;

                // ── SLIDES tab: Slide management + Format ──
                if ribbon-tab == 0 : HorizontalLayout {
                    padding-left: 10px;
                    padding-right: 10px;
                    spacing: 3px;
                    alignment: start;

                    RibbonGroupLabel { label: "SLIDE"; }
                    RibbonToolButtonWide { label: "+ Slide"; tooltip-text: "Add slide"; clicked => { root.add-slide(); } }
                    RibbonToolButton { label: "⎘"; tooltip-text: "Duplicate"; clicked => { root.duplicate-slide(); } }
                    RibbonToolButton { label: "✕"; tooltip-text: "Delete"; clicked => { root.delete-slide(); } }
                    RibbonToolButton { label: "↑"; tooltip-text: "Move up"; clicked => { root.move-slide-up(); } }
                    RibbonToolButton { label: "↓"; tooltip-text: "Move down"; clicked => { root.move-slide-down(); } }

                    RibbonSeparator {}

                    RibbonGroupLabel { label: "FONT"; }
                    RibbonToolButton { label: "B"; tooltip-text: "Bold"; clicked => { root.format-bold(); } }
                    RibbonToolButton { label: "I"; tooltip-text: "Italic"; clicked => { root.format-italic(); } }

                    RibbonSeparator {}

                    RibbonGroupLabel { label: "NOTES"; }
                    RibbonToolButtonWide {
                        label: "Notes";
                        is-active: root.pres-show-speaker-notes;
                        tooltip-text: "Speaker notes";
                        clicked => { root.pres-show-speaker-notes = !root.pres-show-speaker-notes; }
                    }
                }

                // ── DESIGN tab: Layout + Theme + Transition + Templates ──
                if ribbon-tab == 1 : HorizontalLayout {
                    padding-left: 10px;
                    padding-right: 10px;
                    spacing: 3px;
                    alignment: start;

                    RibbonGroupLabel { label: "LAYOUT"; }
                    RibbonDropdown {
                        label: "";
                        value: root.current-layout == 0 ? "Title"
                            : root.current-layout == 1 ? "Content"
                            : root.current-layout == 2 ? "Two Col"
                            : root.current-layout == 3 ? "Section"
                            : root.current-layout == 4 ? "Blank"
                            : "Img+Text";
                        tooltip-text: "Slide layout";
                        clicked => { root.set-layout(mod(root.current-layout + 1, 6)); }
                    }

                    RibbonSeparator {}

                    RibbonGroupLabel { label: "THEME"; }
                    RibbonDropdown {
                        label: "";
                        value: "Theme";
                        tooltip-text: "Slide theme";
                        clicked => { root.set-theme(0); }
                    }

                    RibbonSeparator {}

                    RibbonGroupLabel { label: "TRANSITION"; }
                    RibbonDropdown {
                        label: "";
                        value: root.current-transition == 0 ? "None"
                            : root.current-transition == 1 ? "Fade"
                            : root.current-transition == 2 ? "Slide L"
                            : root.current-transition == 3 ? "Slide R"
                            : "Zoom";
                        tooltip-text: "Transition effect";
                        clicked => { root.set-transition(mod(root.current-transition + 1, 5)); }
                    }

                    RibbonSeparator {}

                    RibbonGroupLabel { label: "TEMPLATES"; }
                    RibbonToolButtonWide {
                        label: "Template";
                        is-active: root.show-templates;
                        tooltip-text: "Quick templates";
                        clicked => { root.show-templates = !root.show-templates; }
                    }
                    RibbonToolButtonWide {
                        label: "Gallery";
                        is-active: root.pres-template-gallery-open;
                        tooltip-text: "Template gallery";
                        clicked => { root.pres-open-template-gallery(); }
                    }
                }

                // ── INSERT tab: Objects ──
                if ribbon-tab == 2 : HorizontalLayout {
                    padding-left: 10px;
                    padding-right: 10px;
                    spacing: 3px;
                    alignment: start;

                    RibbonGroupLabel { label: "OBJECTS"; }
                    RibbonToolButtonWide { label: "Text"; tooltip-text: "Text box"; clicked => { root.insert-object("text"); } }
                    RibbonToolButtonWide { label: "Image"; tooltip-text: "Image"; clicked => { root.insert-object("image"); } }
                    RibbonToolButtonWide { label: "Shape"; tooltip-text: "Shape"; clicked => { root.insert-object("shape"); } }
                    RibbonToolButtonWide { label: "Chart"; tooltip-text: "Chart"; clicked => { root.insert-object("chart"); } }
                    RibbonToolButtonWide { label: "Table"; tooltip-text: "Table"; clicked => { root.insert-object("table"); } }
                    RibbonToolButtonWide { label: "Icon"; tooltip-text: "Icon"; clicked => { root.insert-object("icon"); } }
                }

                // ── EXPORT tab: File + Export ──
                if ribbon-tab == 3 : HorizontalLayout {
                    padding-left: 10px;
                    padding-right: 10px;
                    spacing: 3px;
                    alignment: start;

                    RibbonGroupLabel { label: "FILE"; }
                    RibbonToolButtonWide { label: "Open"; tooltip-text: "Open file"; clicked => { root.load-presentation(); } }

                    RibbonSeparator {}

                    RibbonGroupLabel { label: "EXPORT"; }
                    RibbonToolButtonWide { label: "PDF"; tooltip-text: "Export PDF"; clicked => { root.export-pdf(); } }
                    RibbonToolButtonWide { label: "MD"; tooltip-text: "Export Markdown"; clicked => { root.export-markdown(); } }
                    RibbonToolButtonWide { label: "Outline"; tooltip-text: "Export outline"; clicked => { root.export-outline(); } }
                }

                Rectangle { y: parent.height - 1px; height: 1px; background: Theme.separator; }
            }

            // ── Template picker dropdown ──
            Rectangle {
                height: root.show-templates ? 38px : 0px;
                visible: root.show-templates;
                background: Theme.bg-card;

                HorizontalLayout {
                    padding-left: 12px;
                    spacing: 8px;
                    alignment: start;

                    Text { text: "Templates:"; color: Theme.text-primary; font-size: 12px; font-weight: 600; vertical-alignment: center; }

                    RibbonToolButtonWide { label: "Blank"; clicked => { root.use-template(0); root.show-templates = false; } }
                    RibbonToolButtonWide { label: "Status"; clicked => { root.use-template(1); root.show-templates = false; } }
                    RibbonToolButtonWide { label: "Proposal"; clicked => { root.use-template(2); root.show-templates = false; } }
                    RibbonToolButtonWide { label: "Team"; clicked => { root.use-template(3); root.show-templates = false; } }
                    RibbonToolButtonWide { label: "Quarterly"; clicked => { root.use-template(4); root.show-templates = false; } }
                }

                Rectangle { y: parent.height - 1px; height: 1px; background: Theme.separator; }
            }

            // ── Search bar ──
            Rectangle {
                height: root.show-search ? 34px : 0px;
                visible: root.show-search;
                background: Theme.bg-card;

                HorizontalLayout {
                    padding-left: 12px;
                    padding-right: 12px;
                    spacing: 8px;
                    alignment: start;

                    Text { text: "Search:"; color: Theme.text-primary; font-size: Theme.fs-caption; font-weight: 500; vertical-alignment: center; }

                    search-input := LineEdit {
                        width: 200px;
                        text <=> root.search-query;
                        placeholder-text: "Search slides...";
                        accepted => { root.search-slides(root.search-query); }
                    }

                    RibbonToolButton { label: "↓"; tooltip-text: "Next result"; clicked => { root.search-next(); } }

                    Text {
                        text: root.search-count > 0 ? root.search-count + " found" : "";
                        color: Theme.text-dim;
                        font-size: Theme.fs-caption;
                        vertical-alignment: center;
                    }
                }

                Rectangle { y: parent.height - 1px; height: 1px; background: Theme.separator; }
            }

            // ── Main area: sidebar + editor + notes ──
            HorizontalLayout {
                // ── Slide sidebar ──
                Rectangle {
                    width: 200px;
                    background: Theme.bg-deep;
                    border-width: 0px;

                    VerticalLayout {
                        padding: 10px;
                        spacing: 0px;

                        // Header row
                        HorizontalLayout {
                            height: 28px;
                            spacing: 6px;

                            Text {
                                text: "SLIDES";
                                color: Theme.text-secondary;
                                font-size: 10px;
                                font-weight: 700;
                                letter-spacing: 1px;
                                vertical-alignment: center;
                            }

                            Rectangle {}

                            Text {
                                text: root.slide-count + "";
                                color: Theme.text-dim;
                                font-size: 10px;
                                vertical-alignment: center;
                            }
                        }

                        ListView {
                            for slide[idx] in root.slides : Rectangle {
                                height: 116px;
                                background: transparent;

                                VerticalLayout {
                                    padding-top: 5px;
                                    padding-bottom: 5px;
                                    padding-left: 6px;
                                    padding-right: 6px;
                                    spacing: 3px;

                                    // Slide number badge
                                    HorizontalLayout {
                                        height: 16px;
                                        spacing: 4px;

                                        Rectangle {
                                            width: 22px;
                                            height: 16px;
                                            border-radius: 4px;
                                            background: idx == root.current-slide-index ? Theme.accent.transparentize(0.7) : transparent;

                                            Text {
                                                text: "" + (idx + 1);
                                                color: idx == root.current-slide-index ? Theme.accent : Theme.text-dim;
                                                font-size: 10px;
                                                font-weight: idx == root.current-slide-index ? 700 : 400;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }

                                        Rectangle {}
                                    }

                                    // Thumbnail card
                                    Rectangle {
                                        height: 88px;
                                        background: idx == root.current-slide-index ? Theme.bg-elevated : Theme.bg-surface;
                                        border-radius: 6px;
                                        border-width: idx == root.current-slide-index ? 2px : 1px;
                                        border-color: idx == root.current-slide-index ? Theme.accent : Theme.border-subtle;
                                        opacity: idx == root.current-slide-index ? 1.0 : 0.75;

                                        // Active slide glow
                                        Rectangle {
                                            visible: idx == root.current-slide-index;
                                            width: 100%;
                                            height: 100%;
                                            border-radius: 6px;
                                            background: Theme.accent.transparentize(0.92);
                                        }

                                        VerticalLayout {
                                            padding: 8px;
                                            spacing: 3px;

                                            Text {
                                                text: slide.title;
                                                color: idx == root.current-slide-index ? Theme.text-primary : Theme.text-secondary;
                                                font-size: 9px;
                                                font-weight: 600;
                                                overflow: elide;
                                            }

                                            Text {
                                                text: slide.body;
                                                color: Theme.text-dim;
                                                font-size: 8px;
                                                overflow: elide;
                                                wrap: word-wrap;
                                            }
                                        }

                                        TouchArea {
                                            clicked => { root.select-slide(idx); }
                                        }
                                    }
                                }
                            }
                        }

                        // Inline add-slide button at bottom of rail
                        Rectangle {
                            height: 36px;

                            Rectangle {
                                x: 6px;
                                y: 4px;
                                width: parent.width - 12px;
                                height: 28px;
                                border-radius: 6px;
                                border-width: 1px;
                                border-color: add-rail-ta.has-hover ? Theme.accent.transparentize(0.5) : Theme.border-subtle;
                                background: add-rail-ta.has-hover ? Theme.accent.transparentize(0.9) : transparent;

                                HorizontalLayout {
                                    alignment: center;
                                    spacing: 4px;

                                    Text {
                                        text: "+";
                                        color: add-rail-ta.has-hover ? Theme.accent : Theme.text-dim;
                                        font-size: 14px;
                                        font-weight: 600;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: "Add Slide";
                                        color: add-rail-ta.has-hover ? Theme.text-primary : Theme.text-dim;
                                        font-size: 10px;
                                        vertical-alignment: center;
                                    }
                                }

                                add-rail-ta := TouchArea { clicked => { root.add-slide(); } }
                            }
                        }
                    }
                }

                // Separator
                Rectangle { width: 1px; background: Theme.separator; }

                // ── Center: slide editor + notes ──
                VerticalLayout {
                    spacing: 0px;

                    // Slide editor area
                    Rectangle {
                        background: Theme.bg-deep;

                        Rectangle {
                            x: 24px;
                            y: 16px;
                            width: parent.width - 48px;
                            height: parent.height - 32px;

                            property <length> avail-w: self.width;
                            property <length> avail-h: self.height;
                            property <length> fit-w: min(avail-w, avail-h * 16 / 9);
                            property <length> fit-h: fit-w * 9 / 16;

                            // The actual slide
                            Rectangle {
                                x: (parent.width - self.width) / 2;
                                y: (parent.height - self.height) / 2;
                                width: parent.fit-w;
                                height: parent.fit-h;
                                background: themes.length > 0 ? themes[0].bg-color : Theme.bg-card;
                                border-radius: 6px;
                                border-width: 1px;
                                border-color: Theme.border-subtle;

                                property <brush> t-text: themes.length > 0 ? themes[0].text-color : Theme.text-primary;
                                property <brush> t-accent: themes.length > 0 ? themes[0].accent-color : Theme.accent;

                                // Accent bar for Title Slide and Section Header
                                Rectangle {
                                    visible: current-layout == 0 || current-layout == 3;
                                    x: parent.width * 0.3;
                                    y: current-layout == 0 ? parent.height * 0.48 : parent.height * 0.45;
                                    width: parent.width * 0.4;
                                    height: 3px;
                                    background: t-accent;
                                    border-radius: 1px;
                                }

                                // Title input
                                Rectangle {
                                    visible: current-layout != 4;
                                    x: current-layout == 0 || current-layout == 3 ? parent.width * 0.1 : 30px;
                                    y: current-layout == 0 || current-layout == 3 ? parent.height * 0.25 : 20px;
                                    width: current-layout == 0 || current-layout == 3 ? parent.width * 0.8 : parent.width - 60px;
                                    height: current-layout == 0 ? parent.height * 0.2 : 40px;
                                    clip: true;

                                    title-input := TextInput {
                                        width: 100%;
                                        height: 100%;
                                        text <=> root.current-title;
                                        color: t-text;
                                        font-size: current-layout == 0 || current-layout == 3 ? 24px : 20px;
                                        font-weight: 700;
                                        horizontal-alignment: current-layout == 0 || current-layout == 3 ? center : left;
                                        vertical-alignment: center;
                                        single-line: true;
                                        accepted => { root.title-edited(self.text); }
                                        edited => { root.title-edited(self.text); }
                                    }
                                }

                                // Body input
                                Rectangle {
                                    visible: current-layout != 4;
                                    x: current-layout == 0 || current-layout == 3 ? parent.width * 0.15 : 30px;
                                    y: current-layout == 0 ? parent.height * 0.55 : current-layout == 3 ? parent.height * 0.52 : 70px;
                                    width: current-layout == 2 ? parent.width * 0.45 - 30px
                                         : current-layout == 5 ? parent.width * 0.55 - 30px
                                         : current-layout == 0 || current-layout == 3 ? parent.width * 0.7 : parent.width - 60px;
                                    height: current-layout == 0 || current-layout == 3 ? parent.height * 0.2 : parent.height - 90px;
                                    clip: true;

                                    body-input := TextInput {
                                        width: 100%;
                                        height: 100%;
                                        text <=> root.current-body;
                                        color: t-text;
                                        font-size: current-layout == 0 ? 14px : 13px;
                                        horizontal-alignment: current-layout == 0 || current-layout == 3 ? center : left;
                                        vertical-alignment: top;
                                        single-line: false;
                                        wrap: word-wrap;
                                        edited => { root.body-edited(self.text); }
                                    }
                                }

                                // Two Column: right column placeholder
                                Rectangle {
                                    visible: current-layout == 2;
                                    x: parent.width * 0.52;
                                    y: 70px;
                                    width: parent.width * 0.45 - 30px;
                                    height: parent.height - 90px;
                                    background: Theme.hover-fill;
                                    border-radius: 4px;
                                    border-width: 1px;
                                    border-color: Theme.border-subtle;

                                    Text {
                                        text: "Column 2\n(use body text)";
                                        color: t-text;
                                        font-size: 11px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        opacity: 0.4;
                                    }
                                }

                                // Image + Text: image placeholder
                                Rectangle {
                                    visible: current-layout == 5;
                                    x: parent.width * 0.58;
                                    y: 70px;
                                    width: parent.width * 0.38;
                                    height: parent.height - 90px;
                                    background: Theme.hover-fill;
                                    border-radius: 4px;
                                    border-width: 1px;
                                    border-color: Theme.border-subtle;

                                    VerticalLayout {
                                        alignment: center;
                                        spacing: 4px;

                                        Text {
                                            text: "🖼";
                                            font-size: 28px;
                                            horizontal-alignment: center;
                                            opacity: 0.3;
                                        }
                                        Text {
                                            text: "Image placeholder";
                                            color: t-text;
                                            font-size: 10px;
                                            horizontal-alignment: center;
                                            opacity: 0.3;
                                        }
                                    }
                                }

                                // Blank layout watermark
                                Rectangle {
                                    visible: current-layout == 4;
                                    width: 100%;
                                    height: 100%;

                                    Text {
                                        text: "Blank Slide";
                                        color: t-text;
                                        font-size: 14px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        opacity: 0.15;
                                    }
                                }
                            }
                        }
                    }

                    // Separator
                    Rectangle { height: 1px; background: Theme.separator; }

                    // ── Speaker notes + slide info ──
                    Rectangle {
                        height: 130px;
                        background: Theme.bg-surface;

                        // Top separator with accent hint
                        Rectangle {
                            height: 1px;
                            background: Theme.separator;
                        }

                        VerticalLayout {
                            padding: 0px;
                            spacing: 0px;

                            // Notes header bar
                            Rectangle {
                                height: 30px;
                                background: Theme.bg-card;

                                HorizontalLayout {
                                    padding-left: 12px;
                                    padding-right: 12px;
                                    spacing: 8px;

                                    Text {
                                        text: "Speaker Notes";
                                        color: Theme.text-primary;
                                        font-size: 11px;
                                        font-weight: 600;
                                        vertical-alignment: center;
                                    }

                                    Rectangle {}

                                    // Auto-generate notes button
                                    Rectangle {
                                        width: 76px;
                                        height: 22px;
                                        border-radius: 4px;
                                        background: gen-ta.has-hover ? Theme.accent.transparentize(0.8) : transparent;
                                        border-width: 1px;
                                        border-color: Theme.accent.transparentize(0.6);

                                        gen-ta := TouchArea { clicked => { root.generate-notes(); } }

                                        Text {
                                            text: "AI Generate";
                                            font-size: 9px;
                                            color: Theme.accent;
                                            font-weight: 500;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }

                                    // Slide info inline
                                    RibbonSeparator {}

                                    Text {
                                        text: root.slide-progress;
                                        color: Theme.text-secondary;
                                        font-size: 11px;
                                        vertical-alignment: center;
                                    }

                                    Text {
                                        text: current-layout == 0 ? "Title Slide"
                                            : current-layout == 1 ? "Title + Content"
                                            : current-layout == 2 ? "Two Column"
                                            : current-layout == 3 ? "Section Header"
                                            : current-layout == 4 ? "Blank"
                                            : "Image + Text";
                                        color: Theme.text-dim;
                                        font-size: 10px;
                                        vertical-alignment: center;
                                    }

                                    // Modified indicator
                                    Rectangle {
                                        visible: root.is-modified;
                                        width: 64px;
                                        height: 18px;
                                        border-radius: 4px;
                                        background: Theme.amber-dim;

                                        Text {
                                            text: "Modified";
                                            color: Theme.amber;
                                            font-size: 9px;
                                            font-weight: 500;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }

                                    Text {
                                        visible: root.save-status != "";
                                        text: root.save-status;
                                        color: Theme.text-dim;
                                        font-size: 9px;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                }
                            }

                            // Notes input area
                            Rectangle {
                                background: Theme.bg-deep; clip: true;
                                border-width: 0px;

                                notes-input := TextInput {
                                    x: 12px;
                                    y: 6px;
                                    width: parent.width - 24px;
                                    height: parent.height - 12px;
                                    text <=> root.current-notes;
                                    color: Theme.text-secondary;
                                    font-size: 12px;
                                    single-line: false;
                                    wrap: word-wrap;
                                    vertical-alignment: top;
                                    edited => { root.notes-edited(self.text); }
                                }

                                // Placeholder when empty
                                Text {
                                    visible: root.current-notes == "";
                                    x: 12px;
                                    y: 6px;
                                    text: "Add speaker notes for this slide...";
                                    color: Theme.text-dim;
                                    font-size: 12px;
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    // AI Assist Panel (right sidebar) — Proposal-based architecture
    Rectangle {
        visible: root.show-ai-panel;
        x: parent.width - 300px;
        y: 0px;
        width: 300px;
        height: parent.height;
        background: Theme.bg-card;
        border-width: 1px;
        border-color: Theme.separator;

        VerticalLayout {
            padding: 10px;
            spacing: 6px;

            // ── Section A: Header ──
            HorizontalLayout {
                spacing: 6px;
                height: 28px;

                Text {
                    text: "AI Assistant";
                    color: Theme.accent;
                    font-size: 13px;
                    font-weight: 600;
                    vertical-alignment: center;
                }
                Rectangle { }
                Rectangle {
                    width: 24px; height: 24px; border-radius: 4px;
                    background: close-pres-ai-ta.has-hover ? Theme.hover-fill : transparent;
                    close-pres-ai-ta := TouchArea { clicked => { root.show-ai-panel = false; } }
                    Text { text: "x"; color: Theme.text-dim; font-size: 14px; horizontal-alignment: center; vertical-alignment: center; }
                }
            }

            Rectangle { height: 1px; background: Theme.separator; }

            // ── Section B: Global Actions ──
            Text { text: "Global"; color: Theme.text-secondary; font-size: 10px; }

            HorizontalLayout {
                spacing: 4px;

                Rectangle {
                    height: 28px;
                    border-radius: 4px;
                    background: gen-deck-ta.has-hover ? Theme.accent.transparentize(0.8) : Theme.bg-elevated;
                    border-width: 1px;
                    border-color: Theme.accent.transparentize(0.6);
                    gen-deck-ta := TouchArea { clicked => { root.pres-ai-generate-deck(root.pres-ai-instruction); } }
                    Text { text: "Generate Deck"; color: Theme.accent; font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
                }

                Rectangle {
                    height: 28px;
                    border-radius: 4px;
                    background: struct-text-ta.has-hover ? Theme.accent.transparentize(0.8) : Theme.bg-elevated;
                    border-width: 1px;
                    border-color: Theme.accent.transparentize(0.6);
                    struct-text-ta := TouchArea { clicked => { root.pres-ai-structure-text(root.pres-ai-instruction); } }
                    Text { text: "Structure Text"; color: Theme.accent; font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
                }
            }

            HorizontalLayout {
                spacing: 4px;

                Rectangle {
                    height: 28px;
                    border-radius: 4px;
                    background: all-notes-ta.has-hover ? Theme.accent.transparentize(0.8) : Theme.bg-elevated;
                    border-width: 1px;
                    border-color: Theme.accent.transparentize(0.6);
                    all-notes-ta := TouchArea { clicked => { root.pres-ai-generate-all-notes(); } }
                    Text { text: "All Notes"; color: Theme.accent; font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
                }

                // spacer to keep row balanced
                Rectangle { height: 28px; background: transparent; }
            }

            Rectangle { height: 1px; background: Theme.separator; }

            // ── Section C: Slide Actions ──
            Text { text: "Current Slide"; color: Theme.text-secondary; font-size: 10px; }

            HorizontalLayout {
                spacing: 4px;

                Rectangle {
                    height: 28px;
                    border-radius: 4px;
                    background: improve-slide-ta.has-hover ? Theme.accent.transparentize(0.8) : Theme.bg-elevated;
                    border-width: 1px;
                    border-color: Theme.accent.transparentize(0.6);
                    improve-slide-ta := TouchArea { clicked => { root.pres-ai-improve-slide(); } }
                    Text { text: "Improve Slide"; color: Theme.accent; font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
                }

                Rectangle {
                    height: 28px;
                    border-radius: 4px;
                    background: gen-notes-ta.has-hover ? Theme.accent.transparentize(0.8) : Theme.bg-elevated;
                    border-width: 1px;
                    border-color: Theme.accent.transparentize(0.6);
                    gen-notes-ta := TouchArea { clicked => { root.pres-ai-generate-notes(); } }
                    Text { text: "Generate Notes"; color: Theme.accent; font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
                }
            }

            HorizontalLayout {
                spacing: 4px;

                Rectangle {
                    height: 28px;
                    border-radius: 4px;
                    background: simplify-ta.has-hover ? Theme.accent.transparentize(0.8) : Theme.bg-elevated;
                    border-width: 1px;
                    border-color: Theme.accent.transparentize(0.6);
                    simplify-ta := TouchArea { clicked => { root.pres-ai-simplify(root.pres-ai-instruction); } }
                    Text { text: "Simplify"; color: Theme.accent; font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
                }

                Rectangle {
                    height: 28px;
                    border-radius: 4px;
                    background: split-ta.has-hover ? Theme.accent.transparentize(0.8) : Theme.bg-elevated;
                    border-width: 1px;
                    border-color: Theme.accent.transparentize(0.6);
                    split-ta := TouchArea { clicked => { root.pres-ai-split-slide(); } }
                    Text { text: "Split Slide"; color: Theme.accent; font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
                }
            }

            HorizontalLayout {
                spacing: 4px;

                Rectangle {
                    height: 28px;
                    border-radius: 4px;
                    background: layout-ta.has-hover ? Theme.accent.transparentize(0.8) : Theme.bg-elevated;
                    border-width: 1px;
                    border-color: Theme.accent.transparentize(0.6);
                    layout-ta := TouchArea { clicked => { root.pres-ai-suggest-layout(); } }
                    Text { text: "Suggest Layout"; color: Theme.accent; font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
                }

                Rectangle { height: 28px; background: transparent; }
            }

            Rectangle { height: 1px; background: Theme.separator; }

            // ── Section D: Instruction field ──
            Rectangle {
                height: 28px;
                border-radius: 4px;
                background: Theme.bg-elevated;
                border-width: 1px;
                border-color: Theme.separator;
                clip: true;

                pres-ai-instr-input := TextInput {
                    x: 8px; y: 0px;
                    width: parent.width - 16px;
                    height: parent.height;
                    color: Theme.text-primary;
                    font-size: 10px;
                    wrap: word-wrap;
                    single-line: false;
                    text <=> root.pres-ai-instruction;
                    vertical-alignment: center;
                }
                // placeholder
                Text {
                    visible: root.pres-ai-instruction == "";
                    x: 8px;
                    text: "Optional: audience, tone, instructions...";
                    color: Theme.text-dim;
                    font-size: 10px;
                    vertical-alignment: center;
                }
            }

            // ── Section E: Status ──
            HorizontalLayout {
                visible: root.pres-ai-working;
                spacing: 6px;
                height: 20px;

                Rectangle {
                    width: 8px; height: 8px; border-radius: 4px;
                    background: Theme.accent;
                    y: 6px;

                    animate background {
                        duration: 800ms;
                        iteration-count: -1;
                    }
                }
                Text {
                    text: root.pres-ai-status != "" ? root.pres-ai-status : "Working...";
                    color: Theme.text-secondary;
                    font-size: 10px;
                    vertical-alignment: center;
                }
            }

            // ── Section F: Proposal Preview ──
            Rectangle {
                visible: root.pres-ai-has-proposal;
                background: transparent;

                VerticalLayout {
                    spacing: 6px;

                    // Proposal header
                    HorizontalLayout {
                        height: 22px;
                        spacing: 4px;

                        Text {
                            text: root.pres-ai-proposal.action-name;
                            color: Theme.accent;
                            font-size: 11px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                        Rectangle { }
                        Text {
                            visible: root.pres-ai-proposal.is-deck-proposal;
                            text: root.pres-ai-proposal.slide-count + " slides";
                            color: Theme.text-dim;
                            font-size: 10px;
                            vertical-alignment: center;
                        }
                    }

                    // Deck navigation (only for multi-slide proposals)
                    HorizontalLayout {
                        visible: root.pres-ai-proposal.is-deck-proposal;
                        height: 24px;
                        spacing: 4px;

                        Rectangle {
                            width: 24px; height: 24px; border-radius: 4px;
                            background: prev-preview-ta.has-hover ? Theme.hover-fill : transparent;
                            prev-preview-ta := TouchArea {
                                clicked => {
                                    if root.pres-ai-proposal.current-preview-index > 0 {
                                        root.pres-ai-preview-slide(root.pres-ai-proposal.current-preview-index - 1);
                                    }
                                }
                            }
                            Text { text: "<"; color: Theme.text-secondary; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; }
                        }

                        Text {
                            text: "Slide " + (root.pres-ai-proposal.current-preview-index + 1) + " of " + root.pres-ai-proposal.slide-count;
                            color: Theme.text-secondary;
                            font-size: 10px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        Rectangle {
                            width: 24px; height: 24px; border-radius: 4px;
                            background: next-preview-ta.has-hover ? Theme.hover-fill : transparent;
                            next-preview-ta := TouchArea {
                                clicked => {
                                    if root.pres-ai-proposal.current-preview-index < root.pres-ai-proposal.slide-count - 1 {
                                        root.pres-ai-preview-slide(root.pres-ai-proposal.current-preview-index + 1);
                                    }
                                }
                            }
                            Text { text: ">"; color: Theme.text-secondary; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; }
                        }
                    }

                    // Diff view — scrollable (stacked layout to avoid width loops)
                    ScrollView {
                        min-height: 80px;

                        Rectangle {
                            VerticalLayout {
                                spacing: 6px;
                                width: 260px;

                                // Title diff
                                VerticalLayout {
                                    visible: root.pres-ai-proposal.title-changed;
                                    spacing: 2px;

                                    Text { text: "Title"; color: Theme.accent; font-size: 9px; font-weight: 600; }

                                    Rectangle {
                                        border-radius: 4px;
                                        background: Theme.color-danger-dim;
                                        clip: true;
                                        VerticalLayout {
                                            padding: 4px;
                                            Text { text: "Current:"; color: Theme.text-dim; font-size: 8px; }
                                            Text {
                                                text: root.pres-ai-proposal.original-title;
                                                color: Theme.text-secondary;
                                                font-size: 10px;
                                                overflow: elide;
                                            }
                                        }
                                    }

                                    Rectangle {
                                        border-radius: 4px;
                                        background: Theme.color-success-dim;
                                        clip: true;
                                        VerticalLayout {
                                            padding: 4px;
                                            Text { text: "Proposed:"; color: Theme.text-dim; font-size: 8px; }
                                            Text {
                                                text: root.pres-ai-proposal.proposed-title;
                                                color: Theme.text-primary;
                                                font-size: 10px;
                                                overflow: elide;
                                            }
                                        }
                                    }
                                }

                                // Body diff
                                VerticalLayout {
                                    visible: root.pres-ai-proposal.body-changed;
                                    spacing: 2px;

                                    Text { text: "Body"; color: Theme.accent; font-size: 9px; font-weight: 600; }

                                    Rectangle {
                                        border-radius: 4px;
                                        background: Theme.color-danger-dim;
                                        clip: true;
                                        VerticalLayout {
                                            padding: 4px;
                                            Text { text: "Current:"; color: Theme.text-dim; font-size: 8px; }
                                            Text {
                                                text: root.pres-ai-proposal.original-body;
                                                color: Theme.text-secondary;
                                                font-size: 10px;
                                                wrap: word-wrap;
                                            }
                                        }
                                    }

                                    Rectangle {
                                        border-radius: 4px;
                                        background: Theme.color-success-dim;
                                        clip: true;
                                        VerticalLayout {
                                            padding: 4px;
                                            Text { text: "Proposed:"; color: Theme.text-dim; font-size: 8px; }
                                            Text {
                                                text: root.pres-ai-proposal.proposed-body;
                                                color: Theme.text-primary;
                                                font-size: 10px;
                                                wrap: word-wrap;
                                            }
                                        }
                                    }
                                }

                                // Notes diff
                                VerticalLayout {
                                    visible: root.pres-ai-proposal.notes-changed;
                                    spacing: 2px;

                                    Text { text: "Notes"; color: Theme.accent; font-size: 9px; font-weight: 600; }

                                    Rectangle {
                                        border-radius: 4px;
                                        background: Theme.color-danger-dim;
                                        clip: true;
                                        VerticalLayout {
                                            padding: 4px;
                                            Text { text: "Current:"; color: Theme.text-dim; font-size: 8px; }
                                            Text {
                                                text: root.pres-ai-proposal.original-notes;
                                                color: Theme.text-secondary;
                                                font-size: 10px;
                                                wrap: word-wrap;
                                            }
                                        }
                                    }

                                    Rectangle {
                                        border-radius: 4px;
                                        background: Theme.color-success-dim;
                                        clip: true;
                                        VerticalLayout {
                                            padding: 4px;
                                            Text { text: "Proposed:"; color: Theme.text-dim; font-size: 8px; }
                                            Text {
                                                text: root.pres-ai-proposal.proposed-notes;
                                                color: Theme.text-primary;
                                                font-size: 10px;
                                                wrap: word-wrap;
                                            }
                                        }
                                    }
                                }

                                // Slide type diff
                                VerticalLayout {
                                    visible: root.pres-ai-proposal.slide-type-changed;
                                    spacing: 2px;

                                    Text { text: "Layout"; color: Theme.accent; font-size: 9px; font-weight: 600; }

                                    Rectangle {
                                        height: 24px;
                                        border-radius: 4px;
                                        background: Theme.bg-elevated;

                                        Text {
                                            x: 6px;
                                            text: root.pres-ai-proposal.proposed-slide-type;
                                            color: Theme.text-primary;
                                        font-size: 10px;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                        }
                    }

                    Rectangle { height: 1px; background: Theme.separator; }

                    // Field checkboxes
                    Text { text: "Apply fields:"; color: Theme.text-secondary; font-size: 9px; }

                    HorizontalLayout {
                        spacing: 8px;
                        height: 18px;

                        // Title checkbox
                        HorizontalLayout {
                            visible: root.pres-ai-proposal.title-changed;
                            spacing: 4px;
                            Rectangle {
                                width: 16px; height: 16px; border-radius: 3px;
                                border-width: 1px;
                                border-color: Theme.accent;
                                background: root.pres-ai-apply-title ? Theme.accent : transparent;
                                TouchArea { clicked => { root.pres-ai-apply-title = !root.pres-ai-apply-title; } }
                                Text {
                                    text: root.pres-ai-apply-title ? "✓" : "";
                                    color: white; font-size: 10px;
                                    horizontal-alignment: center; vertical-alignment: center;
                                }
                            }
                            Text { text: "Title"; color: Theme.text-secondary; font-size: 10px; vertical-alignment: center; }
                        }

                        // Body checkbox
                        HorizontalLayout {
                            visible: root.pres-ai-proposal.body-changed;
                            spacing: 4px;
                            Rectangle {
                                width: 16px; height: 16px; border-radius: 3px;
                                border-width: 1px;
                                border-color: Theme.accent;
                                background: root.pres-ai-apply-body ? Theme.accent : transparent;
                                TouchArea { clicked => { root.pres-ai-apply-body = !root.pres-ai-apply-body; } }
                                Text {
                                    text: root.pres-ai-apply-body ? "✓" : "";
                                    color: white; font-size: 10px;
                                    horizontal-alignment: center; vertical-alignment: center;
                                }
                            }
                            Text { text: "Body"; color: Theme.text-secondary; font-size: 10px; vertical-alignment: center; }
                        }
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        height: 18px;

                        // Notes checkbox
                        HorizontalLayout {
                            visible: root.pres-ai-proposal.notes-changed;
                            spacing: 4px;
                            Rectangle {
                                width: 16px; height: 16px; border-radius: 3px;
                                border-width: 1px;
                                border-color: Theme.accent;
                                background: root.pres-ai-apply-notes ? Theme.accent : transparent;
                                TouchArea { clicked => { root.pres-ai-apply-notes = !root.pres-ai-apply-notes; } }
                                Text {
                                    text: root.pres-ai-apply-notes ? "✓" : "";
                                    color: white; font-size: 10px;
                                    horizontal-alignment: center; vertical-alignment: center;
                                }
                            }
                            Text { text: "Notes"; color: Theme.text-secondary; font-size: 10px; vertical-alignment: center; }
                        }

                        // Layout checkbox
                        HorizontalLayout {
                            visible: root.pres-ai-proposal.slide-type-changed;
                            spacing: 4px;
                            Rectangle {
                                width: 16px; height: 16px; border-radius: 3px;
                                border-width: 1px;
                                border-color: Theme.accent;
                                background: root.pres-ai-apply-slide-type ? Theme.accent : transparent;
                                TouchArea { clicked => { root.pres-ai-apply-slide-type = !root.pres-ai-apply-slide-type; } }
                                Text {
                                    text: root.pres-ai-apply-slide-type ? "✓" : "";
                                    color: white; font-size: 10px;
                                    horizontal-alignment: center; vertical-alignment: center;
                                }
                            }
                            Text { text: "Layout"; color: Theme.text-secondary; font-size: 10px; vertical-alignment: center; }
                        }
                    }

                    // Action buttons: Apply / Regenerate / Dismiss
                    HorizontalLayout {
                        spacing: 4px;
                        height: 28px;

                        Rectangle {
                            border-radius: 4px;
                            background: pres-apply-ta.has-hover ? Theme.color-success : Theme.color-success.transparentize(0.2);
                            pres-apply-ta := TouchArea { clicked => { root.pres-ai-apply(); } }
                            Text { text: "Apply"; color: Theme.text-on-accent; font-size: 11px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
                        }
                        Rectangle {
                            border-radius: 4px;
                            background: pres-regen-ta.has-hover ? Theme.accent : Theme.accent.transparentize(0.2);
                            pres-regen-ta := TouchArea { clicked => { root.pres-ai-regenerate(); } }
                            Text { text: "Regenerate"; color: Theme.text-on-accent; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                        }
                        Rectangle {
                            border-radius: 4px;
                            background: pres-dismiss-ta.has-hover ? Theme.color-danger : Theme.color-danger.transparentize(0.2);
                            pres-dismiss-ta := TouchArea { clicked => { root.pres-ai-dismiss(); } }
                            Text { text: "Dismiss"; color: Theme.text-on-accent; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                        }
                    }
                }
            }

            Rectangle { height: 1px; background: Theme.separator; }

            // ── Section G: Freeform ──
            Text { text: "Ask AI"; color: Theme.text-secondary; font-size: 10px; }

            HorizontalLayout {
                spacing: 4px;
                height: 28px;

                Rectangle {
                    border-radius: 4px;
                    background: Theme.bg-elevated;
                    border-width: 1px;
                    border-color: Theme.separator;
                    clip: true;

                    pres-ai-freeform-input := TextInput {
                        x: 8px; y: 0px;
                        width: parent.width - 16px;
                        height: parent.height;
                        color: Theme.text-primary;
                        font-size: 10px;
                        wrap: word-wrap;
                        single-line: false;
                        vertical-alignment: center;
                        accepted => { root.pres-ai-freeform(self.text); self.text = ""; }
                    }
                    Text {
                        visible: pres-ai-freeform-input.text == "";
                        x: 8px;
                        text: "Ask anything about this deck...";
                        color: Theme.text-dim;
                        font-size: 10px;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    width: 48px; height: 28px;
                    border-radius: 4px;
                    background: root.pres-ai-working ? Theme.text-dim : (freeform-ask-ta.has-hover ? Theme.accent : Theme.accent.transparentize(0.2));
                    freeform-ask-ta := TouchArea {
                        enabled: !root.pres-ai-working;
                        clicked => { root.pres-ai-freeform(pres-ai-freeform-input.text); pres-ai-freeform-input.text = ""; }
                    }
                    Text { text: "Ask"; color: white; font-size: 10px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
                }
            }
        }
    }

    // ── Template gallery overlay ──
    Rectangle {
        visible: root.pres-template-gallery-open;
        width: 100%;
        height: 100%;
        background: Theme.overlay-backdrop;

        // Backdrop click to close
        TouchArea {
            clicked => { root.pres-template-gallery-open = false; }
        }

        // Gallery card
        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 420px;
            height: 300px;
            background: Theme.bg-elevated;
            border-radius: Theme.r-lg;
            border-width: 1px;
            border-color: Theme.border-subtle;

            // Prevent backdrop click from passing through
            TouchArea {}

            VerticalLayout {
                padding: 20px;
                spacing: 12px;

                Text {
                    text: "Template Gallery";
                    color: Theme.accent;
                    font-size: 16px;
                    font-weight: 700;
                    horizontal-alignment: center;
                }

                Text {
                    text: "Select a template to apply a theme to your presentation";
                    color: Theme.text-secondary;
                    font-size: 11px;
                    horizontal-alignment: center;
                }

                // Template grid
                Rectangle {
                    HorizontalLayout {
                        padding: 8px;
                        spacing: 10px;
                        alignment: center;

                        for tpl[idx] in root.pres-template-names: Rectangle {
                            width: 70px;
                            height: 90px;
                            border-radius: 8px;
                            background: tpl-ta.has-hover ? Theme.accent.transparentize(0.7) : Theme.hover-fill;
                            border-width: 1px;
                            border-color: tpl-ta.has-hover ? Theme.accent.transparentize(0.4) : Theme.border-subtle;

                            tpl-ta := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    root.pres-select-template(idx);
                                    root.pres-template-gallery-open = false;
                                }
                            }

                            VerticalLayout {
                                padding: 8px;
                                spacing: 6px;
                                alignment: center;

                                // Theme preview swatch
                                Rectangle {
                                    width: 40px;
                                    height: 28px;
                                    border-radius: 4px;
                                    background: idx == 0 ? Theme.bg-card
                                        : idx == 1 ? Theme.accent.transparentize(70%)
                                        : idx == 2 ? Theme.color-danger.transparentize(50%)
                                        : idx == 3 ? Theme.color-success.transparentize(70%)
                                        : Theme.bg-elevated;
                                    border-width: 1px;
                                    border-color: Theme.border-subtle;

                                    Text {
                                        text: "Aa";
                                        color: idx == 0 ? Theme.text-primary
                                            : idx == 1 ? Theme.text-primary
                                            : idx == 2 ? Theme.color-warning
                                            : idx == 3 ? Theme.color-success
                                            : Theme.color-danger;
                                        font-size: 12px;
                                        font-weight: 600;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                Text {
                                    text: tpl;
                                    color: tpl-ta.has-hover ? Theme.accent : Theme.text-primary;
                                    font-size: 10px;
                                    font-weight: 500;
                                    horizontal-alignment: center;
                                }
                            }
                        }
                    }
                }

                // Close button
                Rectangle {
                    height: 32px;

                    Rectangle {
                        width: 80px;
                        height: 28px;
                        x: (parent.width - self.width) / 2;
                        border-radius: 6px;
                        background: close-ta.has-hover ? Theme.hover-fill-strong : Theme.hover-fill;

                        close-ta := TouchArea { clicked => { root.pres-template-gallery-open = false; } }
                        Text { text: "Close"; color: Theme.text-secondary; font-size: 11px; font-weight: 500; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }
            }
        }
    }

    // Keyboard handler
    key-handler := FocusScope {
        width: 0px;
        height: 0px;

        key-pressed(event) => {
            if event.text == "\u{001b}" {
                if root.is-presenting {
                    root.toggle-present();
                }
                root.show-templates = false;
                root.show-search = false;
                root.pres-template-gallery-open = false;
                accept
            } else if root.is-presenting {
                if event.text == Key.RightArrow || event.text == Key.DownArrow || event.text == " " || event.text == Key.PageDown {
                    root.next-slide();
                    accept
                } else if event.text == Key.LeftArrow || event.text == Key.UpArrow || event.text == Key.PageUp {
                    root.prev-slide();
                    accept
                } else if event.text == Key.Home { root.select-slide(0); accept }
                else if event.text == Key.End { root.select-slide(root.slide-count - 1); accept }
                else { reject }
            } else { reject }
        }
    }
}
